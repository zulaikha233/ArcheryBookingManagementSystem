@{
    ViewBag.Title = "Customer Login";
}

<div class="container py-5" data-aos="fade-up">
    <div class="row justify-content-center">
        <div class="col-lg-11">

            <div class="premium-card p-0 overflow-hidden" data-aos="fade-up" data-aos-delay="200">
                <div class="row g-0" style="min-height: 600px;">
                    <!-- Visual Column -->
                    <div class="col-lg-7 d-none d-lg-flex flex-column justify-content-center p-5 text-center" style="background: linear-gradient(135deg, rgba(6, 10, 15, 0.6) 0%, rgba(6, 10, 15, 0.95) 100%), url('/modern_archery_hero.png'); background-size: cover; background-position: center; border-right: 1px solid var(--card-border);">

                        <div class="mb-4">
                            <i class="bi bi-bullseye" style="font-size: 5rem; color: var(--primary); text-shadow: 0 0 30px var(--primary-glow);"></i>
                        </div>
                        <h1 class="hero-title mb-3" style="font-size: 3.8rem;">CUSTOMER <span style="display: block;">PORTAL</span></h1>

                        <p class="text-dim px-4">Join our elite community of archers. Manage your sessions, track progress, and claim exclusive rewards.</p>
                    </div>

                    <!-- Form Column -->
                    <div class="col-lg-5 p-5 d-flex flex-column justify-content-center" style="position: relative; z-index: 10;">

                        <div class="mb-4 d-lg-none text-center">
                             <h1 class="hero-title" style="font-size: 2rem;">CUSTOMER <span>PORTAL</span></h1>
                        </div>

                        @if (ViewBag.ErrorMessage != null)
                        {
                            <div class="alert mb-4" style="background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); color: #ef4444; border-radius: 16px;">
                                <i class="bi bi-exclamation-circle me-2"></i> @ViewBag.ErrorMessage
                            </div>
                        }

                        <form asp-action="CustomerLogin" method="post">
                            <div class="mb-4">
                                <label class="form-label text-dim fw-600 mb-2" style="font-size: 0.7rem; letter-spacing: 2px; text-transform: uppercase;">EMAIL ADDRESS</label>
                                <input type="email" name="Email" class="form-control" placeholder="name@example.com" required />
                            </div>

                            <div class="mb-5">
                                <label class="form-label text-dim fw-600 mb-2" style="font-size: 0.7rem; letter-spacing: 2px; text-transform: uppercase;">PASSWORD</label>
                                <input type="password" name="Password" class="form-control" placeholder="••••••••" required />
                            </div>

                            <button type="submit" class="btn-premium w-100 justify-content-center mb-4">
                                SIGN IN <i class="bi bi-box-arrow-in-right ms-2"></i>
                            </button>
                        </form>
                        
                        <div class="text-center pt-4 border-top" style="border-color: var(--card-border) !important;">
                            <p class="text-dim mb-3" style="font-size: 0.9rem;">Don't have an account?</p>
                            <a href="@Url.Action("CustomerRegister", "Account")" class="btn-premium w-100 justify-content-center" style="background: transparent; border: 1px solid var(--primary); color: var(--primary); box-shadow: none;">
                                CREATE ACCOUNT
                            </a>
                            
                            <div class="mt-4">
                                <a href="@Url.Action("GuestBooking", "Booking")" class="text-decoration-none fw-bold" style="color: var(--secondary); font-size: 0.85rem; letter-spacing: 1px;">
                                    CONTINUE AS GUEST <i class="bi bi-chevron-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-center mt-4">
                <a href="@Url.Action("Index", "Home")" class="text-decoration-none text-dim" style="transition: var(--transition-smooth); font-size: 0.9rem;">
                    <i class="bi bi-arrow-left me-2"></i> Back to Home
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    .fw-600 { font-weight: 600; }
</style>
