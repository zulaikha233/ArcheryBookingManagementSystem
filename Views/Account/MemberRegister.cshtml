@{
    ViewBag.Title = "Customer Register";
}

<style>
    .login-page-wrapper {
        min-height: calc(100vh - 80px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 20px;
    }

    .login-split-card {
        display: flex;
        width: 100%;
        max-width: 920px;
        min-height: 520px;
        border-radius: 28px;
        overflow: hidden;
        box-shadow: 0 40px 100px rgba(0, 0, 0, 0.6);
        position: relative;
    }

    .login-left {
        width: 42%;
        position: relative;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        justify-content: center;
        background:
            linear-gradient(to right, rgba(0,0,0,0.35) 0%, rgba(0,0,0,0.15) 100%),
            url('/modern_archery_hero.png');
        background-size: cover;
        background-position: center;
    }

    .login-left::before {
        content: '';
        position: absolute;
        top: -90px; left: -90px;
        width: 360px; height: 360px;
        background: rgba(255,255,255,0.07);
        transform: rotate(45deg);
        border-radius: 40px;
        pointer-events: none;
    }

    .login-left::after {
        content: '';
        position: absolute;
        bottom: -70px; right: -70px;
        width: 230px; height: 230px;
        background: rgba(255,255,255,0.05);
        transform: rotate(45deg);
        border-radius: 22px;
        pointer-events: none;
    }

    .geo-arrow { position: absolute; width: 0; height: 0; pointer-events: none; }
    .geo-arrow-1 { top: 32%; left: -10px; border-top: 88px solid transparent; border-bottom: 88px solid transparent; border-left: 76px solid rgba(255,255,255,0.09); }
    .geo-arrow-2 { top: 37%; left: 52px;  border-top: 63px solid transparent; border-bottom: 63px solid transparent; border-left: 56px solid rgba(255,255,255,0.06); }
    .geo-arrow-3 { top: 41%; left: 95px;  border-top: 43px solid transparent; border-bottom: 43px solid transparent; border-left: 42px solid rgba(255,255,255,0.04); }

    .login-left-logo {
        position: relative;
        z-index: 3;
        width: 90px; height: 150px;
        object-fit: contain;
        filter: drop-shadow(0 4px 16px rgba(0,0,0,0.6));
        margin-top: 12px;
    }

    .left-panel-header {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        z-index: 2;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
    }

    .left-panel-title {
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 4px;
        text-transform: uppercase;
        color: rgba(255,255,255,0.65);
        margin: 0;
    }

    .login-right {
        flex: 1;
        background: #1a1e28;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 50px 48px 50px 52px;
        position: relative;
        z-index: 5;
    }

    .login-avatar-icon {
        width: 70px; height: 70px;
        border-radius: 50%;
        background: linear-gradient(145deg, #c0002a, #FF4D4D);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.8rem; color: #fff;
        margin-bottom: 12px;
        box-shadow: 0 8px 28px rgba(255,77,77,0.4);
    }

    .login-title {
        font-size: 1.55rem;
        font-weight: 900;
        color: #FF4D4D;
        letter-spacing: 3px;
        text-transform: uppercase;
        margin-bottom: 28px;
    }

    .login-field-group {
        width: 100%;
        margin-bottom: 26px;
        display: flex;
        align-items: center;
        gap: 12px;
        border-bottom: 1.5px solid rgba(255,255,255,0.13);
        padding-bottom: 10px;
        transition: border-color 0.3s;
    }
    .login-field-group:focus-within { border-bottom-color: #FF4D4D; }
    .login-field-group i { color: rgba(255,255,255,0.28); font-size: 1.05rem; flex-shrink: 0; transition: color 0.3s; }
    .login-field-group:focus-within i { color: #FF4D4D; }
    .login-field-group input {
        background: transparent !important; border: none !important;
        outline: none !important; box-shadow: none !important;
        color: #fff !important; font-size: 0.93rem; font-weight: 500;
        width: 100%; padding: 0;
        font-family: 'Plus Jakarta Sans', 'Inter', sans-serif;
    }
    .login-field-group input::placeholder { color: rgba(255,255,255,0.26); }

    .login-actions-row {
        display: flex; align-items: center;
        justify-content: flex-end;
        width: 100%; margin-bottom: 26px;
    }

    .login-submit-btn {
        background: linear-gradient(135deg, #FF4D4D, #c0002a);
        border: none; color: #fff;
        font-size: 0.75rem; font-weight: 800;
        letter-spacing: 2px; text-transform: uppercase;
        padding: 11px 26px; border-radius: 50px;
        cursor: pointer; transition: all 0.3s;
        box-shadow: 0 6px 20px rgba(255,77,77,0.35);
    }
    .login-submit-btn:hover { transform: translateY(-2px); box-shadow: 0 10px 28px rgba(255,77,77,0.5); }

    .login-divider {
        display: flex; align-items: center;
        width: 100%; gap: 14px; margin-bottom: 18px;
        color: rgba(255,255,255,0.22); font-size: 0.7rem; letter-spacing: 1px;
    }
    .login-divider::before, .login-divider::after { content: ''; flex: 1; height: 1px; background: rgba(255,255,255,0.07); }

    .login-bottom-links { display: flex; align-items: center; gap: 16px; font-size: 0.76rem; }
    .login-bottom-links a { color: rgba(255,255,255,0.38); text-decoration: none; font-weight: 600; transition: color 0.2s; display: flex; align-items: center; gap: 5px; }
    .login-bottom-links a:hover { color: #FF4D4D; }

    .login-error-box {
        width: 100%;
        background: rgba(239,68,68,0.08);
        border: 1px solid rgba(239,68,68,0.25);
        color: #ef4444; border-radius: 12px;
        padding: 10px 16px; font-size: 0.8rem;
        margin-bottom: 18px;
        display: flex; align-items: center; gap: 8px;
    }

    .form-panel { width: 100%; }

    @@media (max-width: 768px) {
        .login-left { display: none; }
        .login-right { padding: 40px 28px; }
        .login-split-card { border-radius: 20px; }
    }
</style>

<div class="login-page-wrapper">
    <div class="login-split-card">

        <div class="login-left">
            <div class="geo-arrow geo-arrow-1"></div>
            <div class="geo-arrow geo-arrow-2"></div>
            <div class="geo-arrow geo-arrow-3"></div>

            <div class="left-panel-header">
                <p class="left-panel-title">Member Portal</p>
                <img src="~/images/Archery_Logo.png" alt="Archery Logo" class="login-left-logo" />
            </div>
        </div>

        <div class="login-right">

            <div class="login-avatar-icon">
                <i class="bi bi-person-plus-fill"></i>
            </div>

            <h2 class="login-title">Sign Up</h2>

            @if (ViewBag.ErrorMessage != null)
            {
                <div class="login-error-box">
                    <i class="bi bi-exclamation-circle-fill"></i>
                    @ViewBag.ErrorMessage
                </div>
            }

            <div class="form-panel">
                <form asp-action="CustomerRegister" method="post" id="registerForm">
                    <div class="login-field-group">
                        <i class="bi bi-person-circle"></i>
                        <input type="text" name="Username" placeholder="Username" required />
                    </div>
                    <div class="login-field-group">
                        <i class="bi bi-envelope-fill"></i>
                        <input type="email" name="Email" placeholder="Email Address" required />
                    </div>
                    <div class="login-field-group">
                        <i class="bi bi-lock-fill"></i>
                        <input type="password" name="Password" id="registerPassword" placeholder="Password" required />
                        <i class="bi bi-eye-slash toggle-password" data-target="registerPassword" style="cursor: pointer; color: rgba(255,255,255,0.5);"></i>
                    </div>
                    <div class="login-field-group" id="confirmPasswordGroup">
                        <i class="bi bi-shield-lock-fill"></i>
                        <input type="password" name="ConfirmPassword" id="registerConfirmPassword" placeholder="Confirm Password" required />
                        <i class="bi bi-eye-slash toggle-password" data-target="registerConfirmPassword" style="cursor: pointer; color: rgba(255,255,255,0.5);"></i>
                    </div>
                    <div id="passwordMatchError" style="visibility: hidden; color: #ef4444; font-size: 0.75rem; margin-top: -15px; margin-bottom: 20px; text-align: left; width: 100%; min-height: 18px;">
                        <i class="bi bi-exclamation-triangle-fill"></i> Passwords do not match
                    </div>
                    <div class="login-actions-row">
                        <button type="submit" class="login-submit-btn">Create Account</button>
                    </div>
                </form>
            </div>

            <div class="login-divider">Or</div>

            <div class="login-bottom-links">
                <a href="@Url.Action("CustomerLogin", "Account")">
                    <i class="bi bi-box-arrow-in-right"></i> Already have an account? Login
                </a>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const toggleButtons = document.querySelectorAll('.toggle-password');
        toggleButtons.forEach(btn => {
            btn.addEventListener('click', function () {
                const targetId = this.getAttribute('data-target');
                const passwordField = document.getElementById(targetId);
                if (passwordField) {
                    const type = passwordField.getAttribute('type') === 'password' ? 'text' : 'password';
                    passwordField.setAttribute('type', type);
                    this.classList.toggle('bi-eye');
                    this.classList.toggle('bi-eye-slash');
                }
            });
        });

        // Password Match Validation
        const registerForm = document.getElementById('registerForm');
        const passwordInput = document.getElementById('registerPassword');
        const confirmPasswordInput = document.getElementById('registerConfirmPassword');
        const matchError = document.getElementById('passwordMatchError');
        const confirmGroup = document.getElementById('confirmPasswordGroup');

        if (registerForm) {
            function validatePasswordMatch() {
                // Only validate if confirm password has some value
                if (confirmPasswordInput.value !== '' && passwordInput.value !== confirmPasswordInput.value) {
                    matchError.style.visibility = 'visible';
                    confirmGroup.style.borderBottomColor = '#ef4444';
                    return false;
                } else {
                    matchError.style.visibility = 'hidden';
                    confirmGroup.style.borderBottomColor = '';
                    return true;
                }
            }

            confirmPasswordInput.addEventListener('input', validatePasswordMatch);
            passwordInput.addEventListener('input', validatePasswordMatch);

            registerForm.addEventListener('submit', function (e) {
                if (confirmPasswordInput.value === '' || !validatePasswordMatch()) {
                    e.preventDefault();
                    if (confirmPasswordInput.value === '') {
                        matchError.style.visibility = 'visible';
                        confirmGroup.style.borderBottomColor = '#ef4444';
                    }
                }
            });
        }
    });
</script>
