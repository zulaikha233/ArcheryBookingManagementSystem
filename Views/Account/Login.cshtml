@{
    ViewBag.Title = "Login";
}

<div class="container animate-in">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="text-center mb-5">
                <div style="font-size: 4rem; color: #8A9A5B">🛡️</div>
                <h1 class="hero-title" style="font-size: 2.5rem;">ARENA <span style="color: #2b3a2a">ACCESS</span></h1>
                <p style="color: #adb5bd">Enter your credentials to manage the range.</p>
            </div>

            <div class="premium-card">
                @if (ViewBag.ErrorMessage != null)
                {
                    <div class="alert alert-danger-custom mb-4">
                        <i class="bi bi-shield-lock-fill me-2"></i> @ViewBag.ErrorMessage
                    </div>
                }

                <form asp-action="Login" method="post">
                    <div class="mb-4">
                        <label class="form-label fw-bold text-uppercase" style="color: var(--primary); letter-spacing: 1px; font-size: 0.8rem">EMPLOYEE ID</label>
                        <div class="input-group">
                            <input type="text" name="EmpId" class="form-control border-0 shadow-none fw-bold" placeholder="Enter ID" required />
                        </div>
                    </div>

                    <div class="mb-4 text-start">
                        <label class="form-label fw-bold" style="color: var(--primary); letter-spacing: 1px; font-size: 0.85rem">PASSWORD</label>
                        <div class="password-input-wrapper">
                            <input type="password" name="Password" id="passwordField" class="form-control border-0 shadow-none fw-bold" 
                                   placeholder="••••••••" required />
                            <button class="password-toggle-btn" type="button" id="togglePassword">
                                <i class="bi bi-eye" id="eyeIcon"></i>
                            </button>
                        </div>
                    </div>

                    @section Scripts {
                        <script>
                            document.querySelector('#togglePassword').addEventListener('click', function () {
                                const passwordField = document.querySelector('#passwordField');
                                const eyeIcon = document.querySelector('#eyeIcon');
                                const type = passwordField.getAttribute('type') === 'password' ? 'text' : 'password';
                                passwordField.setAttribute('type', type);
                                eyeIcon.classList.toggle('bi-eye');
                                eyeIcon.classList.toggle('bi-eye-slash');
                            });
                        </script>
                    }

                    <div class="text-center mt-5">
                        <button type="submit" class="btn-premium py-3 px-5 shadow-lg">LOGIN</button>
                    </div>
                </form>
            </div>

            <div class="text-center mt-4">
                <a href="@Url.Action("Index", "Home")" class="text-decoration-none" style="color: #6c757d; transition: 0.3s;"><i class="bi bi-arrow-left me-1"></i> Back to Home</a>
            </div>
        </div>
    </div>
</div>
