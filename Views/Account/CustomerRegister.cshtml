@{
    ViewBag.Title = "Customer Register";
}

<div class="container py-5" data-aos="fade-up">
    <div class="row justify-content-center">
        <div class="col-lg-11">

            <div class="premium-card p-0 overflow-hidden" data-aos="fade-up" data-aos-delay="200">
                <div class="row g-0">
                    <!-- Visual Column -->
                    <div class="col-lg-5 d-none d-lg-flex flex-column justify-content-center p-5 text-center" style="background: linear-gradient(135deg, rgba(6, 10, 15, 0.6) 0%, rgba(6, 10, 15, 0.95) 100%), url('/modern_archery_hero.png'); background-size: cover; background-position: center; border-right: 1px solid var(--card-border);">
                        <div class="mb-4">
                            <i class="bi bi-person-plus" style="font-size: 5rem; color: var(--primary); text-shadow: 0 0 30px var(--primary-glow);"></i>
                        </div>
                        <h1 class="hero-title mb-3">JOIN <span>US</span></h1>
                        <p class="text-dim px-4">Create your account to unlock personalized bookings, exclusive rates, and member rewards.</p>
                    </div>

                    <!-- Form Column -->
                    <div class="col-lg-7 p-5" style="position: relative; z-index: 10;">
                        <div class="mb-4 d-lg-none text-center">
                             <h1 class="hero-title" style="font-size: 2rem;">JOIN <span>THE ARENA</span></h1>
                        </div>

                        @if (ViewBag.ErrorMessage != null)
                        {
                            <div class="alert mb-4" style="background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); color: #ef4444; border-radius: 16px;">
                                <i class="bi bi-exclamation-circle me-2"></i> @ViewBag.ErrorMessage
                            </div>
                        }

                        <form asp-action="CustomerRegister" method="post">
                            <div class="row g-3">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label text-dim fw-600 mb-2" style="font-size: 0.7rem; letter-spacing: 2px; text-transform: uppercase;">FULL NAME</label>
                                    <input type="text" name="FullName" class="form-control" placeholder="e.g. Ali Abu" required />
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label text-dim fw-600 mb-2" style="font-size: 0.7rem; letter-spacing: 2px; text-transform: uppercase;">USERNAME</label>
                                    <input type="text" name="Username" class="form-control" placeholder="e.g. ali88" required />
                                </div>
                            </div>

                            <div class="row g-3">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label text-dim fw-600 mb-2" style="font-size: 0.7rem; letter-spacing: 2px; text-transform: uppercase;">EMAIL ADDRESS</label>
                                    <input type="email" name="Email" class="form-control" placeholder="ali@gmail.com" required />
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label text-dim fw-600 mb-2" style="font-size: 0.7rem; letter-spacing: 2px; text-transform: uppercase;">PHONE NUMBER</label>
                                    <input type="text" name="PhoneNumber" class="form-control" placeholder="0123456789" required />
                                </div>
                            </div>

                            <div class="row g-3 mb-4">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label text-dim fw-600 mb-2" style="font-size: 0.7rem; letter-spacing: 2px; text-transform: uppercase;">PASSWORD</label>
                                    <input type="password" name="Password" class="form-control" placeholder="••••••••" required />
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label text-dim fw-600 mb-2" style="font-size: 0.7rem; letter-spacing: 2px; text-transform: uppercase;">CONFIRM PASSWORD</label>
                                    <input type="password" name="ConfirmPassword" class="form-control" placeholder="••••••••" required />
                                </div>
                            </div>

                            <button type="submit" class="btn-premium w-100 justify-content-center mb-4">
                                CREATE ACCOUNT <i class="bi bi-arrow-right ms-2"></i>
                            </button>
                        </form>
                        
                        <div class="text-center pt-4 border-top" style="border-color: var(--card-border) !important;">
                            <p class="text-dim mb-3" style="font-size: 0.9rem;">Already have an account?</p>
                            <a href="@Url.Action("CustomerLogin", "Account")" class="text-decoration-none fw-bold" style="color: var(--primary); font-size: 0.85rem; letter-spacing: 1px;">
                                LOGIN HERE <i class="bi bi-chevron-right ms-1"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-center mt-4">
                <a href="@Url.Action("Index", "Home")" class="text-decoration-none text-dim" style="transition: var(--transition-smooth); font-size: 0.9rem;">
                    <i class="bi bi-arrow-left me-2"></i> Back to Home
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    .fw-600 { font-weight: 600; }
</style>
