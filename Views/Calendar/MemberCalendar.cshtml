@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "Member Calendar";
    Layout = "_MemberLayout";
}

@section Styles {
    <style>
        .dashboard-container {
            display: grid;
            grid-template-columns: 1fr;
            gap: 30px;
            min-height: calc(100vh - 80px);
            animation: fadeIn 0.8s ease;
        }

        @@media (max-width: 1200px) {
            .dashboard-container {
                grid-template-columns: 1fr;
            }
        }

        /* ─── LEFT COLUMN: CALENDAR VIEW ─── */
        .calendar-card {
            background: rgba(34, 38, 48, 0.6);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: var(--radius-md);
            padding: 30px;
            display: flex;
            flex-direction: column;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
        }

        .calendar-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 25px;
            flex-wrap: wrap;
            gap: 15px;
        }

        .calendar-title-group {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .calendar-month-year {
            font-size: 1.4rem;
            font-weight: 800;
            color: #fff;
            letter-spacing: -0.5px;
        }

        .week-navigator {
            display: flex;
            align-items: center;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 12px;
            padding: 4px;
        }

        .nav-btn {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            border: none;
            background: transparent;
            color: var(--text-dim);
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s ease;
            cursor: pointer;
        }

        .nav-btn:hover {
            background: rgba(255, 255, 255, 0.05);
            color: #fff;
        }

        .btn-create-booking {
            background: linear-gradient(135deg, var(--primary), #D63031);
            color: #fff;
            border: none;
            padding: 10px 24px;
            border-radius: 12px;
            font-weight: 700;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s ease;
            box-shadow: 0 10px 20px rgba(255, 77, 77, 0.2);
            text-decoration: none;
        }

        .btn-create-booking:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 25px rgba(255, 77, 77, 0.3);
            color: #fff;
        }

        /* ─── WEEKLY GRID TABLE ─── */
        .calendar-grid-wrapper {
            overflow-x: auto;
            border-radius: var(--radius-md);
            border: 1px solid rgba(255, 255, 255, 0.04);
            background: rgba(0, 0, 0, 0.1);
        }

        .calendar-table {
            width: 100%;
            border-collapse: collapse;
            table-layout: fixed;
        }

        .calendar-table th {
            border: 1px solid rgba(255, 255, 255, 0.03);
            padding: 12px;
            text-align: center;
            vertical-align: middle;
        }

        .calendar-table td {
            border: 1px solid rgba(255, 255, 255, 0.03);
            text-align: center;
            vertical-align: middle;
        }

        .calendar-table td:not(.td-time-label) {
            padding: 0 !important;
            height: 95px;
            box-sizing: border-box;
        }

        .calendar-table th {
            background: rgba(255, 255, 255, 0.01);
            padding: 16px 12px;
            font-weight: 700;
        }

        .th-time-col {
            width: 90px;
            color: var(--text-dim);
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .th-day-col {
            text-align: center;
        }

        .day-num {
            display: block;
            font-size: 1.5rem;
            font-weight: 800;
            color: #fff;
            margin-top: 4px;
        }

        .day-label {
            font-size: 0.7rem;
            color: var(--text-dim);
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 700;
        }

        .td-time-label {
            font-size: 0.8rem;
            color: var(--text-dim);
            font-weight: 800;
            background: rgba(255, 255, 255, 0.01);
            text-align: right;
            padding-right: 15px;
            vertical-align: top;
            padding-top: 8px;
        }

        .grid-cell-interactive {
            height: 95px;
            position: relative;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        /* Interactive Hover + Icon */
        .grid-cell-interactive::after {
            content: '+';
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-size: 1.8rem;
            color: var(--primary);
            font-weight: 400;
            opacity: 0;
            transition: all 0.2s ease;
        }

        .grid-cell-interactive:hover {
            background: rgba(255, 255, 255, 0.02);
        }

        .grid-cell-interactive:hover::after {
            opacity: 1;
        }

        /* ─── BOOKED APPOINTMENT CARDS ─── */
        .scheduled-card {
            border-radius: 12px;
            padding: 4px; /* Reduced padding */
            text-align: center;
            font-size: 0.75rem;
            color: #fff;
            margin: 2px; /* Reduced margin */
            height: calc(100% - 4px);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            transition: all 0.2s ease;
            box-shadow: 0 4px 10px rgba(0,0,0,0.15);
            border-left: 4px solid transparent;
            cursor: default;
            box-sizing: border-box;
            overflow: hidden; /* Hide overflow */
        }

        .scheduled-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 15px rgba(0,0,0,0.25);
        }

        /* Card Color Profiles */
        .card-game {
            background: linear-gradient(135deg, rgba(255, 77, 77, 0.15), rgba(255, 77, 77, 0.05));
            border: 1px solid rgba(255, 77, 77, 0.2);
            border-left-color: #FF4D4D;
        }
        .card-game .card-title { color: #FF4D4D; }

        .card-self-train {
            background: linear-gradient(135deg, rgba(168, 85, 247, 0.15), rgba(168, 85, 247, 0.05));
            border: 1px solid rgba(168, 85, 247, 0.2);
            border-left-color: #A855F7;
        }
        .card-self-train .card-title { color: #C084FC; }

        .card-class {
            background: linear-gradient(135deg, rgba(59, 130, 246, 0.15), rgba(59, 130, 246, 0.05));
            border: 1px solid rgba(59, 130, 246, 0.2);
            border-left-color: #3B82F6;
        }
        .card-class .card-title { color: #60A5FA; }

        .card-title {
            font-weight: 800;
            text-transform: uppercase;
            font-size: 0.6rem; /* Smaller font */
            letter-spacing: 0px;
            margin-bottom: 2px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 2px;
            white-space: nowrap;
        }

        .card-time {
            font-weight: 800;
            font-size: 0.85rem; /* Smaller time font */
            color: #fff;
            margin: 2px 0 4px 0;
            text-align: center;
        }

        .card-meta {
            color: var(--text-dim);
            font-size: 0.6rem;
            display: flex;
            flex-direction: column; /* Stack vertically to save horizontal space */
            justify-content: center;
            align-items: center;
            gap: 2px;
            width: 100%;
        }

        /* ─── RIGHT COLUMN: UPCOMING APPOINTMENTS ─── */
        .right-column-panel {
            display: flex;
            flex-direction: column;
            gap: 30px;
        }

        .panel-card {
            background: rgba(34, 38, 48, 0.6);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: var(--radius-md);
            padding: 25px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
        }

        .panel-title {
            font-size: 0.8rem;
            color: var(--text-dim);
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 800;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .appointments-list {
            display: flex;
            flex-direction: column;
            gap: 15px;
            max-height: 480px;
            overflow-y: auto;
            padding-right: 5px;
        }

        .appointment-item {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.04);
            border-radius: 16px;
            padding: 18px;
            display: flex;
            flex-direction: column;
            gap: 12px;
            transition: all 0.3s ease;
        }

        .appointment-item:hover {
            border-color: rgba(255, 77, 77, 0.2);
            background: rgba(255, 77, 77, 0.02);
            transform: translateY(-2px);
        }

        .item-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .item-type-badge {
            font-size: 0.65rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            padding: 4px 10px;
            border-radius: 20px;
        }

        .badge-game { background: rgba(255, 77, 77, 0.1); color: #FF4D4D; }
        .badge-self-train { background: rgba(168, 85, 247, 0.1); color: #A855F7; }
        .badge-class { background: rgba(59, 130, 246, 0.1); color: #3B82F6; }

        .item-status {
            font-size: 0.7rem;
            color: #10B981;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .item-body {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .item-datetime {
            font-size: 0.95rem;
            font-weight: 800;
            color: #fff;
        }

        .item-slots-info {
            font-size: 0.8rem;
            color: var(--text-dim);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .item-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-top: 1px dashed rgba(255, 255, 255, 0.05);
            padding-top: 12px;
            font-size: 0.75rem;
        }

        .item-target {
            color: var(--text-dim);
        }

        .item-price {
            font-weight: 800;
            color: #fff;
        }

        /* ─── Empty state styling ─── */
        .empty-state {
            text-align: center;
            padding: 40px 20px;
            color: var(--text-dim);
        }

        .empty-state i {
            font-size: 3rem;
            color: var(--border-color);
            margin-bottom: 15px;
            display: block;
        }

        .empty-state p {
            font-size: 0.85rem;
            margin-bottom: 20px;
        }

        /* CSS Animation */
        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(15px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
}

<div class="dashboard-container">
    <!-- LEFT COLUMN: WEEKLY CALENDAR -->
    <div class="calendar-card">
        <!-- INLINE ERROR ALERT -->
        <div id="bookingErrorAlert" class="alert alert-danger d-none align-items-center mb-4" style="background: rgba(255, 77, 77, 0.1); border: 1px solid rgba(255, 77, 77, 0.2); color: #FF4D4D; border-radius: 12px; padding: 12px 20px; font-size: 0.9rem; font-weight: 600;">
            <i class="bi bi-exclamation-triangle-fill me-2" style="font-size: 1.1rem;"></i>
            <span>You must be an active member and pay the annual fee before you can book a session.</span>
        </div>

        <div class="calendar-header">
            <div class="calendar-title-group">
                <div class="calendar-month-year" id="monthYearDisplay">May 2026</div>
                <div class="week-navigator">
                    <button class="nav-btn" onclick="shiftWeek(-1)"><i class="bi bi-chevron-left"></i></button>
                    <button class="nav-btn" onclick="resetWeek()">Week</button>
                    <button class="nav-btn" onclick="shiftWeek(1)"><i class="bi bi-chevron-right"></i></button>
                </div>
            </div>
        </div>

        <div class="calendar-grid-wrapper">
            <table class="calendar-table">
                <thead>
                    <tr id="calendarHeaders">
                        <th class="th-time-col">Time</th>
                        <!-- Dynamic dates header filled by JS -->
                    </tr>
                </thead>
                <tbody id="calendarGridBody">
                    <!-- Dynamic calendar rows filled by JS -->
                </tbody>
            </table>
        </div>
    </div>

    <!-- Calendar now takes full width -->
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Parse database reservations from ViewBag
        const rawReservations = @Html.Raw(Json.Serialize(ViewBag.Reservations));
        console.log("Reservations Loaded:", rawReservations);
        const customerStatus = "@Context.Session.GetString("CustomerStatus")" || "Inactive";

        function handleBookingClick(url) {
            if (customerStatus === "Inactive") {
                const errAlert = document.getElementById("bookingErrorAlert");
                if (errAlert) {
                    errAlert.classList.remove("d-none");
                    errAlert.classList.add("d-flex");
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                    
                    // Auto-hide after 5 seconds
                    setTimeout(() => {
                        errAlert.classList.add("d-none");
                        errAlert.classList.remove("d-flex");
                    }, 5000);
                }
            } else {
                window.location.href = url;
            }
        }

        // State variables
        let currentDate = new Date(); // Today
        let weekStartDate = getStartOfWeek(currentDate);

        // Fixed Time Rows mapping directly to operational slots
        const timeSlots = [
            { label: "08:00", startTime: "08:15:00", endTime: "09:15:00", isNightSlot: false },
            { label: "09:00", startTime: "09:15:00", endTime: "10:15:00", isNightSlot: false },
            { label: "10:00", startTime: "10:15:00", endTime: "11:15:00", isNightSlot: false },
            { label: "11:00", startTime: "11:15:00", endTime: "12:15:00", isNightSlot: false },
            { label: "12:00", startTime: "12:15:00", endTime: "13:15:00", isNightSlot: false },
            { label: "13:00", startTime: "13:15:00", endTime: "14:15:00", isNightSlot: false },
            { label: "14:00", startTime: "14:15:00", endTime: "15:15:00", isNightSlot: false },
            { label: "15:00", startTime: "15:15:00", endTime: "16:15:00", isNightSlot: false },
            { label: "16:00", startTime: "16:15:00", endTime: "17:15:00", isNightSlot: false },
            { label: "17:00", startTime: "17:15:00", endTime: "18:15:00", isNightSlot: false },
            { label: "18:00", startTime: "18:15:00", endTime: "19:15:00", isNightSlot: false },
            { label: "19:00", startTime: "19:15:00", endTime: "20:00:00", isNightSlot: false },
            { label: "20:00", startTime: "20:00:00", endTime: "21:00:00", isNightSlot: true },
            { label: "21:00", startTime: "21:00:00", endTime: "22:00:00", isNightSlot: true },
            { label: "22:00", startTime: "22:00:00", endTime: "23:00:00", isNightSlot: true },
            { label: "23:00", startTime: "23:00:00", endTime: "00:00:00", isNightSlot: true },
            { label: "00:00", startTime: "00:00:00", endTime: "01:00:00", isNightSlot: true }
        ];

        document.addEventListener("DOMContentLoaded", () => {
            renderDashboard();
        });

        function getStartOfWeek(d) {
            let date = new Date(d);
            let day = date.getDay();
            let diff = date.getDate() - day + (day === 0 ? -6 : 1); // Adjust when Sunday is 0
            return new Date(date.setDate(diff));
        }

        function shiftWeek(offset) {
            weekStartDate.setDate(weekStartDate.getDate() + (offset * 7));
            renderDashboard();
        }

        function resetWeek() {
            weekStartDate = getStartOfWeek(new Date());
            renderDashboard();
        }

        function formatDateStr(date) {
            return date.toISOString().split('T')[0];
        }

        function renderDashboard() {
            renderCalendarHeader();
            renderCalendarBody();
        }

        function renderCalendarHeader() {
            const display = document.getElementById("monthYearDisplay");
            
            // Generate range details
            const startStr = weekStartDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
            const endDate = new Date(weekStartDate);
            endDate.setDate(endDate.getDate() + 6);
            const endStr = endDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
            
            display.innerText = `${startStr} - ${endStr}`;

            // Render table header columns
            const headersRow = document.getElementById("calendarHeaders");
            headersRow.innerHTML = `<th class="th-time-col" style="width: 80px;">Time</th>`;
            
            const daysNames = ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"];
            for (let i = 0; i < 7; i++) {
                const dayDate = new Date(weekStartDate);
                dayDate.setDate(dayDate.getDate() + i);

                const isToday = dayDate.toDateString() === new Date().toDateString();
                const style = isToday ? 'style="border-bottom: 3px solid var(--primary);"' : '';

                headersRow.innerHTML += `
                    <th class="th-day-col" ${style}>
                        <div class="day-label">${daysNames[i]}</div>
                        <div class="day-num" style="${isToday ? 'color: var(--primary);' : ''}">${dayDate.getDate()}</div>
                    </th>
                `;
            }
        }

        function isMatchingSlot(resSlotStartTime, calendarSlotStartTime) {
            return false;
        }

        function renderCalendarBody() {
            const gridBody = document.getElementById("calendarGridBody");
            gridBody.innerHTML = "";

            timeSlots.forEach(time => {
                const row = document.createElement("tr");

                // Time column
                row.innerHTML = `<td class="td-time-label" style="border-right: 1px solid rgba(255,255,255,0.05);">
                    <div>${time.label}</div>
                </td>`;

                // Mon-Sun columns
                for (let i = 0; i < 7; i++) {
                    const dayDate = new Date(weekStartDate);
                    dayDate.setDate(dayDate.getDate() + i);
                    const dateStr = formatDateStr(dayDate);
                    
                    const cellTd = document.createElement("td");
                    cellTd.style.verticalAlign = "top";
                    cellTd.style.padding = "0"; // No padding for absolute children
                    cellTd.style.height = "60px"; // Compact height
                    cellTd.style.border = "1px solid rgba(255,255,255,0.05)";
                    cellTd.style.position = "relative"; // Important for absolute stacking

                    // Filter matching reservations for this day AND time slot
                    const dayReservations = rawReservations.filter(res => {
                        const resDate = res.reservedOn.split('T')[0];
                        const resTime = res.slot && res.slot.slotStartTime ? res.slot.slotStartTime : "00:00:00";
                        
                        // Extract hour to match regardless of minutes (e.g. 14:30 falls into 14:00 row)
                        const resHour = resTime.substring(0, 2);
                        const slotHour = time.label.substring(0, 2);

                        return resDate === dateStr && resHour === slotHour;
                    });

                    if (dayReservations.length > 0) {
                        const cardsContainer = document.createElement("div");
                        cardsContainer.style.position = "relative";
                        cardsContainer.style.width = "100%";
                        cardsContainer.style.height = "100%";

                        // Group by identical time and type
                        const groupedRes = [];
                        dayReservations.forEach(res => {
                            const resTime = res.slot && res.slot.slotStartTime ? res.slot.slotStartTime : "00:00:00";
                            const match = groupedRes.find(g => {
                                const gTime = g.slot && g.slot.slotStartTime ? g.slot.slotStartTime : "00:00:00";
                                return gTime === resTime && g.rateCode === res.rateCode && g.customerName === res.customerName;
                            });
                            if (match) {
                                match.grouped.push(res);
                            } else {
                                groupedRes.push({
                                    ...res,
                                    grouped: [res]
                                });
                            }
                        });

                        groupedRes.sort((a, b) => {
                            const timeA = a.slot && a.slot.slotStartTime ? a.slot.slotStartTime : "00:00:00";
                            const timeB = b.slot && b.slot.slotStartTime ? b.slot.slotStartTime : "00:00:00";
                            return timeA.localeCompare(timeB);
                        });

                        groupedRes.forEach((matchingRes, index) => {
                            let typeClass = "card-game";
                            let typeTitle = "Game Session";
                            let typeIcon = "bi-bullseye";
                            let rateCodeUpper = matchingRes.rateCode ? matchingRes.rateCode.toUpperCase() : "";

                            if (rateCodeUpper === "CLASS SESSION" || rateCodeUpper === "CLASS") {
                                typeClass = "card-class";
                                typeTitle = "Class Session";
                                typeIcon = "bi-mortarboard";
                            } else if (rateCodeUpper === "SELF_TRAINING" || (matchingRes.slot && matchingRes.slot.isNight)) {
                                typeClass = "card-self-train";
                                typeTitle = "Self Training";
                                typeIcon = "bi-moon-stars";
                            }

                            let startStr = matchingRes.slot && matchingRes.slot.slotStartTime ? matchingRes.slot.slotStartTime.substring(0, 5) : "";
                            let timeText = startStr;

                            if (startStr && matchingRes.durationHours) {
                                let parts = startStr.split(':');
                                let hours = parseInt(parts[0], 10);
                                let mins = parseInt(parts[1], 10);
                                hours += Math.floor(matchingRes.durationHours);
                                mins += (matchingRes.durationHours % 1) * 60;
                                if (mins >= 60) {
                                    hours += Math.floor(mins / 60);
                                    mins = mins % 60;
                                }
                                let endStr = `${hours.toString().padStart(2, '0')}:${mins.toString().padStart(2, '0')}`;
                                timeText = `${startStr} - ${endStr}`;
                            }

                            let totalPax = 0;
                            if (rateCodeUpper === "CLASS SESSION" || rateCodeUpper === "CLASS") {
                                totalPax = matchingRes.grouped.reduce((sum, r) => sum + (r.numberOfPax || 1), 0);
                            } else {
                                totalPax = matchingRes.grouped[0].numberOfPax || 1;
                            }

                            let namesStr = totalPax > 1 ? `${totalPax} Archers` : matchingRes.customerName;

                            let metaHtml = "";
                            if (rateCodeUpper === "CLASS SESSION" || rateCodeUpper === "CLASS") {
                                metaHtml = `<span style="font-weight: 700; color: #fff;">${namesStr}</span>`;
                            } else {
                                let tgts = matchingRes.grouped.map(r => r.targetNo).join(', ');
                                metaHtml = `
                                    <span style="font-weight: 700; color: #fff; margin-bottom: 2px;">${namesStr}</span>
                                    <span style="opacity: 0.9;">• Tgt ${tgts}</span>
                                `;
                            }

                            // Calculate dynamic positioning
                            const duration = matchingRes.durationHours || 1;
                            const heightPx = duration * 60; // 60px per hour row
                            const totalEvents = groupedRes.length;
                            const widthPercent = totalEvents > 1 ? (100 / totalEvents) : 95; // 95% if single to leave a tiny right margin
                            const leftOffset = index * (100 / totalEvents);
                            const zIndex = 10 + index;

                            const cardHtml = `
                                <div class="scheduled-card ${typeClass}" style="position: absolute; top: 0; left: ${leftOffset}%; width: ${widthPercent}%; height: ${heightPx}px; z-index: ${zIndex}; border-radius: 8px; padding: 8px 10px; cursor: default; display: flex; flex-direction: column; justify-content: flex-start; align-items: center; text-align: center; box-shadow: 0 4px 10px rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.1); overflow: hidden;">
                                    <div class="card-title" style="font-size: 0.7rem; margin-bottom: 4px; display: flex; gap: 4px; align-items: center; justify-content: center;"><i class="bi ${typeIcon}"></i> ${typeTitle}</div>
                                    ${timeText ? `<div class="card-time" style="font-size: 0.85rem; margin: 0 0 6px 0;">${timeText}</div>` : ''}
                                    <div class="card-meta" style="font-size: 0.75rem; display: flex; flex-direction: column; gap: 2px; align-items: center;">
                                        ${metaHtml}
                                    </div>
                                </div>
                            `;
                            cardsContainer.insertAdjacentHTML('beforeend', cardHtml);
                        });
                        
                        cellTd.appendChild(cardsContainer);
                    } else {
                        // Interactive cell for empty slots
                        cellTd.className = "grid-cell-interactive";
                        cellTd.onclick = (e) => {
                            const isWeekend = dayDate.getDay() === 0 || dayDate.getDay() === 6;
                            const targetUrl = isWeekend ? `/Booking/ClassBooking?date=${dateStr}` : `/Booking/GetFreeSlots?date=${dateStr}`;
                            handleBookingClick(targetUrl);
                        };
                    }
                    row.appendChild(cellTd);
                }
                gridBody.appendChild(row);
            });
        }

        function renderUpcomingPanel() {
            const listContainer = document.getElementById("upcomingList");
            const countDisplay = document.getElementById("appointmentsCount");
            
            // Get current and future reservations sorted by date & time
            const nowStr = formatDateStr(new Date());
            
            const activeReservations = rawReservations.filter(res => {
                const resDate = res.reservedOn.split('T')[0];
                return resDate >= nowStr && res.status !== 2; // Not cancelled
            }).sort((a, b) => new Date(a.reservedOn) - new Date(b.reservedOn));

            countDisplay.innerText = activeReservations.length;

            if (activeReservations.length === 0) {
                listContainer.innerHTML = `
                    <div class="empty-state">
                        <i class="bi bi-calendar-x"></i>
                        <h6 class="text-white fw-bold mb-2">No Upcoming Appointments</h6>
                        <p class="text-dim">You don't have any dynamic shooting sessions scheduled yet.</p>
                        <a href="javascript:void(0)" onclick="handleBookingClick('/Booking/GetFreeSlots')" class="btn-create-booking mt-3 justify-content-center">Book Now</a>
                    </div>
                `;
                return;
            }

            listContainer.innerHTML = "";

            activeReservations.forEach(res => {
                const item = document.createElement("div");
                item.className = "appointment-item";

                let badgeClass = "badge-game";
                let typeTitle = "Game Session";
                let typeIcon = "bi-bullseye";

                if (res.rateCode === "CLASS" || res.rateCode === "Class Session") {
                    badgeClass = "badge-class";
                    typeTitle = "Class Session";
                    typeIcon = "bi-mortarboard";
                } else if (res.rateCode === "SELF_TRAINING" || (res.slot && res.slot.isNight)) {
                    badgeClass = "badge-self-train";
                    typeTitle = "Self Training";
                    typeIcon = "bi-moon-stars";
                }

                const resDateObj = new Date(res.reservedOn);
                const readableDate = resDateObj.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric' });
                
                const startStr = res.slot ? res.slot.slotStartTime.substring(0,5) : "";
                const endStr = res.slot ? res.slot.slotEndTime.substring(0,5) : "";

                item.innerHTML = `
                    <div class="item-header">
                        <span class="item-type-badge ${badgeClass}"><i class="bi ${typeIcon} me-1"></i> ${typeTitle}</span>
                        <span class="item-status"><i class="bi bi-patch-check-fill"></i> Confirmed</span>
                    </div>
                    <div class="item-body">
                        <div class="item-datetime">${readableDate}</div>
                        <div class="item-slots-info">
                            <i class="bi bi-clock-fill text-primary"></i> ${startStr} - ${endStr} (${res.durationHours} ${res.durationHours === 1 ? 'Slot' : 'Slots'})
                        </div>
                    </div>
                    <div class="item-footer">
                        <span class="item-target"><i class="bi bi-bullseye"></i> Target ${res.targetNo} (Lane ${res.rangeNo})</span>
                        <span class="item-price">RM ${(res.totalPrice).toFixed(2)}</span>
                    </div>
                `;
                listContainer.appendChild(item);
            });
        }
    </script>
}
