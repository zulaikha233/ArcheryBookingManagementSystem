@model ArcheryAlley.Models.Customers
@{
    ViewBag.Title = "Member Profile";
    Layout = "~/Views/Shared/_MemberLayout.cshtml";

    // Split Full Name into First Name & Last Name for separate fields
    string firstName = "";
    string lastName = "";
    if (!string.IsNullOrEmpty(Model.FullName))
    {
        var parts = Model.FullName.Split(new[] { ' ' }, StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length > 0)
        {
            firstName = parts[0];
            lastName = string.Join(" ", parts.Skip(1));
        }
    }

    // Generate Avatar Initials
    string initials = "M";
    if (!string.IsNullOrEmpty(Model.FullName))
    {
        var parts = Model.FullName.Split(new[] { ' ' }, StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length > 0)
        {
            initials = parts[0][0].ToString();
            if (parts.Length > 1)
            {
                initials += parts[parts.Length - 1][0].ToString();
            }
        }
    }
    else if (!string.IsNullOrEmpty(Model.Username))
    {
        initials = Model.Username[0].ToString().ToUpper();
    }
    initials = initials.ToUpper();
}

<style>
    /* ── LEFT SIDEBAR ── */
    .sidebar-card {
        background: rgba(30, 35, 45, 0.4);
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 24px;
        padding: 30px 20px;
    }

    .sidebar-title {
        font-size: 1.4rem;
        font-weight: 800;
        color: #fff;
        margin-bottom: 5px;
        letter-spacing: -0.5px;
    }

    .sidebar-subtitle {
        font-size: 0.78rem;
        color: var(--text-dim);
        margin-bottom: 30px;
    }

    .settings-nav {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .settings-nav-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 18px;
        border-radius: 14px;
        color: var(--text-dim);
        font-size: 0.85rem;
        font-weight: 600;
        text-decoration: none !important;
        transition: all 0.25s ease;
        border: 1px solid transparent;
        cursor: pointer;
    }

    .settings-nav-item:hover {
        color: #fff;
        background: rgba(255, 255, 255, 0.03);
    }

    .settings-nav-item.active {
        background: linear-gradient(135deg, rgba(255, 77, 77, 0.12), rgba(255, 77, 77, 0.02));
        border-color: rgba(255, 77, 77, 0.15);
        color: var(--primary) !important;
        font-weight: 700;
        box-shadow: 0 4px 20px rgba(255, 77, 77, 0.05);
    }

    .settings-nav-item i {
        font-size: 1.05rem;
    }

    /* ── PROFILE CUSTOM THEME ── */
    .settings-container {
        max-width: 1250px;
        margin: 0 auto;
        animation: fadeIn 0.6s ease;
    }

    .settings-grid {
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 30px;
        align-items: start;
    }

    @@media (max-width: 992px) {
        .settings-grid {
            grid-template-columns: 1fr;
        }
    }

    /* ── RIGHT CONTENT CARD ── */
    .profile-card {
        background: rgba(20, 24, 33, 0.6);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.04);
        border-radius: 28px;
        padding: 40px;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
    }

    .profile-header-wrap {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 35px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        padding-bottom: 25px;
        flex-wrap: wrap;
        gap: 15px;
    }

    .profile-card-title {
        font-size: 1.5rem;
        font-weight: 900;
        color: #fff;
        margin: 0;
        letter-spacing: -0.5px;
    }

    /* Avatar Banner */
    .avatar-row {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 35px;
    }

    .profile-avatar-circle {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--primary), #c0002a);
        color: #000;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.6rem;
        font-weight: 900;
        letter-spacing: 0.5px;
        box-shadow: 0 8px 25px rgba(255, 77, 77, 0.3);
        border: 2px solid rgba(255, 255, 255, 0.1);
        text-transform: uppercase;
    }

    .avatar-info h4 {
        color: #fff;
        font-weight: 800;
        font-size: 1.25rem;
        margin: 0 0 4px 0;
        letter-spacing: -0.3px;
    }

    .avatar-info p {
        color: var(--text-dim);
        font-size: 0.8rem;
        margin: 0;
        font-weight: 500;
    }

    /* Form Design */
    .form-section-title {
        font-size: 1rem;
        font-weight: 800;
        color: #fff;
        margin-bottom: 20px;
        letter-spacing: -0.2px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .form-section-title::after {
        content: '';
        flex: 1;
        height: 1px;
        background: rgba(255, 255, 255, 0.05);
    }

    .premium-form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 24px;
    }

    /* ── CUSTOM RADIO ── */
    .premium-radio-btn {
        display: flex;
        align-items: center;
        cursor: pointer;
        position: relative;
        margin-right: 20px;
    }
    .premium-radio-btn input[type="radio"] {
        appearance: none !important;
        -webkit-appearance: none !important;
        width: 18px !important;
        height: 18px !important;
        min-width: 18px !important;
        border: 2px solid rgba(255, 255, 255, 0.4) !important;
        border-radius: 50% !important;
        outline: none !important;
        background: transparent !important;
        cursor: pointer;
        position: relative;
        transition: 0.3s;
        margin: 0 10px 0 0 !important;
        display: inline-block !important;
    }
    .premium-radio-btn input[type="radio"]:checked {
        border-color: #ff4d4d !important;
    }
    .premium-radio-btn input[type="radio"]:checked::after {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 10px;
        height: 10px;
        background: #ff4d4d;
        border-radius: 50%;
    }
    .premium-radio-btn span {
        color: #fff;
        font-weight: 600;
        font-size: 0.85rem;
    }

    @@media (max-width: 768px) {
        .premium-form-grid {
            grid-template-columns: 1fr;
        }
    }

    .form-group-premium {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .form-label-premium {
        font-size: 0.72rem;
        font-weight: 700;
        color: var(--text-dim);
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .form-control-premium {
        background: rgba(255, 255, 255, 0.02) !important;
        border: 1px solid rgba(255, 255, 255, 0.07) !important;
        border-radius: 14px !important;
        color: #fff !important;
        padding: 12px 18px !important;
        font-size: 0.88rem !important;
        font-weight: 600 !important;
        transition: all 0.25s ease !important;
        outline: none !important;
    }

    .form-control-premium:focus {
        border-color: #ff4d4d;
        box-shadow: 0 0 15px rgba(255, 77, 77, 0.15);
        background: rgba(255, 255, 255, 0.08);
    }
    
    .form-control-premium option {
        background-color: #1a1d24;
        color: #ffffff;
    }

    .form-control-premium[readonly],
    .form-control-premium:disabled {
        background: rgba(255, 255, 255, 0.01) !important;
        border-color: rgba(255, 255, 255, 0.04) !important;
        color: rgba(255, 255, 255, 0.4) !important;
        cursor: not-allowed;
    }

    /* Notification Area */
    .alert-premium {
        border-radius: 16px;
        border: 1px solid rgba(255, 255, 255, 0.05);
        font-size: 0.85rem;
        font-weight: 600;
    }

    /* Form Validation Feedback */
    .was-validated .form-control-premium:invalid ~ .invalid-feedback,
    .was-validated .form-control-premium:invalid ~ div > .invalid-feedback {
        display: block !important;
    }

    .was-validated .form-control-premium:invalid {
        border-color: #ff4d4d !important;
        background-image: none !important;
    }

    /* Back & Save Button */
    .btn-premium-edit {
        background: var(--primary);
        border: none;
        color: #000;
        font-weight: 800;
        font-size: 0.82rem;
        letter-spacing: 0.5px;
        padding: 10px 24px;
        border-radius: 50px;
        box-shadow: 0 8px 20px var(--primary-glow);
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.25s ease;
        text-decoration: none !important;
    }

    .btn-premium-edit:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 25px var(--primary-glow);
        background: #ff6666;
        color: #000;
    }

    .btn-premium-edit i {
        font-size: 0.95rem;
    }

    .btn-outline-premium {
        background: transparent;
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: var(--text-dim);
        font-weight: 700;
        font-size: 0.82rem;
        padding: 12px 24px;
        border-radius: 50px;
        transition: all 0.25s ease;
        text-decoration: none !important;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-outline-premium:hover {
        border-color: rgba(255, 255, 255, 0.2);
        color: #fff;
        background: rgba(255, 255, 255, 0.02);
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(12px); }
        to   { opacity: 1; transform: translateY(0); }
    }
</style>

<div class="settings-container py-4">
    <div class="settings-grid">
        
        <!-- ─── LEFT SIDEBAR ─── -->
        <div class="sidebar-card" data-aos="fade-right">
            <h2 class="sidebar-title">Settings</h2>
            <p class="sidebar-subtitle">You can find all settings here.</p>
            
            <nav class="settings-nav">
                <a href="javascript:void(0)" class="settings-nav-item active" id="tab-nav-profile" onclick="switchTab('profile')">
                    <i class="bi bi-person"></i> Profile Information
                </a>
                <a href="javascript:void(0)" class="settings-nav-item" id="tab-nav-class" onclick="switchTab('class')">
                    <i class="bi bi-box-seam-fill"></i> Class Details
                </a>
                <a href="/Account/MemberSettings" class="settings-nav-item">
                    <i class="bi bi-shield-lock"></i> Security Options
                </a>
            </nav>
        </div>

        <!-- ─── RIGHT CONTENT CARD ─── -->
        <div class="profile-card" data-aos="fade-left">
            
            <!-- PROFILE PANE -->
            <div id="pane-profile" style="display: block;">
                <form asp-action="MemberProfile" method="post" id="profileForm" class="needs-validation" novalidate>
            
            <!-- Hidden stitched input -->
            <input type="hidden" name="FullName" id="hiddenFullName" value="@Model.FullName" />

            <!-- Profile Header -->
            <div class="profile-header-wrap">
                <h3 class="profile-card-title">Profile Information</h3>
            </div>

            <!-- Live Alerts / Notifications -->

            <!-- Avatar Row -->
            <div class="avatar-row">
                <div class="profile-avatar-circle">
                    @initials
                </div>
                <div class="avatar-info">
                    <div class="position-relative d-inline-block">
                        <input type="text" name="Username" id="inputUsername" class="form-control-premium m-0" value="@Model.Username" style="font-size: 1.25rem; font-weight: 700; padding: 8px 15px; width: 220px; color: #fff !important; border-radius: 12px !important;" required>
                    </div>
                    <p style="margin-top: 6px;">Archery Club Member &middot; @Model.Email</p>
                    
                    <div style="margin-top: 8px;">
                        @if (ViewBag.MainAccountClassReg == null)
                        {
                            <span style="font-size: 0.75rem; font-weight: 700; color: var(--primary); background: rgba(255, 77, 77, 0.1); border: 1px solid rgba(255, 77, 77, 0.2); padding: 4px 12px; border-radius: 50px;">
                                Not Registered
                            </span>
                        }
                        else
                        {
                            var reg = (ArcheryAlley.Models.ClassRegistrations)ViewBag.MainAccountClassReg;
                            var isPaidProfile = reg.PaymentStatus == "Paid" || reg.PaymentStatus == "Success";
                            
                            if (ViewBag.MainAccountIsCompleted == true)
                            {
                                <span style="font-size: 0.75rem; font-weight: 700; color: #00C6FF; background: rgba(0, 198, 255, 0.1); border: 1px solid rgba(0, 198, 255, 0.2); padding: 4px 12px; border-radius: 50px;">
                                    <i class="bi bi-award-fill" style="margin-right: 4px;"></i> Completed
                                </span>
                            }
                            else if (ViewBag.MainAccountIsExpired == true)
                            {
                                <span style="font-size: 0.75rem; font-weight: 700; color: #ff4d4d; background: rgba(255, 77, 77, 0.1); border: 1px solid rgba(255, 77, 77, 0.2); padding: 4px 12px; border-radius: 50px;">
                                    <i class="bi bi-exclamation-octagon-fill" style="margin-right: 4px;"></i> Expired
                                </span>
                            }
                            else if (isPaidProfile)
                            {
                                <span style="font-size: 0.75rem; font-weight: 700; color: #10B981; background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.2); padding: 4px 12px; border-radius: 50px;">
                                    <i class="bi bi-check-circle-fill" style="margin-right: 4px;"></i> Active
                                </span>
                            }
                            else
                            {
                                <span style="font-size: 0.75rem; font-weight: 700; color: #F59E0B; background: rgba(245, 158, 11, 0.1); border: 1px solid rgba(245, 158, 11, 0.2); padding: 4px 12px; border-radius: 50px;">
                                    <i class="bi bi-clock-fill" style="margin-right: 4px;"></i> Pending
                                </span>
                            }
                        }
                    </div>
                </div>
            </div>

            <!-- Section: Personal Details -->
            <div class="form-section-title">Personal Details</div>
            
            <div class="premium-form-grid">
                <!-- First Name -->
                <div class="form-group-premium">
                    <label class="form-label-premium">First Name</label>
                    <input type="text" id="inputFirstName" class="form-control-premium" value="@firstName" placeholder="First Name" required>
                    <div class="invalid-feedback" style="font-size: 0.72rem; color: #ff4d4d; margin-top: 3px;">First name is required.</div>
                </div>

                <!-- Last Name -->
                <div class="form-group-premium">
                    <label class="form-label-premium">Last Name</label>
                    <input type="text" id="inputLastName" class="form-control-premium" value="@lastName" placeholder="Last Name">
                </div>

                <!-- Email Address (Readonly Key) -->
                <div class="form-group-premium">
                    <label class="form-label-premium">Email Address</label>
                    <input type="email" class="form-control-premium" value="@Model.Email" readonly disabled>
                </div>

                <!-- Phone Number -->
                <div class="form-group-premium">
                    <label class="form-label-premium">Phone</label>
                    <input type="tel" name="PhoneNumber" class="form-control-premium" value="@Model.PhoneNumber" placeholder="e.g. 0123456789" required>
                    <div class="invalid-feedback" style="font-size: 0.72rem; color: #ff4d4d; margin-top: 3px;">Phone number is required.</div>
                </div>

                <!-- Gender (Radio Buttons) -->
                <div class="form-group-premium">
                    <label class="form-label-premium">GENDER</label>
                    <div class="d-flex align-items-center gap-4 mt-2" style="height: 100%; padding-left: 10px;">
                        <label class="premium-radio-btn">
                            <input type="radio" name="Gender" id="genderMale" value="Male">
                            <span>Male</span>
                        </label>
                        <label class="premium-radio-btn">
                            <input type="radio" name="Gender" id="genderFemale" value="Female">
                            <span>Female</span>
                        </label>
                    </div>
                </div>

                <!-- Age (Readonly dynamically populated from IC) -->
                <div class="form-group-premium">
                    <label class="form-label-premium">AGE</label>
                    <input type="text" id="dobDisplay" class="form-control-premium" readonly>
                </div>

                <!-- National ID (IC Number) -->
                <div class="form-group-premium">
                    <label class="form-label-premium">National ID (IC Number)</label>
                    <input type="text" name="ICNumber" id="icInput" class="form-control-premium" value="@Model.ICNumber" placeholder="e.g. 980102145678" pattern="\d{12}" maxlength="12" required>
                    <div id="icFeedback" class="small mt-1" style="font-size: 0.75rem;"></div>
                    <div class="invalid-feedback" style="font-size: 0.72rem; color: #ff4d4d; margin-top: 3px;">Please enter a valid 12-digit IC number (numbers only).</div>
                </div>
            </div>

            <!-- Section: Address Details -->
            <div class="form-section-title">Address Details</div>

            <input type="hidden" name="Address" id="hiddenAddress" value="@Model.Address" />

            <div class="form-group-premium mb-3">
                <label class="form-label-premium">STREET</label>
                <input type="text" id="inputStreet" class="form-control-premium" placeholder="e.g. Jalan Sentosa 4, Taman Sentosa" required>
            </div>

            <div class="premium-form-grid" style="grid-template-columns: 1fr 1fr 1fr; gap: 15px;">
                <div class="form-group-premium">
                    <label class="form-label-premium">POSTCODE</label>
                    <input type="text" id="inputPostcode" class="form-control-premium" placeholder="e.g. 76000" required>
                </div>
                <div class="form-group-premium">
                    <label class="form-label-premium">CITY</label>
                    <input type="text" id="inputCity" class="form-control-premium" placeholder="e.g. Raub" required>
                </div>
                <div class="form-group-premium">
                    <label class="form-label-premium">STATE</label>
                    <select id="inputState" class="form-control-premium" style="appearance: auto; -webkit-appearance: auto;" required>
                        <option value="">Select State</option>
                        <option value="Johor">Johor</option>
                        <option value="Kedah">Kedah</option>
                        <option value="Kelantan">Kelantan</option>
                        <option value="Melaka">Melaka</option>
                        <option value="Negeri Sembilan">Negeri Sembilan</option>
                        <option value="Pahang">Pahang</option>
                        <option value="Perak">Perak</option>
                        <option value="Perlis">Perlis</option>
                        <option value="Pulau Pinang">Pulau Pinang</option>
                        <option value="Sabah">Sabah</option>
                        <option value="Sarawak">Sarawak</option>
                        <option value="Selangor">Selangor</option>
                        <option value="Terengganu">Terengganu</option>
                        <option value="Kuala Lumpur">Kuala Lumpur</option>
                        <option value="Labuan">Labuan</option>
                        <option value="Putrajaya">Putrajaya</option>
                    </select>
                </div>
            </div>

                    <div class="d-flex justify-content-end pt-3 border-top mb-4" style="border-color: rgba(255,255,255,0.05) !important;">
                        <button type="submit" class="btn-premium-edit">
                            <i class="bi bi-pencil-square"></i> Save Changes
                        </button>
                    </div>
                    
                    <div class="d-flex justify-content-start">
                        <a href="/Account/MemberDashboard" class="btn-outline-premium">
                            Back to Dashboard
                        </a>
                    </div>
                </form>
            </div>

            <!-- CLASS DETAILS PANE -->
            <div id="pane-class" style="display: none; animation: fadeIn 0.4s ease;">
                <div class="profile-header-wrap">
                    <h3 class="profile-card-title">Class Details</h3>
                </div>

                @if (ViewBag.MainAccountClassReg != null)
                {
                    var reg = (ArcheryAlley.Models.ClassRegistrations)ViewBag.MainAccountClassReg;
                    string displayPkg = reg.PackageType ?? "";
                    if (displayPkg.Contains("4 Slot")) displayPkg = "Starter Tier";
                    else if (displayPkg.Contains("6 Slot")) displayPkg = "Progressive Tier";

                    <div class="premium-form-grid" style="margin-bottom: 20px;">
                        <div class="form-group-premium">
                            <label class="form-label-premium">Package Type</label>
                            <input type="text" class="form-control-premium" readonly value="@displayPkg" />
                        </div>
                        
                        <div class="form-group-premium">
                            <label class="form-label-premium">Payment Status</label>
                            <div style="background: transparent; border: none; padding: 0; padding-top: 10px;">
                                @{
                                    var isPaid = reg.PaymentStatus == "Paid" || reg.PaymentStatus == "Success";
                                }
                                @if (isPaid)
                                {
                                    <span style="font-size: 0.9rem; font-weight: 700; color: #10B981; background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.2); padding: 8px 16px; border-radius: 50px; display: inline-flex; align-items: center; gap: 8px;">
                                        <i class="bi bi-check-circle-fill"></i> Paid
                                    </span>
                                }
                                else
                                {
                                    <span style="font-size: 0.9rem; font-weight: 700; color: #F59E0B; background: rgba(245, 158, 11, 0.1); border: 1px solid rgba(245, 158, 11, 0.2); padding: 8px 16px; border-radius: 50px; display: inline-flex; align-items: center; gap: 8px;">
                                        <i class="bi bi-clock-fill"></i> Pending
                                    </span>
                                }
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="bi bi-clipboard-x text-dim" style="font-size: 3rem; opacity: 0.5;"></i>
                        <p class="text-dim mt-3" style="font-size: 1rem; font-weight: 500;">You have not registered for any classes yet.</p>
                        <a href="/Account/ClassRegistration" class="btn-premium-edit mt-3">
                            <i class="bi bi-mortarboard-fill me-2"></i> Register Now
                        </a>
                    </div>
                }

                @{
                    var historyList = ViewBag.ClassHistory as List<ArcheryAlley.Models.ClassRegistrations>;
                }
                @if (historyList != null && historyList.Any())
                {
                    <div class="form-section-title mt-5" style="border-bottom: none;">
                        <i class="bi bi-clock-history"></i> Class Registration History
                    </div>
                    <div style="display: flex; flex-direction: column; gap: 15px; max-height: 320px; overflow-y: auto; padding-right: 5px;">
                        @foreach (var h in historyList)
                        {
                            string displayPkgHist = h.PackageType ?? "";
                            if (displayPkgHist.Contains("4 Slot")) displayPkgHist = "Starter Tier";
                            else if (displayPkgHist.Contains("6 Slot")) displayPkgHist = "Progressive Tier";

                            <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 16px; display: flex; justify-content: space-between; align-items: center;">
                                <div>
                                    <div style="font-weight: 700; color: #fff; font-size: 0.95rem; margin-bottom: 4px;">@displayPkgHist</div>
                                    <div style="color: var(--text-dim); font-size: 0.8rem;">
                                        Registered on @h.RegistrationDate.ToString("dd MMM yyyy, hh:mm tt")
                                    </div>
                                </div>
                                <div style="text-align: right;">
                                    <div style="font-weight: 800; color: #fff; font-size: 0.95rem; margin-bottom: 4px;">RM @h.TotalPrice.ToString("0.00")</div>
                                    @if (h.PaymentStatus == "Paid" || h.PaymentStatus == "Success")
                                    {
                                        <span style="font-size: 0.7rem; font-weight: 700; color: #10B981; background: rgba(16, 185, 129, 0.1); padding: 2px 8px; border-radius: 50px;">
                                            <i class="bi bi-check-circle-fill"></i> Paid
                                        </span>
                                    }
                                    else
                                    {
                                        <span style="font-size: 0.7rem; font-weight: 700; color: #F59E0B; background: rgba(245, 158, 11, 0.1); padding: 2px 8px; border-radius: 50px;">
                                            <i class="bi bi-clock-fill"></i> @h.PaymentStatus
                                        </span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <style>
        .swal-custom-popup {
            border-radius: 32px !important;
            border: 1px solid rgba(255,255,255,0.05);
        }
        .swal-custom-confirm {
            background-color: #007bff !important;
            color: #fff !important;
            border-radius: 50px !important;
            padding: 10px 30px !important;
            font-weight: 700 !important;
            border: none !important;
            transition: 0.3s;
        }
        .swal-custom-confirm:hover {
            background-color: #0056b3 !important;
        }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        @if (ViewBag.SuccessMessage != null)
        {
            <text>
            Swal.fire({
                icon: 'success',
                title: 'Success!',
                text: '@Html.Raw(ViewBag.SuccessMessage)',
                background: '#0d121c',
                color: '#fff',
                confirmButtonText: 'OK',
                customClass: {
                    popup: 'swal-custom-popup',
                    confirmButton: 'swal-custom-confirm'
                },
                buttonsStyling: false
            });
            </text>
        }

        @if (ViewBag.ErrorMessage != null)
        {
            <text>
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: '@Html.Raw(ViewBag.ErrorMessage)',
                background: '#0d121c',
                color: '#fff',
                confirmButtonText: 'OK',
                customClass: {
                    popup: 'swal-custom-popup',
                    confirmButton: 'swal-custom-confirm'
                },
                buttonsStyling: false
            });
            </text>
        }

        // Form Validation & Stitching
        (function () {
            'use strict';
            var form = document.getElementById('profileForm');
            form.addEventListener('submit', function (event) {
                // Stitch First Name & Last Name into FullName hidden input
                const first = document.getElementById('inputFirstName').value.trim();
                const last = document.getElementById('inputLastName').value.trim();
                const hiddenName = document.getElementById('hiddenFullName');
                
                if (first) {
                    hiddenName.value = last ? `${first} ${last}` : first;
                }

                // Stitch Address inputs into Address hidden input
                const street = document.getElementById('inputStreet').value.trim();
                const postcode = document.getElementById('inputPostcode').value.trim();
                const city = document.getElementById('inputCity').value.trim();
                const state = document.getElementById('inputState').value.trim();
                
                if (street && postcode && city && state) {
                    document.getElementById('hiddenAddress').value = `${street}, ${postcode}, ${city}, ${state}`;
                }

                if (!form.checkValidity()) {
                    event.preventDefault();
                    event.stopPropagation();
                    
                    Swal.fire({
                        icon: 'warning',
                        title: 'Incomplete Profile',
                        text: 'Please complete all required fields to update your profile.',
                        background: '#0d121c',
                        color: '#fff',
                        confirmButtonText: 'OK',
                        customClass: {
                            popup: 'swal-custom-popup',
                            confirmButton: 'swal-custom-confirm'
                        },
                        buttonsStyling: false
                    });
                }
                form.classList.add('was-validated');
            }, false);
        })();

        // Malaysian IC Parser (DOB, Age, Gender)
        const icInput = document.getElementById('icInput');
        const dobDisplay = document.getElementById('dobDisplay');
        const icFeedback = document.getElementById('icFeedback');

        function parseIC(ic) {
            ic = ic.trim();
            if (!ic || ic.length !== 12 || !/^\d+$/.test(ic)) {
                icFeedback.innerHTML = '<span class="text-danger"><i class="bi bi-x-circle-fill me-1"></i> IC must be exactly 12 numeric digits</span>';
                return;
            }

            const year2Digit = parseInt(ic.substring(0, 2));
            const month = parseInt(ic.substring(2, 4));
            const day = parseInt(ic.substring(4, 6));

            if (month < 1 || month > 12 || day < 1 || day > 31) {
                icFeedback.innerHTML = '<span class="text-danger"><i class="bi bi-x-circle-fill me-1"></i> Invalid birthdate encoded in IC number</span>';
                return;
            }

            const currentYear = new Date().getFullYear();
            const currentYear2Digit = currentYear % 100;
            const year = year2Digit + (year2Digit > currentYear2Digit ? 1900 : 2000);

            const birthDate = new Date(year, month - 1, day);
            if (isNaN(birthDate.getTime())) {
                icFeedback.innerHTML = '<span class="text-danger"><i class="bi bi-x-circle-fill me-1"></i> Invalid Date of Birth</span>';
                return;
            }

            // Calculate age
            let age = currentYear - year;
            const m = new Date().getMonth() - (month - 1);
            if (m < 0 || (m === 0 && new Date().getDate() < day)) {
                age--;
            }

            dobDisplay.value = age;
            
            // Auto-select gender radio button based on the last digit (Odd = Male, Even = Female)
            const lastDigit = parseInt(ic.charAt(11));
            if (lastDigit % 2 === 0) {
                document.getElementById('genderFemale').checked = true;
            } else {
                document.getElementById('genderMale').checked = true;
            }

            // Clear any error messages when successful
            icFeedback.innerHTML = '';
        }

        icInput.addEventListener('input', function() {
            parseIC(this.value);
        });

        // Initialize parser on page load
        if (icInput.value) {
            parseIC(icInput.value);
        }

        // Initialize address fields from hidden address value
        const fullAddr = document.getElementById('hiddenAddress').value;
        if (fullAddr) {
            const parts = fullAddr.split(',').map(p => p.trim());
            if (parts.length >= 4) {
                // Assuming format is: Street, Postcode, City, State
                const stateValue = parts[parts.length - 1];
                const stateSelect = document.getElementById('inputState');
                // Ensure state matches one of the options
                for(let i=0; i<stateSelect.options.length; i++) {
                    if(stateSelect.options[i].value.toLowerCase() === stateValue.toLowerCase()) {
                        stateSelect.selectedIndex = i;
                        break;
                    }
                }
                document.getElementById('inputCity').value = parts[parts.length - 2];
                document.getElementById('inputPostcode').value = parts[parts.length - 3];
                document.getElementById('inputStreet').value = parts.slice(0, parts.length - 3).join(', ');
            } else {
                // Fallback to putting everything in Street if it wasn't stitched properly before
                document.getElementById('inputStreet').value = fullAddr;
            }
        }

        // Tab Switching Logic
        function switchTab(tabId) {
            // Update nav items
            document.getElementById('tab-nav-profile').classList.remove('active');
            document.getElementById('tab-nav-class').classList.remove('active');
            document.getElementById('tab-nav-' + tabId).classList.add('active');

            // Update panes
            document.getElementById('pane-profile').style.display = 'none';
            document.getElementById('pane-class').style.display = 'none';
            document.getElementById('pane-' + tabId).style.display = 'block';
        }
    </script>
}
