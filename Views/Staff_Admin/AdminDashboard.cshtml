@section Scripts {
<script>
    async function loadCoachRoster() {
        try {
            const response = await fetch('/Slot/GetCoachRoster');
            const roster   = await response.json();

            const present   = roster.filter(c => c.status === 'Present' || c.status === 'Completed');
            const absent    = roster.filter(c => c.status === 'Absent');

            document.getElementById('rosterPresentCount').textContent = present.length;
            document.getElementById('rosterAbsentCount').textContent  = absent.length;

            renderRosterList('rosterPresent', present, false);
            renderRosterList('rosterAbsent',  absent,  true);

        } catch (err) {
            console.error('Load roster error:', err);
        }
    }

    function renderRosterList(containerId, coaches, isAbsent) {
        const container = document.getElementById(containerId);
        container.innerHTML = '';

        if (coaches.length === 0) {
            container.innerHTML = `
                <div class="roster-empty">
                    <i class="bi bi-person-lines-fill"></i>
                    <p>${isAbsent ? 'All coaches are on the field!' : 'No coaches have clocked in yet.'}</p>
                </div>`;
            return;
        }

        coaches.forEach(c => {
            const row = document.createElement('div');
            row.className = 'roster-row';

            const badgeClass = c.status === 'Present'   ? 'badge-present'   :
                               c.status === 'Completed' ? 'badge-completed' : 'badge-absent';
            const badgeText  = c.status === 'Present'   ? 'On Field'        :
                               c.status === 'Completed' ? 'Shift Done'      : 'Not In';

            const timeText = c.clockIn
                ? `Clocked in at ${c.clockIn}${c.clockOut ? ` · Out at ${c.clockOut}` : ''}`
                : 'No record today';

            row.innerHTML = `
                <div class="coach-info">
                    <div class="coach-avatar ${isAbsent ? 'absent-av' : ''}">
                        ${c.name.charAt(0).toUpperCase()}
                    </div>
                    <div>
                        <div class="coach-name">${c.name}</div>
                        <div class="coach-time">${timeText}</div>
                    </div>
                </div>
                <span class="status-badge ${badgeClass}">${badgeText}</span>`;

            container.appendChild(row);
        });
    }

    function switchRosterTab(tab) {
        document.querySelectorAll('.roster-tab').forEach(t => t.classList.remove('active'));
        tab.classList.add('active');

        const isPresent = tab.dataset.tab === 'present';
        document.getElementById('rosterPresent').style.display = isPresent ? '' : 'none';
        document.getElementById('rosterAbsent').style.display  = isPresent ? 'none' : '';
    }

    window.addEventListener('DOMContentLoaded', () => {
        loadCoachRoster();
    });
</script>
}