@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Staff_Admin/AdminNavBar.cshtml";
}

<style>
    /* --- CSS ROOT & BASE --- */
    :root {
        --bg-dark: #0a0a0a;
        --card-glass: #141414;
        --border-glass: rgba(255, 255, 255, 0.05);
        --text-main: #ffffff;
        --text-muted: #888888;
        --primary-orange: #ff6b00;
        --primary-glow: rgba(255, 107, 0, 0.2);
    }

    .dashboard-container {
        max-width: 900px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: 24px;
    }

    /* --- 1. QUICK ACTION TILES (TOP ROW) --- */
    .quick-action-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
    }

    .action-tile {
        background: var(--card-glass);
        border: 1px solid var(--border-glass);
        border-radius: 18px;
        padding: 16px;
        display: flex;
        align-items: center;
        gap: 12px;
        text-decoration: none;
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        cursor: pointer;
    }

    .action-tile:hover {
        background: rgba(255, 255, 255, 0.03);
        transform: translateY(-3px);
        border-color: rgba(255, 255, 255, 0.1);
    }

    .tile-icon {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        color: #fff;
        flex-shrink: 0;
    }

    /* Gradients matching your reference image */
    .icon-orange { background: linear-gradient(135deg, #ff8a00, #e52e71); box-shadow: 0 4px 15px rgba(255, 138, 0, 0.3); }
    .icon-red    { background: linear-gradient(135deg, #ff416c, #ff4b2b); box-shadow: 0 4px 15px rgba(255, 65, 108, 0.3); }
    .icon-gray   { background: linear-gradient(135deg, #606c88, #3f4c6b); box-shadow: 0 4px 15px rgba(96, 108, 136, 0.3); }
    .icon-blue   { background: linear-gradient(135deg, #36D1DC, #5B86E5); box-shadow: 0 4px 15px rgba(54, 209, 220, 0.3); }

    .tile-label {
        color: var(--text-main);
        font-size: 0.85rem;
        font-weight: 700;
        letter-spacing: 0.5px;
    }

    /* --- 2. WELCOME & STATUS CARD (MIDDLE) --- */
    .welcome-card {
        background: linear-gradient(145deg, #1a1a1a, #0f0f0f);
        border: 1px solid var(--border-glass);
        border-radius: 24px;
        padding: 32px;
        position: relative;
        overflow: hidden;
    }

    .welcome-header {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 24px;
    }

    .emoji-hand {
        font-size: 3rem;
        animation: wave 2.5s infinite;
        transform-origin: 70% 70%;
    }

    @@keyframes wave {
        0% { transform: rotate(0deg); }
        10% { transform: rotate(14deg); }
        20% { transform: rotate(-8deg); }
        30% { transform: rotate(14deg); }
        40% { transform: rotate(-4deg); }
        50% { transform: rotate(10deg); }
        60%, 100% { transform: rotate(0deg); }
    }

    .welcome-text p {
        color: var(--text-muted);
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        margin: 0 0 4px 0;
    }

    .welcome-text h2 {
        color: var(--text-main);
        font-size: 2rem;
        font-weight: 800;
        margin: 0;
        letter-spacing: -0.5px;
    }

    .welcome-divider {
        height: 1px;
        background: rgba(255, 255, 255, 0.06);
        width: 100px;
        margin-bottom: 24px;
    }

    .date-text .day {
        color: var(--primary-orange);
        font-size: 0.8rem;
        font-weight: 800;
        letter-spacing: 2px;
        text-transform: uppercase;
        margin: 0 0 6px 0;
    }

    .date-text .full-date {
        color: var(--text-main);
        font-size: 1.6rem;
        font-weight: 800;
        margin: 0 0 16px 0;
    }

    .system-status {
        display: flex;
        align-items: center;
        gap: 8px;
        color: var(--text-muted);
        font-size: 0.85rem;
        font-weight: 500;
    }

    .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--primary-orange);
        box-shadow: 0 0 10px var(--primary-glow);
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.5; transform: scale(0.8); }
    }

    /* --- 3. TODAY'S ROSTER (BOTTOM) --- */
    /* ── ROSTER CARD ── */
    .roster-card {
        margin-top: 28px;
        max-width: 1100px;
        overflow: hidden;
    }

    .roster-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 20px 24px;
        border-bottom: 1px solid rgba(255,255,255,0.06);
        flex-wrap: wrap;
        gap: 12px;
    }

    .roster-title { font-size: 0.95rem; font-weight: 700; color: var(--white); }
    .roster-sub   { font-size: 0.72rem; color: var(--text-dim); margin-top: 3px; }

    .roster-stats { display: flex; gap: 16px; }
    .roster-stat  {
        text-align: center;
        padding: 8px 16px;
        border-radius: 10px;
        background: rgba(249,115,22,0.1);
        border: 1px solid rgba(249,115,22,0.25);
    }
    .roster-stat.absent {
        background: rgba(220,38,38,0.1);
        border-color: rgba(220,38,38,0.25);
    }
    .stat-num { display: block; font-size: 1.4rem; font-weight: 800; color: var(--primary); }
    .roster-stat.absent .stat-num { color: var(--red); }
    .stat-lbl { font-size: 0.6rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: 1px; }

    /* ── ROSTER TABS ── */
    .roster-tabs {
        display: flex;
        gap: 0;
        border-bottom: 1px solid rgba(255,255,255,0.06);
    }

    .roster-tab {
        flex: 1;
        padding: 12px;
        background: transparent;
        border: none;
        color: var(--text-dim);
        font-size: 0.82rem;
        font-weight: 600;
        cursor: pointer;
        font-family: 'Outfit', sans-serif;
        transition: 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 7px;
        border-bottom: 2px solid transparent;
    }
    .roster-tab:hover { color: var(--primary); }
    .roster-tab.active {
        color: var(--primary);
        border-bottom-color: var(--primary);
        background: rgba(249,115,22,0.05);
    }

    /* ── ROSTER ROWS ── */
    .roster-list { display: flex; flex-direction: column; }

    .roster-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 24px;
        border-bottom: 1px solid rgba(255,255,255,0.03);
        transition: 0.2s;
        gap: 12px;
    }
    .roster-row:last-child { border-bottom: none; }
    .roster-row:hover { background: rgba(255,255,255,0.015); }

    .coach-info { display: flex; align-items: center; gap: 12px; }

    .coach-avatar {
        width: 38px; height: 38px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        display: flex; align-items: center; justify-content: center;
        font-size: 0.95rem; font-weight: 800; color: #fff;
        flex-shrink: 0;
    }
    .coach-avatar.absent-av {
        background: rgba(255,255,255,0.06);
        color: var(--text-dim);
    }

    .coach-name { font-size: 0.88rem; font-weight: 600; color: var(--white); }
    .coach-time { font-size: 0.7rem; color: var(--text-dim); margin-top: 2px; }

    .status-badge {
        font-size: 0.65rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: 1px;
        padding: 4px 12px; border-radius: 20px;
        flex-shrink: 0;
    }
    .badge-present  { background: rgba(52,211,153,0.12); color: #34D399; border: 1px solid rgba(52,211,153,0.3); }
    .badge-completed{ background: rgba(255,255,255,0.06); color: var(--text-dim); border: 1px solid rgba(255,255,255,0.1); }
    .badge-absent   { background: rgba(220,38,38,0.1); color: #f87171; border: 1px solid rgba(220,38,38,0.25); }

    .roster-empty {
        padding: 40px;
        text-align: center;
        color: var(--text-dim);
        font-size: 0.85rem;
        font-size: 0.85rem;
    }
    .roster-empty i { font-size: 2rem; display: block; margin-bottom: 10px; opacity: 0.3; }
    /* --- RESPONSIVE ADJUSTMENTS --- */
    @@media (max-width: 900px) {
        .quick-action-grid { grid-template-columns: repeat(3, 1fr); }
    }

    @@media (max-width: 600px) {
        /* Forces 2-row stack exactly like the picture conceptually */
        .quick-action-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
        .action-tile { padding: 12px; flex-direction: column; text-align: center; justify-content: center; height: 110px;}
        .welcome-card, .roster-card { padding: 24px; }
        .welcome-text h2 { font-size: 1.6rem; }
        .emoji-hand { font-size: 2.5rem; }
    }
</style>

<div class="dashboard-container">

    <div class="quick-action-grid">
        <a href="/Slot/AdminProfile" class="action-tile">
            <div class="tile-icon icon-orange"><i class="bi bi-person-fill"></i></div>
            <span class="tile-label">Profile</span>
        </a>
        <a href="/Slot/AdminAttendance" class="action-tile">
            <div class="tile-icon icon-red"><i class="bi bi-calendar-check-fill"></i></div>
            <span class="tile-label">Attendance</span>
        </a>
        <a href="/Report/AdminStudentPerformance" class="action-tile">
            <div class="tile-icon icon-gray"><i class="bi bi-bar-chart-fill"></i></div>
            <span class="tile-label">Reports</span>
        </a>
        <a href="/Management/ManageLanes" class="action-tile">
            <div class="tile-icon icon-orange"><i class="bi bi-bullseye"></i></div>
            <span class="tile-label">Targets</span>
        </a>
        <a href="/Rate/ManageRates" class="action-tile">
            <div class="tile-icon icon-blue"><i class="bi bi-tags-fill"></i></div>
            <span class="tile-label">Rates</span>
        </a>
        <a href="/Account/Register" class="action-tile">
            <div class="tile-icon icon-gray"><i class="bi bi-people-fill"></i></div>
            <span class="tile-label">Staff</span>
        </a>
        <a href="/Booking/BookingHistory" class="action-tile">
            <div class="tile-icon icon-red"><i class="bi bi-clock-history"></i></div>
            <span class="tile-label">Bookings</span>
        </a>
    </div>

    <div class="welcome-card">
        <div class="welcome-header">
            <div class="emoji-hand">👋</div>
            <div class="welcome-text">
                <p>Welcome Back, Head Coach</p>
                <h2>@(ViewBag.AdminName ?? "Admin")</h2>
            </div>
        </div>
        
        <div class="welcome-divider"></div>
        
        <div class="date-text">
            <p class="day">@DateTime.Today.ToString("dddd")</p>
            <h3 class="full-date">@DateTime.Today.ToString("dd MMMM yyyy")</h3>
        </div>
        
        <div class="system-status">
            <span class="status-dot"></span> System Online
        </div>
    </div>
    <!--Mock Data-->
<!-- ── COACH ROSTER WIDGET ── -->
<div class="roster-card glass-card">
    <div class="roster-header">
        <div>
            <div class="roster-title">Today's Staff Roster</div>
            <div class="roster-sub" id="rosterDate">@DateTime.Today.ToString("dddd, dd MMM yyyy")</div>
        </div>
        <div class="roster-stats">
            <div class="roster-stat" id="statPresent">
                <span class="stat-num" id="rosterPresentCount">—</span>
                <span class="stat-lbl">On Field</span>
            </div>
            <div class="roster-stat absent" id="statAbsent">
                <span class="stat-num" id="rosterAbsentCount">—</span>
                <span class="stat-lbl">Absent</span>
            </div>
        </div>
    </div>

    <!-- Tab buttons -->
    <div class="roster-tabs">
        <button class="roster-tab active" data-tab="present" onclick="switchRosterTab(this)">
            <i class="bi bi-person-check-fill"></i> On Field
        </button>
        <button class="roster-tab" data-tab="absent" onclick="switchRosterTab(this)">
            <i class="bi bi-person-dash-fill"></i> Absent
        </button>
    </div>

    <!-- Present list -->
    <div class="roster-list" id="rosterPresent"></div>

    <!-- Absent list -->
    <div class="roster-list" id="rosterAbsent" style="display:none;"></div>

    <!-- Empty state -->
    <div class="roster-empty" id="rosterEmpty" style="display:none;">
        <i class="bi bi-person-lines-fill"></i>
        <p>No staff data available</p>
    </div>
</div>
