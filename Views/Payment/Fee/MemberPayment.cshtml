<div class="billing-container py-4">
    <div class="page-header mb-4">
        <h1 class="text-white">BILLING & <span style="color: var(--primary);">PAYMENTS</span></h1>
        <p class="text-dim small">Reserve lanes, buy memberships, and clear training dues seamlessly.</p>
    </div>

    <div class="row gx-lg-5">
        <!-- Left Column: Payment Methods + Transaction History -->
        <div class="col-lg-8 col-xl-9">
            @if (actualPending > 0)
            {
                <!-- Pending Payment Card -->
                <div class="pending-payment-card mb-4" data-aos="fade-up">
                    <div class="d-flex align-items-center justify-content-between flex-wrap gap-4">
                        <div class="d-flex align-items-center gap-3">
                            <div class="pending-icon-ring">
                                <i class="bi bi-clock-history"></i>
                            </div>
                            <div>
                                <h5 class="text-white fw-bold mb-1">Outstanding Dues</h5>
                                <p class="text-dim small mb-0">Please clear your pending payment to activate/renew your services.</p>
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-4">
                            <div class="pending-amount-display">
                                <span class="currency">RM</span>
                                <span class="amount">@actualPending.ToString("N2")</span>
                            </div>
                            <button type="button" class="btn-pay-now-pill" id="btnPayNow" onclick="handlePayNow('all')" style="margin-left: 25px;">
                                Pay Now <i class="bi bi-credit-card-fill"></i>
                            </button>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <!-- Cleared Payment Card -->
                <div class="cleared-payment-card mb-4" data-aos="fade-up">
                    <div class="d-flex align-items-center justify-content-between flex-wrap gap-4">
                        <div class="d-flex align-items-center gap-3">
                            <div class="cleared-icon-ring">
                                <i class="bi bi-shield-check"></i>
                            </div>
                            <div>
                                <h5 class="text-white fw-bold mb-1">No Outstanding Payment</h5>
                                <p class="text-dim small mb-0">All your payments are cleared. Thank you for your support!</p>
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-4">
                            <div class="pending-amount-display">
                                <span class="currency" style="color: #10B981;">RM</span>
                                <span class="amount" style="color: #ffffff;">0.00</span>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <!-- Payment Methods Card -->
            <div class="payment-methods-card mb-4" data-aos="fade-up">
                <h5 class="section-title mb-2 text-white"><i class="bi bi-wallet2 me-2" style="color: #10B981;"></i> Default Payment Method</h5>
                <p class="text-dim small mb-4">Set your preferred default payment method for lane bookings, class memberships, and renewals.</p>
                
                <div class="payment-radio-grid">
                    <!-- Online Banking -->
                    <label class="payment-radio-card">
                        <input type="radio" name="defaultPaymentMethod" value="OnlineBanking" @(defaultMethod == "OnlineBanking" ? "checked" : "")>
                        <div class="payment-radio-content">
                            <i class="bi bi-bank payment-icon"></i>
                            <div class="flex-grow-1">
                                <span class="payment-title">Online Banking</span>
                                <span class="payment-desc">FPX Direct Transfer</span>
                            </div>
                            <div class="radio-indicator"></div>
                        </div>
                    </label>

                    <!-- Card -->
                    <label class="payment-radio-card">
                        <input type="radio" name="defaultPaymentMethod" value="Card" @(defaultMethod == "Card" ? "checked" : "")>
                        <div class="payment-radio-content">
                            <i class="bi bi-credit-card-2-front payment-icon"></i>
                            <div class="flex-grow-1">
                                <span class="payment-title">Debit/Credit Card</span>
                                <span class="payment-desc">Visa / Mastercard</span>
                            </div>
                            <div class="radio-indicator"></div>
                        </div>
                    </label>
                </div>

                <!-- Card Details Panel (multi-card wallet) -->
                <div id="defaultCardDetailsPanel" class="mt-4" style="display: @(defaultMethod == "Card" ? "block" : "none");">

                    <!-- ── Saved Cards List ─────────────────────────────────── -->
                    <div id="savedCardsList">
                        @if (savedCards.Count == 0)
                        {
                            <div id="noCardsMsg" class="text-center py-4" style="border: 1px dashed rgba(255,255,255,0.08); border-radius: 16px;">
                                <i class="bi bi-credit-card text-dim" style="font-size: 2rem;"></i>
                                <p class="text-dim small mt-2 mb-0">No saved cards yet. Add one below.</p>
                            </div>
                        }
                        else
                        {
                            @foreach (var card in savedCards)
                            {
                                var cId     = card.ContainsKey("id")     ? card["id"]     : "";
                                var cNum    = card.ContainsKey("number") ? card["number"] : "";
                                var cExp    = card.ContainsKey("expiry") ? card["expiry"] : "";
                                var isActive = cId == selectedCardId;
                                var last4   = cNum.Replace(" ", "").Length >= 4 ? cNum.Replace(" ", "").Substring(cNum.Replace(" ", "").Length - 4) : "••••";
                                <div class="saved-card-row @(isActive ? "card-row-active" : "")" data-card-id="@cId">
                                    <label style="display:flex; align-items:center; gap:14px; cursor:pointer; flex:1;">
                                        <input type="radio" name="selectedCard" value="@cId" @(isActive ? "checked" : "")
                                               onchange="selectCard('@cId')"
                                               style="accent-color: var(--primary); width:18px; height:18px; flex-shrink:0;">
                                        <div style="width:44px; height:30px; background:rgba(255,255,255,0.06); border-radius:6px; display:flex; align-items:center; justify-content:center; border:1px solid rgba(255,255,255,0.08); flex-shrink:0;">
                                            <i class="bi bi-credit-card text-white" style="font-size:1.1rem;"></i>
                                        </div>
                                        <div style="flex:1;">
                                            <span class="text-white fw-bold d-block" style="font-size:0.87rem; letter-spacing:0.5px;">•••• •••• •••• @last4</span>
                                            <span class="text-dim" style="font-size:0.72rem;">Expires @cExp</span>
                                        </div>

                                    </label>
                                    <button type="button" onclick="deleteCard('@cId', this)"
                                            style="background:rgba(220,53,69,0.08); border:1px solid rgba(220,53,69,0.25); color:#dc3545; border-radius:8px; padding:5px 10px; font-size:0.75rem; font-weight:600; cursor:pointer; flex-shrink:0; display:inline-flex; align-items:center; gap:5px;">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </div>
                            }
                        }
                    </div>

                    <!-- ── Add Card Button ───────────────────────────────────── -->
                    <div class="mt-3">
                        <button type="button" id="btnShowAddCard" onclick="showAddCardForm()"
                                style="background:rgba(255,255,255,0.04); border:1px dashed rgba(255,255,255,0.15); color:#fff; border-radius:12px; padding:10px 20px; font-size:0.8rem; font-weight:600; cursor:pointer; display:inline-flex; align-items:center; gap:8px; transition:all 0.2s;">
                            <i class="bi bi-plus-circle" style="color:var(--primary);"></i> Add New Card
                        </button>
                    </div>

                    <!-- ── Add Card Form (hidden by default) ────────────────── -->
                    <div id="addCardForm" class="p-4 mt-3" style="display:none; background:rgba(255,255,255,0.015); border:1px solid rgba(255,255,255,0.07); border-radius:16px;">
                        <h6 class="text-white mb-1" style="font-weight:700; font-size:0.9rem;">
                            <i class="bi bi-plus-circle me-2" style="color:var(--primary);"></i> Add New Card
                        </h6>
                        <p class="text-dim small mb-3">Your card details are saved securely for quicker checkouts.</p>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label text-dim small mb-1" style="font-size:0.72rem; font-weight:600; text-transform:uppercase; letter-spacing:0.5px;">Card Number</label>
                                <input type="text" id="newCardNumber" class="form-control" placeholder="4111 2222 3333 4444"
                                       style="color:#ffffff !important; font-size:0.85rem; padding:10px; border-radius:8px; border:1px solid rgba(255,255,255,0.1); background-color:rgba(0,0,0,0.2) !important;">
                            </div>
                            <div class="col-md-3">
                                <label class="form-label text-dim small mb-1" style="font-size:0.72rem; font-weight:600; text-transform:uppercase; letter-spacing:0.5px;">Expiry Date</label>
                                <input type="text" id="newCardExpiry" class="form-control" placeholder="MM/YY"
                                       style="color:#ffffff !important; font-size:0.85rem; padding:10px; border-radius:8px; border:1px solid rgba(255,255,255,0.1); background-color:rgba(0,0,0,0.2) !important;">
                            </div>
                            <div class="col-md-3">
                                <label class="form-label text-dim small mb-1" style="font-size:0.72rem; font-weight:600; text-transform:uppercase; letter-spacing:0.5px;">CVV</label>
                                <input type="password" id="newCardCvv" class="form-control" placeholder="•••"
                                       style="color:#ffffff !important; font-size:0.85rem; padding:10px; border-radius:8px; border:1px solid rgba(255,255,255,0.1); background-color:rgba(0,0,0,0.2) !important;">
                            </div>
                        </div>
                        <div class="d-flex justify-content-end gap-2 mt-3">
                            <button type="button" onclick="cancelAddCard()"
                                    style="background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.1); color:#fff; border-radius:8px; padding:8px 18px; font-size:0.8rem; font-weight:600; cursor:pointer;">
                                Cancel
                            </button>
                            <button type="button" onclick="submitAddCard()"
                                    style="background:var(--primary); border:none; color:#000; border-radius:8px; padding:8px 20px; font-size:0.8rem; font-weight:700; cursor:pointer; display:inline-flex; align-items:center; gap:6px;">
                                <i class="bi bi-save"></i> Save Card
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Transaction History Card -->
            <div class="transactions-card" style="margin-top: 0;" data-aos="fade-up">
                <div class="trans-header-wrap">
                    <div class="trans-title-area">
                        <h4>Transaction</h4>
                        <p>Reserve courts, buy equipment, and pay coaching fees with just a few taps.</p>
                    </div>
                    
                    <div class="filter-controls">
                        <div class="search-wrapper">
                            <input type="text" id="transactionSearch" class="search-input-premium" placeholder="Search">
                            <i class="bi bi-search search-icon-inside"></i>
                        </div>
                        
                        <div class="select-premium-wrapper">
                            <i class="bi bi-calendar select-icon-left"></i>
                            <select class="select-premium select-premium-icon" id="dateFilter">
                                <option value="All">This Week</option>
                                <option value="All">All Time</option>
                            </select>
                            <i class="bi bi-chevron-down select-chevron"></i>
                        </div>

                        <div class="select-premium-wrapper">
                            <select class="select-premium" id="statusFilter">
                                <option value="All">All Transactions</option>
                                <option value="Paid">Paid</option>
                                <option value="Pending">Pending</option>
                            </select>
                            <i class="bi bi-chevron-down select-chevron"></i>
                        </div>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table premium-table align-middle" id="transactionTable">
                        <thead>
                            <tr>
                                <th class="text-center">Date & Time <i class="bi bi-chevron-expand ms-1" style="font-size: 0.65rem; opacity: 0.5;"></i></th>
                                <th class="text-center">Transaction Type <i class="bi bi-chevron-expand ms-1" style="font-size: 0.65rem; opacity: 0.5;"></i></th>
                                <th class="text-center">For Archer <i class="bi bi-chevron-expand ms-1" style="font-size: 0.65rem; opacity: 0.5;"></i></th>
                                <th class="text-center">Payment <i class="bi bi-chevron-expand ms-1" style="font-size: 0.65rem; opacity: 0.5;"></i></th>
                                <th class="text-center">Status <i class="bi bi-chevron-expand ms-1" style="font-size: 0.65rem; opacity: 0.5;"></i></th>
                                <th class="text-center"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @* Dynamic Class Registrations from DB *@
                            @foreach (var c in classRegs)
                            {
                                var isPaid = c.PaymentStatus == "Paid" || c.PaymentStatus == "Success";
                                var statusText = isPaid ? "Paid" : "Pending";
                                var archerName = !string.IsNullOrEmpty(c.CustomerName) ? c.CustomerName : "Myself";
                                <tr class="trans-row" data-status="@statusText">
                                    <!-- Date & Time -->
                                    <td class="text-dim">
                                        <div class="fw-bold text-white">@c.RegistrationDate.ToString("ddd, MMM dd")</div>
                                        <span style="font-size: 0.75rem;">@c.RegistrationDate.ToString("hh:mm tt")</span>
                                    </td>
                                    <!-- Transaction Type -->
                                    <td>
                                        <span class="badge-session badge-class">
                                            <i class="bi bi-mortarboard"></i> Class Registration
                                        </span>
                                    </td>
                                    <!-- For Archer -->
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="avatar-cell-initial">@archerName[0].ToString().ToUpper()</div>
                                            <div class="fw-bold text-white">@archerName</div>
                                        </div>
                                    </td>
                                    <!-- Payment -->
                                    <td class="text-end fw-bold text-white">
                                        RM @c.TotalPrice.ToString("F2")
                                    </td>
                                    <!-- Status -->
                                    <td class="text-center">
                                        <span class="@(isPaid ? "badge-paid-pill" : "badge-pending-pill")">
                                            @if (isPaid) {
                                                <i class="bi bi-check-lg"></i>
                                            } else {
                                                <i class="bi bi-clock"></i>
                                            }
                                            @statusText
                                        </span>
                                    </td>
                                    <!-- Actions -->
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-light rounded-pill px-3" style="font-size: 0.75rem; border-color: rgba(255,255,255,0.15); color: var(--text-dim); font-weight: 700; transition: 0.2s;" onmouseover="this.style.color='#fff'; this.style.borderColor='var(--primary)';" onmouseout="this.style.color='var(--text-dim)'; this.style.borderColor='rgba(255,255,255,0.15)';" onclick="openViewDetailsModal({ type: 'Class Registration', date: '@c.RegistrationDate.ToString("ddd, MMM dd, yyyy")', time: '@c.RegistrationDate.ToString("hh:mm tt")', archer: '@archerName', amount: 'RM @c.TotalPrice.ToString("F2")', status: '@statusText', method: '@(c.PaymentMethod ?? "Online (FPX)")', refId: '@c.TransactionId', package: '@c.PackageType' })">
                                            View
                                        </button>
                                        @if (!isPaid)
                                        {
                                            <button type="button" onclick="handlePayNow('class', @c.RegistrationId)" class="btn btn-sm btn-danger rounded-pill px-3 ms-2" style="font-size: 0.75rem; background: var(--primary) !important; color: #000; border: none; font-weight: 800; transition: 0.2s; box-shadow: 0 4px 10px rgba(255, 77, 77, 0.2);" onmouseover="this.style.transform='translateY(-1px)'; this.style.boxShadow='0 6px 15px rgba(255, 77, 77, 0.35)';" onmouseout="this.style.transform='none'; this.style.boxShadow='0 4px 10px rgba(255, 77, 77, 0.2)';">
                                                Pay
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
 
                            @* Dynamic Bookings from DB *@
                            @foreach (var r in reservations)
                            {
                                var isPaid = r.Status == 1;
                                var statusText = isPaid ? "Paid" : "Pending";
                                var isSelfTraining = r.RateCode == "SELF_TRAINING" || (r.Slot != null && r.Slot.SlotStartTime.Hours >= 18);
                                var archerName = r.Student != null ? r.Student.FullName : (!string.IsNullOrEmpty(r.CustomerName) ? r.CustomerName : "Myself");
                                
                                var pRecord = paymentsList.FirstOrDefault(p => p.ReservationId == r.ReservationId);
                                var txnDate = pRecord?.PaymentDate ?? r.ReservedOn;

                                <tr class="trans-row" data-status="@statusText">
                                    <!-- Date & Time -->
                                    <td class="text-dim">
                                        <div class="fw-bold text-white">@txnDate.ToString("ddd, MMM dd")</div>
                                        <span style="font-size: 0.75rem;">@txnDate.ToString("hh:mm tt")</span>
                                    </td>
                                    <!-- Transaction Type -->
                                    <td>
                                        @if (isSelfTraining) {
                                            <span class="badge-session badge-self-train">
                                                <i class="bi bi-moon-stars"></i> Self Training
                                            </span>
                                        } else {
                                            <span class="badge-session badge-game">
                                                <i class="bi bi-bullseye"></i> Target Session
                                            </span>
                                        }
                                    </td>
                                    <!-- For Archer -->
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="avatar-cell-initial">@archerName[0].ToString().ToUpper()</div>
                                            <div class="fw-bold text-white">@archerName</div>
                                        </div>
                                    </td>
                                    <!-- Payment -->
                                    <td class="text-end fw-bold text-white">
                                        RM @r.TotalPrice.ToString("F2")
                                    </td>
                                    <!-- Status -->
                                    <td class="text-center">
                                        <span class="@(isPaid ? "badge-paid-pill" : "badge-pending-pill")">
                                            @if (isPaid) {
                                                <i class="bi bi-check-lg"></i>
                                            } else {
                                                <i class="bi bi-clock"></i>
                                            }
                                            @statusText
                                        </span>
                                    </td>
                                    <!-- Actions -->
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-light rounded-pill px-3" style="font-size: 0.75rem; border-color: rgba(255,255,255,0.15); color: var(--text-dim); font-weight: 700; transition: 0.2s;" onmouseover="this.style.color='#fff'; this.style.borderColor='var(--primary)';" onmouseout="this.style.color='var(--text-dim)'; this.style.borderColor='rgba(255,255,255,0.15)';" onclick="openViewDetailsModal({ type: '@(isSelfTraining ? "Self Training" : "Target Session")', date: '@txnDate.ToString("ddd, MMM dd, yyyy")', time: '@txnDate.ToString("hh:mm tt")', archer: '@archerName', amount: 'RM @r.TotalPrice.ToString("F2")', status: '@statusText', method: '@(pRecord?.PaymentMethod ?? "Online (FPX)")', refId: '@(pRecord?.TransactionId ?? "N/A")', lane: 'Lane @r.RangeNo', target: 'Target @r.TargetNo' })">
                                            View
                                        </button>
                                        @if (!isPaid)
                                        {
                                            <button type="button" onclick="handlePayNow('reservation', @r.ReservationId)" class="btn btn-sm btn-danger rounded-pill px-3 ms-2" style="font-size: 0.75rem; background: var(--primary) !important; color: #000; border: none; font-weight: 800; transition: 0.2s; box-shadow: 0 4px 10px rgba(255, 77, 77, 0.2);" onmouseover="this.style.transform='translateY(-1px)'; this.style.boxShadow='0 6px 15px rgba(255, 77, 77, 0.35)';" onmouseout="this.style.transform='none'; this.style.boxShadow='0 4px 10px rgba(255, 77, 77, 0.2)';">
                                                Pay
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }

                            @if (!classRegs.Any() && !reservations.Any())
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-5 text-dim">
                                        <i class="bi bi-receipt-cutoff d-block mb-3" style="font-size: 2.5rem; opacity: 0.3;"></i>
                                        No transaction history found for your account.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Right Column: Promo & Discounts -->
        <div class="col-lg-4 col-xl-3">
            <!-- Promo & Discounts Card -->
            <div class="promo-card" data-aos="fade-left" style="margin-top: 0;">
                <h5 class="section-title mb-2 text-white"><i class="bi bi-tag me-2" style="color: #10B981;"></i> Promo & Discounts</h5>
                <p class="text-dim small mb-3">Redeem archery session promo codes or seasonal discounts.</p>
                <div class="promo-empty-container text-center py-4 px-3">
                    <div class="promo-empty-dash-box">
                        <i class="bi bi-ticket-perforated mb-2 d-block text-dim" style="font-size: 1.8rem; opacity: 0.5;"></i>
                        <span class="d-block fw-bold text-white small mb-1">No Active Promos Available</span>
                        <span class="d-block text-dim" style="font-size: 0.72rem;">Promo cards are empty right now. Check back during seasonal events!</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Back to Dashboard button -->
    <div class="d-flex justify-content-start mt-4">
        <a href="/Account/MemberDashboard" class="btn-outline-premium">
            <i class="bi bi-arrow-left"></i> Back to Dashboard
        </a>
    </div>

    <!-- Payment Simulation Modal -->
    <div id="paymentSimModal" class="success-modal-overlay" style="display: none; align-items: center; justify-content: center; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(10, 12, 18, 0.6); backdrop-filter: blur(8px); z-index: 999;">
        <div class="success-modal" style="background: #0d121c; border: 1px solid rgba(255,255,255,0.05); border-radius: 36px; padding: 45px 35px; max-width: 500px; width: 95%; box-shadow: 0 45px 120px rgba(0, 0, 0, 0.9); margin: auto;">
            
            <!-- SCREEN 1: Choose Payment Method -->
            <div id="paymentFormScreen" class="text-start">
                <h3 class="text-white fw-extrabold mb-2 text-center" style="font-size: 1.8rem; letter-spacing: -0.5px;">SECURE PAYMENT</h3>
                <p class="text-dim text-center small mb-4">Complete your outstanding dues via FPX or Credit Card.</p>
                
                <div class="p-3 mb-4 text-center" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 18px;">
                    <span class="text-dim small d-block">TOTAL AMOUNT DUE</span>
                    <span class="text-primary fw-extrabold" id="modalTotalAmount" style="font-size: 2.2rem;">RM @actualPending.ToString("N2")</span>
                </div>

                <!-- Payment Breakdown Section -->
                <div class="mb-4 p-3" style="background: rgba(255,255,255,0.01); border: 1px solid rgba(255, 255, 255, 0.04); border-radius: 16px;">
                    <h6 class="text-white fw-bold mb-3 small" style="letter-spacing: 0.5px; opacity: 0.8; font-size: 0.75rem;"><i class="bi bi-list-ul me-1 text-primary"></i> PAYMENT BREAKDOWN</h6>
                    <div style="display: flex; flex-direction: column; gap: 12px; max-height: 180px; overflow-y: auto; padding-right: 5px;">
                        @foreach (var c in classRegs.Where(r => r.PaymentStatus == "Pending"))
                        {
                            <div class="d-flex justify-content-between align-items-start border-bottom pb-2 modal-breakdown-item class-reg-item" data-id="@c.RegistrationId" data-amount="@c.TotalPrice" style="border-color: rgba(255,255,255,0.05) !important;">
                                <div style="flex: 1; padding-right: 10px;">
                                    <span class="text-white fw-bold d-block" style="font-size: 0.82rem;">Class Registration Fee</span>
                                    <span class="text-dim d-block" style="font-size: 0.7rem; margin-top: 2px;">Archer: <strong class="text-white">@c.CustomerName</strong></span>
                                    <span class="text-dim d-block" style="font-size: 0.7rem;">Package: <strong class="text-white">@c.PackageType</strong></span>
                                    <span class="text-dim d-block" style="font-size: 0.7rem;">Annual Fee: <strong class="text-white">RM 80.00</strong></span>
                                </div>
                                <span class="text-white fw-bold" style="font-size: 0.85rem;">RM @c.TotalPrice.ToString("N2")</span>
                            </div>
                        }
                        
                        @foreach (var r in reservations.Where(r => r.Status == 0))
                        {
                            var isSelfTraining = r.RateCode == "SELF_TRAINING" || (r.Slot != null && r.Slot.SlotStartTime.Hours >= 18);
                            var archerName = r.Student != null ? r.Student.FullName : (!string.IsNullOrEmpty(r.CustomerName) ? r.CustomerName : "Myself");
                            <div class="d-flex justify-content-between align-items-start border-bottom pb-2 modal-breakdown-item reservation-item" data-id="@r.ReservationId" data-amount="@r.TotalPrice" style="border-color: rgba(255,255,255,0.05) !important;">
                                <div style="flex: 1; padding-right: 10px;">
                                    <span class="text-white fw-bold d-block" style="font-size: 0.82rem;">@(isSelfTraining ? "Self Training" : "Target Session")</span>
                                    <span class="text-dim d-block" style="font-size: 0.7rem; margin-top: 2px;">Archer: <strong class="text-white">@archerName</strong></span>
                                    <span class="text-dim d-block" style="font-size: 0.7rem;">Lanes: <strong class="text-white">Lane @r.RangeNo | Target @r.TargetNo</strong></span>
                                </div>
                                <span class="text-white fw-bold" style="font-size: 0.85rem;">RM @r.TotalPrice.ToString("N2")</span>
                            </div>
                        }
                    </div>
                </div>

                <h5 class="text-white fw-bold mb-3 small" style="letter-spacing: 0.5px;">SELECT PAYMENT METHOD</h5>
                
                <div class="mb-4">
                    <label class="payment-radio mb-3" style="display: flex; align-items: center; gap: 10px; color: #fff; font-weight: 600; cursor: pointer;">
                        <input type="radio" name="modalPaymentOption" value="fpx" @(defaultMethod == "Card" ? "" : "checked") onchange="toggleModalPaymentUI()" style="accent-color: var(--primary); width: 18px; height: 18px;"> FPX Online Banking
                    </label>
                    <div id="modalFpxUI" class="payment-ui-box p-3 mb-3" style="display: @(defaultMethod == "Card" ? "none" : "block"); background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 12px;">
                        <select class="form-select bg-dark text-white border-secondary mb-2" id="modalFpxBank" style="font-size: 0.85rem; padding: 10px; border-radius: 8px; cursor: pointer;">
                            <option value="">-- Select Retail Bank --</option>
                            <option value="Maybank2U">Maybank2U</option>
                            <option value="CIMB Clicks">CIMB Clicks</option>
                            <option value="Public Bank">Public Bank</option>
                            <option value="RHB Now">RHB Now</option>
                            <option value="Bank Islam">Bank Islam</option>
                            <option value="AmBank">AmBank</option>
                        </select>
                        <p class="text-dim small mb-0" style="font-size: 0.72rem; color: var(--text-dim);"><i class="bi bi-shield-lock me-1"></i> Redirecting to secure bank portal.</p>
                    </div>

                    <label class="payment-radio mb-3" style="display: flex; align-items: center; gap: 10px; color: #fff; font-weight: 600; cursor: pointer;">
                        <input type="radio" name="modalPaymentOption" value="card" @(defaultMethod == "Card" ? "checked" : "") onchange="toggleModalPaymentUI()" style="accent-color: var(--primary); width: 18px; height: 18px;"> Credit / Debit Card
                    </label>
                    <div id="modalCardUI" class="payment-ui-box p-3" style="display: @(defaultMethod == "Card" ? "block" : "none"); background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 12px;">
                        @if (savedCards.Count > 0)
                        {
                            var activeCardObj = savedCards.FirstOrDefault(c => c.ContainsKey("id") && c["id"] == selectedCardId) ?? savedCards[0];
                            var actNum = activeCardObj.ContainsKey("number") ? activeCardObj["number"] : "";
                            var actExp = activeCardObj.ContainsKey("expiry") ? activeCardObj["expiry"] : "";
                            var last4 = actNum.Replace(" ", "").Length >= 4 ? actNum.Replace(" ", "").Substring(actNum.Replace(" ", "").Length - 4) : "••••";
                            <div class="d-flex align-items-center gap-3 p-2" style="border: 1px solid rgba(16,185,129,0.3); background: rgba(16,185,129,0.05); border-radius: 10px;">
                                <i class="bi bi-credit-card text-success" style="font-size: 1.5rem;"></i>
                                <div>
                                    <span class="text-white fw-bold d-block" style="font-size: 0.85rem;">•••• •••• •••• @last4</span>
                                    <span class="text-dim d-block" style="font-size: 0.72rem;">Expires @actExp</span>
                                </div>
                                <span class="badge bg-success bg-opacity-10 text-success ms-auto" style="font-size: 0.65rem; border: 1px solid rgba(16,185,129,0.2);">SELECTED</span>
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-2">
                                <p class="text-dim small mb-2" style="font-size: 0.8rem;">No saved cards found.</p>
                                <button type="button" class="btn btn-sm btn-outline-danger" onclick="closeModal(); showAddCardForm(); document.getElementById('btnShowAddCard').scrollIntoView({ behavior: 'smooth' });" style="border-radius: 20px; font-size: 0.75rem; border: 1px solid rgba(255,77,77,0.3); background: rgba(255,77,77,0.05); color: #fff; padding: 4px 12px; transition: all 0.2s;">Add Card First</button>
                            </div>
                        }
                    </div>
                </div>

                <div class="d-flex gap-3 mt-4">
                    <button type="button" class="btn-outline-premium justify-content-center w-50" onclick="closeModal()" style="padding: 12px; border-radius: 50px;">
                        CANCEL
                    </button>
                    <button type="button" class="btn-pay-now-pill justify-content-center w-50" id="btnConfirmModalPay" onclick="submitModalPayment()" style="padding: 12px; font-size: 0.85rem; border-radius: 50px;">
                        PAY NOW
                    </button>
                </div>
            </div>

            <!-- SCREEN 2: Loader screen -->
            <div id="paymentLoader" class="text-center" style="display: none;">
                <div class="spinner-border text-danger mb-4" role="status" style="width: 4rem; height: 4rem; border-width: 0.35em;">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <h4 class="text-white fw-bold mb-2">Connecting to Secure Payment Gateway</h4>
                <p class="text-dim small">Processing your online transaction with FPX Bank...</p>
            </div>

            <!-- SCREEN 3: Success screen -->
            <div id="paymentSuccess" class="text-center" style="display: none;">
                <div class="success-badge-icon" style="width: 80px; height: 80px; border-radius: 28px; background: #10B981; color: #000; font-size: 2.5rem; display: flex; align-items: center; justify-content: center; margin: 0 auto 25px; box-shadow: 0 20px 40px rgba(16, 185, 129, 0.3);"><i class="bi bi-check-lg"></i></div>
                <h4 class="text-white fw-bold mb-2">Payment Successful!</h4>
                <p class="text-dim small mb-4">All outstanding dues have been successfully paid and your account is active.</p>
                <button type="button" class="btn-pay-now-pill w-100 justify-content-center" onclick="window.location.reload()" style="border-radius: 50px; padding: 12px;">
                    Done <i class="bi bi-arrow-right ms-2"></i>
                </button>
            </div>

        </div>
    </div>

    <!-- View Details Modal -->
    <div id="viewDetailsModal" class="success-modal-overlay" style="display: none; align-items: center; justify-content: center; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(10, 12, 18, 0.6); backdrop-filter: blur(8px); z-index: 999;">
        <div class="success-modal" style="background: #0d121c; border: 1px solid rgba(255,255,255,0.05); border-radius: 32px; padding: 40px 35px; max-width: 500px; width: 95%; box-shadow: 0 45px 120px rgba(0, 0, 0, 0.9); margin: auto; animation: fadeIn 0.3s ease;">
            <div class="text-start">
                <h3 class="text-white fw-extrabold mb-2 text-center" style="font-size: 1.6rem; letter-spacing: -0.5px;">TRANSACTION DETAILS</h3>
                <p class="text-dim text-center small mb-4">Verification and breakdown of your payment record.</p>

                <div class="p-3 mb-4 text-center" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 18px;">
                    <span class="text-dim small d-block">TRANSACTION AMOUNT</span>
                    <span class="text-primary fw-extrabold" style="font-size: 2.2rem;" id="detailAmount">RM 0.00</span>
                </div>

                <div class="mb-4 p-3" style="background: rgba(255,255,255,0.01); border: 1px solid rgba(255, 255, 255, 0.04); border-radius: 16px;">
                    <div style="display: flex; flex-direction: column; gap: 14px;" id="detailItemsList">
                        <!-- Filled in JS -->
                    </div>
                </div>

                <button type="button" class="btn-pay-now-pill w-100 justify-content-center" onclick="closeDetailsModal()" style="border-radius: 50px; padding: 12px; background: var(--primary); color: #000; font-weight: 800; font-size: 0.9rem; border: none; cursor: pointer; transition: 0.3s;">
                    CLOSE
                </button>
            </div>
        </div>
    </div>


@section Scripts {
    <script>
        let currentPaymentType = 'all';
        let currentPaymentId = null;

        function handlePayNow(type = 'all', id = null) {
            currentPaymentType = type;
            currentPaymentId = id;

            // Sync default payment selection to modal
            const selectedDefault = document.querySelector('input[name="defaultPaymentMethod"]:checked').value;
            if (selectedDefault === "OnlineBanking") {
                document.querySelector('input[name="modalPaymentOption"][value="fpx"]').checked = true;
            } else if (selectedDefault === "Card") {
                document.querySelector('input[name="modalPaymentOption"][value="card"]').checked = true;
            }
            toggleModalPaymentUI();

            // Sync card input fields from settings to modal using active card resolved in Razor
            const defaultCardNumber = "@savedCardNumber";
            const defaultCardExpiry = "@savedCardExpiry";
            const defaultCardCvv = "@savedCardCvv";

            const modalInputs = document.getElementById("modalCardUI").querySelectorAll("input");
            if (modalInputs.length >= 3) {
                modalInputs[0].value = defaultCardNumber;
                modalInputs[1].value = defaultCardExpiry;
                modalInputs[2].value = defaultCardCvv;
            }

            // Filter breakdown items dynamically based on the payment selection
            let calculatedTotal = 0;
            document.querySelectorAll(".modal-breakdown-item").forEach(item => {
                const itemId = parseInt(item.getAttribute("data-id"));
                const itemAmount = parseFloat(item.getAttribute("data-amount")) || 0;
                let showItem = false;

                if (type === 'all') {
                    showItem = true;
                } else if (type === 'class' && item.classList.contains('class-reg-item') && itemId === id) {
                    showItem = true;
                } else if (type === 'reservation' && item.classList.contains('reservation-item') && itemId === id) {
                    showItem = true;
                }

                if (showItem) {
                    item.style.setProperty("display", "flex", "important");
                    calculatedTotal += itemAmount;
                } else {
                    item.style.setProperty("display", "none", "important");
                }
            });

            // Update outstanding sum in the modal dynamically
            document.getElementById("modalTotalAmount").innerText = "RM " + calculatedTotal.toFixed(2);

            document.getElementById("paymentSimModal").style.display = "flex";
            document.getElementById("paymentFormScreen").style.display = "block";
            document.getElementById("paymentLoader").style.display = "none";
            document.getElementById("paymentSuccess").style.display = "none";
        }

        function closeModal() {
            document.getElementById("paymentSimModal").style.display = "none";
        }

        function toggleModalPaymentUI() {
            const method = document.querySelector('input[name="modalPaymentOption"]:checked').value;
            document.getElementById("modalFpxUI").style.display = (method === "fpx") ? "block" : "none";
            document.getElementById("modalCardUI").style.display = (method === "card") ? "block" : "none";
        }

        async function submitModalPayment() {
            const method = document.querySelector('input[name="modalPaymentOption"]:checked').value;
            if (method === "fpx") {
                const bank = document.getElementById("modalFpxBank").value;
                if (!bank) {
                    alert("Please select a bank to proceed.");
                    return;
                }
            }

            const formScreen = document.getElementById("paymentFormScreen");
            const loader = document.getElementById("paymentLoader");
            const success = document.getElementById("paymentSuccess");

            // Customize loader text based on option
            const loaderText = loader.querySelector("p");
            if (method === "fpx") {
                const bank = document.getElementById("modalFpxBank").value;
                loaderText.innerText = `Processing your online transaction with ${bank} FPX...`;
            } else {
                loaderText.innerText = "Authorizing credit card and processing payment...";
            }

            formScreen.style.display = "none";
            loader.style.display = "block";
            success.style.display = "none";

            try {
                // Simulate gateway call for 2 seconds
                await new Promise(resolve => setTimeout(resolve, 2000));

                let url = "/Account/ClearPendingPayments";
                if (currentPaymentType !== 'all') {
                    url += `?type=${encodeURIComponent(currentPaymentType)}&id=${encodeURIComponent(currentPaymentId)}`;
                }

                const resp = await fetch(url, {
                    method: "POST"
                });
                const result = await resp.json();

                if (result.success) {
                    loader.style.display = "none";
                    success.style.display = "block";
                } else {
                    alert("Payment failed: " + result.message);
                    document.getElementById("paymentSimModal").style.display = "none";
                }
            } catch (err) {
                alert("An error occurred during payment.");
                document.getElementById("paymentSimModal").style.display = "none";
            }
        }

        document.addEventListener("DOMContentLoaded", function () {
            const searchInput = document.getElementById("transactionSearch");
            const statusFilter = document.getElementById("statusFilter");
            const rows = document.querySelectorAll(".trans-row");

            function filterTable() {
                const query = searchInput.value.toLowerCase().trim();
                const status = statusFilter.value;

                rows.forEach(row => {
                    const text = row.textContent.toLowerCase();
                    const rowStatus = row.getAttribute("data-status");
                    
                    const matchesQuery = text.includes(query);
                    const matchesStatus = (status === "All") || (rowStatus === status);

                    if (matchesQuery && matchesStatus) {
                        row.style.display = "";
                    } else {
                        row.style.display = "none";
                    }
                });
            }

            searchInput.addEventListener("input", filterTable);
            statusFilter.addEventListener("change", filterTable);

            // Handle default payment method change
            const paymentRadios = document.querySelectorAll('input[name="defaultPaymentMethod"]');
            const cardPanel = document.getElementById("defaultCardDetailsPanel");
            
            paymentRadios.forEach(radio => {
                radio.addEventListener("change", async function () {
                    const selectedMethod = this.value;
                    
                    // Toggle Card Details Panel visibility
                    if (selectedMethod === "Card") {
                        cardPanel.style.display = "block";
                    } else {
                        cardPanel.style.display = "none";
                    }

                    try {
                        const response = await fetch(`/Account/UpdateDefaultPaymentMethod?method=${selectedMethod}`, {
                            method: "POST"
                        });
                        const result = await response.json();
                        if (result.success) {
                            console.log("Default payment method updated successfully to " + selectedMethod);
                        } else {
                            console.error("Failed to update default payment method: " + result.message);
                        }
                    } catch (err) {
                        console.error("Error updating default payment method:", err);
                    }
                });
            });

            // Real-time input formatting for new card inputs
            document.addEventListener('input', function(e) {
                if (e.target.id === 'newCardNumber') {
                    let val = e.target.value.replace(/\D/g, '');
                    let newVal = '';
                    for (let i = 0; i < val.length; i++) {
                        if (i > 0 && i % 4 === 0) newVal += ' ';
                        newVal += val[i];
                    }
                    e.target.value = newVal.substring(0, 19);
                }
                if (e.target.id === 'newCardExpiry') {
                    let val = e.target.value.replace(/\D/g, '');
                    e.target.value = val.length > 2 ? val.substring(0, 2) + '/' + val.substring(2, 4) : val;
                    if (e.target.value.length > 5) e.target.value = e.target.value.substring(0, 5);
                }
                if (e.target.id === 'newCardCvv') {
                    e.target.value = e.target.value.replace(/\D/g, '').substring(0, 3);
                }
            });
        });

        // ─── Multi-card: Select active card ───────────────────────────────────
        async function selectCard(cardId) {
            try {
                await fetch(`/Account/SelectCard?cardId=${encodeURIComponent(cardId)}`, { method: 'POST' });
                // Update visual highlight without full reload
                document.querySelectorAll('.saved-card-row').forEach(row => {
                    const rowId = row.getAttribute('data-card-id');
                    if (rowId === cardId) {
                        row.classList.add('card-row-active');
                    } else {
                        row.classList.remove('card-row-active');
                    }
                });
            } catch(err) {
                console.error('Error selecting card:', err);
            }
        }

        // ─── Multi-card: Delete a card ────────────────────────────────────────
        async function deleteCard(cardId, btn) {
            if (!confirm('Delete this saved card?')) return;
            try {
                const response = await fetch(`/Account/DeleteSavedCard?cardId=${encodeURIComponent(cardId)}`, { method: 'POST' });
                const result = await response.json();
                if (result.success) {
                    // Remove row from DOM
                    const row = document.querySelector(`.saved-card-row[data-card-id="${cardId}"]`);
                    if (row) row.remove();

                    // If no cards left, show empty message
                    const remaining = document.querySelectorAll('.saved-card-row');
                    if (remaining.length === 0) {
                        document.getElementById('savedCardsList').innerHTML = `
                            <div class="text-center py-4" style="border:1px dashed rgba(255,255,255,0.08);border-radius:16px;">
                                <i class="bi bi-credit-card text-dim" style="font-size:2rem;"></i>
                                <p class="text-dim small mt-2 mb-0">No saved cards yet. Add one below.</p>
                            </div>`;
                    } else {
                        // Auto-select first remaining card if deleted was active
                        const firstRow = remaining[0];
                        const firstId = firstRow.getAttribute('data-card-id');
                        if (!document.querySelector('.saved-card-row.card-row-active')) {
                            firstRow.querySelector('input[type=radio]').checked = true;
                            selectCard(firstId);
                        }
                    }
                } else {
                    alert('Failed to delete card: ' + result.message);
                }
            } catch(err) {
                console.error('Error deleting card:', err);
                alert('An error occurred while deleting the card.');
            }
        }

        // ─── Show / Hide Add Card Form ─────────────────────────────────────────
        function showAddCardForm() {
            document.getElementById('addCardForm').style.display = 'block';
            document.getElementById('btnShowAddCard').style.display = 'none';
            document.getElementById('newCardNumber').value = '';
            document.getElementById('newCardExpiry').value = '';
            document.getElementById('newCardCvv').value = '';
        }

        function cancelAddCard() {
            document.getElementById('addCardForm').style.display = 'none';
            document.getElementById('btnShowAddCard').style.display = 'inline-flex';
        }

        async function submitSaveCardDetails() {
            const cardNumInput = document.getElementById("defaultCardNumber");
            const cardExpInput = document.getElementById("defaultCardExpiry");
            const cardCvvInput = document.getElementById("defaultCardCvv");

            const cardNumber = cardNumInput.value.trim();
            const cardExpiry = cardExpInput.value.trim();
            const cardCvv = cardCvvInput.value.trim();

            if (!cardNumber || !cardExpiry || !cardCvv) {
                alert("Please fill in all card details.");
                return;
            }

            try {
                const response = await fetch(`/Account/UpdateCardDetails?cardNumber=${encodeURIComponent(cardNumber)}&cardExpiry=${encodeURIComponent(cardExpiry)}&cardCvv=${encodeURIComponent(cardCvv)}`, {
                    method: "POST"
                });
                const result = await response.json();
                if (result.success) {
                    // Update Saved Card View fields
                    const last4 = cardNumber.replace(/\s+/g, '').slice(-4);
                    document.getElementById("savedCardNumberMasked").innerText = `•••• •••• •••• ${last4}`;
                    document.getElementById("savedCardExpiryDisplay").innerText = `Expires ${cardExpiry}`;

                    // Toggle displays
                    document.getElementById("addCardForm").style.display = "none";
                    document.getElementById("savedCardDisplay").style.display = "block";
                    
                    // Allow cancel going forward
                    document.getElementById("btnCancelAddCard").style.display = "inline-block";

                    // Sync details to pending payment modal card fields
                    const modalInputs = document.getElementById("modalCardUI")?.querySelectorAll("input");
                    if (modalInputs && modalInputs.length >= 3) {
                        modalInputs[0].value = cardNumber;
                        modalInputs[1].value = cardExpiry;
                        modalInputs[2].value = cardCvv;
                    }

                    alert("Card details saved successfully.");
                } else {
                    alert("Failed to save card details: " + result.message);
                }
            } catch (err) {
                console.error("Error saving card details:", err);
                alert("An error occurred while saving card details.");
            }
        }

        // ─── Multi-card: Submit new card ──────────────────────────────────────
        async function submitAddCard() {
            const cardNumber = document.getElementById('newCardNumber').value.trim();
            const cardExpiry = document.getElementById('newCardExpiry').value.trim();
            const cardCvv    = document.getElementById('newCardCvv').value.trim();

            if (!cardNumber || !cardExpiry || !cardCvv) {
                alert('Please fill in all card fields.');
                return;
            }

            try {
                const response = await fetch(
                    `/Account/AddSavedCard?cardNumber=${encodeURIComponent(cardNumber)}&cardExpiry=${encodeURIComponent(cardExpiry)}&cardCvv=${encodeURIComponent(cardCvv)}`,
                    { method: 'POST' }
                );
                const result = await response.json();
                if (result.success) {
                    // Remove empty-state message if present
                    const noCardsMsg = document.querySelector('#savedCardsList > div:not(.saved-card-row)');
                    if (noCardsMsg) noCardsMsg.remove();

                    // Build last4
                    const last4 = cardNumber.replace(/\s+/g, '').slice(-4);
                    const newId = result.id;

                    // Deactivate all current active rows
                    document.querySelectorAll('.saved-card-row').forEach(r => {
                        r.classList.remove('card-row-active');
                        r.querySelector('input[type=radio]').checked = false;
                    });

                    // Build and inject new card row
                    const newRow = document.createElement('div');
                    newRow.className = 'saved-card-row card-row-active';
                    newRow.setAttribute('data-card-id', newId);
                    newRow.innerHTML = `
                        <label style="display:flex;align-items:center;gap:14px;cursor:pointer;flex:1;">
                            <input type="radio" name="selectedCard" value="${newId}" checked
                                   onchange="selectCard('${newId}')"
                                   style="accent-color:var(--primary);width:18px;height:18px;flex-shrink:0;">
                            <div style="width:44px;height:30px;background:rgba(255,255,255,0.06);border-radius:6px;display:flex;align-items:center;justify-content:center;border:1px solid rgba(255,255,255,0.08);flex-shrink:0;">
                                <i class="bi bi-credit-card text-white" style="font-size:1.1rem;"></i>
                            </div>
                            <div style="flex:1;">
                                <span class="text-white fw-bold d-block" style="font-size:0.87rem;letter-spacing:0.5px;">•••• •••• •••• ${last4}</span>
                                <span class="text-dim" style="font-size:0.72rem;">Expires ${cardExpiry}</span>
                            </div>

                        </label>
                        <button type="button" onclick="deleteCard('${newId}', this)"
                                style="background:rgba(220,53,69,0.08);border:1px solid rgba(220,53,69,0.25);color:#dc3545;border-radius:8px;padding:5px 10px;font-size:0.75rem;font-weight:600;cursor:pointer;flex-shrink:0;display:inline-flex;align-items:center;gap:5px;">
                            <i class="bi bi-trash"></i> Delete
                        </button>`;
                    document.getElementById('savedCardsList').appendChild(newRow);

                    // Hide form, show button
                    cancelAddCard();
                } else {
                    alert('Failed to save card: ' + result.message);
                }
            } catch(err) {
                console.error('Error adding card:', err);
                alert('An error occurred while saving the card.');
            }
        }

        function openViewDetailsModal(data) {
            document.getElementById("detailAmount").innerText = data.amount;
            
            let listHtml = `
                <div class="d-flex justify-content-between pb-2 border-bottom" style="border-color: rgba(255,255,255,0.05) !important;">
                    <span class="text-dim small">Transaction Type</span>
                    <span class="text-white fw-bold small">${data.type}</span>
                </div>
                <div class="d-flex justify-content-between pb-2 border-bottom" style="border-color: rgba(255,255,255,0.05) !important;">
                    <span class="text-dim small">Archer Name</span>
                    <span class="text-white fw-bold small">${data.archer}</span>
                </div>
                <div class="d-flex justify-content-between pb-2 border-bottom" style="border-color: rgba(255,255,255,0.05) !important;">
                    <span class="text-dim small">Date & Time</span>
                    <span class="text-white fw-bold small">${data.date} | ${data.time}</span>
                </div>
            `;

            if (data.type === "Class Registration") {
                listHtml += `
                    <div class="d-flex justify-content-between pb-2 border-bottom" style="border-color: rgba(255,255,255,0.05) !important;">
                        <span class="text-dim small">Package Plan</span>
                        <span class="text-white fw-bold small">${data.package}</span>
                    </div>
                `;
            } else {
                listHtml += `
                    <div class="d-flex justify-content-between pb-2 border-bottom" style="border-color: rgba(255,255,255,0.05) !important;">
                        <span class="text-dim small">Target & Lane</span>
                        <span class="text-white fw-bold small">${data.lane} | ${data.target}</span>
                    </div>
                `;
            }

            listHtml += `
                <div class="d-flex justify-content-between pb-2 border-bottom" style="border-color: rgba(255,255,255,0.05) !important;">
                    <span class="text-dim small">Status</span>
                    <span class="fw-bold small" style="color: ${data.status === "Paid" ? "#10B981" : "#F59E0B"};">${data.status}</span>
                </div>
            `;

            if (data.status === "Paid" && data.refId && data.refId !== "N/A" && data.refId !== "null") {
                listHtml += `
                    <div class="d-flex justify-content-between pb-2">
                        <span class="text-dim small">Payment Reference</span>
                        <span class="text-primary fw-bold small" style="letter-spacing: 0.5px;">${data.refId}</span>
                    </div>
                `;
            }

            document.getElementById("detailItemsList").innerHTML = listHtml;
            document.getElementById("viewDetailsModal").style.display = "flex";
        }

        function closeDetailsModal() {
            document.getElementById("viewDetailsModal").style.display = "none";
        }
    </script>
}
