@using Microsoft.AspNetCore.Http
@model ArcheryAlley.Models.Customers
@{
    ViewBag.Title = "Fee & Payments";
    Layout = "~/Views/Shared/_MemberLayout.cshtml";

    var classRegs = ViewBag.ClassRegs as IEnumerable<ArcheryAlley.Models.ClassRegistrations> ?? new List<ArcheryAlley.Models.ClassRegistrations>();
    var reservations = ViewBag.Reservations as IEnumerable<ArcheryAlley.Models.Reservations> ?? new List<ArcheryAlley.Models.Reservations>();
    var paymentsList = ViewBag.Payments as IEnumerable<ArcheryAlley.Models.Payments> ?? new List<ArcheryAlley.Models.Payments>();

    // Calculate dynamic totals from actual DB data (or default simulated if none)
    decimal actualPaid = classRegs.Where(r => r.PaymentStatus == "Paid" || r.PaymentStatus == "Success").Sum(r => r.TotalPrice) + 
                         reservations.Where(r => r.Status == 1).Sum(r => r.TotalPrice); // status 1 = Paid/Confirmed
                         
    decimal actualPending = classRegs.Where(r => r.PaymentStatus == "Pending").Sum(r => r.TotalPrice) + 
                           reservations.Where(r => r.Status == 0).Sum(r => r.TotalPrice); // status 0 = Pending

    decimal totalTransactions = actualPaid + actualPending;

    // Calculate last transaction amount dynamically
    var lastTrans = classRegs.Select(c => new { Date = c.RegistrationDate, Amount = c.TotalPrice })
                        .Concat(reservations.Select(r => new { Date = r.ReservedOn, Amount = r.TotalPrice }))
                        .OrderByDescending(x => x.Date)
                        .FirstOrDefault();
    decimal lastTransactionAmt = lastTrans?.Amount ?? 0;

    var defaultMethod   = Context.Session.GetString("DefaultPaymentMethod") ?? "OnlineBanking";
    var selectedCardId  = Context.Session.GetString("SelectedCardId") ?? "";

    // Parse saved cards JSON from session
    var savedCardsJson  = Context.Session.GetString("SavedCards") ?? "[]";
    var savedCards      = System.Text.Json.JsonSerializer.Deserialize<List<Dictionary<string, string>>>(savedCardsJson)
                         ?? new List<Dictionary<string, string>>();

    // If no card selected yet but cards exist, default to first
    if (string.IsNullOrEmpty(selectedCardId) && savedCards.Count > 0)
        selectedCardId = savedCards[0]["id"];

    // Active card details for legacy compatibility
    var activeCard      = savedCards.FirstOrDefault(c => c.ContainsKey("id") && c["id"] == selectedCardId);
    var savedCardNumber = activeCard != null && activeCard.ContainsKey("number") ? activeCard["number"] : "";
    var savedCardExpiry = activeCard != null && activeCard.ContainsKey("expiry") ? activeCard["expiry"] : "";
    var savedCardCvv    = activeCard != null && activeCard.ContainsKey("cvv")    ? activeCard["cvv"]    : "";
}

<style>
