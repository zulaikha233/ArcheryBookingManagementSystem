@using Microsoft.AspNetCore.Http
@model ArcheryAlley.Models.Customers
@{
    ViewBag.Title = "Fee & Payments";
    Layout = "~/Views/Shared/_MemberLayout.cshtml";

    var classRegs = ViewBag.ClassRegs as IEnumerable<ArcheryAlley.Models.ClassRegistrations> ?? new List<ArcheryAlley.Models.ClassRegistrations>();
    var membershipPayments = ViewBag.MembershipPayments as IEnumerable<ArcheryAlley.Models.MembershipPayments> ?? new List<ArcheryAlley.Models.MembershipPayments>();
    var reservations = ViewBag.Reservations as IEnumerable<ArcheryAlley.Models.Reservations> ?? new List<ArcheryAlley.Models.Reservations>();
    var paymentsList = ViewBag.Payments as IEnumerable<ArcheryAlley.Models.Payments> ?? new List<ArcheryAlley.Models.Payments>();

    // Group reservations to prevent duplicate target rows
    var groupedReservations = reservations
        .Select(r => {
            var p = paymentsList.FirstOrDefault(pay => pay.ReservationId == r.ReservationId);
            string txnKey = !string.IsNullOrEmpty(p?.TransactionId) 
                ? p.TransactionId 
                : $"FALLBACK-{r.CustomerName}-{r.SlotId}-{r.ReservedOn.Date:yyyyMMdd}-{r.ReservedBy}-{r.StudentId}-{r.TotalPrice}";
            return new { Reservation = r, TxnKey = txnKey };
        })
        .GroupBy(x => x.TxnKey)
        .Select(g => {
            var first = g.First().Reservation;
            var targetNos = g.Select(x => x.Reservation.TargetNo).OrderBy(t => t).ToList();
            var rangeNos = g.Select(x => x.Reservation.RangeNo).Distinct().OrderBy(r => r).ToList();
            
            var targetListStr = string.Join(", ", targetNos);
            var rangeListStr = string.Join(", ", rangeNos);

            // Get payment record
            var pRecord = paymentsList.FirstOrDefault(p => g.Any(x => x.Reservation.ReservationId == p.ReservationId));
            
            return new {
                ReservationId = g.Min(x => x.Reservation.ReservationId),
                CustomerName = first.CustomerName,
                CustomerEmail = first.CustomerEmail,
                ReservedBy = first.ReservedBy,
                ReservedOn = first.ReservedOn,
                Slot = first.Slot,
                TargetNo = first.TargetNo, 
                RangeNo = first.RangeNo,   
                LanesDisplay = "Lane " + rangeListStr,
                TargetsDisplay = "Target " + targetListStr,
                DurationHours = first.DurationHours,
                TotalPrice = g.Sum(x => x.Reservation.TotalPrice), 
                RateCode = first.RateCode,
                NumberOfPax = (first.RateCode == "CLASS" || first.RateCode == "Class Session") ? g.Sum(x => x.Reservation.NumberOfPax) : first.NumberOfPax,
                Status = first.Status,
                StudentId = first.StudentId,
                Student = first.Student,
                PaymentRecord = pRecord
            };
        }).ToList();

    // Calculate dynamic totals from actual DB data (or default simulated if none)
    decimal actualPaid = classRegs.Where(r => r.PaymentStatus == "Paid" || r.PaymentStatus == "Success").Sum(r => r.TotalPrice) + 
                         reservations.Where(r => r.Status == 1).Sum(r => r.TotalPrice) +
                         membershipPayments.Where(m => m.Status == "Success").Sum(m => m.Amount); // status 1 = Paid/Confirmed
                         
    decimal actualPending = classRegs.Where(r => r.PaymentStatus == "Pending").Sum(r => r.TotalPrice) + 
                            reservations.Where(r => r.Status == 0).Sum(r => r.TotalPrice) +
                            membershipPayments.Where(m => m.Status == "Pending").Sum(m => m.Amount); // status 0 = Pending

    decimal totalTransactions = actualPaid + actualPending;

    // Calculate last transaction amount dynamically (excluding free RM0.00 items)
    var lastTrans = classRegs.Where(c => c.TotalPrice > 0).Select(c => new { Date = c.RegistrationDate, Amount = c.TotalPrice })
                        .Concat(reservations.Where(r => r.TotalPrice > 0).Select(r => new { Date = r.ReservedOn, Amount = r.TotalPrice }))
                        .Concat(membershipPayments.Where(m => m.Amount > 0).Select(m => new { Date = m.PaymentDate, Amount = m.Amount }))
                        .OrderByDescending(x => x.Date)
                        .FirstOrDefault();
    decimal lastTransactionAmt = lastTrans?.Amount ?? 0;

    var defaultMethod   = Context.Session.GetString("DefaultPaymentMethod") ?? "OnlineBanking";
    var selectedCardId  = Context.Session.GetString("SelectedCardId") ?? "";

    // Parse saved cards JSON from session
    var savedCardsJson  = Context.Session.GetString("SavedCards") ?? "[]";
    var savedCards      = System.Text.Json.JsonSerializer.Deserialize<List<Dictionary<string, string>>>(savedCardsJson)
                         ?? new List<Dictionary<string, string>>();

    // If no card selected yet but cards exist, default to first
    if (string.IsNullOrEmpty(selectedCardId) && savedCards.Count > 0)
        selectedCardId = savedCards[0]["id"];

    // Active card details for legacy compatibility
    var activeCard      = savedCards.FirstOrDefault(c => c.ContainsKey("id") && c["id"] == selectedCardId);
    var savedCardNumber = activeCard != null && activeCard.ContainsKey("number") ? activeCard["number"] : "";
    var savedCardExpiry = activeCard != null && activeCard.ContainsKey("expiry") ? activeCard["expiry"] : "";
    var savedCardCvv    = activeCard != null && activeCard.ContainsKey("cvv")    ? activeCard["cvv"]    : "";
}

