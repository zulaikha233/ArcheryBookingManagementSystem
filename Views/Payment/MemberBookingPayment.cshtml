@model ArcheryAlley.Models.PaymentViewModel
@using Microsoft.AspNetCore.Http

@{
    ViewData["Title"] = "Payment";
    Layout = Context.Session.GetString("IsGuest") == "true" ? "_Layout" : "_MemberLayout";
    var defaultMethod  = Context.Session.GetString("DefaultPaymentMethod") ?? "OnlineBanking";
    var selectedCardId = Context.Session.GetString("SelectedCardId") ?? "";

    var savedCardsJson = Context.Session.GetString("SavedCards") ?? "[]";
    var savedCards     = System.Text.Json.JsonSerializer.Deserialize<List<Dictionary<string, string>>>(savedCardsJson)
                        ?? new List<Dictionary<string, string>>();

    if (string.IsNullOrEmpty(selectedCardId) && savedCards.Count > 0)
        selectedCardId = savedCards[0]["id"];

    var activeCard      = savedCards.FirstOrDefault(c => c.ContainsKey("id") && c["id"] == selectedCardId);
    var savedCardNumber = activeCard != null && activeCard.ContainsKey("number") ? activeCard["number"] : "";
    var savedCardExpiry = activeCard != null && activeCard.ContainsKey("expiry") ? activeCard["expiry"] : "";
    var savedCardCvv    = activeCard != null && activeCard.ContainsKey("cvv")    ? activeCard["cvv"]    : "";
}

<style>
:root {
    --active-blue: var(--primary);
}

.checkout-wrap { max-width: 1000px; margin: 0 auto; }

.data-row { display: flex; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid var(--card-border); }
.data-label { color: var(--text-dim); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; }
.data-value { color: #fff; font-weight: 700; font-size: 0.95rem; }

.payment-radio { display: flex; align-items: center; gap: 12px; color: #fff; font-weight: 600; cursor: pointer; }
.payment-radio input { accent-color: var(--primary); width: 18px; height: 18px; }

.payment-ui-box { background: rgba(255,255,255,0.03); border: 1px solid var(--card-border); border-radius: 16px; }

/* Modal */
.custom-modal-overlay {
    position: fixed; top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(0,0,0,0.9); backdrop-filter: blur(15px);
    display: none; align-items: center; justify-content: center; z-index: 10000;
}
.custom-modal {
    background: #0f172a; border: 1px solid var(--card-border); border-radius: 32px;
    padding: 60px 40px; text-align: center; max-width: 450px; width: 90%;
    box-shadow: 0 40px 100px rgba(0,0,0,0.8);
}
.success-icon {
    width: 80px; height: 80px; border-radius: 24px; background: var(--primary);
    color: #000; font-size: 2.5rem; display: flex; align-items: center; justify-content: center;
    margin: 0 auto 25px; box-shadow: 0 15px 30px var(--primary-glow);
}
.fw-900 { font-weight: 900; }

.premium-card.static-card:hover {
    transform: none !important;
    border-color: var(--card-border) !important;
    box-shadow: none !important;
}
.premium-card.static-card:hover::before {
    opacity: 0 !important;
}
</style>


<div id="successModal" class="custom-modal-overlay">
    <div class="custom-modal text-center" style="max-width: 400px; padding: 40px; border-radius: 28px; background: #0c1017; border: 1px solid rgba(255, 77, 77, 0.15); box-shadow: 0 20px 50px rgba(0,0,0,0.8);">
        <div class="success-icon mb-4" style="width: 80px; height: 80px; background: rgba(255, 77, 77, 0.1); border-radius: 20px; display: inline-flex; align-items: center; justify-content: center; font-size: 2.5rem; color: var(--primary); box-shadow: 0 10px 25px rgba(255, 77, 77, 0.2); margin: 0 auto;">
            <i class="bi bi-check-lg"></i>
        </div>
        <h3 class="fw-900 mb-3" style="font-size: 1.8rem; color: #fff; letter-spacing: 0.5px;">Payment Secured</h3>
        <p class="text-dim mb-4" style="color: var(--text-dim); font-size: 0.95rem; line-height: 1.6;">
            Your reservation has been verified and processed.<br/>
            Your bullseye journey begins here!
        </p>
        <div>
            <button onclick="goToDashboard()" class="btn btn-premium py-3 px-5" style="background: var(--primary); border-radius: 12px; font-weight: 800; border: none; box-shadow: 0 10px 20px var(--primary-glow); color: #000; letter-spacing: 1px; transition: all 0.3s ease; display: inline-block;">
                OK
            </button>
        </div>
    </div>
</div>

<partial name="~/Views/Home/BookingProgress.cshtml" model="4" />
<div class="checkout-wrap py-5 px-4" data-aos="zoom-in">
    <div class="premium-card static-card">
        <h3 class="fw-bold mb-4" style="color: var(--primary);">Booking Details</h3>
        
        <div class="detail-grid">
            <div class="col-left">
                <div class="data-row">
                    <div class="data-label">SERVICE</div>
                    <div class="data-value">@(ViewBag.ServiceName ?? "Archery Game Session")</div>
                </div>
                <div class="data-row">
                    <div class="data-label">LANES</div>
                    <div class="data-value">
                        @if (ViewBag.EnableLaneSelection == true)
                        {
                            @Model.TargetDetails
                        }
                        else
                        {
                            var totalLanes = Model.SelectedLanes?.Split(new[] { ',' }, StringSplitOptions.RemoveEmptyEntries).Length ?? 1;
                            @($"{totalLanes} Lane{(totalLanes > 1 ? "s" : "")}")
                        }
                    </div>
                </div>
                <div class="data-row">
                    <div class="data-label">DURATION</div>
                    <div class="data-value">@Model.Duration Hour(s)</div>
                </div>
            </div>
            <div class="col-right">
                <div class="data-row">
                    <div class="data-label">DATE</div>
                    <div class="data-value">@Model.Date</div>
                </div>
                <div class="data-row">
                    <div class="data-label">TIME</div>
                    <div class="data-value">@Model.Time</div>
                </div>
                <div class="data-row">
                    <div class="data-label">PAX</div>
                    <div class="data-value">@Model.NumberOfPax Archers</div>
                </div>
            </div>
        </div>

        <h3 class="fw-bold mt-5 mb-4" style="color: var(--primary);">Customer Info</h3>
        <div class="premium-card static-card mb-5" style="background: rgba(255,255,255,0.02); padding: 25px; border: 1px solid var(--primary) !important;">
            <div class="row g-4">
                <div class="col-md-4">
                    <label class="form-label-premium">NAME</label>
                    <div class="fw-bold">@(string.IsNullOrWhiteSpace(Model.CustomerName) ? "-" : Model.CustomerName)</div>
                </div>
                <div class="col-md-4">
                    <label class="form-label-premium">EMAIL</label>
                    <div class="fw-bold">@(string.IsNullOrWhiteSpace(Model.CustomerEmail) ? "-" : Model.CustomerEmail)</div>
                </div>
                <div class="col-md-4">
                    <label class="form-label-premium">PHONE</label>
                    <div class="fw-bold">
                        @{
                            var phone = Model.PhoneNumber ?? "";
                            if (string.IsNullOrWhiteSpace(phone)) {
                                phone = "-";
                            } else {
                                if (phone.StartsWith("0")) phone = "+6" + phone;
                                else if (phone.StartsWith("6")) phone = "+" + phone;
                                else if (!phone.StartsWith("+")) phone = "+60" + phone;
                            }
                        }
                        @phone
                    </div>
                </div>
                @if (ViewBag.ShooterName != null)
                {
                    <div class="col-md-4">
                        <label class="form-label-premium">ARCHER</label>
                        <div class="fw-bold text-danger">@ViewBag.ShooterName</div>
                    </div>
                }
            </div>
        </div>

        <div class="row g-5">
            <div class="col-md-7">
                <h3 class="fw-bold mb-4" style="color: var(--secondary);">Promo Code</h3>
                <div class="d-flex mb-3" style="gap: 15px !important;">
                    <input type="text" id="promoCodeInput" class="form-control" placeholder="ENTER CODE" oninput="this.value=this.value.toUpperCase(); clearPromo()">
                    <button class="btn-premium" onclick="applyPromo()" style="background: var(--secondary); padding: 0 25px;">APPLY</button>
                </div>
                <div id="promoMsg" class="small mb-5" style="display:none;"></div>

                <h3 class="fw-bold mb-4" style="color: var(--primary);">Payment Method</h3>
                <div class="payment-methods">
                    <label class="payment-radio mb-3">
                        <input type="radio" name="paymentOption" value="fpx" @(defaultMethod == "Card" ? "" : "checked") onchange="togglePaymentUI()"> FPX Online Banking
                    </label>
                    <div id="fpxUI" class="payment-ui-box p-4 mb-4" style="display: @(defaultMethod == "Card" ? "none" : "block");">
                        <select class="form-select mb-3" style="font-size: 0.85rem; padding: 6px 12px; cursor: pointer; height: auto;">
                            <option value="">Select Retail Bank</option>
                            <option value="Maybank2U">Maybank2U</option>
                            <option value="CIMB Clicks">CIMB Clicks</option>
                            <option value="Public Bank">Public Bank</option>
                            <option value="RHB Now">RHB Now</option>
                            <option value="Bank Islam">Bank Islam</option>
                            <option value="AmBank">AmBank</option>
                        </select>
                        <p class="text-dim small mb-0"><i class="bi bi-shield-lock me-2"></i> Redirecting to secure bank portal.</p>
                    </div>

                    <label class="payment-radio mb-3">
                        <input type="radio" name="paymentOption" value="card" @(defaultMethod == "Card" ? "checked" : "") onchange="togglePaymentUI()"> Credit / Debit Card
                    </label>
                    <div id="cardUI" class="payment-ui-box p-4" style="display: @(defaultMethod == "Card" ? "block" : "none");">
                        @if (savedCards.Count > 0)
                        {
                            <!-- Saved card selector -->
                            <p class="text-dim small mb-3" style="font-size:0.75rem; font-weight:600; text-transform:uppercase; letter-spacing:0.5px;">Choose Saved Card</p>
                            @foreach (var card in savedCards)
                            {
                                var cId   = card.ContainsKey("id")     ? card["id"]     : "";
                                var cNum  = card.ContainsKey("number") ? card["number"] : "";
                                var cExp  = card.ContainsKey("expiry") ? card["expiry"] : "";
                                var cCvv  = card.ContainsKey("cvv")    ? card["cvv"]    : "";
                                var isSelected = cId == selectedCardId;
                                var last4 = cNum.Replace(" ", "").Length >= 4 ? cNum.Replace(" ", "").Substring(cNum.Replace(" ", "").Length - 4) : "••••";
                                <label class="checkout-card-item" onclick="selectCheckoutCard('@cId', this)"
                                       style="display:flex; align-items:center; gap:12px; padding:10px 12px; border-radius:10px;
                                              border:1px solid @(isSelected ? "rgba(16,185,129,0.4)" : "rgba(255,255,255,0.07)");
                                              background:@(isSelected ? "rgba(16,185,129,0.06)" : "rgba(255,255,255,0.02)");
                                              margin-bottom:8px; cursor:pointer; transition:all 0.2s;">
                                    <input type="radio" name="checkoutCard" value="@cId" @(isSelected ? "checked" : "")
                                           style="accent-color:var(--primary); width:16px; height:16px; flex-shrink:0;">
                                    <i class="bi bi-credit-card text-white" style="font-size:1rem; flex-shrink:0;"></i>
                                    <div style="flex:1;">
                                        <span class="text-white fw-bold d-block" style="font-size:0.83rem;">•••• •••• •••• @last4</span>
                                        <span class="text-dim" style="font-size:0.7rem;">Expires @cExp</span>
                                    </div>
                                </label>
                            }
                        }
                        else
                        {
                            <!-- No saved cards — link to add card in member settings -->
                            <div class="text-center py-4 px-3" style="background: rgba(255,255,255,0.01); border: 1px dashed rgba(255,255,255,0.1); border-radius: 16px;">
                                <i class="bi bi-credit-card text-dim mb-3 d-block" style="font-size: 2.2rem;"></i>
                                <h6 class="text-white fw-bold mb-1" style="font-size: 0.9rem;">No Saved Cards Found</h6>
                                <p class="text-dim small mb-4" style="font-size: 0.78rem; max-width: 250px; margin: 0 auto;">You need to save a card in your settings first to pay using Credit/Debit Card.</p>
                                <a href="/Account/MemberPayment" class="btn-premium d-inline-flex align-items-center justify-content-center" style="font-size: 0.75rem; padding: 8px 18px; border-radius: 50px; text-decoration: none;">
                                    <i class="bi bi-plus-circle me-1"></i> Add Card In Settings
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-md-5">
                <div class="price-summary-card">
                    <div class="price-breakdown mb-4">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-dim">Original Price</span>
                            <span id="originalPriceDisplay" class="fw-bold">RM @Model.TotalPrice.ToString("0.00")</span>
                        </div>
                        <div id="discountRow" class="justify-content-between mb-2" style="display: none; color: #22c55e;">
                            <span>Promo Discount</span>
                            <span id="discountValue">-RM 0.00</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-dim">Taxes & Fees</span>
                            <span class="fw-bold" style="color: #22c55e;">INCLUDED</span>
                        </div>
                    </div>
                    
                    <div class="d-flex justify-content-between align-items-center pt-3 border-top" style="border-color: rgba(255,255,255,0.1) !important;">
                        <span class="fw-bold text-uppercase" style="letter-spacing: 1px;">Total Due</span>
                        <h2 id="displayedPrice" class="m-0" style="color: var(--primary); font-weight: 800;">RM @Model.TotalPrice.ToString("0.00")</h2>
                    </div>

                    <button class="btn-premium w-100 mt-4 justify-content-center" id="payConfirmBtn" onclick="finalizeBooking()">
                        PAY NOW
                    </button>
                </div>
        </div>
    </div>
</div>

<script>
    const originalPrice = @Model.TotalPrice;
    let appliedPrice    = originalPrice;
    let appliedRateCode = "@(Model.RateCode ?? "")";
    const bookingDate   = "@Model.Date";

    function togglePaymentUI() {
        const method = document.querySelector('input[name="paymentOption"]:checked').value;
        document.getElementById("fpxUI").style.display = (method === "fpx") ? "block" : "none";
        document.getElementById("cardUI").style.display = (method === "card") ? "block" : "none";
    }

    // Dynamically update checkout card selection, style the item with a green border/background, and sync to backend session
    async function selectCheckoutCard(cardId, element) {
        // Set the radio button as checked
        const radio = element.querySelector('input[type="radio"]');
        if (radio) {
            radio.checked = true;
        }

        // Reset styling for all checkout-card-items
        const items = document.querySelectorAll('.checkout-card-item');
        items.forEach(item => {
            item.style.border = '1px solid rgba(255, 255, 255, 0.07)';
            item.style.background = 'rgba(255, 255, 255, 0.02)';
        });

        // Set green styling for selected card item
        element.style.border = '1px solid rgba(16, 185, 129, 0.4)';
        element.style.background = 'rgba(16, 185, 129, 0.06)';

        // Sync card selection with the backend session
        try {
            await fetch('/Account/SelectCard', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded'
                },
                body: new URLSearchParams({ cardId: cardId })
            });
        } catch (err) {
            console.error("Failed to sync card selection with server", err);
        }
    }

    async function applyPromo() {
        const code  = document.getElementById('promoCodeInput').value.trim();
        const msgEl = document.getElementById('promoMsg');

        if (!code) {
            msgEl.style.display = 'block';
            msgEl.style.color   = '#f87171';
            msgEl.textContent   = 'Please enter a promo code.';
            return;
        }

        msgEl.style.display = 'block';
        msgEl.style.color   = '#888';
        msgEl.textContent   = 'Validating...';

        try {
            const resp = await fetch(`/Rate/ValidatePromoCode?code=${encodeURIComponent(code)}&date=${bookingDate}`);
            const data = await resp.json();

            if (data.valid) {
                appliedRateCode = data.rateCode;
                const duration  = @Model.Duration;
                appliedPrice    = data.finalPrice * duration;
                const discount  = originalPrice - appliedPrice;

                document.getElementById('originalPriceDisplay').style.textDecoration = 'line-through';
                document.getElementById('originalPriceDisplay').style.opacity = '0.5';
                
                document.getElementById('discountRow').style.display = 'flex';
                document.getElementById('discountValue').textContent = `-RM ${discount.toFixed(2)}`;

                document.getElementById('displayedPrice').textContent = `RM ${appliedPrice.toFixed(2)}`;
                document.getElementById('displayedPrice').style.color = '#22c55e';

                msgEl.style.color = '#22c55e';
                msgEl.innerHTML   = `<i class="bi bi-check-circle me-1"></i> ${data.message}`;
                document.getElementById('promoCodeInput').style.borderColor = '#22c55e';
            } else {
                clearPromo();
                msgEl.style.display = 'block';
                msgEl.style.color   = '#f87171';
                msgEl.innerHTML     = `<i class="bi bi-x-circle me-1"></i> ${data.message}`;
                document.getElementById('promoCodeInput').style.borderColor = '#f87171';
            }
        } catch (e) {
            msgEl.style.color = '#f87171';
            msgEl.textContent = 'Could not validate promo code. Try again.';
        }
    }

    function clearPromo() {
        appliedRateCode = '';
        appliedPrice    = originalPrice;
        
        document.getElementById('originalPriceDisplay').style.textDecoration = 'none';
        document.getElementById('originalPriceDisplay').style.opacity = '1';
        document.getElementById('discountRow').style.display = 'none';
        
        document.getElementById('displayedPrice').textContent = `RM ${originalPrice.toFixed(2)}`;
        document.getElementById('displayedPrice').style.color = 'var(--primary)';
        
        document.getElementById('promoCodeInput').style.borderColor = 'rgba(255,255,255,0.1)';
        const msgEl = document.getElementById('promoMsg');
        msgEl.style.display = 'none';
        msgEl.textContent   = '';
    }

    // Fallback notification system if globalNotif is not available
    const originalShowNotif = window.showNotif;
    window.showNotif = function(message, type = 'info') {
        const overlay = document.getElementById('globalNotifOverlay');
        if (overlay && typeof originalShowNotif === 'function') {
            originalShowNotif(message, type);
        } else {
            alert(message);
        }
    };

    async function finalizeBooking() {
        const confirmBtn = document.getElementById("payConfirmBtn");
        confirmBtn.disabled = true;

        const method = document.querySelector('input[name="paymentOption"]:checked').value;
        
        if (method === "fpx") {
            const bank = document.querySelector('#fpxUI select').value;
            if (!bank) {
                showNotif("Please select a bank to proceed.", 'warning');
                confirmBtn.disabled = false;
                return;
            }
            confirmBtn.innerText = `Redirecting to ${bank}...`;
        } else {
            confirmBtn.innerText = "Authorizing Card...";
        }

        await new Promise(r => setTimeout(r, 1500));
        confirmBtn.innerText = "Processing Payment...";

        const formData = new FormData();
        formData.append("SlotId", "@Model.SlotId");
        formData.append("CustomerName", "@Model.CustomerName");
        formData.append("CustomerEmail", "@Model.CustomerEmail");
        const firstLane = "@Model.SelectedLanes".split(',')[0].trim();
        formData.append("TargetNo", firstLane);
        formData.append("RangeNo", "1");
        formData.append("Duration", "@Model.Duration");
        formData.append("TotalPrice", appliedPrice.toFixed(2));
        formData.append("SelectedLanes", "@Model.SelectedLanes");
        formData.append("SelectedLaneRanges", "@Model.SelectedLaneRanges");
        formData.append("NumberOfPax", "@Model.NumberOfPax");
        formData.append("RateCode", appliedRateCode);
        formData.append("PaymentMethod", method);
        formData.append("Date", "@Model.Date");
        formData.append("StudentId", "@Model.StudentId");

        try {
            const response = await fetch('/Booking/CreateCustomerBooking', {
                method: 'POST',
                body: formData
            });
            const result = await response.json();

            if (result.success) {
                const modal = document.getElementById('successModal');
                modal.style.display = 'flex';
                setTimeout(() => modal.classList.add('show'), 10);
            } else {
                showNotif("Booking failed: " + result.message, 'error');
                confirmBtn.disabled = false;
                confirmBtn.innerText = "Confirm Payment";
            }
        } catch (err) {
            showNotif("Connection error. Please try again.", 'error');
            confirmBtn.disabled = false;
            confirmBtn.innerText = "Confirm Payment";
        }
    }

    function goToDashboard() {
        window.location.href = "/Booking/MemberCalendar";
    }
</script>

