                    }
                </div>
            }
            else
            {
                <div style="text-align: center; padding: 30px 0; color: var(--text-dim);">
                    <i class="bi bi-people" style="font-size: 2.5rem; opacity: 0.2; display: block; margin-bottom: 12px;"></i>
                    <p style="font-size: 0.85rem; margin-bottom: 16px;">No archers added yet.</p>
                    <a href="/Archer/AddArcher" style="background: var(--primary); color: #000; font-size: 0.8rem; font-weight: 800; padding: 10px 20px; border-radius: 10px; text-decoration: none; letter-spacing: 0.5px;">
                        <i class="bi bi-plus-circle me-2"></i> ADD ARCHER
                    </a>
                </div>
            }
        </div>
    </div>


    <!-- RIGHT COLUMN: APPOINTMENTS & ACCOUNT BILLING -->
    <div class="right-col">
        <!-- Fee / Payment Section -->
        <h3 class="section-title">FEE STATUS <i class="bi bi-three-dots"></i></h3>
        @if (actualPending > 0)
        {
            <div class="payment-card">
                <p style="font-size: 0.75rem; opacity: 0.9; margin-bottom: 5px; text-transform: uppercase; letter-spacing: 1px;">Outstanding Balance</p>
                <h2 style="font-size: 2.5rem; font-weight: 800; margin-bottom: 20px;">RM @actualPending.ToString("N2")</h2>
                <div style="background: rgba(255,255,255,0.2); padding: 12px 15px; border-radius: 12px; display: flex; align-items: center; gap: 10px;">
                    <i class="bi bi-exclamation-circle-fill" style="font-size: 1.2rem;"></i>
                    <div>
                        <div style="font-size: 0.8rem; font-weight: 700;">@pendingHeader</div>
                        <div style="font-size: 0.65rem; opacity: 0.8;">@pendingTypeText</div>
                    </div>
                </div>
                <button onclick="window.location.href='/Account/MemberPayment'" style="width: 100%; padding: 12px; border-radius: 10px; border: none; background: #fff; color: #000; font-weight: 800; font-size: 0.9rem; margin-top: 20px; cursor: pointer; transition: 0.3s;">
                    PAY NOW
                </button>
            </div>
        }
        else
        {
            <div class="payment-card cleared">
                <p style="font-size: 0.75rem; opacity: 0.9; margin-bottom: 5px; text-transform: uppercase; letter-spacing: 1px;">Outstanding Balance</p>
                <h2 style="font-size: 2.5rem; font-weight: 800; margin-bottom: 20px;">RM 0.00</h2>
                <div style="background: rgba(255,255,255,0.2); padding: 12px 15px; border-radius: 12px; display: flex; align-items: center; gap: 10px;">
                    <i class="bi bi-shield-check" style="font-size: 1.2rem;"></i>
                    <div>
                        <div style="font-size: 0.8rem; font-weight: 700;">No Outstanding Payment</div>
                        <div style="font-size: 0.65rem; opacity: 0.8;">All payments are cleared!</div>
                    </div>
                </div>
                <button onclick="window.location.href='/Account/MemberPayment'" style="width: 100%; padding: 12px; border-radius: 10px; border: 1px solid rgba(255,255,255,0.3); background: transparent; color: #fff; font-weight: 800; font-size: 0.9rem; margin-top: 20px; cursor: pointer; transition: 0.3s;">
                    VIEW HISTORY
                </button>
            </div>
        }

        <!-- Upcoming Appointments -->
        <h3 class="section-title">🏹 Upcoming Appointments <span class="badge bg-danger rounded-pill ms-2" id="appointmentsCount">0</span></h3>
        <div class="card-premium" style="margin-bottom: 0px;">
            <div class="appointments-list" id="upcomingList">
                <!-- Dynamic cards filled in JS -->
            </div>
        </div>

        <!-- Attendance Summary -->
        <h3 class="section-title">ATTENDANCE SUMMARY</h3>
        <div class="card-premium" style="padding: 10px 25px;">
            <div class="attendance-stat">
                <div class="d-flex align-items-center">
                    <div class="stat-icon" style="color: #4ade80;"><i class="bi bi-check-circle-fill"></i></div>
                    <div>
                        <div style="font-weight: 700; font-size: 0.9rem;">Classes Attended</div>
                        <div style="font-size: 0.7rem; color: var(--text-dim);">Since joined</div>
                    </div>
                </div>
                <div style="font-weight: 800; font-size: 1.1rem; color: #4ade80;">8</div>
            </div>
            <div class="attendance-stat">
                <div class="d-flex align-items-center">
                    <div class="stat-icon" style="color: #f87171;"><i class="bi bi-x-circle-fill"></i></div>
                    <div>
                        <div style="font-weight: 700; font-size: 0.9rem;">Classes Missed</div>
                        <div style="font-size: 0.7rem; color: var(--text-dim);">Absences</div>
                    </div>
                </div>
                <div style="font-weight: 800; font-size: 1.1rem; color: #f87171;">1</div>
            </div>
            <div class="attendance-stat">
                <div class="d-flex align-items-center">
                    <div class="stat-icon" style="color: var(--primary);"><i class="bi bi-graph-up-arrow"></i></div>
                    <div>
                        <div style="font-weight: 700; font-size: 0.9rem;">Attendance Rate</div>
                        <div style="font-size: 0.7rem; color: var(--text-dim);">Overall score</div>
                    </div>
                </div>
                <div style="font-weight: 800; font-size: 1.1rem; color: var(--primary);">88%</div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const rawReservations = @Html.Raw(Json.Serialize(ViewBag.Reservations));
        
        document.addEventListener("DOMContentLoaded", () => {
            renderUpcomingPanel();
        });

        function renderUpcomingPanel() {
            const listContainer = document.getElementById("upcomingList");
            const countDisplay = document.getElementById("appointmentsCount");
            
            const formatDateStr = (date) => date.toISOString().split('T')[0];
            const nowStr = formatDateStr(new Date());
            
            const activeReservationsRaw = rawReservations.filter(res => {
                const resDate = res.reservedOn.split('T')[0];
                return resDate >= nowStr && res.status !== 2;
            }).sort((a, b) => new Date(a.reservedOn) - new Date(b.reservedOn));

            const activeReservations = [];
            const seenKeys = new Set();
            activeReservationsRaw.forEach(res => {
                const startStr = res.slot ? res.slot.slotStartTime : "";
                const key = res.reservedOn + "_" + startStr + "_" + res.rateCode;
                if (!seenKeys.has(key)) {
                    seenKeys.add(key);
                    activeReservations.push(res);
                }
            });

            countDisplay.innerText = activeReservations.length;

            if (activeReservations.length === 0) {
                listContainer.innerHTML = `
                    <div class="empty-state">
                        <i class="bi bi-calendar-x"></i>
                        <h6 class="text-white fw-bold mb-2">No Upcoming Appointments</h6>
                        <p class="text-dim">Schedule a session to start shooting.</p>
                    </div>
                `;
                return;
            }

            listContainer.innerHTML = "";

            activeReservations.forEach(res => {
                const item = document.createElement("div");
                item.className = "appointment-item";

                let badgeClass = "badge-game";
                let typeTitle = "Game Session";
                let typeIcon = "bi-bullseye";

                if (res.rateCode === "CLASS" || res.rateCode === "Class Session") {
                    badgeClass = "badge-class";
                    typeTitle = "Class Session";
                    typeIcon = "bi-mortarboard";
                } else if (res.rateCode === "SELF_TRAINING" || (res.slot && res.slot.isNight)) {
                    badgeClass = "badge-self-train";
                    typeTitle = "Self Training";
                    typeIcon = "bi-moon-stars";
                }

                const resDateObj = new Date(res.reservedOn);
                const readableDate = resDateObj.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric' });
                
                const startStr = res.slot ? res.slot.slotStartTime.substring(0,5) : "";
                const endStr = res.slot ? res.slot.slotEndTime.substring(0,5) : "";

                item.innerHTML = `
                    <div class="item-header">
                        <span class="item-type-badge ${badgeClass}"><i class="bi ${typeIcon} me-1"></i> ${typeTitle}</span>
                        <span class="item-status"><i class="bi bi-patch-check-fill"></i> Confirmed</span>
                    </div>
                    <div class="item-body">
                        <div class="item-datetime">${readableDate}</div>
                        <div class="item-slots-info">
                            <i class="bi bi-clock-fill text-primary"></i> ${startStr} - ${endStr} (${res.durationHours} ${res.durationHours === 1 ? 'Slot' : 'Slots'})
                        </div>
                    </div>
                    <div class="item-footer">
                        <span class="item-target"><i class="bi bi-bullseye"></i> Target ${res.targetNo} (Lane ${res.rangeNo})</span>
                        <span class="item-price">RM ${(res.totalPrice).toFixed(2)}</span>
                    </div>
                `;
                listContainer.appendChild(item);
            });
        }
    </script>
}
