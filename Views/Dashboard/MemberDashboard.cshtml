        <!-- ─── MY ARCHERS SECTION ─── -->
        @{
            var students = ViewBag.Students as dynamic;
        }
        <h3 class="section-title">
            MY ARCHERS
            <a href="/Archer/AddArcher" style="font-size: 0.72rem; color: var(--primary); font-weight: 700; text-decoration: none; display: flex; align-items: center; gap: 5px; letter-spacing: 1px;">
                <i class="bi bi-plus-circle"></i> ADD ARCHER
            </a>
        </h3>
        <div class="card-premium" style="padding: 20px 25px;">
            @if (students != null && ((IEnumerable<dynamic>)students).Any())
            {
                <div style="display: flex; flex-direction: column; gap: 14px; max-height: 290px; overflow-y: auto; padding-right: 8px;">
                    @foreach (var s in students)
                    {
                        bool hasReg = s.ClassReg != null;
                        <div style="background: rgba(255,255,255,0.02); border: 1px solid var(--border-color); border-radius: 14px; padding: 16px 18px; display: flex; align-items: center; justify-content: space-between; gap: 14px;">
                            <div style="display: flex; align-items: center; gap: 14px;">
                                <div style="width: 42px; height: 42px; border-radius: 50%; background: var(--primary-light); border: 1px solid rgba(255,77,77,0.2); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                                    <i class="bi bi-person-fill" style="color: var(--primary); font-size: 1.1rem;"></i>
                                </div>
                                <div>
                                    <div style="font-weight: 700; font-size: 0.95rem; color: #fff;">@s.FullName</div>
                                    <div style="font-size: 0.7rem; color: var(--text-dim); margin-top: 2px;">
                                        @if (s.Birthday != null)
                                        {
                                            var birthDate = (DateTime)s.Birthday;
                                            var age = DateTime.Today.Year - birthDate.Year;
                                            if (birthDate.Date > DateTime.Today.AddYears(-age)) age--;
                                            @($"{age} years old (Born: {birthDate.ToString("dd MMM yyyy")})")
                                        }
                                        @if (!string.IsNullOrEmpty(s.ICNumber))
                                        {
                                            @($" | IC: {s.ICNumber}")
                                        }
                                    </div>
                                    @if (hasReg)
                                    {
                                        <span style="font-size: 0.65rem; background: rgba(16,185,129,0.15); color: #10B981; padding: 2px 8px; border-radius: 20px; font-weight: 700; margin-top: 4px; display: inline-block;">
                                            @s.ClassReg.PackageType
                                        </span>
                                    }
                                    else
                                    {
                                        <span style="font-size: 0.65rem; background: rgba(245,158,11,0.15); color: #F59E0B; padding: 2px 8px; border-radius: 20px; font-weight: 700; margin-top: 4px; display: inline-block;">
                                            Not Registered
                                        </span>
                                    }
                                </div>
                            </div>
                            @if (!hasReg)
                            {
                                <a href="/Archer/AddArcherRegister?studentId=@s.StudentId"
                                   style="flex-shrink: 0; background: var(--primary); color: #000; font-size: 0.72rem; font-weight: 800; padding: 7px 14px; border-radius: 10px; text-decoration: none; letter-spacing: 0.5px; white-space: nowrap; transition: 0.3s;"
                                   onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">
                                    <i class="bi bi-mortarboard-fill me-1"></i> REGISTER CLASS
                                </a>
                            }
                            else
                            {
                                var isPaid = s.ClassReg.PaymentStatus == "Paid" || s.ClassReg.PaymentStatus == "Success";
                                if (isPaid)
                                {
                                    <span style="flex-shrink: 0; font-size: 0.72rem; font-weight: 700; color: #10B981; white-space: nowrap;">
                                        <i class="bi bi-check-circle-fill me-1"></i> Active
                                    </span>
                                }
                                else
                                {
                                    <span style="flex-shrink: 0; font-size: 0.72rem; font-weight: 700; color: #F59E0B; white-space: nowrap;">
                                        <i class="bi bi-clock-fill me-1"></i> Pending
                                    </span>
                                }
                            }
