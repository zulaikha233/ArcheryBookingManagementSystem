@{
    ViewData["Title"] = "Member Dashboard";
    Layout = "_MemberLayout";

    var classRegs = ViewBag.ClassRegistrations as IEnumerable<ArcheryAlley.Models.ClassRegistrations> ?? new List<ArcheryAlley.Models.ClassRegistrations>();
    var membershipPayments = ViewBag.MembershipPayments as IEnumerable<ArcheryAlley.Models.MembershipPayments> ?? new List<ArcheryAlley.Models.MembershipPayments>();
    var reservations = ViewBag.Reservations as IEnumerable<dynamic> ?? new List<dynamic>();
    var parentClassRegs = classRegs.Where(cr => cr.StudentId == null);

    decimal actualPending = 0;
    if (membershipPayments != null)
    {
        foreach(var mp in membershipPayments)
        {
            if (mp.Status == "Pending")
            {
                actualPending += mp.Amount;
            }
        }
    }
    if (classRegs != null)
    {
        foreach (var r in classRegs)
        {
            if (r.PaymentStatus == "Pending")
            {
                actualPending += r.TotalPrice;
            }
        }
    }
    if (reservations != null)
    {
        foreach (var r in reservations)
        {
            if (r.Status == 0)
            {
                actualPending += (decimal)r.TotalPrice;
            }
        }
    }

    // Determine the specific type/message of pending payment
    string pendingHeader = "Pending Payment";
    string pendingTypeText = "Please clear outstanding dues.";

    if (actualPending > 0)
    {
        var pendingMembership = membershipPayments.FirstOrDefault(mp => mp.Status == "Pending");
        if (pendingMembership != null)
        {
            pendingHeader = "Annual Membership";
            pendingTypeText = "Please pay your Annual Membership fee.";
        }
        else
        {
            var pendingClass = classRegs.FirstOrDefault(cr => cr.PaymentStatus == "Pending");
            if (pendingClass != null)
            {
                pendingHeader = "Class Registration";
                pendingTypeText = "Please clear class registration payment.";
            }
            else
            {
                var pendingRes = reservations.FirstOrDefault(r => r.Status == 0);
                if (pendingRes != null)
                {
                    string rateCode = pendingRes.RateCode ?? "";
                    if (rateCode == "SELF_TRAINING" || (pendingRes.Slot != null && pendingRes.Slot.IsNight))
                    {
                        pendingHeader = "Self Training";
                        pendingTypeText = "Please clear self training session payment.";
                    }
                    else
                    {
                        pendingHeader = "Lane Booking";
                        pendingTypeText = "Please clear lane booking payment.";
                    }
                }
            }
        }
    }
}

@section Styles {
    <style>
        .dashboard-grid {
            display: grid;
            grid-template-columns: 1fr 380px;
            gap: 30px;
            min-height: calc(100vh - 80px);
            animation: fadeIn 0.8s ease;
        }

        @@media (max-width: 1200px) {
            .dashboard-grid {
                grid-template-columns: 1fr;
            }
        }

        .section-title {
            font-size: 0.8rem;
            color: var(--text-dim);
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 700;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .card-premium {
            background-color: var(--bg-card);
            border-radius: var(--radius-md);
            padding: 25px;
            border: 1px solid rgba(255,255,255,0.03);
            margin-bottom: 30px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        }

        .middle-col { display: flex; flex-direction: column; }
        .performance-card { flex: 1; display: flex; flex-direction: column; }

        .chart-row { display: flex; align-items: center; margin-bottom: 25px; }
        .chart-label { width: 150px; font-size: 0.85rem; color: var(--text-dim); font-weight: 600; }
        .chart-bar-wrapper { flex: 1; position: relative; display: flex; align-items: center; }
        .chart-line { height: 2px; background-color: var(--border-color); width: 100%; position: absolute; z-index: 1; }
        .chart-fill { height: 4px; background-color: var(--primary); border-radius: 4px; position: relative; z-index: 2; }
        .chart-dot { width: 12px; height: 12px; background-color: #fff; border: 3px solid var(--primary); border-radius: 50%; position: absolute; right: -6px; top: -4px; z-index: 3; box-shadow: 0 0 10px var(--primary); }
        .chart-value { position: absolute; right: -10px; top: -30px; background: #fff; color: #000; font-size: 0.75rem; font-weight: 800; padding: 4px 10px; border-radius: 8px; box-shadow: 0 5px 15px rgba(0,0,0,0.2); }

        .equipment-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        .eq-card { background-color: var(--bg-card); border-radius: var(--radius-md); padding: 25px; border: 1px solid rgba(255,255,255,0.03); }

        .right-col { display: flex; flex-direction: column; gap: 30px; }
        .payment-card { background: linear-gradient(135deg, #FF4D4D, #D63031); border-radius: var(--radius-md); padding: 30px 25px; color: #fff; position: relative; overflow: hidden; box-shadow: 0 15px 30px rgba(255, 77, 77, 0.2); }
        .payment-card.cleared { background: linear-gradient(135deg, #10B981, #059669) !important; box-shadow: 0 15px 30px rgba(16, 185, 129, 0.2) !important; }
        .payment-card::after { content: ''; position: absolute; top: -50px; right: -50px; width: 150px; height: 150px; background: rgba(255,255,255,0.1); border-radius: 50%; }

        .attendance-stat { display: flex; justify-content: space-between; align-items: center; padding: 15px 0; border-bottom: 1px dashed var(--border-color); }
        .attendance-stat:last-child { border-bottom: none; }
        .stat-icon { width: 36px; height: 36px; border-radius: 10px; display: flex; align-items: center; justify-content: center; background: rgba(255,255,255,0.05); margin-right: 12px; }

        /* ─── UPCOMING APPOINTMENTS ─── */
        .appointments-list {
            display: flex;
            flex-direction: column;
            gap: 15px;
            height: 340px; /* Fixed height to fit exactly 2 appointments */
            overflow-y: auto;
            padding-right: 5px;
        }

        .appointment-item {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.04);
            border-radius: 16px;
            padding: 18px;
            display: flex;
            flex-direction: column;
            gap: 12px;
            transition: all 0.3s ease;
        }

        .appointment-item:hover {
            border-color: rgba(255, 77, 77, 0.2);
            background: rgba(255, 77, 77, 0.02);
            transform: translateY(-2px);
        }

        .item-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .item-type-badge {
            font-size: 0.65rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            padding: 4px 10px;
            border-radius: 20px;
        }

        .badge-game { background: rgba(255, 77, 77, 0.1); color: #FF4D4D; }
        .badge-self-train { background: rgba(168, 85, 247, 0.1); color: #A855F7; }
        .badge-class { background: rgba(59, 130, 246, 0.1); color: #3B82F6; }

        .item-status {
            font-size: 0.7rem;
            color: #10B981;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .item-body {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .item-datetime {
            font-size: 0.95rem;
            font-weight: 800;
            color: #fff;
        }

        .item-slots-info {
            font-size: 0.8rem;
            color: var(--text-dim);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .item-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-top: 1px dashed rgba(255, 255, 255, 0.05);
            padding-top: 12px;
            font-size: 0.75rem;
        }

        .item-target {
            color: var(--text-dim);
        }

        .item-price {
            font-weight: 800;
            color: #fff;
        }

        .empty-state {
            text-align: center;
            padding: 30px 20px;
            color: var(--text-dim);
        }

        .empty-state i {
            font-size: 2.5rem;
            color: var(--border-color);
            margin-bottom: 15px;
            display: block;
        }

        .empty-state p {
            font-size: 0.8rem;
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(15px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert" style="background-color: rgba(255, 77, 77, 0.15); border: 1px solid rgba(255, 77, 77, 0.3); color: #FF4D4D; border-radius: var(--radius-md); padding: 18px 25px; margin-bottom: 25px; font-weight: 600; display: flex; align-items: center; justify-content: space-between;">
        <div>
            <i class="bi bi-exclamation-triangle-fill me-2" style="font-size: 1.1rem;"></i>
            @TempData["ErrorMessage"]
        </div>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close" style="font-size: 0.8rem; box-shadow: none;"></button>
    </div>
}

@if (!parentClassRegs.Any())
{
    <div class="banner-premium" style="background: linear-gradient(135deg, #131924, #1a1e28); border-radius: var(--radius-md); padding: 30px; border: 1px solid rgba(255,255,255,0.05); margin-bottom: 30px; display: flex; align-items: center; justify-content: space-between; box-shadow: 0 15px 35px rgba(0,0,0,0.4);">
        <div>
            <span class="badge bg-danger text-uppercase mb-2" style="font-size: 0.7rem; letter-spacing: 1px; padding: 6px 12px; border-radius: 6px; box-shadow: 0 0 10px rgba(255,77,77,0.3);">WEEKEND CLASS</span>
            <h2 class="text-white fw-bold mb-2" style="font-size: 1.4rem; letter-spacing: -0.5px;">Unlock Certified Archery Coaching</h2>
            <p class="text-dim m-0" style="font-size: 0.9rem;">Register today for annual access and choose either 4 Slots or 6 Slots with expert coaching.</p>
        </div>
        <div>
            <a href="@Url.Action("ClassRegistration", "Account")" class="btn-premium" style="padding: 12px 25px; text-decoration: none; display: inline-flex; align-items: center; gap: 10px; box-shadow: 0 0 20px rgba(255,77,77,0.4);">
                REGISTER
            </a>
        </div>
    </div>
}



<div class="dashboard-grid">
    <!-- LEFT COLUMN: PERFORMANCE & EQUIPMENT -->
