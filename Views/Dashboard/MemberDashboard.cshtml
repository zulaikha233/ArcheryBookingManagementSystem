                    <span class="text-warning fw-bold" style="font-size: 0.8rem;"><i class="bi bi-arrow-right"></i> Tune</span>
                </div>
                <p class="text-dim" style="font-size: 0.75rem;">Coming Soon Feature</p>
                <div class="d-flex justify-content-between align-items-end mt-4">
                    <div>
                        <div style="font-size: 1.4rem; color: #fff; font-weight: 800;">Carbon</div>
                        <div style="font-size: 0.7rem; color: var(--text-dim);">Material Type</div>
                    </div>
                    <div style="font-size: 1.1rem; color: #facc15; font-weight: 800;">Upgrade</div>
                </div>
            </div>
