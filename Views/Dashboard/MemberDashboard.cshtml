                    <div class="chart-line"></div>
                    <div class="chart-fill" style="width: 60%;"><div class="chart-value">60%</div><div class="chart-dot"></div></div>
                </div>
            </div>
            <div class="chart-row mt-4">
                <div class="chart-label">Release Smoothness</div>
                <div class="chart-bar-wrapper">
                    <div class="chart-line"></div>
                    <div class="chart-fill" style="width: 75%;"><div class="chart-value">75%</div><div class="chart-dot"></div></div>
                </div>
            </div>
            <div class="chart-row mt-4">
                <div class="chart-label">Focus & Timing</div>
                <div class="chart-bar-wrapper">
                    <div class="chart-line"></div>
                    <div class="chart-fill" style="width: 90%;"><div class="chart-value">90%</div><div class="chart-dot"></div></div>
                </div>
            </div>
        </div>

        <!-- Equipment Needed -->
        <h3 class="section-title">EQUIPMENT RECOMMENDATIONS</h3>
        <div class="equipment-grid mb-4">
            <div class="eq-card">
                <div class="d-flex justify-content-between mb-2">
                    <h4 style="font-size: 1.1rem; font-weight: 800;">Bow Limbs</h4>
                    <span class="text-primary fw-bold" style="font-size: 0.8rem;"><i class="bi bi-arrow-up"></i> Lvl 3</span>
                </div>
                <p class="text-dim" style="font-size: 0.75rem;">Coming Soon Feature</p>
                <div class="d-flex justify-content-between align-items-end mt-4">
