@{
    ViewData["Title"] = "Gamified Progress";
    Layout = "_MemberLayout";
}

<style>
    /* Premium Gamified Theme Colors */
    :root {
        --gamify-bg: #131924;
        --gamify-text: #f3f4f6;
        --gamify-primary: #ff4d4d; /* Archery Alley Red */
        --gamify-secondary: #00d2ff;
        --gamify-success: #22c55e;
        --gamify-card: rgba(25, 30, 40, 0.8);
        --gamify-shadow: rgba(0, 0, 0, 0.5);
    }

    body {
        background-color: var(--gamify-bg) !important;
        color: var(--gamify-text) !important;
    }

    .gamify-container {
        padding: 40px;
        max-width: 1200px;
        margin: 0 auto;
        font-family: 'Inter', sans-serif;
    }

    /* Header Section */
    .gamify-header {
        text-align: center;
        margin-bottom: 50px;
        position: relative;
        z-index: 2;
    }

    .gamify-title {
        font-size: 2.5rem;
        font-weight: 900;
        color: #fff;
        margin-bottom: 10px;
        letter-spacing: -1px;
    }

    .gamify-title span {
        color: var(--gamify-primary); /* Red highlight */
        text-transform: uppercase;
        text-shadow: 0 0 15px rgba(255, 77, 77, 0.4);
    }

    /* Main Grid */
    .gamify-grid {
        display: grid;
        grid-template-columns: 1fr 1.5fr;
        gap: 40px;
        align-items: stretch;
    }

    /* Cards */
    .gamify-card {
        background: var(--gamify-card);
        border-radius: 24px;
        padding: 30px;
        box-shadow: 0 15px 35px var(--gamify-shadow);
        position: relative;
        overflow: hidden;
        border: 1px solid rgba(255, 77, 77, 0.15);
        backdrop-filter: blur(10px);
    }

    /* Left Column: Overall Circular Progress */
    .circle-progress-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }
    
    .progress-circle {
        position: relative;
        width: 180px;
        height: 180px;
        border-radius: 50%;
        background: conic-gradient(var(--gamify-success) 45%, rgba(255,255,255,0.05) 0);
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 10px 25px rgba(34, 197, 94, 0.2);
    }

    .progress-circle::before {
        content: "";
        position: absolute;
        width: 140px;
        height: 140px;
        background: #1a1e28;
        border-radius: 50%;
        box-shadow: inset 0 5px 15px rgba(0,0,0,0.5);
    }
    
    .progress-circle.small {
        width: 80px;
        height: 80px;
        box-shadow: 0 5px 15px rgba(34, 197, 94, 0.2);
    }
    .progress-circle.small::before {
        width: 60px;
        height: 60px;
    }
    .progress-circle.small .progress-value {
        font-size: 1.3rem;
    }

    .progress-value {
        position: relative;
        font-size: 2.5rem;
        font-weight: 900;
        color: #fff;
        z-index: 1;
    }

    .progress-label {
        margin-top: 20px;
        font-size: 1.2rem;
        font-weight: 800;
        color: #9ca3af;
        text-align: center;
    }

    /* Center Mascot */
    .mascot-container {
        text-align: center;
        position: relative;
        animation: floatMascot 3s ease-in-out infinite;
    }

    @@keyframes floatMascot {
        0% { transform: translateY(0px); }
        50% { transform: translateY(-15px); }
        100% { transform: translateY(0px); }
    }

    .mascot-img {
        width: 100%;
        max-width: 280px;
        filter: drop-shadow(0 20px 30px rgba(0,0,0,0.4)); /* Darker shadow for image */
    }

    /* Linear Progress Bars (Right Column) */
    .skill-bar-wrapper {
        margin-bottom: 25px;
    }

    .skill-bar-wrapper:last-child {
        margin-bottom: 0;
    }

    .skill-header {
        display: flex;
        justify-content: space-between;
        margin-bottom: 8px;
        font-weight: 700;
        color: #d1d5db;
        font-size: 0.95rem;
    }

    .skill-track {
        height: 14px;
        background: rgba(255,255,255,0.05);
        border-radius: 20px;
        overflow: hidden;
        box-shadow: inset 0 2px 4px rgba(0,0,0,0.2);
    }

    .skill-fill {
        height: 100%;
        border-radius: 20px;
        transition: width 1s ease-in-out;
        position: relative;
    }

    .skill-fill::after {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(90deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.4) 50%, rgba(255,255,255,0) 100%);
        background-size: 200% 100%;
        animation: shimmer 2s infinite linear;
    }

    @@keyframes shimmer {
        0% { background-position: 200% 0; }
        100% { background-position: -200% 0; }
    }

    /* Colors for specific skills */
    .fill-blue { background: linear-gradient(90deg, #3b82f6, #60a5fa); }
    .fill-orange { background: linear-gradient(90deg, #f97316, #fb923c); }
    .fill-green { background: linear-gradient(90deg, #10b981, #34d399); }
    .fill-purple { background: linear-gradient(90deg, #8b5cf6, #a78bfa); }

    /* Bottom Row: Achievements */
    .achievements-section {
        margin-top: 40px;
    }

    .achievements-grid {
        display: flex;
        justify-content: center;
        gap: 20px;
        flex-wrap: wrap;
    }

    .badge-card {
        background: rgba(255, 77, 77, 0.03);
        border-radius: 20px;
        padding: 20px;
        width: 140px;
        text-align: center;
        box-shadow: 0 10px 20px rgba(0,0,0,0.2);
        border: 1px solid rgba(255, 77, 77, 0.2);
        transition: all 0.3s ease;
        position: relative;
    }

    .badge-card:hover {
        transform: translateY(-5px);
        border-color: var(--gamify-primary);
        box-shadow: 0 10px 25px rgba(255, 77, 77, 0.15);
    }

    .badge-icon {
        width: 60px;
        height: 60px;
        margin: 0 auto 10px;
        background: rgba(255, 77, 77, 0.1);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
    }

    .badge-icon.locked {
        background: rgba(255,255,255,0.03);
        color: #6b7280;
        filter: grayscale(100%);
    }

    .badge-title {
        font-weight: 800;
        font-size: 0.85rem;
        color: #e5e7eb;
    }

    .badge-status {
        font-size: 0.7rem;
        font-weight: 700;
        margin-top: 5px;
        color: #22c55e;
    }

    .badge-status.locked {
        color: #6b7280;
    }

    /* Table Styling for Coach Reports */
    .gamify-table-container {
        overflow-x: auto;
        margin-top: 15px;
        border-radius: 12px;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }
    
    .gamify-table {
        width: 100%;
        border-collapse: collapse;
        color: #d1d5db;
        font-size: 0.95rem;
    }
    
    .gamify-table th {
        background: rgba(0, 0, 0, 0.4);
        color: #fff;
        font-weight: 800;
        padding: 15px 20px;
        text-align: left;
        letter-spacing: 0.5px;
    }
    
    .gamify-table td {
        padding: 15px 20px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        background: rgba(255, 255, 255, 0.02);
    }
    
    .gamify-table tr:hover td {
        background: rgba(255, 255, 255, 0.05);
    }
    
    .gamify-btn-view {
        background: rgba(0, 210, 255, 0.15);
        color: var(--gamify-secondary);
        border: 1px solid var(--gamify-secondary);
        padding: 6px 15px;
        border-radius: 20px;
        font-weight: 700;
        font-size: 0.85rem;
        text-decoration: none;
        transition: all 0.3s ease;
        display: inline-block;
    }
    
    .gamify-btn-view:hover {
        background: var(--gamify-secondary);
        color: #000;
        box-shadow: 0 0 15px rgba(0, 210, 255, 0.4);
    }

    /* End of CSS */

</style>

<div class="gamify-container" data-aos="fade-in">
    <!-- Header Row -->
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px; flex-wrap: wrap; gap: 20px;">
        <div class="gamify-header" style="margin-bottom: 0; text-align: left;">
            <h1 class="gamify-title">Your Path to <span>MASTERY</span></h1>
            <p style="color: #6b7280; font-size: 1.1rem; font-weight: 500;">Track your archery performance journey, @ViewBag.CustomerName!</p>
        </div>

        <!-- Small Overall Mastery Card -->
        <div class="gamify-card" style="padding: 15px 25px; display: flex; align-items: center; gap: 20px; box-shadow: 0 10px 25px rgba(0,0,0,0.3);">
            <div class="progress-circle small">
                <span class="progress-value">45<span style="font-size: 0.8rem;">%</span></span>
            </div>
            <div>
                <div class="progress-label" style="margin-top: 0; font-size: 1.1rem; text-align: left; color: #fff;">Overall Mastery</div>
                <p style="font-size: 0.8rem; color: #9ca3af; margin: 2px 0 0 0;">Keep practicing!</p>
            </div>
        </div>
    </div>

    <!-- Main Grid -->
    <div class="gamify-grid">
        <!-- Left: Cute Mascot -->
        <div class="mascot-container" style="display: flex; flex-direction: column; align-items: center; justify-content: center;">
            <!-- User Uploaded Mascot Image -->
            <img src="~/images/Grassroot_level.png" alt="Archery Mascot" class="mascot-img" style="max-width: 320px;" />
            
            <!-- Level Badge -->
            <div style="margin-top: 10px; background: rgba(16, 185, 129, 0.15); border: 2px solid #10b981; padding: 8px 25px; border-radius: 30px; display: inline-flex; align-items: center; gap: 10px; box-shadow: 0 5px 15px rgba(16, 185, 129, 0.2);">
                <i class="bi bi-award-fill" style="color: #10b981; font-size: 1.3rem;"></i>
                <span style="color: #fff; font-weight: 800; font-size: 1.1rem; letter-spacing: 1px;">GRASSROOTS</span>
            </div>
        </div>

        <!-- Right: Skill Radar Chart -->
        <div class="gamify-card" style="display: flex; flex-direction: column;">
            <h3 style="font-weight: 900; font-size: 1.5rem; margin-bottom: 15px; color: #fff; text-align: center;">Skill Progress</h3>
            <div style="position: relative; flex-grow: 1; min-height: 400px; width: 100%; display: flex; justify-content: center; align-items: center;">
                <canvas id="skillRadarChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Target Progression Section -->
    <div class="gamify-card" style="margin-top: 40px; margin-bottom: 40px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 30px;">
        <div style="flex: 1; min-width: 300px;">
            <h3 style="font-weight: 900; font-size: 1.5rem; color: #fff; margin-bottom: 5px;">Target Mastery</h3>
            <p style="color: #9ca3af; font-size: 0.95rem; margin-bottom: 25px;">Master your current target size to unlock the next level.</p>
            
            <div style="background: rgba(255,255,255,0.05); padding: 20px; border-radius: 15px; border: 1px solid rgba(255,255,255,0.1);">
                <div style="display: flex; justify-content: space-between; margin-bottom: 10px;">
                    <span style="font-weight: 700; color: #f3f4f6; font-size: 1.1rem;">120cm Target (Current)</span>
                    <span style="color: #10b981; font-weight: 900; font-size: 1.1rem;">2 / 3 Sessions</span>
                </div>
                
                <!-- Progress bar for 2/3 passes -->
                <div class="skill-track" style="height: 16px; margin-bottom: 15px; background: rgba(0,0,0,0.4);">
                    <div class="skill-fill fill-green" style="width: 66%;"></div>
                </div>
                
                <p style="font-size: 0.85rem; color: #d1d5db; margin: 0; display: flex; gap: 10px; align-items: flex-start;">
                    <i class="bi bi-info-circle-fill" style="color: var(--gamify-secondary); font-size: 1.1rem;"></i> 
                    <span>
                        Get a <strong>5-star rating</strong> in 1 more session and reach <strong>80% overall mastery</strong> to unlock the <strong>60cm Target</strong> for your next booking!
                    </span>
                </p>
            </div>
        </div>
        
        <!-- Target Visualization Image -->
        <div style="text-align: center; background: rgba(0,0,0,0.2); padding: 30px; border-radius: 20px; border: 1px dashed rgba(255, 77, 77, 0.3);">
            <img src="~/images/archery_image.png" alt="120cm Target" style="width: 120px; height: 120px; object-fit: contain; margin: 0 auto 15px; display: block; filter: drop-shadow(0 10px 15px rgba(0,0,0,0.5));" />
            <h4 style="color: #fff; font-weight: 800; font-size: 1.2rem; margin: 0 0 5px 0;">120cm Target</h4>
            <span style="font-size: 0.8rem; background: rgba(16, 185, 129, 0.2); color: #10b981; padding: 4px 10px; border-radius: 10px; font-weight: 700; letter-spacing: 1px;">ACTIVE</span>
        </div>
    </div>

    <!-- Achievements Section -->
    <div class="achievements-section gamify-card">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 style="font-weight: 900; font-size: 1.5rem; color: #fff; margin: 0;">Achievements</h3>
            <a href="#" style="color: var(--gamify-primary); font-weight: 700; text-decoration: none;">See All ></a>
        </div>
        
        <div class="achievements-grid">
            <!-- Badge 1: Grassroots -->
            <div class="badge-card">
                <div class="badge-icon" style="background: rgba(16, 185, 129, 0.1); color: #10b981;">
                    <i class="bi bi-award-fill"></i>
                </div>
                <div class="badge-title">GrassRoots</div>
                <div class="badge-status">COMPLETED!</div>
            </div>

            <!-- Badge 2: Beginner 1 -->
            <div class="badge-card">
                <div class="badge-icon" style="background: rgba(59, 130, 246, 0.1); color: #3b82f6;">
                    <i class="bi bi-star-fill"></i>
                </div>
                <div class="badge-title">Beginner 1</div>
                <div class="badge-status" style="color: #3b82f6;">IN PROGRESS</div>
            </div>

            <!-- Badge 3: Beginner 2 (Locked) -->
            <div class="badge-card">
                <div class="badge-icon locked">
                    <i class="bi bi-lock-fill"></i>
                </div>
                <div class="badge-title" style="color: #9ca3af;">Beginner 2</div>
                <div class="badge-status locked">LOCKED</div>
            </div>

            <!-- Badge 4: Intermediate (Locked) -->
            <div class="badge-card">
                <div class="badge-icon locked">
                    <i class="bi bi-shield-lock-fill"></i>
                </div>
                <div class="badge-title" style="color: #9ca3af;">Intermediate 1</div>
                <div class="badge-status locked">LOCKED</div>
            </div>
            
            <!-- Badge 5: Expert (Locked) -->
            <div class="badge-card">
                <div class="badge-icon locked">
                    <i class="bi bi-trophy-fill"></i>
                </div>
                <div class="badge-title" style="color: #9ca3af;">Expert</div>
                <div class="badge-status locked">LOCKED</div>
            </div>
        </div>
    </div>

    <!-- Coach Reports Section -->
    <div class="gamify-card" style="margin-top: 40px;">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 style="font-weight: 900; font-size: 1.5rem; color: #fff; margin: 0;">All Performance Reports</h3>
        </div>
        
        <div class="gamify-table-container">
            <table class="gamify-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Coach</th>
                        <th>Session Type</th>
                        <th>Mastery Rating</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>12 Aug 2026</td>
                        <td>Coach Farhan</td>
                        <td>Class Session</td>
                        <td>
                            <div style="color: #fbbf24; font-size: 1.1rem;">
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>
                            </div>
                        </td>
                        <td>
                            <a href="#" class="gamify-btn-view"><i class="bi bi-eye-fill"></i> View</a>
                        </td>
                    </tr>
                    <tr>
                        <td>05 Aug 2026</td>
                        <td>Coach Amir</td>
                        <td>Self-Training (Evaluated)</td>
                        <td>
                            <div style="color: #fbbf24; font-size: 1.1rem;">
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star text-muted"></i>
                            </div>
                        </td>
                        <td>
                            <a href="#" class="gamify-btn-view"><i class="bi bi-eye-fill"></i> View</a>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const ctx = document.getElementById('skillRadarChart').getContext('2d');
            const skillRadarChart = new Chart(ctx, {
                type: 'radar',
                data: {
                    labels: ['Stance & Posture', 'Anchor Point', 'Draw & Release', 'Follow Through', 'Focus & Timing'],
                    datasets: [{
                        label: 'Skill Level',
                        data: [70, 85, 60, 75, 90], // Sample data
                        backgroundColor: 'rgba(255, 77, 77, 0.2)', // gamify-primary with opacity
                        borderColor: '#ff4d4d',
                        pointBackgroundColor: '#00d2ff', // gamify-secondary
                        pointBorderColor: '#fff',
                        pointHoverBackgroundColor: '#fff',
                        pointHoverBorderColor: '#00d2ff',
                        borderWidth: 2,
                        pointRadius: 4,
                        pointHoverRadius: 6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        r: {
                            min: 0,
                            max: 100,
                            angleLines: {
                                color: 'rgba(255, 255, 255, 0.2)'
                            },
                            grid: {
                                color: 'rgba(255, 255, 255, 0.2)'
                            },
                            pointLabels: {
                                color: '#f3f4f6',
                                font: {
                                    size: 14,
                                    family: "'Inter', sans-serif",
                                    weight: '700'
                                }
                            },
                            ticks: {
                                color: '#9ca3af',
                                backdropColor: 'transparent',
                                stepSize: 20,
                                showLabelBackdrop: false,
                                font: { size: 12 }
                            }
                        }
                    },
                    plugins: {
                        legend: {
                            display: false
                        },
                        tooltip: {
                            backgroundColor: 'rgba(25, 30, 40, 0.9)',
                            titleFont: { size: 13, family: "'Inter', sans-serif" },
                            bodyFont: { size: 12, family: "'Inter', sans-serif" },
                            padding: 10,
                            displayColors: false,
                            borderColor: 'rgba(255, 77, 77, 0.3)',
                            borderWidth: 1
                        }
                    }
                }
            });
        });
    </script>
}
