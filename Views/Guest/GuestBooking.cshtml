@{
    ViewData["Title"] = "Guest Booking";
}

<div class="booking-wizard-container animate-fade-in" data-aos="fade-up">
    <!-- Progress Header -->
    <partial name="~/Views/Home/BookingProgress.cshtml" model="1" />

    <!-- Step 1: Customer Info & Session -->
    <div class="wizard-step active" id="wizard-step-1">
        <div class="premium-card p-0 overflow-hidden">
            <div class="p-5 border-bottom" style="background: rgba(255, 77, 77, 0.08); border-color: var(--card-border) !important; box-shadow: inset 0 0 40px rgba(255, 77, 77, 0.05);">

                <div class="d-flex flex-wrap">
                    <div style="width: 220px; margin-right: 24px;">
                        <label class="form-label-premium">Booking Date</label>
                        <input type="text" id="bookingDate" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" placeholder="Select Date">
                    </div>
                    <div style="width: 220px;">
                        <label class="form-label-premium">Select Slots</label>
                        <select id="duration" class="form-control">
                            <option value="2">1 Slot</option>
                            <option value="4">2 Slots</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="p-5">
                <div class="session-group mb-5">
                    <h5 class="session-label">&#9728; Morning Session</h5>
                    <div id="morning-slots" class="slots-grid"></div>
                </div>
            </div>

            <div class="wizard-actions px-5 pb-5 d-flex justify-content-between align-items-center">
                <a href="@Url.Action("CustomerLogin", "Account")" class="btn-premium-outline text-decoration-none">BACK</a>
                <div class="d-flex align-items-center">
                    <div id="slot-hint" class="me-3 fw-bold" style="color: var(--primary); display:none; font-size: 0.9rem;"></div>
                    <button class="btn-premium" onclick="proceedToConfigure()">NEXT</button>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .booking-wizard-container {
        max-width: 1200px;
        margin: 40px auto;
    }
    .form-label-premium {
        font-size: 0.75rem;
        color: var(--text-dim);
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        margin-bottom: 10px;
        display: block;
    }
    .session-label {
        font-size: 0.75rem;
        color: var(--primary);
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        gap: 15px;
    }
    .session-label::after {
        content: '';
        flex: 1;
        height: 1px;
        background: rgba(255, 77, 77, 0.1);
    }
    .slots-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 15px;
    }
    .slot-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--card-border);
        border-radius: 16px;
        padding: 20px;
        text-align: center;
        cursor: pointer;
        transition: var(--transition-smooth);
    }
    .slot-card:hover {
        border-color: var(--primary);
        background: rgba(255, 77, 77, 0.05);
        transform: translateY(-3px);
    }
    .slot-card.selected {
        background: var(--primary);
        border-color: var(--primary);
        color: #000;
        box-shadow: 0 10px 20px var(--primary-glow);
    }
    .slot-number { display: block; font-size: 0.65rem; font-weight: 800; opacity: 0.6; margin-bottom: 5px; text-transform: uppercase; }
    .slot-time { display: block; font-size: 1.1rem; font-weight: 800; }
    
    .btn-premium-outline {
        padding: 1rem 2rem;
        border: 1px solid var(--card-border);
        background: transparent;
        color: var(--text-dim);
        border-radius: 16px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: var(--transition-smooth);
    }
    .btn-premium-outline:hover {
        border-color: var(--primary);
        color: var(--primary);
    }

    /* Dropdown visibility fix */
    select.form-control option {
        background-color: #1a1f26 !important;
        color: #fff !important;
        padding: 10px !important;
    }
</style>


<script>
    let bookingData = {
        name: "",
        email: "",
        phone: "",
        date: "@DateTime.Today.ToString("yyyy-MM-dd")",
        duration: 2,
        selectedSlotIds: [],
        slotId: null,
        allAvailableSlots: []
    };

    document.addEventListener("DOMContentLoaded", () => {
        const fp = flatpickr("#bookingDate", {
            dateFormat: "Y-m-d",
            minDate: "today",
            disableMobile: "true",
            static: true,
            disable: [
                function(date) {
                    // Disable weekends (0 is Sunday, 6 is Saturday)
                    return (date.getDay() === 0 || date.getDay() === 6);
                }
            ],
            onChange: function(selectedDates, dateStr) {
                bookingData.date = dateStr;
                bookingData.selectedSlotIds = [];
                loadSlots();
            }
        });

        loadSlots();

        document.getElementById("duration").addEventListener("change", (e) => {
            bookingData.duration = parseInt(e.target.value);
            bookingData.selectedSlotIds = [];
            document.querySelectorAll(".slot-card").forEach(c => c.classList.remove("selected"));
            document.getElementById("slot-hint").style.display = "none";
        });
    });

    async function loadSlots() {
        const morningGrid = document.getElementById("morning-slots");
        if (!morningGrid) return;
        
        morningGrid.innerHTML = "<div class='text-dim small'>Loading...</div>";
        
        try {
            const response = await fetch(`/Booking/GetAvailableSlotsAjax?date=${bookingData.date}`);
            const slots = await response.json();
            
            morningGrid.innerHTML = "";
            bookingData.allAvailableSlots = slots;

            slots.forEach(slot => {
                if (slot.isNight) return; // Guests cannot book night sessions
                const card = document.createElement("div");
                card.className = "slot-card";
                card.id = `slot-${slot.slotId}`;
                card.onclick = () => selectSlot(slot);
                card.innerHTML = `
                    <span class="slot-number">${slot.label}</span>
                    <span class="slot-time">${slot.slotStartTime} - ${slot.slotEndTime}</span>
                `;
                morningGrid.appendChild(card);
            });

            if (morningGrid.innerHTML === "") morningGrid.innerHTML = "<p class='text-dim small'>No morning slots available</p>";
        } catch (err) {
            console.error(err);
        }
    }

    function selectSlot(slot) {
        const maxSlots = bookingData.duration / 2;
        const index = bookingData.selectedSlotIds.indexOf(slot.slotId);

        if (index > -1) {
            bookingData.selectedSlotIds.splice(index, 1);
        } else {
            if (bookingData.selectedSlotIds.length >= maxSlots) {
                if (maxSlots === 1) {
                    bookingData.selectedSlotIds = [];
                } else {
                    alert(`Please select only ${maxSlots} slot(s) (${bookingData.duration} hours).`);
                    return;
                }
            }
            bookingData.selectedSlotIds.push(slot.slotId);
        }

        document.querySelectorAll(".slot-card").forEach(c => c.classList.remove("selected"));
        bookingData.selectedSlotIds.forEach(id => {
            const el = document.getElementById(`slot-${id}`);
            if (el) el.classList.add("selected");
        });

        const hint = document.getElementById("slot-hint");
        const picks = bookingData.selectedSlotIds.length;
        if (picks < maxSlots) {
            if (hint) {
                hint.style.display = "block";
                hint.innerText = `Select ${maxSlots} slot(s) (${maxSlots - picks} left)`;
            }
        } else {
            if (hint) {
                hint.style.display = "block";
                hint.innerText = "All slots selected.";
            }
            bookingData.selectedSlotIds.sort((a,b)=>a-b);
            bookingData.slotId = bookingData.selectedSlotIds[0];
        }
    }

    function proceedToConfigure() {
        bookingData.name = "Guest User";
        bookingData.email = "guest@archery.com";
        bookingData.phone = "0000000000";

        const maxSlots = bookingData.duration / 2;
        if (bookingData.selectedSlotIds.length < maxSlots) {
            alert("Please select your time slots first.");
            return;
        }
        
        const url = `/Booking/SelectTarget?slotId=${bookingData.slotId}&name=${encodeURIComponent(bookingData.name)}&email=${encodeURIComponent(bookingData.email)}&phone=${encodeURIComponent(bookingData.phone)}&date=${bookingData.date}&duration=${bookingData.duration}`;
        window.location.href = url;
    }
</script>
