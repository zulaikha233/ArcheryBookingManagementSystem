@{
    ViewData["Title"] = "Select Your Lane";
    Layout = "_Layout";
    var slotId       = ViewBag.SlotId;
    var name         = ViewBag.Name;
    var email        = ViewBag.Email;
    var phone        = ViewBag.Phone;
    var date         = ViewBag.Date;
    var duration     = ViewBag.Duration;
    var targetSize   = ViewBag.TargetSize;
    var targetAmount = ViewBag.TargetAmount;
    var isGuest      = true;
    var enableLaneSelection = ViewBag.EnableLaneSelection ?? false;
    var studentId    = ViewBag.StudentId;
    var sessionType  = ViewBag.SessionType;
}

<div class="booking-wizard-container py-5">
    <div data-aos="fade-down">
        <partial name="~/Views/Home/BookingProgress.cshtml" model="3" />
    </div>

    <div class="premium-card" data-aos="fade-up">
        <h3 class="fw-bold mb-4" style="color: var(--primary);">Select Your Lane</h3>

        <!-- Pax Counter -->
        <div class="premium-card mb-4 p-4" style="background: rgba(255,255,255,0.02);">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-4">
                <div>
                    <label class="form-label-premium mb-1">Number of Archers</label>
                    <p class="mb-0 text-dim small" id="laneRequiredHint">
                        <i class="bi bi-info-square me-1"></i> Minimum 1 lane recommended per 4 archers.
                    </p>
                </div>
                <div class="counter-input-container">
                    <button class="counter-btn" type="button" onclick="updatePax(-1)"><i class="bi bi-dash"></i></button>
                    <div class="counter-input" id="paxDisplay" style="width: 60px;">1</div>
                    <button class="counter-btn" type="button" onclick="updatePax(1)"><i class="bi bi-plus"></i></button>
                    <input type="hidden" id="numberOfPax" value="1">
                </div>
            </div>
        </div>

        <!-- Auto Assign Allocation Display -->
        <div id="autoAssignContainer" class="premium-card p-4 mb-4 text-center" style="display: none; background: rgba(255,255,255,0.01); border: 1px dashed var(--card-border);">
            <div class="display-6 mb-3" style="color: var(--primary);"><i class="bi bi-cpu"></i></div>
            <h5 class="fw-bold mb-2">Automatic Lane Allocation</h5>
            <p class="text-dim mb-0" id="autoAssignText" style="font-size: 0.95rem;">
                Based on your archer count, lanes will be dynamically allocated for your session.
            </p>
        </div>

        <div id="target-hint" class="mb-4 fw-bold text-center text-dim" style="font-size: 0.9rem;">Select your preferred lane(s) on the grid.</div>
        <div id="targetsGrid" class="targets-grid"></div>

        <div class="wizard-actions d-flex justify-content-between mt-5">
            <button type="button" class="btn-premium-outline" onclick="history.back()">BACK</button>
            <button class="btn-premium" type="button" onclick="goToPayment()">CONFIRM BOOKING</button>
        </div>
    </div>
</div>

<style>
    .booking-wizard-container { max-width: 1100px; margin: 40px auto; }

    .fw-900 { font-weight: 900; }

    .targets-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; margin-top: 20px; }

    .target-box {
        aspect-ratio: 1;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--card-border);
        border-radius: 16px;
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        cursor: pointer;
        transition: var(--transition-smooth);
    }
    .target-box:hover:not(.disabled) { border-color: var(--primary); transform: scale(1.05); }
    .target-box.selected  { background: var(--primary); color: #000; border: none; font-weight: 900; box-shadow: 0 10px 20px var(--primary-glow); }
    .target-box.disabled  { opacity: 0.4; cursor: not-allowed; filter: grayscale(1); background: rgba(255,255,255,0.01); border-color: rgba(255,255,255,0.05); }
    .target-box.restricted { opacity: 0.5; cursor: not-allowed; border-style: dashed; border-color: rgba(255,255,255,0.2); }

    .counter-btn {
        width: 40px; height: 40px;
        border-radius: 50%;
        border: 1px solid var(--card-border);
        background: rgba(255, 255, 255, 0.05);
        color: #fff;
        display: flex; align-items: center; justify-content: center;
        transition: var(--transition-smooth);
    }
    .counter-btn:hover { background: var(--primary); color: #000; border-color: var(--primary); }

    .counter-input-container {
        display: flex; align-items: center; gap: 15px;
        background: rgba(255, 255, 255, 0.03);
        padding: 10px 20px;
        border-radius: 100px;
        border: 1px solid var(--card-border);
    }

    .form-label-premium {
        font-size: 0.75rem; color: var(--text-dim);
        font-weight: 700; letter-spacing: 1.5px;
        text-transform: uppercase; display: block;
    }
</style>

<script>
    const bookingData = {
        slotId:             "@slotId",
        name:               "@name",
        email:              "@email",
        phone:              "@phone",
        date:               "@date",
        duration:           "@duration",
        targetSize:         "@targetSize",
        targetAmount:       parseInt("@targetAmount") || 1,
        isGuest:            true,
        enableLaneSelection: "@enableLaneSelection".toLowerCase() === "true",
        pax:                1,
        selectedTargetIds:  [],
        laneRanges:         {},
        studentId:          "@studentId",
        sessionType:        "@sessionType"
    };

    let cachedOpenLanes = [];

    // Load lane grid on page load
    document.addEventListener("DOMContentLoaded", loadLaneGrid);

    async function loadLaneGrid() {
        const grid = document.getElementById("targetsGrid");
        grid.innerHTML = "<div class='text-center w-100 py-4'><div class='spinner-border text-success'></div><p class='mt-2'>Loading available lanes...</p></div>";

        try {
            const resp = await fetch(`/Booking/GetAvailableTargetsAjax?slotId=${bookingData.slotId}&date=${bookingData.date}&duration=${bookingData.duration}`);
            const availableTargets = await resp.json();

            cachedOpenLanes = availableTargets.filter(t => t.status === 'Available').map(t => t.targetNumber);

            if (!bookingData.enableLaneSelection) {
                // Hide manual selection UI elements
                grid.style.display = "none";
                document.getElementById("target-hint").style.display = "none";

                // Show auto assign summary box
                document.getElementById("autoAssignContainer").style.display = "block";

                // Calculate required lanes count
                const requiredLanes = Math.ceil(bookingData.pax / 4);
                bookingData.selectedTargetIds = cachedOpenLanes.slice(0, requiredLanes);
                if (bookingData.selectedTargetIds.length === 0) {
                    bookingData.selectedTargetIds = [1]; // Fallback to Lane 1
                }

                // Update UI text
                document.getElementById("autoAssignText").innerHTML = `Based on <strong>${bookingData.pax} archers</strong>, <strong>${requiredLanes} lane${requiredLanes > 1 ? 's' : ''}</strong> will be automatically allocated for your session.`;
                
                const hint = document.getElementById("laneRequiredHint");
                hint.innerHTML = `<i class="bi bi-info-square me-1"></i> ${requiredLanes} Lane${requiredLanes > 1 ? 's' : ''} Auto-Assigned`;
                hint.style.color = "var(--text-dim)";
            } else {
                // Show manual selection UI elements
                grid.style.display = "grid";
                document.getElementById("target-hint").style.display = "block";
                document.getElementById("autoAssignContainer").style.display = "none";

                grid.innerHTML = "";

                for (let item of availableTargets) {
                    const i            = item.targetNumber;
                    const status       = item.status;
                    const isTaken      = (status === 'Taken');
                    const isMaint      = (status === 'Maintenance');

                    const box       = document.createElement("div");
                    box.className   = `target-box ${isTaken || isMaint ? 'disabled' : ''}`;
                    const statusText = isMaint ? 'MAINTENANCE' : (isTaken ? 'Taken' : 'Open');

                    box.innerHTML = `
                        <span style="font-size: 1.2rem; font-weight: 800;">${i}</span>
                        <small style="font-size:0.5rem; text-transform: uppercase; opacity: 0.9; font-weight:800; letter-spacing: -0.2px;">${statusText}</small>
                    `;

                    if (!isTaken && !isMaint) {
                        box.onclick = () => selectTarget(i);
                    } else if (isMaint) {
                        box.style.background = "#ff6b6b";
                        box.style.color = "white";
                        box.title = "This lane is currently under maintenance.";
                    }
                    grid.appendChild(box);
                }
            }
        } catch (e) {
            grid.innerHTML = "<div class='text-center w-100 p-4 text-danger'>Error loading lanes. Please try again.</div>";
        }
    }

    function selectTarget(num) {
        if (!bookingData.enableLaneSelection) return;
        const idx = bookingData.selectedTargetIds.indexOf(num);
        if (idx > -1) {
            bookingData.selectedTargetIds.splice(idx, 1);
        } else {
            bookingData.selectedTargetIds.push(num);
        }
        document.querySelectorAll(".target-box").forEach(b => b.classList.remove("selected"));
        bookingData.selectedTargetIds.forEach(id => {
            const el = document.querySelectorAll(".target-box")[id - 1];
            if (el) el.classList.add("selected");
        });
    }

    function updatePax(change) {
        let val = parseInt(document.getElementById("numberOfPax").value);
        val += change;
        if (val < 1)  val = 1;
        if (val > 80) val = 80;
        document.getElementById("numberOfPax").value  = val;
        document.getElementById("paxDisplay").innerText = val;
        bookingData.pax = val;

        const requiredLanes = Math.ceil(val / 4);

        if (!bookingData.enableLaneSelection) {
            // Auto allocate lanes based on pax counter
            bookingData.selectedTargetIds = cachedOpenLanes.slice(0, requiredLanes);
            if (bookingData.selectedTargetIds.length === 0) {
                bookingData.selectedTargetIds = [1];
            }

            document.getElementById("autoAssignText").innerHTML = `Based on <strong>${val} archers</strong>, <strong>${requiredLanes} lane${requiredLanes > 1 ? 's' : ''}</strong> will be automatically allocated for your session.`;

            const hint = document.getElementById("laneRequiredHint");
            hint.innerHTML = `<i class="bi bi-info-square me-1"></i> ${requiredLanes} Lane${requiredLanes > 1 ? 's' : ''} Auto-Assigned`;
            hint.style.color = "var(--text-dim)";
        } else {
            const hint = document.getElementById("laneRequiredHint");
            hint.innerHTML = `<i class="bi bi-info-square me-1"></i> Min ${requiredLanes} Lane${requiredLanes > 1 ? 's' : ''} Required`;
            hint.style.color = (bookingData.selectedTargetIds.length < requiredLanes && bookingData.selectedTargetIds.length > 0)
                ? "#dc3545" : "var(--text-dim)";
        }
    }

    function goToPayment() {
        bookingData.pax = parseInt(document.getElementById("numberOfPax").value);

        if (bookingData.selectedTargetIds.length === 0) { alert("Select a lane."); return; }

        const maxCapacity = bookingData.selectedTargetIds.length * 4;
        if (bookingData.pax > maxCapacity) {
            alert(`You have ${bookingData.pax} archers but selected lanes can only hold ${maxCapacity}. Please select more lanes.`);
            return;
        }

        let calculatedPrice = 0;
        const dur = parseInt(bookingData.duration);
        const paxCount = parseInt(bookingData.pax);
        
        // 1 slot (2 hours) = RM 20. Price is based on duration, not per pax.
        calculatedPrice = (dur / 2) * 20;

        const form   = document.createElement("form");
        form.method  = "POST";
        form.action  = "/Booking/PaymentGuest";

        const fields = {
            SlotId:            bookingData.slotId,
            CustomerName:      bookingData.name,
            CustomerEmail:     bookingData.email,
            PhoneNumber:       bookingData.phone,
            Date:              bookingData.date,
            Duration:          bookingData.duration,
            TotalPrice:        calculatedPrice,
            SelectedLanes:     bookingData.selectedTargetIds.join(", "),
            TargetSize:        bookingData.targetSize,
            TargetAmount:      bookingData.targetAmount,
            NumberOfPax:       bookingData.pax,
            StudentId:         bookingData.studentId
        };

        for (let k in fields) {
            const input = document.createElement("input");
            input.type  = "hidden";
            input.name  = k;
            input.value = fields[k];
            form.appendChild(input);
        }
        document.body.appendChild(form);
        form.submit();
    }
</script>
