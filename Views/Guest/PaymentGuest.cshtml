@model ArcheryAlley.Models.PaymentViewModel

@{
    ViewData["Title"] = "PAYMENT";
    Layout = "_Layout";
}

<div class="booking-wizard-container py-5" data-aos="fade-up">
    <div class="premium-card static-card p-0 overflow-hidden">
                <div class="row g-0">
                    <!-- Left Column: Summary -->
                    <div class="col-lg-5 p-5" style="background: rgba(255, 77, 77, 0.03); border-right: 1px solid var(--card-border);">
                        <div class="mb-4 text-center">
                             <div class="mb-3">
                                 <i class="bi bi-receipt" style="font-size: 3rem; color: var(--primary);"></i>
                             </div>
                             <h2 class="hero-title" style="font-size: 1.8rem;">BOOKING <span>SUMMARY</span></h2>
                        </div>

                        <div class="summary-list">
                            <div class="summary-item">
                                <span class="label">Service</span>
                                <span class="value">@(ViewBag.ServiceName ?? "Archery Game Session")</span>
                            </div>
                            <div class="summary-item">
                                <span class="label">Date</span>
                                <span class="value">@Model.Date</span>
                            </div>
                            <div class="summary-item">
                                <span class="label">Time</span>
                                <span class="value">@Model.Time</span>
                            </div>
                            <div class="summary-item">
                                <span class="label">Lanes</span>
                                <span class="value">
                                    @if (ViewBag.EnableLaneSelection == true)
                                    {
                                        @Model.SelectedLanes
                                    }
                                    else
                                    {
                                        var totalLanes = Model.SelectedLanes?.Split(new[] { ',' }, StringSplitOptions.RemoveEmptyEntries).Length ?? 1;
                                        @($"{totalLanes} Lane{(totalLanes > 1 ? "s" : "")}")
                                    }
                                </span>
                            </div>
                            <div class="summary-item">
                                <span class="label">Pax</span>
                                <span class="value">@Model.NumberOfPax Archers</span>
                            </div>
                        </div>

                        <div class="total-box mt-5 text-center">
                            <p class="text-dim mb-1" style="font-size: 0.7rem; letter-spacing: 2px;">TOTAL AMOUNT</p>
                            <h1 style="color: var(--primary); font-weight: 900; font-size: 3rem;">RM @Model.TotalPrice.ToString("0.00")</h1>
                        </div>
                    </div>

                    <!-- Right Column: Payment Options -->
                    <div class="col-lg-7 p-5">
                        <h4 class="mb-4 text-dim fw-bold" style="font-size: 0.8rem; letter-spacing: 2px;">SELECT PAYMENT METHOD</h4>
                        
                        <div class="payment-methods mb-4">
                            <label class="payment-radio mb-3">
                                <input type="radio" name="paymentMethod" value="fpx" checked onchange="togglePaymentUI()"> FPX Online Banking
                            </label>

                            <!-- Payment Detail Boxes -->
                            <div id="fpxUI" class="payment-ui-box p-4 mb-4" style="display: block;">
                                <select id="bankSelection" class="form-select mb-3" style="border-radius: 50px; font-size: 0.8rem; padding: 4px 16px; height: 36px; cursor: pointer;">
                                    <option value="">Select Retail Bank</option>
                                    <option value="Maybank2U">Maybank2U</option>
                                    <option value="CIMB Clicks">CIMB Clicks</option>
                                    <option value="Public Bank">Public Bank</option>
                                    <option value="RHB Now">RHB Now</option>
                                    <option value="Bank Islam">Bank Islam</option>
                                    <option value="AmBank">AmBank</option>
                                </select>
                                <p class="text-dim small mb-0"><i class="bi bi-shield-lock me-1"></i> Redirecting to secure bank portal.</p>
                            </div>

                            <label class="payment-radio mb-3">
                                <input type="radio" name="paymentMethod" value="card" onchange="togglePaymentUI()"> Credit / Debit Card
                            </label>

                            <div id="cardUI" class="payment-ui-box p-4 mb-4" style="display: none;">
                                <label class="form-label-premium mb-2">Card Details</label>
                                <input type="text" class="form-control mb-3" placeholder="Card Number (0000 0000 0000 0000)" style="padding: 4px 12px; height: 36px; font-size: 0.85rem;">
                                <div class="row g-3">
                                    <div class="col-6">
                                        <input type="text" class="form-control" placeholder="MM/YY" style="padding: 4px 12px; height: 36px; font-size: 0.85rem;">
                                    </div>
                                    <div class="col-6">
                                        <input type="text" class="form-control" placeholder="CVV" style="padding: 4px 12px; height: 36px; font-size: 0.85rem;">
                                    </div>
                                </div>
                            </div>
                            
                            <label class="payment-radio mb-3">
                                <input type="radio" name="paymentMethod" value="counter" onchange="togglePaymentUI()"> At Counter (Cash/QR)
                            </label>
                        </div>



                        <!-- Customer Details -->
                        <div class="payment-detail-box p-4 mb-4">
                            <h5 class="fw-bold mb-3" style="font-size: 0.9rem;">Customer Details <span class="text-dim fw-normal">(Optional)</span></h5>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label-premium">Customer Name</label>
                                    <input type="text" id="guestName" class="form-control" placeholder="Full Name" style="padding: 4px 12px; height: 36px; font-size: 0.85rem;">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label-premium">Contact Number</label>
                                    <input type="text" id="guestPhone" class="form-control" placeholder="Phone Number" style="padding: 4px 12px; height: 36px; font-size: 0.85rem;">
                                </div>
                            </div>
                        </div>

                        <div class="price-breakdown mb-4">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-dim">Original Price</span>
                                <span class="fw-bold">RM @Model.TotalPrice.ToString("0.00")</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-dim">Taxes & Fees</span>
                                <span class="fw-bold" style="color: #22c55e;">INCLUDED</span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center pt-3 border-top" style="border-color: rgba(255,255,255,0.1) !important;">
                            <span class="fw-bold text-uppercase" style="letter-spacing: 1px;">Total Due</span>
                            <h2 class="m-0" style="color: var(--primary); font-weight: 800;">RM @Model.TotalPrice.ToString("0.00")</h2>
                        </div>

                        <div class="d-flex gap-3 mt-4">
                            <button class="btn-premium-outline w-50 justify-content-center text-center" onclick="cancelBooking()">
                                CANCEL
                            </button>
                            <button class="btn-premium w-50 justify-content-center text-center" id="confirmBtn" onclick="generateKioskCode()">
                                CONFIRM & PAY
                            </button>
                        </div>
                    </div>
                </div>
    </div>
</div>

<!-- Kiosk Success Modal -->
<div id="kioskModal" class="global-notif-overlay" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.9); backdrop-filter: blur(15px); display: none; align-items: center; justify-content: center; z-index: 2000; padding: 20px;">
    <div class="premium-card static-card text-center" style="max-width: 500px; padding: 40px; height: auto; border-color: var(--primary);">
        <div class="mb-4">
            <i class="bi bi-check-circle-fill" style="font-size: 3.5rem; color: var(--primary);"></i>
        </div>
        <h2 class="fw-900 mb-2" style="font-size: 1.8rem;">BOOKING CONFIRMED!</h2>
        <p class="text-dim mb-4" style="font-size: 0.9rem;">Please show this code at the counter for payment and entry.</p>
        
        <div id="displayCode" style="font-size: 3.5rem; font-weight: 900; color: var(--primary); letter-spacing: 8px; border: 2px dashed var(--card-border); padding: 25px; border-radius: 20px; background: rgba(255, 77, 77, 0.05);">------</div>
        
        <button class="btn-premium w-100 justify-content-center mt-4" onclick="window.location.href='/'">
            DONE <i class="bi bi-house-door ms-2"></i>
        </button>
    </div>
</div>

<style>
    .premium-card.static-card:hover {
        transform: none !important;
        border-color: var(--card-border) !important;
        box-shadow: none !important;
    }
    .premium-card.static-card:hover::before {
        opacity: 0 !important;
    }

    .booking-wizard-container {
        max-width: 1100px;
        margin: 0 auto;
    }
    .summary-item {
        display: flex;
        justify-content: space-between;
        padding: 15px 0;
        border-bottom: 1px solid var(--card-border);
    }
    .summary-item .label { color: var(--text-dim); font-size: 0.8rem; text-transform: uppercase; font-weight: 600; }
    .summary-item .value { color: #fff; font-weight: 700; }

    .payment-radio { display: flex; align-items: center; gap: 12px; color: #fff; font-weight: 600; cursor: pointer; }
    .payment-radio input { accent-color: var(--primary); width: 18px; height: 18px; }
    
    .payment-ui-box {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--card-border);
        border-radius: 16px;
        animation: fadeInDown 0.3s ease;
    }

    .form-label-premium {
        font-size: 0.7rem;
        color: var(--text-dim);
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        display: block;
    }

    @@keyframes fadeInDown {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    const originalShowNotif = window.showNotif;
    window.showNotif = function(message, type = 'info') {
        const overlay = document.getElementById('globalNotifOverlay');
        if (overlay && typeof originalShowNotif === 'function') {
            originalShowNotif(message, type);
        } else {
            alert(message);
        }
    };

    function togglePaymentUI() {
        const method = document.querySelector('input[name="paymentMethod"]:checked').value;
        document.getElementById("fpxUI").style.display = (method === "fpx") ? "block" : "none";
        document.getElementById("cardUI").style.display = (method === "card") ? "block" : "none";
    }

    function cancelBooking() {
        Swal.fire({
            title: 'Cancel Booking?',
            text: "Are you sure you want to cancel the booking?",
            icon: 'warning',
            background: '#0f172a',
            color: '#ffffff',
            showCancelButton: true,
            confirmButtonColor: '#ff4d4d',
            cancelButtonColor: '#3b82f6',
            confirmButtonText: 'Yes, cancel it!',
            cancelButtonText: 'No, proceed'
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '/Booking/GuestBooking';
            }
        });
    }

    async function generateKioskCode() {
        const btn = document.getElementById("confirmBtn");
        const method = document.querySelector('input[name="paymentMethod"]:checked').value;

        if (method === 'fpx') {
            const bank = document.getElementById('bankSelection').value;
            if (!bank) {
                showNotif("Please select a bank to proceed with FPX payment.", 'warning');
                return;
            }
        }

        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> PROCESSING...';

        const nameInput = document.getElementById("guestName").value.trim() || "Guest User";
        const phoneInput = document.getElementById("guestPhone").value.trim() || "0000000000";

        const formData = new FormData();
        formData.append("SlotId", "@Model.SlotId");
        formData.append("CustomerName", nameInput);
        formData.append("PhoneNumber", phoneInput);
        formData.append("CustomerEmail", "@Model.CustomerEmail");
        const firstLane = "@Model.SelectedLanes".split(',')[0].trim();
        formData.append("TargetNo", firstLane);
        formData.append("RangeNo", "1");
        formData.append("Duration", "@Model.Duration");
        formData.append("TotalPrice", "@Model.TotalPrice");
        formData.append("SelectedLanes", "@Model.SelectedLanes");
        formData.append("SelectedLaneRanges", "@Model.SelectedLaneRanges");
        formData.append("NumberOfPax", "@Model.NumberOfPax");
        formData.append("RateCode", ""); 
        formData.append("PaymentMethod", method);
        formData.append("Date", "@Model.Date");

        try {
            const response = await fetch('/Booking/CreateCustomerBooking', {
                method: 'POST',
                body: formData
            });
            const result = await response.json();

            if (result.success) {
                document.getElementById("displayCode").innerText = result.bookingCode;
                document.getElementById("kioskModal").style.display = "flex";
            } else {
                showNotif("Error: " + result.message, 'error');
                btn.disabled = false;
                btn.innerHTML = 'CONFIRM & PAY <i class="bi bi-shield-check ms-2"></i>';
            }
        } catch (err) {
            showNotif("Connection error. Please try again.", 'error');
            btn.disabled = false;
            btn.innerHTML = 'CONFIRM & PAY <i class="bi bi-shield-check ms-2"></i>';
        }
    }
</script>
