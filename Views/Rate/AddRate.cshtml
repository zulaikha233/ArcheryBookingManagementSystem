@{
    ViewBag.Title = "Add New Rate";
}

<div class="container py-5" data-aos="fade-up" style="max-width: 640px">

    <!-- Back link -->
    <a asp-action="ManageRates" class="text-decoration-none d-inline-flex align-items-center gap-2 mb-4"
       style="color: var(--text-dim); font-size: 0.85rem; font-weight: 600; letter-spacing: 0.5px; transition: var(--transition-smooth);"
       onmouseover="this.style.color='var(--primary)'" onmouseout="this.style.color='var(--text-dim)'">
        <i class="bi bi-arrow-left"></i> BACK TO MANAGE RATES
    </a>

    <!-- Header -->
    <div class="mb-4">
        <span id="headerCodeBadge" style="font-family: 'Courier New', monospace; font-size: 0.75rem; font-weight: 800;
                     letter-spacing: 2px; color: var(--primary); background: rgba(163, 230, 53, 0.05);
                     padding: 4px 14px; border-radius: 6px; border: 1px solid var(--primary)">
            NEW RATE
        </span>
        <h1 class="hero-title mt-3" style="font-size: 2rem; margin: 0">
            ADD <span style="color: var(--primary)">NEW RATE</span>
        </h1>
        <p class="text-dim mt-2">Create a new custom pricing rate for archery bookings.</p>
    </div>

    <!-- Form Card -->
    <div class="premium-card">
        <form method="post" asp-action="AddRate" id="addRateForm">

            <!-- Rate Code -->
            <div class="mb-4">
                <label for="rateCodeInput" class="form-label-premium">
                    RATE CODE
                </label>
                <div class="position-relative">
                    <input type="text" id="rateCodeInput" name="RateCode"
                           maxlength="20" required
                           placeholder="e.g. DJOF23X"
                           class="form-control ps-5"
                           style="font-family: 'Courier New', monospace; font-size: 1rem; font-weight: 700; letter-spacing: 2px;"
                           oninput="this.value = this.value.toUpperCase().replace(/[^A-Z0-9\-]/g,''); document.getElementById('headerCodeBadge').textContent = this.value || 'NEW RATE'" />
                    <i class="bi bi-hash position-absolute start-0 top-50 translate-middle-y ms-3" style="color: var(--primary); font-size: 1.2rem"></i>
                </div>
                <div class="text-dim mt-2" style="font-size: 0.78rem;">
                    Letters, numbers and hyphens only. Max 20 characters.
                </div>
            </div>

            <!-- Rate Name -->
            <div class="mb-4">
                <label for="rateNameInput" class="form-label-premium">
                    RATE NAME
                </label>
                <div class="position-relative">
                    <input type="text" id="rateNameInput" name="RateName"
                           maxlength="100" required
                           placeholder="e.g. Raya Promo"
                           class="form-control ps-5" />
                    <i class="bi bi-tag position-absolute start-0 top-50 translate-middle-y ms-3" style="color: var(--primary); font-size: 1.2rem"></i>
                </div>
            </div>

            <!-- Category + Session Row -->
            <div class="row g-3 mb-4">
                <div class="col-6">
                    <label class="form-label-premium">CATEGORY</label>
                    <select id="catSelect" name="RateCategory" required onchange="onCatChanged()" class="form-control">
                        <option value="1">Normal</option>
                        <option value="2">Discount</option>
                        <option value="3">Special</option>
                        <option value="4">FOC</option>
                    </select>
                </div>
                <div class="col-6">
                    <label class="form-label-premium">SESSION</label>
                    <select id="sesSelect" name="SessionType" required class="form-control">
                        <option value="1">Siang</option>
                        <option value="2">Malam</option>
                        <option value="0">All Sessions</option>
                    </select>
                </div>
            </div>

            <!-- Base Price -->
            <div class="mb-4" id="priceSection">
                <label for="basePrice" class="form-label-premium">
                    BASE PRICE (RM)
                </label>
                <div class="input-group">
                    <span class="input-group-text" style="background: transparent; border: 1px solid var(--card-border); border-right: none; border-radius: 16px 0 0 16px; color: var(--primary); font-weight: 700;">RM</span>
                    <input type="number" id="basePrice" name="BasePrice"
                           value="10.00" step="0.50" min="0" required
                           oninput="updatePreview()"
                           class="form-control" style="border-left: none; border-radius: 0 16px 16px 0;" />
                </div>
                <div class="text-dim mt-2" style="font-size: 0.78rem;">
                    Default: Siang = RM 10.00 &nbsp;|&nbsp; Malam = RM 12.00
                </div>
            </div>

            <!-- Discount Percentage -->
            <div class="mb-4" id="discountSection">
                <label for="discountPct" class="form-label-premium">
                    DISCOUNT (%)
                </label>
                <div class="d-flex align-items-center gap-3">
                    <input type="range" id="discountSlider" min="0" max="100" step="1" value="0"
                           oninput="syncDiscount(this.value)"
                           style="flex: 1; accent-color: var(--secondary); height: 6px; cursor: pointer" />
                    <div class="input-group" style="width: 110px;">
                        <input type="number" id="discountPct" name="DiscountPercentage"
                               value="0" min="0" max="100" step="1"
                               oninput="syncSlider(this.value)"
                               class="form-control text-center" style="color: var(--secondary); font-weight: 700;" />
                        <span class="input-group-text" style="background: transparent; border: 1px solid var(--card-border); border-left: none; border-radius: 0 16px 16px 0; color: var(--secondary); font-weight: 700;">%</span>
                    </div>
                </div>
            </div>

            <!-- Promo Date Range (Special only) -->
            <div class="mb-4" id="promoDateSection" style="display:none">
                <label class="form-label-premium" style="color: var(--secondary)">
                    <i class="bi bi-calendar-event me-1"></i> PROMO VALIDITY PERIOD
                </label>
                <div style="background: rgba(251, 191, 36, 0.05); border: 1px solid rgba(251, 191, 36, 0.2); border-radius: 16px; padding: 20px;">
                    <div class="row g-3">
                        <div class="col-6">
                            <label class="form-label-premium" style="font-size: 0.65rem;">VALID FROM</label>
                            <input type="date" id="validFrom" name="ValidFrom" class="form-control" />
                        </div>
                        <div class="col-6">
                            <label class="form-label-premium" style="font-size: 0.65rem;">VALID TO</label>
                            <input type="date" id="validTo" name="ValidTo" class="form-control" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- FOC notice -->
            <div id="focNotice" style="display:none" class="mb-4 p-4 text-center"
                 style="background: rgba(163, 230, 53, 0.05); border-radius: 16px; border: 1px dashed var(--primary)">
                <div style="font-size: 2.5rem; font-weight: 900; color: var(--primary)">FREE</div>
                <p class="text-dim mt-2">FOC rate is always RM 0.00. No price configuration needed.</p>
            </div>

            <!-- Live Preview -->
            <div class="mb-5 p-4" id="previewBox" style="background: rgba(255, 255, 255, 0.03); border-radius: 16px; border: 1px dashed var(--card-border)">
                <div class="text-dim mb-2" style="font-size: 0.7rem; font-weight: 700; letter-spacing: 1px;">PRICE PREVIEW</div>
                <div id="pricePreview" style="font-size: 2rem; font-weight: 900; color: var(--primary)">RM 10.00</div>
                <div id="discountNote" class="text-dim" style="font-size: 0.85rem; margin-top: 5px"></div>
            </div>

            <!-- Action Buttons -->
            <div class="d-flex gap-3">
                <button type="submit" class="btn-premium flex-grow-1 justify-content-center">
                    <i class="bi bi-plus-circle me-2"></i> CREATE RATE
                </button>
                <a asp-action="ManageRates" class="btn-premium-outline">
                    CANCEL
                </a>
            </div>
        </form>
    </div>
</div>

<style>
    .form-label-premium {
        font-size: 0.75rem;
        color: var(--text-dim);
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        margin-bottom: 8px;
        display: block;
    }
    .btn-premium-outline {
        padding: 1rem 2rem;
        border: 1px solid var(--card-border);
        background: transparent;
        color: var(--text-dim);
        border-radius: 16px;
        text-decoration: none;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: var(--transition-smooth);
        display: inline-flex;
        align-items: center;
    }
    .btn-premium-outline:hover {
        border-color: var(--primary);
        color: var(--primary);
    }
    select.form-control option {
        background: #0f172a;
        color: #fff;
    }
</style>

@section Scripts {
    <script>
        function onCatChanged() {
            const cat    = document.getElementById('catSelect').value;
            const isFoc  = cat === '4';
            const isSpec = cat === '3';

            document.getElementById('priceSection').style.display    = isFoc ? 'none' : 'block';
            document.getElementById('discountSection').style.display  = isFoc ? 'none' : 'block';
            document.getElementById('focNotice').style.display        = isFoc ? 'block' : 'none';
            document.getElementById('previewBox').style.display       = isFoc ? 'none' : 'block';
            document.getElementById('promoDateSection').style.display = isSpec ? 'block' : 'none';

            // Update preview color
            const catColors = { '1': 'var(--primary)', '2': 'var(--secondary)', '3': '#a29bfe', '4': 'var(--primary)' };
            document.getElementById('pricePreview').style.color = catColors[cat] || 'var(--primary)';

            updatePreview();
        }

        function syncDiscount(val) {
            document.getElementById('discountPct').value = val;
            updatePreview();
        }
        function syncSlider(val) {
            document.getElementById('discountSlider').value = val;
            updatePreview();
        }

        function updatePreview() {
            const cat     = document.getElementById('catSelect').value;
            const base    = parseFloat(document.getElementById('basePrice')?.value || 0);
            const disc    = parseFloat(document.getElementById('discountPct')?.value || 0);
            const preview = document.getElementById('pricePreview');
            const note    = document.getElementById('discountNote');

            if (cat === '4') { if (preview) preview.textContent = 'FREE'; return; }

            const final = disc > 0 ? base * (1 - disc / 100) : base;
            if (preview) preview.textContent = 'RM ' + final.toFixed(2);
            if (note)    note.textContent    = disc > 0 ? `${disc}% discount · RM ${base.toFixed(2)} → RM ${final.toFixed(2)}` : '';
        }

        // Init
        onCatChanged();
    </script>
}
