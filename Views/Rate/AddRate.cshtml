@{
    ViewBag.Title = "Add New Rate";
}

<div class="container animate-in" style="max-width: 640px">

    <!-- Back link -->
    <a asp-action="ManageRates" class="text-decoration-none d-inline-flex align-items-center gap-2 mb-4"
       style="color: #888; font-size: 0.85rem; font-weight: 600; letter-spacing: 0.5px; transition: color 0.2s"
       onmouseover="this.style.color='#8A9A5B'" onmouseout="this.style.color='#888'">
        <i class="bi bi-arrow-left"></i> BACK TO MANAGE RATES
    </a>

    <!-- Header -->
    <div class="mb-4">
        <span id="headerCodeBadge" style="font-family: 'Courier New', monospace; font-size: 0.75rem; font-weight: 800;
                     letter-spacing: 2px; color: #8A9A5B; background: rgba(255,255,255,0.04);
                     padding: 4px 14px; border-radius: 6px; border: 1px solid #8A9A5B">
            NEW RATE
        </span>
        <h1 class="hero-title mt-3" style="font-size: 2rem; margin: 0">
            ADD <span style="color: #8A9A5B">NEW RATE</span>
        </h1>
        <p style="color: #888; margin-top: 6px">Create a new custom pricing rate for archery bookings.</p>
    </div>

    <!-- Form Card -->
    <div class="premium-card">
        <form method="post" asp-action="AddRate" id="addRateForm">

            <!-- Rate Code -->
            <div class="mb-4">
                <label for="rateCodeInput" style="color: #b0b0b0; font-size: 0.8rem; font-weight: 700; letter-spacing: 1px; display: block; margin-bottom: 8px">
                    RATE CODE
                </label>
                <div style="position: relative">
                    <input type="text" id="rateCodeInput" name="RateCode"
                           maxlength="20" required
                           placeholder="e.g. DJOF23X"
                           oninput="this.value = this.value.toUpperCase().replace(/[^A-Z0-9\-]/g,''); document.getElementById('headerCodeBadge').textContent = this.value || 'NEW RATE'"
                           style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.15);
                                  color: #2b3a2a; border-radius: 12px; padding: 12px 16px 12px 48px;
                                  width: 100%; font-family: 'Courier New', monospace; font-size: 1rem;
                                  font-weight: 700; letter-spacing: 2px; outline: none; transition: border-color 0.2s"
                           onfocus="this.style.borderColor='#8A9A5B'"
                           onblur="this.style.borderColor='rgba(255,255,255,0.15)'" />
                    <i class="bi bi-hash" style="position: absolute; left: 16px; top: 50%; transform: translateY(-50%); color: #8A9A5B; font-size: 1rem"></i>
                </div>
                <div style="color: #555; font-size: 0.78rem; margin-top: 6px">
                    Letters, numbers and hyphens only. Max 20 characters.
                </div>
            </div>

            <!-- Rate Name -->
            <div class="mb-4">
                <label for="rateNameInput" style="color: #b0b0b0; font-size: 0.8rem; font-weight: 700; letter-spacing: 1px; display: block; margin-bottom: 8px">
                    RATE NAME
                </label>
                <div style="position: relative">
                    <input type="text" id="rateNameInput" name="RateName"
                           maxlength="100" required
                           placeholder="e.g. Raya Promo"
                           style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.15);
                                  color: #2b3a2a; border-radius: 12px; padding: 12px 16px 12px 48px;
                                  width: 100%; font-size: 1rem; outline: none; transition: border-color 0.2s"
                           onfocus="this.style.borderColor='#8A9A5B'"
                           onblur="this.style.borderColor='rgba(255,255,255,0.15)'" />
                    <i class="bi bi-tag" style="position: absolute; left: 16px; top: 50%; transform: translateY(-50%); color: #8A9A5B; font-size: 1rem"></i>
                </div>
            </div>

            <!-- Category + Session Row -->
            <div class="row g-3 mb-4">
                <div class="col-6">
                    <label style="color: #b0b0b0; font-size: 0.8rem; font-weight: 700; letter-spacing: 1px; display: block; margin-bottom: 8px">
                        CATEGORY
                    </label>
                    <select id="catSelect" name="RateCategory" required onchange="onCatChanged()"
                            style="background: #ECE7CA; border: 1px solid rgba(255,255,255,0.15); color: #2b3a2a;
                                   border-radius: 12px; padding: 12px 16px; width: 100%; outline: none; cursor: pointer">
                        <option value="1" style="background:#ECE7CA">Normal</option>
                        <option value="2" style="background:#ECE7CA">Discount</option>
                        <option value="3" style="background:#ECE7CA">Special</option>
                        <option value="4" style="background:#ECE7CA">FOC</option>
                    </select>
                </div>
                <div class="col-6">
                    <label style="color: #b0b0b0; font-size: 0.8rem; font-weight: 700; letter-spacing: 1px; display: block; margin-bottom: 8px">
                        SESSION
                    </label>
                    <select id="sesSelect" name="SessionType" required
                            style="background: #ECE7CA; border: 1px solid rgba(255,255,255,0.15); color: #2b3a2a;
                                   border-radius: 12px; padding: 12px 16px; width: 100%; outline: none; cursor: pointer">
                        <option value="1" style="background:#ECE7CA">Siang</option>
                        <option value="2" style="background:#ECE7CA">Malam</option>
                        <option value="0" style="background:#ECE7CA">All Sessions</option>
                    </select>
                </div>
            </div>

            <!-- Base Price -->
            <div class="mb-4" id="priceSection">
                <label for="basePrice" style="color: #b0b0b0; font-size: 0.8rem; font-weight: 700; letter-spacing: 1px; display: block; margin-bottom: 8px">
                    BASE PRICE (RM)
                </label>
                <div class="input-group" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.12); border-radius: 12px; overflow: hidden">
                    <span style="background: transparent; border: none; color: #8A9A5B; padding: 12px 16px; font-weight: 700; font-size: 1rem">RM</span>
                    <input type="number" id="basePrice" name="BasePrice"
                           value="10.00" step="0.50" min="0" required
                           oninput="updatePreview()"
                           style="background: transparent; border: none; color: #2b3a2a; font-size: 1rem; font-weight: 600; padding: 12px 16px; outline: none; width: 100%" />
                </div>
                <div style="color: #555; font-size: 0.78rem; margin-top: 6px">
                    Default: Siang = RM 10.00 &nbsp;|&nbsp; Malam = RM 12.00
                </div>
            </div>

            <!-- Discount Percentage (all categories except FOC) -->
            <div class="mb-4" id="discountSection">
                <label for="discountPct" style="color: #b0b0b0; font-size: 0.8rem; font-weight: 700; letter-spacing: 1px; display: block; margin-bottom: 8px">
                    DISCOUNT (%)
                </label>
                <div style="display: flex; align-items: center; gap: 16px">
                    <input type="range" id="discountSlider" min="0" max="100" step="1" value="0"
                           oninput="syncDiscount(this.value)"
                           style="flex: 1; accent-color: #f9c74f; height: 6px; cursor: pointer" />
                    <div class="input-group" style="width: 100px; background: rgba(255,255,255,0.04); border: 1px solid rgba(249,199,79,0.3); border-radius: 10px; overflow: hidden; flex-shrink: 0">
                        <input type="number" id="discountPct" name="DiscountPercentage"
                               value="0" min="0" max="100" step="1"
                               oninput="syncSlider(this.value)"
                               style="background: transparent; border: none; color: #f9c74f; font-size: 1rem; font-weight: 700; padding: 10px 8px; outline: none; width: 70%; text-align: right" />
                        <span style="background: transparent; border: none; color: #f9c74f; font-weight: 700; padding: 10px 8px">%</span>
                    </div>
                </div>
                <div style="color: #555; font-size: 0.78rem; margin-top: 6px">Set to 0 for no discount.</div>
            </div>

            <!-- Promo Date Range (Special only) -->
            <div class="mb-4" id="promoDateSection" style="display:none">
                <label style="color: #a29bfe; font-size: 0.8rem; font-weight: 700; letter-spacing: 1px; display: block; margin-bottom: 8px">
                    <i class="bi bi-calendar-event me-1"></i> PROMO VALIDITY PERIOD
                </label>
                <div style="background: rgba(162,155,254,0.05); border: 1px solid rgba(162,155,254,0.2); border-radius: 14px; padding: 16px;">
                    <div class="row g-3">
                        <div class="col-6">
                            <label style="color: #888; font-size: 0.75rem; letter-spacing: 1px; display: block; margin-bottom: 6px">VALID FROM</label>
                            <input type="date" id="validFrom" name="ValidFrom"
                                   style="background: rgba(255,255,255,0.04); border: 1px solid rgba(162,155,254,0.3);
                                          color: #2b3a2a; border-radius: 10px; padding: 10px 14px; width: 100%; outline: none;"
                                   onfocus="this.style.borderColor='#a29bfe'" onblur="this.style.borderColor='rgba(162,155,254,0.3)'" />
                        </div>
                        <div class="col-6">
                            <label style="color: #888; font-size: 0.75rem; letter-spacing: 1px; display: block; margin-bottom: 6px">VALID TO</label>
                            <input type="date" id="validTo" name="ValidTo"
                                   style="background: rgba(255,255,255,0.04); border: 1px solid rgba(162,155,254,0.3);
                                          color: #2b3a2a; border-radius: 10px; padding: 10px 14px; width: 100%; outline: none;"
                                   onfocus="this.style.borderColor='#a29bfe'" onblur="this.style.borderColor='rgba(162,155,254,0.3)'" />
                        </div>
                    </div>
                    <div style="color: #666; font-size: 0.75rem; margin-top: 10px">
                        <i class="bi bi-info-circle me-1"></i> Customer can enter the Rate Code as promo during this period only. Leave blank for no expiry.
                    </div>
                </div>
            </div>

            <!-- FOC notice -->
            <div id="focNotice" style="display:none" class="mb-4 p-4 text-center"
                 style="background: rgba(85,239,196,0.05); border-radius: 14px; border: 1px dashed rgba(85,239,196,0.2)">
                <div style="font-size: 2.5rem; font-weight: 900; color: #55efc4">FREE</div>
                <p style="color: #888; margin: 4px 0 0">FOC rate is always RM 0.00. No price configuration needed.</p>
            </div>

            <!-- Live Preview -->
            <div class="mb-5 p-4" id="previewBox" style="background: rgba(255,255,255,0.03); border-radius: 14px; border: 1px dashed rgba(255,255,255,0.12)">
                <div style="color: #666; font-size: 0.78rem; font-weight: 700; letter-spacing: 1px; margin-bottom: 8px">PRICE PREVIEW</div>
                <div id="pricePreview" style="font-size: 1.8rem; font-weight: 900; color: #8A9A5B">RM 10.00</div>
                <div id="discountNote" style="color: #888; font-size: 0.82rem; margin-top: 4px"></div>
            </div>

            <!-- Action Buttons -->
            <div class="d-flex gap-3">
                <button type="submit" class="btn-premium flex-grow-1"
                        style="height: 48px; font-size: 0.9rem; border-radius: 14px">
                    <i class="bi bi-plus-circle me-2"></i> CREATE RATE
                </button>
                <a asp-action="ManageRates"
                   style="height: 48px; padding: 0 24px; border-radius: 14px; border: 1px solid rgba(255,255,255,0.15);
                          background: transparent; color: #888; font-weight: 700; font-size: 0.9rem;
                          display: flex; align-items: center; text-decoration: none; transition: all 0.2s"
                   onmouseover="this.style.borderColor='#8A9A5B'; this.style.color='#8A9A5B'"
                   onmouseout="this.style.borderColor='rgba(255,255,255,0.15)'; this.style.color='#888'">
                    CANCEL
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function onCatChanged() {
            const cat    = document.getElementById('catSelect').value;
            const isFoc  = cat === '4';
            const isSpec = cat === '3';

            document.getElementById('priceSection').style.display    = isFoc ? 'none' : 'block';
            document.getElementById('discountSection').style.display  = isFoc ? 'none' : 'block';
            document.getElementById('focNotice').style.display        = isFoc ? 'block' : 'none';
            document.getElementById('previewBox').style.display       = isFoc ? 'none' : 'block';
            document.getElementById('promoDateSection').style.display = isSpec ? 'block' : 'none';

            // Update preview color
            const catColors = { '1': '#8A9A5B', '2': '#f9c74f', '3': '#a29bfe', '4': '#55efc4' };
            document.getElementById('pricePreview').style.color = catColors[cat] || '#8A9A5B';

            updatePreview();
        }

        function syncDiscount(val) {
            document.getElementById('discountPct').value = val;
            updatePreview();
        }
        function syncSlider(val) {
            document.getElementById('discountSlider').value = val;
            updatePreview();
        }

        function updatePreview() {
            const cat     = document.getElementById('catSelect').value;
            const base    = parseFloat(document.getElementById('basePrice')?.value || 0);
            const disc    = parseFloat(document.getElementById('discountPct')?.value || 0);
            const preview = document.getElementById('pricePreview');
            const note    = document.getElementById('discountNote');

            if (cat === '4') { if (preview) preview.textContent = 'FREE'; return; }

            const final = disc > 0 ? base * (1 - disc / 100) : base;
            if (preview) preview.textContent = 'RM ' + final.toFixed(2);
            if (note)    note.textContent    = disc > 0 ? `${disc}% discount · RM ${base.toFixed(2)} → RM ${final.toFixed(2)}` : '';
        }

        // Init
        onCatChanged();
    </script>
}
