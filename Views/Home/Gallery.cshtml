@*
@{
    ViewData["Title"] = "Gallery";
}

<div class="container py-5">
    <!-- Header -->
    <div class="text-center mb-5" data-aos="fade-down">
        <h1 class="hero-title" style="font-size: 3.5rem;">OUR <span style="color: var(--primary);">GALLERY</span></h1>
        <p class="hero-subtitle mx-auto">Moments of focus, precision, and community captured at Akma Archery.</p>
    </div>

    <!-- Gallery Grid -->
    <div class="row g-4">
        <!-- Item 1 -->
        <div class="col-md-4 col-sm-6" data-aos="zoom-in" data-aos-delay="100">
            <div class="gallery-item" style="position: relative; border-radius: 20px; overflow: hidden; height: 300px; border: 1px solid var(--card-border);">
                <img src="https://images.unsplash.com/photo-1544253139-44473336785e?q=80&w=2070&auto=format&fit=crop" alt="Archery Focus" style="width: 100%; height: 100%; object-fit: cover; transition: var(--transition-smooth);" class="gallery-img">
                <div class="gallery-overlay" style="position: absolute; inset: 0; background: rgba(249, 115, 22, 0.4); opacity: 0; transition: var(--transition-smooth); display: flex; align-items: center; justify-content: center;">
                    <i class="bi bi-search" style="font-size: 2rem; color: #000;"></i>
                </div>
            </div>
        </div>
        <!-- Item 2 -->
        <div class="col-md-4 col-sm-6" data-aos="zoom-in" data-aos-delay="200">
            <div class="gallery-item" style="position: relative; border-radius: 20px; overflow: hidden; height: 300px; border: 1px solid var(--card-border);">
                <img src="https://images.unsplash.com/photo-1593121925328-369ec8459c08?q=80&w=2070&auto=format&fit=crop" alt="Bullseye" style="width: 100%; height: 100%; object-fit: cover; transition: var(--transition-smooth);" class="gallery-img">
                <div class="gallery-overlay" style="position: absolute; inset: 0; background: rgba(249, 115, 22, 0.4); opacity: 0; transition: var(--transition-smooth); display: flex; align-items: center; justify-content: center;">
                    <i class="bi bi-search" style="font-size: 2rem; color: #000;"></i>
                </div>
            </div>
        </div>
        <!-- Item 3 -->
        <div class="col-md-4 col-sm-6" data-aos="zoom-in" data-aos-delay="300">
            <div class="gallery-item" style="position: relative; border-radius: 20px; overflow: hidden; height: 300px; border: 1px solid var(--card-border);">
