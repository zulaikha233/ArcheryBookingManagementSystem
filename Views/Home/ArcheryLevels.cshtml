@{
    ViewData["Title"] = "Archery Levels";
}

<div class="levels-container">
    <!-- Premium Hero Section -->
    <div class="levels-hero" data-aos="zoom-out">
        <div class="hero-bg"></div>
        <div class="hero-overlay"></div>
        <div class="container text-center position-relative" style="z-index: 10;">
            <div class="mb-4 animate-in">
                <i class="bi bi-trophy-fill" style="font-size: 5rem; color: var(--primary); filter: drop-shadow(0 0 20px var(--primary-glow));"></i>
            </div>
            <h1 class="hero-title animate-in" style="font-size: 4.5rem; letter-spacing: -2px;">ARCHERY <span style="color: var(--primary);">LEVELS</span></h1>
            <p class="hero-subtitle mx-auto animate-in" style="max-width: 700px;">Track your journey from a Rookie to a Master Archer. Our 6-tier progression system ensures you master every aspect of the sport.</p>
        </div>
    </div>

    <div class="container pb-5 mb-5" style="margin-top: -80px;">
        <div class="row g-5 justify-content-center">
            <!-- Level 1: Rookie -->
            <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="100">
                <div class="level-card-premium">
                    <div class="pennant-wrapper">
                        <div class="pennant" style="background-color: #26C6DA;">
                            <i class="bi bi-star"></i>
                            <span class="pennant-text">GRASS ROOT</span>
                        </div>
                    </div>
                    <div class="level-content text-center px-4 pb-4">
                        <p class="level-desc">Introduction to the world of archery. Focus on safety and basic range rules.</p>
                    </div>
                </div>
            </div>

            <!-- Level 2: Beginner -->
            <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="200">
                <div class="level-card-premium">
                    <div class="pennant-wrapper">
                        <div class="pennant" style="background-color: #66BB6A;">
                            <i class="bi bi-bullseye"></i>
                            <span class="pennant-text">BEGINNER (1)</span>
                        </div>
                    </div>
                    <div class="level-content text-center px-4 pb-4">
                        <p class="level-desc">Building the foundation of a consistent shot process and proper stance.</p>
                    </div>
                </div>
            </div>

            <!-- Level 3: Intermediate -->
            <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="300">
                <div class="level-card-premium">
                    <div class="pennant-wrapper">
                        <div class="pennant" style="background-color: #FFCA28;">
                            <i class="bi bi-lightning-fill"></i>
                            <span class="pennant-text">BEGINNER (2)</span>
                        </div>
                    </div>
                    <div class="level-content text-center px-4 pb-4">
                        <p class="level-desc">Refining technical form and increasing distance to 30 meters.</p>
                    </div>
                </div>
            </div>

            <!-- Level 4: Advanced -->
            <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="400">
                <div class="level-card-premium">
                    <div class="pennant-wrapper">
                        <div class="pennant" style="background-color: #FF7043;">
                            <i class="bi bi-fire"></i>
                            <span class="pennant-text">INTERMEDIATE (1)</span>
                        </div>
                    </div>
                    <div class="level-content text-center px-4 pb-4">
                        <p class="level-desc">Mastering equipment tuning and achieving high consistency at 50 meters.</p>
                    </div>
                </div>
            </div>

            <!-- Level 5: Elite -->
            <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="500">
                <div class="level-card-premium">
                    <div class="pennant-wrapper">
                        <div class="pennant" style="background-color: #EF5350;">
                            <i class="bi bi-shield-shaded"></i>
                            <span class="pennant-text">INTERMEDIATE (2)</span>
                        </div>
                    </div>
                    <div class="level-content text-center px-4 pb-4">
                        <p class="level-desc">Competition-ready training. Focus on mental game and extreme precision.</p>
                    </div>
                </div>
            </div>

            <!-- Level 6: Master -->
            <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="600">
                <div class="level-card-premium">
                    <div class="pennant-wrapper">
                        <div class="pennant" style="background-color: #AB47BC;">
                            <i class="bi bi-award-fill"></i>
                            <span class="pennant-text">EXPERTS</span>
                        </div>
                    </div>
                    <div class="level-content text-center px-4 pb-4">
                        <p class="level-desc">The pinnacle of archery. Perfect form, absolute focus, and podium potential.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .levels-container {
        background-color: #000;
        min-height: 100vh;
        overflow-y: auto;
        display: block;
        padding-bottom: 100px;
    }

    .levels-hero {
        position: relative;
        height: 60vh;
        min-height: 500px;
        display: flex;
        align-items: center;
        overflow: hidden;
        background: #000;
    }

    .hero-bg {
        position: absolute;
        inset: 0;
        background: url('/modern_archery_hero.png') center/cover;
        transform: scale(1.1);
        z-index: 1;
        opacity: 0.6;
    }

    .hero-overlay {
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at center, rgba(0,0,0,0.4) 0%, #000 90%);
        z-index: 2;
    }

    .level-card-premium {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 24px;
        position: relative;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        margin-top: 40px;
    }

    .level-card-premium:hover {
        transform: translateY(-10px);
        background: rgba(255, 255, 255, 0.07);
        border-color: rgba(255, 255, 255, 0.2);
        box-shadow: 0 20px 40px rgba(0,0,0,0.4);
    }

    .pennant-wrapper {
        position: absolute;
        top: -40px;
        left: 50%;
        transform: translateX(-50%);
        width: 120px;
        height: 140px;
        filter: drop-shadow(0 10px 15px rgba(0,0,0,0.3));
    }

    .pennant {
        position: relative;
        width: 100%;
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding-bottom: 20px;
        color: #fff;
    }

    /* The Pennant Shape */
    .pennant::after {
        content: "";
        position: absolute;
        bottom: 0;
        left: 0;
        width: 0;
        height: 0;
        border-left: 60px solid transparent;
        border-right: 60px solid transparent;
        border-bottom: 25px solid #000; /* Matches container background */
    }

    .pennant i {
        font-size: 2rem;
        margin-bottom: 5px;
    }

    .pennant-text {
        font-weight: 800;
        font-size: 0.85rem;
        letter-spacing: 1px;
    }

    .hero-title {
        font-weight: 900;
        text-transform: uppercase;
        margin-bottom: 1.5rem;
        color: #fff;
    }

    .hero-subtitle {
        color: rgba(255, 255, 255, 0.6);
        font-size: 1.2rem;
        font-weight: 300;
    }

    .level-content {
        padding-top: 110px; /* Increased gap from the badge */
        min-height: 200px;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .level-desc {
        color: rgba(255, 255, 255, 0.5);
        font-size: 1rem;
        line-height: 1.6;
        font-weight: 400;
        margin-bottom: 0;
        transition: var(--transition-smooth);
    }

    .level-card-premium:hover .level-desc {
        color: rgba(255, 255, 255, 1);
        transform: translateY(-5px);
    }
</style>
