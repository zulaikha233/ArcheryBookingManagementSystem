@{
    ViewData["Title"] = "About Us";
}

<div class="container py-5">
    <!-- Header Section -->
    <div class="text-center mb-5" data-aos="fade-down">
        <h1 class="hero-title" style="font-size: 3.5rem;">ABOUT <span style="color: var(--primary);">AKMA</span></h1>
        <p class="hero-subtitle mx-auto">Discover the legacy of precision and the passion for archery that drives us.</p>
    </div>

    <!-- Content Section -->
    <div class="row g-4 align-items-center">
        <div class="col-lg-6" data-aos="fade-right">
            <div class="premium-card">
                <h2 class="mb-4" style="color: var(--primary); font-weight: 800;">Our Vision</h2>
                <p style="color: var(--text-dim); line-height: 1.8;">
                    At Akma Archery, we believe that archery is more than just a sport—it's a discipline of the mind, body, and spirit. Founded by enthusiasts for enthusiasts, our mission is to provide a world-class environment where archers of all levels can hone their skills and find their focus.
                </p>
                <p style="color: var(--text-dim); line-height: 1.8;">
                    Whether you're a first-timer picking up a bow or a seasoned professional preparing for competition, we offer the facilities, equipment, and community to support your journey.
                </p>
                <div class="mt-4">
                    <div class="d-flex align-items-center mb-3">
                        <div style="width: 40px; height: 40px; background: rgba(249, 115, 22, 0.1); border-radius: 10px; display: flex; align-items: center; justify-content: center; margin-right: 15px;">
                            <i class="bi bi-check-lg" style="color: var(--primary);"></i>
                        </div>
                        <span>Professional Coaching</span>
                    </div>
                    <div class="d-flex align-items-center mb-3">
                        <div style="width: 40px; height: 40px; background: rgba(249, 115, 22, 0.1); border-radius: 10px; display: flex; align-items: center; justify-content: center; margin-right: 15px;">
                            <i class="bi bi-check-lg" style="color: var(--primary);"></i>
                        </div>
                        <span>Olympic-Standard Lanes</span>
                    </div>
                    <div class="d-flex align-items-center">
                        <div style="width: 40px; height: 40px; background: rgba(249, 115, 22, 0.1); border-radius: 10px; display: flex; align-items: center; justify-content: center; margin-right: 15px;">
                            <i class="bi bi-check-lg" style="color: var(--primary);"></i>
                        </div>
                        <span>Premium Gear Support</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-6" data-aos="fade-left">
            <div style="position: relative; border-radius: 24px; overflow: hidden; border: 1px solid var(--card-border); box-shadow: 0 20px 50px rgba(0,0,0,0.5);">
                <img src="https://images.unsplash.com/photo-1511306361225-d1955ecd3927?q=80&w=2070&auto=format&fit=crop" alt="Archery Range" style="width: 100%; height: 450px; object-fit: cover; opacity: 0.8;">
                <div style="position: absolute; inset: 0; background: linear-gradient(to top, var(--dark-bg), transparent);"></div>
                <div style="position: absolute; bottom: 30px; left: 30px;">
                    <h4 style="font-weight: 800; margin-bottom: 5px;">Modern Facilities</h4>
                    <p style="color: var(--text-dim); margin: 0; font-size: 0.9rem;">State-of-the-art range designed for excellence.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Stats Section -->
    <div class="row g-4 mt-5">
        <div class="col-md-4" data-aos="zoom-in" data-aos-delay="100">
            <div class="premium-card text-center">
                <h1 style="color: var(--primary); font-weight: 900; font-size: 3rem;">10+</h1>
                <p style="text-transform: uppercase; letter-spacing: 2px; font-size: 0.8rem; color: var(--text-dim);">Years Experience</p>
            </div>
        </div>
        <div class="col-md-4" data-aos="zoom-in" data-aos-delay="200">
            <div class="premium-card text-center">
                <h1 style="color: var(--primary); font-weight: 900; font-size: 3rem;">24</h1>
                <p style="text-transform: uppercase; letter-spacing: 2px; font-size: 0.8rem; color: var(--text-dim);">Active Lanes</p>
            </div>
        </div>
        <div class="col-md-4" data-aos="zoom-in" data-aos-delay="300">
            <div class="premium-card text-center">
                <h1 style="color: var(--primary); font-weight: 900; font-size: 3rem;">5k+</h1>
                <p style="text-transform: uppercase; letter-spacing: 2px; font-size: 0.8rem; color: var(--text-dim);">Happy Archers</p>
            </div>
        </div>
    </div>
</div>
