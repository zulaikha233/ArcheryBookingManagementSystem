@{
    ViewData["Title"] = "Archery Equipment - Akma Archery Club";
}

<div class="page-header" data-aos="fade-down">
    <div class="container">
        <h1 class="display-3 fw-900">PRO <span class="text-primary-glow">GEAR</span></h1>
        <p class="lead text-dim">The tools you need to hit the bullseye every time.</p>
    </div>
</div>

<div class="container py-5">
    <div class="row g-4">
        <!-- Recurve Bow -->
        <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="100">
            <div class="premium-card h-100">
                <div class="equipment-img-wrapper mb-4">
                    <img src="https://images.unsplash.com/photo-1620138546344-7b2c38516dee?q=80&w=2070&auto=format&fit=crop" alt="Recurve Bow" class="img-fluid rounded-4">
                </div>
                <h3 class="fw-800 text-primary mb-3">Recurve Bows</h3>
                <p class="text-dim">The traditional choice for Olympic competition. Featuring a sleek design that curves away from the archer, providing more power and speed.</p>
                <ul class="list-unstyled text-dim small">
                    <li><i class="bi bi-check2-circle text-primary me-2"></i> Lightweight Carbon Fiber</li>
                    <li><i class="bi bi-check2-circle text-primary me-2"></i> Adjustable Draw Weight</li>
                    <li><i class="bi bi-check2-circle text-primary me-2"></i> Perfect for Beginners</li>
                </ul>
            </div>
        </div>

        <!-- Compound Bow -->
        <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="200">
            <div class="premium-card h-100">
                <div class="equipment-img-wrapper mb-4">
                    <img src="https://images.unsplash.com/photo-1541535881105-02bc45097893?q=80&w=2070&auto=format&fit=crop" alt="Compound Bow" class="img-fluid rounded-4">
                </div>
                <h3 class="fw-800 text-secondary mb-3">Compound Bows</h3>
                <p class="text-dim">The pinnacle of archery technology. Uses a levering system of cables and pulleys to provide incredible accuracy and let-off.</p>
                <ul class="list-unstyled text-dim small">
                    <li><i class="bi bi-check2-circle text-secondary me-2"></i> High Velocity Shots</li>
                    <li><i class="bi bi-check2-circle text-secondary me-2"></i> Integrated Sight Systems</li>
                    <li><i class="bi bi-check2-circle text-secondary me-2"></i> Advanced Stabilization</li>
                </ul>
            </div>
        </div>

        <!-- Arrows & Accessories -->
        <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="300">
            <div class="premium-card h-100">
                <div class="equipment-img-wrapper mb-4">
                    <img src="https://images.unsplash.com/photo-1612043063863-8d93370b33ec?q=80&w=2071&auto=format&fit=crop" alt="Arrows" class="img-fluid rounded-4">
                </div>
                <h3 class="fw-800 text-primary mb-3">Precision Arrows</h3>
                <p class="text-dim">Premium carbon and aluminum arrows fletched for maximum stability and consistent flight paths in all conditions.</p>
                <ul class="list-unstyled text-dim small">
                    <li><i class="bi bi-check2-circle text-primary me-2"></i> Custom Fletching</li>
                    <li><i class="bi bi-check2-circle text-primary me-2"></i> Hardened Steel Tips</li>
                    <li><i class="bi bi-check2-circle text-primary me-2"></i> Vibration Dampening</li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Rental Info -->
    <div class="mt-5 pt-5" data-aos="zoom-in">
        <div class="premium-card text-center bg-primary-subtle border-primary">
            <h2 class="fw-800 mb-3">Don't Have Your Own Gear?</h2>
            <p class="text-dim mb-4 mx-auto" style="max-width: 700px;">
                No worries! We provide full rental kits for all ages and skill levels. Our kits include a bow, 6 arrows, an arm guard, and a finger tab.
            </p>
            <a href="@Url.Action("CustomerLogin", "Account")" class="btn-premium">
                BOOK WITH RENTAL <i class="bi bi-calendar-check ms-2"></i>
            </a>
        </div>
    </div>
</div>

<style>
    .page-header {
        padding: 120px 0 60px;
        background: linear-gradient(to bottom, rgba(249, 115, 22, 0.05), transparent);
        text-align: center;
    }

    .fw-900 { font-weight: 900; }
    .text-primary-glow {
        color: var(--primary);
        text-shadow: 0 0 20px var(--primary-glow);
    }

    .equipment-img-wrapper {
        overflow: hidden;
        border-radius: 20px;
        aspect-ratio: 16/10;
    }

    .equipment-img-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .premium-card:hover .equipment-img-wrapper img {
        transform: scale(1.1);
    }

    .bg-primary-subtle {
        background: rgba(249, 115, 22, 0.05) !important;
    }

    .border-primary {
        border-color: var(--primary) !important;
    }
</style>
