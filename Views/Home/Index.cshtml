@{
    ViewData["Title"] = "Archery Arena | Precision & Power";
}

@{
    ViewData["Title"] = "Archery Arena | Precision & Power";
}

<div class="home-hero-container">
    <div class="home-hero-bg"></div>
    <div class="home-hero-overlay"></div>
    
    <div class="container py-5 home-content">
        <div class="text-center mb-5" data-aos="zoom-out" data-aos-duration="1500">
            <h1 class="hero-title" style="font-size: 5.5rem;">ARCHERY <span>ARENA</span></h1>
            <p class="hero-subtitle mx-auto" style="font-size: 1.4rem; color: #fff; text-shadow: 0 2px 15px rgba(0,0,0,0.8);">Elevate your game at the city's most premium outdoor archery facility. Precision, Focus, and Power in every shot.</p>
        </div>

        <div class="row justify-content-center g-4 mt-2">
            <!-- Customer Card -->
            <div class="col-md-5" data-aos="fade-right" data-aos-delay="200">
                <div class="premium-card text-center" onclick="location.href='@Url.Action("CustomerLogin", "Account")'" style="cursor: pointer; background: rgba(6, 10, 15, 0.7); backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.1);">
                    <div class="mb-4">
                        <i class="bi bi-person-bounding-box" style="font-size: 3.5rem; color: var(--primary);"></i>
                    </div>
                    <h2 class="fw-bold mb-3">I'm a Customer</h2>
                    <p class="text-dim mb-4">Ready to hit the bullseye? Secure your lane in seconds and experience world-class archery.</p>
                    <div class="btn-premium w-100 justify-content-center">
                        BOOK A SESSION <i class="bi bi-arrow-right-short ms-2"></i>
                    </div>
                </div>
            </div>

            <!-- Staff Card -->
            <div class="col-md-5" data-aos="fade-left" data-aos-delay="400">
                <div class="premium-card text-center" onclick="location.href='@Url.Action("Login", "Account")'" style="cursor: pointer; background: rgba(6, 10, 15, 0.7); backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.1);">
                    <div class="mb-4">
                        <i class="bi bi-shield-check" style="font-size: 3.5rem; color: var(--secondary);"></i>
                    </div>
                    <h2 class="fw-bold mb-3">I'm a Staff</h2>
                    <p class="text-dim mb-4">Access the management portal to handle bookings, lanes, and administrative tasks.</p>
                    <div class="btn-premium w-100 justify-content-center" style="background: var(--secondary); color: #000; box-shadow: 0 10px 20px rgba(251, 191, 36, 0.2);">
                        STAFF PORTAL <i class="bi bi-lock ms-2"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Stats / Trust Section -->
        <div class="row mt-5 pt-5 text-center g-4" data-aos="fade-up" data-aos-offset="0">
            <div class="col-md-4">
                <div class="stat-card">
                    <h3 class="fw-800" style="color: var(--primary);">20+</h3>
                    <p class="text-dim">Premium Lanes</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card">
                    <h3 class="fw-800" style="color: var(--primary);">15k+</h3>
                    <p class="text-dim">Happy Archers</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card">
                    <h3 class="fw-800" style="color: var(--primary);">4.9/5</h3>
                    <p class="text-dim">User Rating</p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .home-hero-container {
        position: relative;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 100px 0;
        margin-top: -80px; /* Offset for navbar if needed */
    }

    .home-hero-bg {
        position: fixed;
        inset: 0;
        background: url('/modern_archery_hero.png') center/cover no-repeat;
        z-index: -2;
    }
    
    .home-hero-overlay {
        position: fixed;
        inset: 0;
        background: linear-gradient(to bottom, rgba(6, 10, 15, 0.3), rgba(6, 10, 15, 0.9));
        z-index: -1;
    }
    
    .home-content {
        position: relative;
        z-index: 10;
    }
    
    .fw-800 { font-weight: 800; font-size: 2.5rem; }
    
    .stat-card {
        background: rgba(6, 10, 15, 0.6);
        backdrop-filter: blur(10px);
        padding: 30px;
        border-radius: 24px;
        border: 1px solid rgba(255,255,255,0.08);
        transition: var(--transition-smooth);
    }

    .stat-card:hover {
        transform: translateY(-5px);
        background: rgba(6, 10, 15, 0.8);
        border-color: var(--primary);
    }
</style>






