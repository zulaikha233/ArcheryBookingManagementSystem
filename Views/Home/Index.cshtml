@{
    ViewData["Title"] = "Archery Arena | Precision & Power";
}

<div class="landing-container">
    <div class="glass-header animate-fade-in">
        <h1 class="brand-title">ARCHERY<span>ARENA</span></h1>
        <p class="brand-tagline">Master your focus. Release your potential.</p>
    </div>

    <div class="user-selection-grid">
        <!-- Customer Card -->
        <div class="user-card customer-card animate-slide-up" onclick="location.href='@Url.Action("CustomerLogin", "Account")'">
            
            <div class="card-content">
                <h2>I'm a Customer</h2>
                <p>Ready to hit the bullseye? Let's booking your lane now!</p>
                <div class="card-action">
                    <span>Book Now</span>
                    <i class="arrow-right"></i>
                </div>
            </div>
        </div>

        <!-- Staff Card -->
        <div class="user-card staff-card animate-slide-up" style="animation-delay: 0.1s;" onclick="location.href='@Url.Action("Login", "Account")'">
           
            <div class="card-content">
                <h2>I'm a Staff</h2>
                <p>Manage bookings and lanes efficiently.</p>
                <div class="card-action">
                    <span>Staff Portal</span>
                    <i class="arrow-right"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --primary: #8A9A5B;
        --secondary: #6D7B48;
        --dark-bg: #ECE7CA;
        --glass: #A9BA9D;
        --glass-border: rgba(255, 255, 255, 0.1);
    }

    body {
        background: linear-gradient(rgba(236, 231, 202, 0.3), rgba(236, 231, 202, 0.45)), url('/images/archery_hero.png') center/cover no-repeat fixed !important;
        color: #2b3a2a;
        overflow-x: hidden;
        font-family: 'Inter', sans-serif;
    }

    .landing-container {
        min-height: 80vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 2rem;
    }

    .glass-header {
        text-align: center;
        margin-bottom: 3rem;
        width: 100%;
    }

    .brand-title {
        font-size: 4rem;
        font-weight: 800;
        letter-spacing: -2px;
        margin-bottom: 0.5rem;
    }

    .brand-title span {
        background: linear-gradient(to right, var(--primary), var(--secondary));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .brand-tagline {
        font-size: 1.1rem;
        color: #888;
        letter-spacing: 2px;
        text-transform: uppercase;
    }


    .user-selection-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 2rem;
        width: 100%;
        max-width: 800px;
    }

    .user-card {
        background: var(--glass);
        backdrop-filter: blur(20px);
        border: 1px solid var(--glass-border);
        border-radius: 30px;
        padding: 3rem 2rem;
        cursor: pointer;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        position: relative;
        overflow: hidden;
    }

    .user-card:hover {
        transform: translateY(-10px);
        border-color: var(--primary);
        box-shadow: 0 20px 40px rgba(138, 154, 91, 0.2); 
        background: #9dad92; /* slightly darker/different green for hover */
    }

    .card-icon {
        font-size: 3.5rem;
        margin-bottom: 1.5rem;
    }

    .card-content h2 {
        font-size: 1.8rem;
        font-weight: 700;
        margin-bottom: 1rem;
        color: #2b3a2a;
    }

    .card-content p {
        color: #2b3a2a; 
        line-height: 1.6;
        margin-bottom: 2rem;
    }

    .card-action {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-weight: 600;
        color: var(--primary);
        text-transform: uppercase;
        font-size: 0.9rem;
        letter-spacing: 1px;
    }

    .animate-fade-in { animation: fadeIn 1s ease-out; }
    .animate-slide-up { animation: slideUp 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) both; }

    @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    @@keyframes slideUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
</style>



