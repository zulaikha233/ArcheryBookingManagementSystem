@{
    ViewData["Title"] = "Gear Support";
}

<div class="gear-container">
    <!-- Premium Hero Section -->
    <div class="gear-hero" data-aos="zoom-out">
        <div class="hero-bg"></div>
        <div class="hero-overlay"></div>
        <div class="container text-center position-relative" style="z-index: 10;">
            <div class="mb-4 animate-in">
                <i class="bi bi-gear-wide-connected" style="font-size: 5rem; color: var(--primary); filter: drop-shadow(0 0 20px var(--primary-glow));"></i>
            </div>
            <h1 class="hero-title animate-in" style="font-size: 4.5rem; letter-spacing: -2px;">GEAR <span style="color: var(--primary);">SUPPORT</span></h1>
            <p class="hero-subtitle mx-auto animate-in" style="max-width: 700px;">Explore our range of professional archery equipment and maintenance services available for all members.</p>
        </div>
    </div>

    <div class="container pb-5" style="margin-top: -100px;">

    <!-- Categories -->
    <div class="row g-4 mb-5">
        <div class="col-lg-4" data-aos="fade-up" data-aos-delay="100">
            <div class="premium-card">
                <div style="font-size: 2.5rem; color: var(--primary); margin-bottom: 1.5rem;">
                    <i class="bi bi-bullseye"></i>
                </div>
                <h3 style="font-weight: 800; margin-bottom: 1rem;">Bows</h3>
                <p style="color: var(--text-dim); font-size: 0.95rem;">From traditional longbows to modern compound bows, we provide options for every style.</p>
                <ul style="list-style: none; padding: 0; color: var(--text-dim);">
                    <li class="mb-2"><i class="bi bi-chevron-right text-primary me-2"></i> Recurve Bows</li>
                    <li class="mb-2"><i class="bi bi-chevron-right text-primary me-2"></i> Compound Bows</li>
                    <li><i class="bi bi-chevron-right text-primary me-2"></i> Barebow Options</li>
                </ul>
            </div>
        </div>
        <div class="col-lg-4" data-aos="fade-up" data-aos-delay="200">
            <div class="premium-card">
                <div style="font-size: 2.5rem; color: var(--primary); margin-bottom: 1.5rem;">
                    <i class="bi bi-arrow-up-right"></i>
                </div>
                <h3 style="font-weight: 800; margin-bottom: 1rem;">Arrows</h3>
                <p style="color: var(--text-dim); font-size: 0.95rem;">Precision-engineered arrows matched to your bow's draw weight and length.</p>
                <ul style="list-style: none; padding: 0; color: var(--text-dim);">
                    <li class="mb-2"><i class="bi bi-chevron-right text-primary me-2"></i> Carbon Fiber Arrows</li>
                    <li class="mb-2"><i class="bi bi-chevron-right text-primary me-2"></i> Aluminum Arrows</li>
                    <li><i class="bi bi-chevron-right text-primary me-2"></i> Custom Fletching</li>
                </ul>
            </div>
        </div>
        <div class="col-lg-4" data-aos="fade-up" data-aos-delay="300">
            <div class="premium-card">
                <div style="font-size: 2.5rem; color: var(--primary); margin-bottom: 1.5rem;">
                    <i class="bi bi-shield-check"></i>
                </div>
                <h3 style="font-weight: 800; margin-bottom: 1rem;">Protection</h3>
                <p style="color: var(--text-dim); font-size: 0.95rem;">Essential safety gear for a comfortable and secure archery experience.</p>
                <ul style="list-style: none; padding: 0; color: var(--text-dim);">
                    <li class="mb-2"><i class="bi bi-chevron-right text-primary me-2"></i> Arm Guards</li>
                    <li class="mb-2"><i class="bi bi-chevron-right text-primary me-2"></i> Finger Tabs & Gloves</li>
                    <li><i class="bi bi-chevron-right text-primary me-2"></i> Chest Guards</li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Maintenance Section -->
    <div class="premium-card" data-aos="zoom-in" style="background: linear-gradient(135deg, rgba(255, 77, 77, 0.1) 0%, rgba(15, 23, 42, 0.5) 100%);">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h2 style="font-weight: 800; margin-bottom: 1rem;">Equipment Maintenance</h2>
                <p style="color: var(--text-dim); margin-bottom: 0;">Our technicians provide professional bow tuning, string replacement, and arrow repair services. Keep your gear in top condition with Akma's expert support.</p>
            </div>
            <div class="col-md-4 text-md-end mt-4 mt-md-0">
                <a href="#" class="btn-premium">BOOK SERVICE</a>
            </div>
        </div>
    </div>
</div>

<style>
    .gear-container {
        background-color: #000;
        min-height: 100vh;
    }

    .gear-hero {
        position: relative;
        height: 60vh;
        min-height: 500px;
        display: flex;
        align-items: center;
        overflow: hidden;
        background: #000;
    }

    .hero-bg {
        position: absolute;
        inset: 0;
        background: url('/modern_archery_hero.png') center/cover;
        transform: scale(1.1);
        z-index: 1;
        opacity: 0.6;
    }

    .hero-overlay {
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at center, rgba(0,0,0,0.4) 0%, #000 90%);
        z-index: 2;
    }

    .hero-title {
        font-weight: 900;
        text-transform: uppercase;
        margin-bottom: 1.5rem;
        color: #fff;
    }

    .hero-subtitle {
        color: rgba(255, 255, 255, 0.6);
        font-size: 1.2rem;
        font-weight: 300;
    }
</style>
