@{
    ViewData["Title"] = "Gear Support";
}

<div class="gear-container">
    <!-- Premium Hero Section -->
    <div class="gear-hero" data-aos="zoom-out">
        <div class="hero-bg"></div>
        <div class="hero-overlay"></div>
        <div class="container text-center position-relative" style="z-index: 10;">
            <div class="mb-4 animate-in">
                <i class="bi bi-shield-shaded" style="font-size: 5rem; color: var(--primary); filter: drop-shadow(0 0 20px var(--primary-glow));"></i>
            </div>
            <h1 class="hero-title animate-in" style="font-size: 4.5rem; letter-spacing: -2px;">GEAR <span style="color: var(--primary);">GUIDE</span></h1>
            <p class="hero-subtitle mx-auto animate-in" style="max-width: 700px;">Know your equipment. From safety essentials to professional performance gear.</p>
        </div>
    </div>

    <div class="container pb-5" style="margin-top: -100px;">
        
        <!-- SECTION 1: SAFETY (TOP) -->
        <div class="row justify-content-center mb-5">
            <div class="col-lg-12 text-center mb-4" data-aos="fade-up">
                <h6 class="text-uppercase tracking-widest mb-2" style="color: var(--primary); font-weight: 700; letter-spacing: 4px;">Requirement</h6>
                <h2 class="fw-900" style="font-size: 2.5rem;">SAFETY FIRST</h2>
            </div>
            <div class="col-lg-6" data-aos="fade-up" data-aos-delay="100">
                <div class="gear-card premium-card">
                    <div class="gear-tag mandatory">MANDATORY</div>
                    <div class="gear-img-wrapper">
                        <img src="/images/shoes.png" alt="Closed Shoes" class="img-fluid">
                    </div>
                    <div class="gear-info text-center mt-4">
                        <h3 class="fw-800">CLOSED-TOE SHOES</h3>
                        <p class="text-dim">Proper footwear is strictly required on the shooting line for safety and stability.</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- SECTION 2: CORE EQUIPMENT (MANDATORY) -->
        <div class="row g-4 mb-5 pt-4">
            <div class="col-lg-12 text-center mb-4" data-aos="fade-up">
                <h6 class="text-uppercase tracking-widest mb-2" style="color: var(--primary); font-weight: 700; letter-spacing: 4px;">The Essentials</h6>
                <h2 class="fw-900" style="font-size: 2.5rem;">MAIN EQUIPMENT</h2>
            </div>
            
            <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="100">
                <div class="gear-card premium-card">
                    <div class="gear-tag mandatory">CORE GEAR</div>
                    <div class="gear-img-wrapper">
                        <img src="/images/bow.jpg" alt="Bow" class="img-fluid">
                    </div>
                    <div class="gear-info text-center mt-4">
                        <h3 class="fw-800">RECURVE BOW</h3>
                        <p class="text-dim">The soul of archery. Precision-crafted for consistency.</p>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="200">
                <div class="gear-card premium-card">
                    <div class="gear-tag mandatory">CORE GEAR</div>
                    <div class="gear-img-wrapper">
                        <img src="/images/bow%20stand.png" alt="Bow Stand" class="img-fluid">
                    </div>
                    <div class="gear-info text-center mt-4">
                        <h3 class="fw-800">BOW STAND</h3>
                        <p class="text-dim">Essential for keeping your bow safe and off the ground.</p>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="300">
                <div class="gear-card premium-card">
                    <div class="gear-tag mandatory">CORE GEAR</div>
                    <div class="gear-img-wrapper">
                        <img src="/images/target.png" alt="Target" class="img-fluid">
                    </div>
                    <div class="gear-info text-center mt-4">
                        <h3 class="fw-800">TARGET FACE</h3>
                        <p class="text-dim">Standard FITA competition target sheets for practice.</p>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="400">
                <div class="gear-card premium-card">
                    <div class="gear-tag mandatory">CORE GEAR</div>
                    <div class="gear-img-wrapper">
                        <img src="/images/arrow.png" alt="Arrows" class="img-fluid">
                    </div>
                    <div class="gear-info text-center mt-4">
                        <h3 class="fw-800">ARROWS</h3>
                        <p class="text-dim">Precision-engineered for flight stability and accuracy.</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- SECTION 3: ACCESSORIES -->
        <div class="row g-4 justify-content-center" style="row-gap: 60px;">
            <div class="col-lg-12 text-center mb-4 mt-5" data-aos="fade-up">
                <h6 class="text-uppercase tracking-widest mb-2" style="color: var(--primary); font-weight: 700; letter-spacing: 4px;">Enhancements</h6>
                <h2 class="fw-900" style="font-size: 2.5rem;">ACCESSORIES</h2>
            </div>

            <!-- Arm Guard -->
            <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="100">
                <div class="gear-card-small premium-card">
                    <div class="gear-img-wrapper-sm">
                        <img src="/images/arm%20guard.png" alt="Arm Guard">
                    </div>
                    <div class="gear-info-sm mt-3 text-center">
                        <h5 class="fw-800">ARM GUARD</h5>
                        <p class="text-dim small">Protects your forearm from string slap.</p>
                    </div>
                </div>
            </div>

            <!-- Chest Guard -->
            <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="200">
                <div class="gear-card-small premium-card">
                    <div class="gear-img-wrapper-sm">
                        <img src="/images/chest%20guard.jpg" alt="Chest Guard">
                    </div>
                    <div class="gear-info-sm mt-3 text-center">
                        <h5 class="fw-800">CHEST GUARD</h5>
                        <p class="text-dim small">Ensures smooth string clearance and protection.</p>
                    </div>
                </div>
            </div>

            <!-- Finger Tab -->
            <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="300">
                <div class="gear-card-small premium-card">
                    <div class="gear-img-wrapper-sm">
                        <img src="/images/finger%20tab.png" alt="Finger Tab">
                    </div>
                    <div class="gear-info-sm mt-3 text-center">
                        <h5 class="fw-800">FINGER TAB</h5>
                        <p class="text-dim small">Provides grip and protects fingers during release.</p>
                    </div>
                </div>
            </div>

            <!-- Quiver -->
            <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="400">
                <div class="gear-card-small premium-card">
                    <div class="gear-img-wrapper-sm">
                        <img src="/images/quiver.png" alt="Quiver">
                    </div>
                    <div class="gear-info-sm mt-3 text-center">
                        <h5 class="fw-800">QUIVER</h5>
                        <p class="text-dim small">Keep your arrows organized and ready.</p>
                    </div>
                </div>
            </div>

            <!-- Stabilizer -->
            <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="500">
                <div class="gear-card-small premium-card">
                    <div class="gear-img-wrapper-sm">
                        <img src="/images/stabilizer.png" alt="Stabilizer">
                    </div>
                    <div class="gear-info-sm mt-3 text-center">
                        <h5 class="fw-800">STABILIZER</h5>
                        <p class="text-dim small">Reduces vibration and improves bow balance.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .gear-container {
        background-color: #000;
        min-height: 100vh;
        overflow-y: auto;
        padding-bottom: 100px;
    }

    .gear-hero {
        position: relative;
        height: 60vh;
        min-height: 500px;
        display: flex;
        align-items: center;
        overflow: hidden;
        background: #000;
    }

    .hero-bg {
        position: absolute;
        inset: 0;
        background: url('/modern_archery_hero.png') center/cover;
        transform: scale(1.1);
        z-index: 1;
        opacity: 0.6;
    }

    .hero-overlay {
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at center, rgba(0,0,0,0.4) 0%, #000 90%);
        z-index: 2;
    }

    .fw-900 { font-weight: 900; }
    .fw-800 { font-weight: 800; }

    .gear-card {
        padding: 40px;
        transition: var(--transition-smooth);
        position: relative;
        border: 1px solid rgba(255, 77, 77, 0.4) !important; /* Static colored border */
        background: rgba(15, 23, 42, 0.8) !important; /* Solid static fill */
        backdrop-filter: blur(10px);
    }

    .gear-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.6);
    }

    .gear-tag {
        position: absolute;
        top: 20px;
        right: 20px;
        background: var(--primary);
        color: #000;
        padding: 4px 12px;
        border-radius: 8px;
        font-size: 0.7rem;
        font-weight: 900;
        letter-spacing: 1px;
    }

    .gear-img-wrapper {
        height: 250px; /* Adjusted for 4-column layout */
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        border-radius: 16px;
        background: rgba(255,255,255,0.02);
    }

    .gear-img-wrapper img {
        max-height: 100%;
        width: auto;
        transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .gear-card:hover .gear-img-wrapper img {
        transform: scale(1.1);
    }

    .gear-card-small {
        padding: 25px;
        height: 100%;
        border: 1px solid rgba(255, 77, 77, 0.3) !important; /* Static colored border */
        background: rgba(15, 23, 42, 0.6) !important; /* Static fill */
    }

    .gear-card-small:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 30px rgba(0, 0, 0, 0.5);
    }

    .gear-img-wrapper-sm {
        height: 200px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255,255,255,0.02);
        border-radius: 12px;
        overflow: hidden;
    }

    .gear-img-wrapper-sm img {
        max-height: 80%;
        width: auto;
        transition: var(--transition-smooth);
    }

    .gear-card-small:hover .gear-img-wrapper-sm img {
        transform: scale(1.1) rotate(5deg);
    }

    .hero-title {
        font-weight: 900;
        text-transform: uppercase;
        margin-bottom: 1.5rem;
        color: #fff;
    }

    .hero-subtitle {
        color: rgba(255, 255, 255, 0.6);
        font-size: 1.2rem;
        font-weight: 300;
    }

    .tracking-widest { letter-spacing: 0.2em; }
</style>
