@{
    ViewData["Title"] = "Contact Us | Get In Touch";
}

<div class="contact-container">
    <!-- Premium Hero Section -->
    <div class="contact-hero" data-aos="zoom-out">
        <div class="hero-bg"></div>
        <div class="hero-overlay"></div>
        <div class="container text-center position-relative" style="z-index: 10;">
            <div class="mb-4 animate-in">
                <i class="bi bi-geo-alt-fill" style="font-size: 5rem; color: var(--primary); filter: drop-shadow(0 0 20px var(--primary-glow));"></i>
            </div>
            <h1 class="hero-title animate-in" style="font-size: 4.5rem; letter-spacing: -2px;">GET IN <span style="color: var(--primary);">TOUCH</span></h1>
            <p class="hero-subtitle mx-auto animate-in" style="max-width: 700px;">Have questions or want to book a corporate event? We're here to help you hit your goals.</p>
        </div>
    </div>

    <div class="container pb-5" style="margin-top: -100px;">
        <div class="row gx-5">
            <!-- Location Card -->
            <div class="col-lg-6 mb-5" data-aos="fade-up" data-aos-delay="100">
                <div class="premium-card contact-card-horizontal d-flex align-items-center p-4">
                    <div class="contact-icon-wrapper" style="min-width: 60px; margin-right: 3rem;">
                        <i class="bi bi-map"></i>
                    </div>
                    <div class="text-start flex-grow-1">
                        <h4 class="fw-800 mb-2">OUR LOCATION</h4>
                        <p class="text-dim mb-0">Akma Archery Club,<br>Jalan 6b/11, Seksyen 16,<br>43650 Bandar Baru Bangi, <br>Selangor, Malaysia</p>
                    </div>
                    <a href="https://www.google.com/maps/search/?api=1&query=Akma+Archery+Club+Bangi" target="_blank" class="social-btn" style="width: 45px; height: 45px; font-size: 1.2rem;" title="Open in Google Maps">
                        <i class="bi bi-geo-alt"></i>
                    </a>
                </div>
            </div>

            <!-- Class Hours Card -->
            <div class="col-lg-6 mb-5" data-aos="fade-up" data-aos-delay="200">
                <div class="premium-card contact-card-horizontal d-flex align-items-center p-4">
                    <div class="contact-icon-wrapper" style="min-width: 60px; margin-right: 3rem;">
                        <i class="bi bi-clock"></i>
                    </div>
                    <div class="text-start flex-grow-1">
                        <h4 class="fw-800 mb-2">CLASS HOURS</h4>
                        <p class="text-dim mb-0">Tue - Sun: <span style="color: #fff;">8:15 AM - 4:30 PM</span></p>
                        <p class="text-dim mb-0" style="color: var(--primary) !important;"><small>Closed on Mon & Public Holidays</small></p>
                    </div>
                </div>
            </div>

            <!-- Phone Card -->
            <div class="col-lg-6 mb-5" data-aos="fade-up" data-aos-delay="300">
                <div class="premium-card contact-card-horizontal d-flex align-items-center p-4">
                    <div class="contact-icon-wrapper" style="min-width: 60px; margin-right: 3rem;">
                        <i class="bi bi-telephone-outbound"></i>
                    </div>
                    <div class="text-start flex-grow-1">
                        <h4 class="fw-800 mb-2">PHONE NUMBER</h4>
                        <p class="text-dim mb-0">Any Inquiries:</p>
                        <h4 class="mb-0" style="color: var(--primary); font-weight: 800;">+6016-4214136</h4>
                    </div>
                    <div class="d-flex gap-3">
                        <a href="https://wa.me/60164214136" class="social-btn" style="width: 45px; height: 45px;"><i class="bi bi-whatsapp"></i></a>
                    </div>
                </div>
            </div>

            <!-- Social Media Card -->
            <div class="col-lg-6 mb-5" data-aos="fade-up" data-aos-delay="400">
                <div class="premium-card contact-card-horizontal d-flex align-items-center p-4">
                    <div class="contact-icon-wrapper" style="min-width: 60px; margin-right: 3rem;">
                        <i class="bi bi-share"></i>
                    </div>
                    <div class="text-start flex-grow-1">
                        <h4 class="fw-800 mb-2">SOCIAL MEDIA</h4>
                        <p class="text-dim mb-0">Follow us: <span style="color: #fff;">@@akma_archery</span></p>
                    </div>
                    <div class="d-flex" style="gap: 0.5rem;">
                        <a href="https://www.facebook.com/kelabmemanahakma/?locale=ms_MY" class="social-btn" style="width: 45px; height: 45px;"><i class="bi bi-facebook"></i></a>
                        <a href="https://www.instagram.com/kelab_memanah_akma/?hl=en" class="social-btn" style="width: 45px; height: 45px;"><i class="bi bi-instagram"></i></a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .contact-container {
        background-color: #000;
        min-height: 100vh;
    }

    .contact-hero {
        position: relative;
        height: 60vh;
        display: flex;
        align-items: center;
        overflow: hidden;
    }

    .hero-bg {
        position: absolute;
        inset: 0;
        background: url('/modern_archery_hero.png') center/cover;
        transform: scale(1.1);
        z-index: 1;
    }

    .hero-overlay {
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at center, rgba(0,0,0,0.4) 0%, #000 90%);
        z-index: 2;
    }

    .fw-800 { font-weight: 800; }

    .contact-card-info {
        background: rgba(6, 10, 15, 0.85);
        backdrop-filter: blur(20px);
        padding: 40px !important;
        height: 100%;
        transition: var(--transition-smooth);
    }

    .contact-card-horizontal {
        background: rgba(6, 10, 15, 0.85);
        backdrop-filter: blur(20px);
        border: 1px solid var(--card-border);
        border-radius: 20px;
        transition: var(--transition-smooth);
        min-height: 140px;
    }

    .contact-card-horizontal:hover {
        transform: translateY(-5px);
        border-color: var(--primary);
        box-shadow: 0 10px 30px rgba(255, 77, 77, 0.1);
    }

    .contact-card-info:hover {
        transform: translateY(-10px);
        border-color: var(--primary);
    }

    .contact-icon-wrapper {
        width: 70px;
        height: 70px;
        background: rgba(255, 77, 77, 0.1);
        border: 1px solid rgba(255, 77, 77, 0.2);
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto;
        font-size: 2rem;
        color: var(--primary);
        box-shadow: 0 10px 20px rgba(255, 77, 77, 0.1);
    }

    .social-btn {
        width: 50px;
        height: 50px;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 1.2rem;
        transition: var(--transition-smooth);
        text-decoration: none;
    }

    .social-btn:hover {
        background: var(--primary);
        color: #000;
        transform: scale(1.1) rotate(10deg);
        box-shadow: 0 0 20px var(--primary-glow);
        border-color: var(--primary);
    }
</style>
