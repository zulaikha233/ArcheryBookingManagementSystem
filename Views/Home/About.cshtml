@{
    ViewData["Title"] = "About Us - Archery Arena";
}

<div class="page-header" data-aos="fade-down">
    <div class="container">
        <h1 class="display-3 fw-900">OUR <span class="text-primary-glow">STORY</span></h1>
        <p class="lead text-dim">Precision, Focus, and the Heritage of Archery.</p>
    </div>
</div>

<div class="container py-5">
    <div class="row g-5 align-items-center">
        <div class="col-lg-6" data-aos="fade-right">
            <div class="premium-card">
                <h2 class="fw-800 mb-4">The Akma Archery Club Legacy</h2>
                <p class="text-dim mb-4">
                    Founded in 2020, Akma Archery Club started with a simple vision: to create a world-class facility where precision meets passion. 
                    What began as a small practice range has evolved into the city's premier destination for both professional archers and enthusiasts.
                </p>
                <p class="text-dim mb-4">
                    Our facility features 20+ Olympic-standard lanes, climate-controlled environments, and a community of experts dedicated to the art of the bow.
                </p>
                <div class="d-flex gap-3">
                    <div class="stat-mini">
                        <span class="d-block fw-800 fs-4 text-primary">5+</span>
                        <span class="text-dim small">Years of Excellence</span>
                    </div>
                    <div class="stat-mini">
                        <span class="d-block fw-800 fs-4 text-primary">10k+</span>
                        <span class="text-dim small">Members</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-6" data-aos="fade-left">
            <div class="image-stack">
                <div class="image-stack-item main">
                    <img src="https://images.unsplash.com/photo-1511033036817-e6d0ad9b25b5?q=80&w=2070&auto=format&fit=crop" alt="Archery Range" class="img-fluid rounded-4 shadow-lg">
                </div>
                <div class="image-stack-item sub">
                    <img src="https://images.unsplash.com/photo-1580048215399-2461d624c62b?q=80&w=2070&auto=format&fit=crop" alt="Archer Focus" class="img-fluid rounded-4 shadow-lg">
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-5 pt-5 g-4">
        <div class="col-md-4" data-aos="zoom-in" data-aos-delay="100">
            <div class="premium-card text-center h-100">
                <i class="bi bi-clock-history mb-3 d-block text-primary fs-1"></i>
                <h3 class="fw-700">Operating Hours</h3>
                <ul class="list-unstyled text-dim mt-3">
                    <li>Mon - Fri: 10:00 AM - 10:00 PM</li>
                    <li>Sat - Sun: 08:00 AM - 11:00 PM</li>
                    <li class="text-primary mt-2 small">*Closed on Public Holidays</li>
                </ul>
            </div>
        </div>
        <div class="col-md-4" data-aos="zoom-in" data-aos-delay="200">
            <div class="premium-card text-center h-100">
                <i class="bi bi-geo-alt mb-3 d-block text-primary fs-1"></i>
                <h3 class="fw-700">Location</h3>
                <p class="text-dim mt-3">
                    123 Precision Way,<br>
                    Elite Sports District,<br>
                    Kuala Lumpur, 50450
                </p>
            </div>
        </div>
        <div class="col-md-4" data-aos="zoom-in" data-aos-delay="300">
            <div class="premium-card text-center h-100">
                <i class="bi bi-telephone mb-3 d-block text-primary fs-1"></i>
                <h3 class="fw-700">Contact</h3>
                <p class="text-dim mt-3">
                    Phone: +60 3-1234 5678<br>
                    Email: hello@archeryarena.com
                </p>
            </div>
        </div>
    </div>
</div>

<style>
    .page-header {
        padding: 120px 0 60px;
        background: linear-gradient(to bottom, rgba(249, 115, 22, 0.05), transparent);
        text-align: center;
    }

    .fw-900 { font-weight: 900; }
    .text-primary-glow {
        color: var(--primary);
        text-shadow: 0 0 20px var(--primary-glow);
    }

    .stat-mini {
        background: rgba(255, 255, 255, 0.05);
        padding: 15px 25px;
        border-radius: 16px;
        border: 1px solid var(--card-border);
    }

    .image-stack {
        position: relative;
        padding-bottom: 40px;
    }

    .image-stack-item.main {
        width: 90%;
        margin-left: 0;
    }

    .image-stack-item.sub {
        position: absolute;
        width: 60%;
        bottom: 0;
        right: 0;
        z-index: 2;
        border: 5px solid var(--dark-bg);
        border-radius: 20px;
    }

    .rounded-4 { border-radius: 24px !important; }
</style>
