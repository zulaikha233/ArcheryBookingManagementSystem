@{
    ViewData["Title"] = "Book Your Session";
}

<div class="booking-wizard-container animate-fade-in">
    <!-- Progress Header -->
    <partial name="~/Views/Home/_BookingProgress.cshtml" model="1" />

    <!-- Step 1: Customer Info & Session -->
    <div class="wizard-step active" id="wizard-step-1">
        <div class="glass-card main-booking-card p-0">
            <div class="wizard-grid-layout">
                <!-- Column 1 -->
                <div class="wizard-column">
                    <div class="p-4 mb-3 rounded-3" style="background: linear-gradient(to right, var(--active-blue), var(--deep-blue)); border: none; margin: 0rem 0rem 1rem 0rem; box-shadow: 0 5px 15px rgba(138, 154, 91, 0.2);">
                         <p class="mb-1" style="font-size: 0.75rem; color: rgba(0,0,0,0.6); letter-spacing: 1px; font-weight: bold;">Your Details</p>
                         <h5 class="mb-0 font-weight-bold" style="letter-spacing: 0.5px; color: black;">@(ViewBag.CustomerName ?? "Guest User")</h5>
                         <small style="color: rgba(0,0,0,0.8); font-weight: 500;">@(ViewBag.CustomerEmail ?? "guest@archery.com")</small>
                         <input type="hidden" id="customerName" value="@(ViewBag.CustomerName ?? "Guest")">
                         <input type="hidden" id="customerEmail" value="@(ViewBag.CustomerEmail ?? "guest@domain.com")">
                    </div>

                    <div class="session-group px-4 pb-4">
                        <h5 class="session-label">&#9728; Morning Session</h5>
                        <div id="morning-slots" class="slots-grid"></div>
                    </div>
                </div>

                <!-- Column 2 -->
                <div class="wizard-column">
                    <div class="form-group p-4 pb-0">
                        <label class="form-label-premium">Booking Date</label>
                        <input type="date" id="bookingDate" class="form-control-premium" value="@DateTime.Today.ToString("yyyy-MM-dd")">
                    </div>

                    <div class="form-group p-4 pt-0 pb-2">
                        <label class="form-label-premium">Duration</label>
                        <select id="duration" class="form-control-premium">
                            <option value="1">1 Hour</option>
                            <option value="2">2 Hours</option>
                            <option value="3">3 Hours</option>
                            <option value="4">4 Hours</option>
                        </select>
                    </div>

                    <div class="form-group p-4 py-0">
                        <label class="form-label-premium">Age Group</label>
                        <select id="ageGroup" class="form-control-premium">
                            <option value="Adult">Adult (18+)</option>
                            <option value="Junior">Junior (12-17)</option>
                            <option value="Child">Child (Under 12)</option>
                        </select>
                    </div>

                    <div class="session-group px-4 pb-4">
                        <h5 class="session-label">&#127769; Night Session</h5>
                        <div id="night-slots" class="slots-grid"></div>
                    </div>
                </div>
            </div>

            <div class="wizard-actions px-3 pb-3">
                <div id="slot-hint" class="text-center mb-3 fw-bold" style="color: var(--active-blue); display:none;"></div>
                <button class="btn-premium w-100" onclick="proceedToConfigure()">Next </button>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --active-blue: #8A9A5B;
        --deep-blue: #6D7B48;
        --glass: #A9BA9D;
        --glass-border: rgba(255, 255, 255, 0.08);
        --text-muted: #8e92a6;
    }

    body {
        background: #ECE7CA !important;
        font-family: 'Outfit', sans-serif;
        color: #2b3a2a;
    }

    .booking-wizard-container {
        max-width: 1300px;
        margin: 50px auto;
        padding: 0 20px;
    }

    .glass-card {
        background: var(--glass);
        backdrop-filter: blur(20px);
        border: 1px solid var(--glass-border);
        border-radius: 30px;
        padding: 3rem;
    }

    .form-label-premium {
        display: block;
        font-size: 0.85rem;
        color: #000000;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        margin-bottom: 10px;
        font-weight: 700;
    }

    .form-control-premium {
        background: #ffffff !important;
        border: 1px solid var(--glass-border) !important;
        color: #2b3a2a !important;
        border-radius: 12px !important;
        padding: 12px 20px !important;
        width: 100%;
        transition: 0.3s;
    }

    .wizard-grid-layout {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 40px;
        padding: 40px;
    }

    .wizard-column {
        display: flex;
        flex-direction: column;
        gap: 25px;
    }

    .session-label {
        font-size: 0.8rem;
        color: #000000;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 20px;
        font-weight: 700;
        padding-bottom: 15px;
        border-bottom: 2px solid;
        border-image: linear-gradient(to right, var(--active-blue), var(--deep-blue)) 1;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .slots-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

    .slot-card {
        background: #ddead1;
        border: 1px solid var(--glass-border);
        border-radius: 18px;
        padding: 22px;
        text-align: center;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .slot-card:hover { 
        border-color: var(--active-blue); 
        background: rgba(138, 154, 91, 0.1);
        transform: scale(1.02);
    }

    .slot-card.selected {
        background: linear-gradient(135deg, var(--active-blue), var(--deep-blue)) !important;
        color: black !important;
        border: none;
        box-shadow: 0 10px 25px rgba(138, 154, 91, 0.4);
    }

    .slot-number { 
        display: block; font-size: 0.8rem; text-transform: uppercase; font-weight: 800; opacity: 0.7; margin-bottom: 8px;
    }

    .slot-time { 
        display: block; font-size: 1.3rem; font-weight: 800; letter-spacing: 0.5px;
    }

    .btn-premium {
        background: linear-gradient(to right, var(--active-blue), var(--deep-blue));
        border: none;
        color: black;
        padding: 14px 30px;
        border-radius: 12px;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: 0.3s;
    }
</style>

<script>
    let bookingData = {
        name: "@(ViewBag.CustomerName ?? "Guest")",
        email: "@(ViewBag.CustomerEmail ?? "guest@archery.com")",
        date: "@DateTime.Today.ToString("yyyy-MM-dd")",
        duration: 1,
        selectedSlotIds: [],
        slotId: null,
        allAvailableSlots: []
    };

    document.addEventListener("DOMContentLoaded", () => {
        loadSlots();
        
        document.getElementById("bookingDate").addEventListener("change", (e) => {
            bookingData.date = e.target.value;
            bookingData.selectedSlotIds = [];
            loadSlots();
        });

        document.getElementById("duration").addEventListener("change", (e) => {
            bookingData.duration = parseInt(e.target.value);
            bookingData.selectedSlotIds = [];
            document.querySelectorAll(".slot-card").forEach(c => c.classList.remove("selected"));
            document.getElementById("slot-hint").style.display = "none";
        });
    });

    async function loadSlots() {
        const morningGrid = document.getElementById("morning-slots");
        const nightGrid = document.getElementById("night-slots");
        if (!morningGrid || !nightGrid) return;
        
        morningGrid.innerHTML = "<div class='text-muted small'>Loading...</div>";
        nightGrid.innerHTML = "<div class='text-muted small'>Loading...</div>";
        
        try {
            const response = await fetch(`/Booking/GetAvailableSlotsAjax?date=${bookingData.date}`);
            const slots = await response.json();
            
            morningGrid.innerHTML = "";
            nightGrid.innerHTML = "";
            bookingData.allAvailableSlots = slots;

            slots.forEach(slot => {
                const card = document.createElement("div");
                card.className = "slot-card";
                card.id = `slot-${slot.slotId}`;
                card.onclick = () => selectSlot(slot);
                card.innerHTML = `
                    <span class="slot-number">${slot.label}</span>
                    <span class="slot-time">${slot.slotStartTime} - ${slot.slotEndTime}</span>
                `;
                if (slot.isNight) nightGrid.appendChild(card);
                else morningGrid.appendChild(card);
            });

            if (morningGrid.innerHTML === "") morningGrid.innerHTML = "<p class='text-muted small'>No morning slots available</p>";
            if (nightGrid.innerHTML === "") nightGrid.innerHTML = "<p class='text-muted small'>No night slots available</p>";
        } catch (err) {
            console.error(err);
        }
    }

    function selectSlot(slot) {
        const duration = bookingData.duration;
        const index = bookingData.selectedSlotIds.indexOf(slot.slotId);

        if (index > -1) {
            bookingData.selectedSlotIds.splice(index, 1);
        } else {
            if (bookingData.selectedSlotIds.length >= duration) {
                alert(`Please select only ${duration} slot(s).`);
                return;
            }
            bookingData.selectedSlotIds.push(slot.slotId);
        }

        document.querySelectorAll(".slot-card").forEach(c => c.classList.remove("selected"));
        bookingData.selectedSlotIds.forEach(id => {
            const el = document.getElementById(`slot-${id}`);
            if (el) el.classList.add("selected");
        });

        const hint = document.getElementById("slot-hint");
        const picks = bookingData.selectedSlotIds.length;
        if (picks < duration) {
            hint.style.display = "block";
            hint.innerText = `Please select ${duration} slots. (${duration - picks} remaining)`;
        } else {
            hint.style.display = "block";
            hint.innerText = "Required slots selected. Click Next.";
            bookingData.slotId = bookingData.selectedSlotIds.sort((a,b)=>a-b)[0];
        }
    }

    function proceedToConfigure() {
        if (bookingData.selectedSlotIds.length < bookingData.duration) {
            alert("Please select your time slots first.");
            return;
        }
        
        const ageGroup = document.getElementById("ageGroup").value;
        const url = `/Booking/SelectionLane?slotId=${bookingData.slotId}&name=${encodeURIComponent(bookingData.name)}&email=${encodeURIComponent(bookingData.email)}&date=${bookingData.date}&duration=${bookingData.duration}&ageGroup=${ageGroup}`;
        window.location.href = url;
    }
</script>
