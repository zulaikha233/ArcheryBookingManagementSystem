@{
    ViewData["Title"] = "Book Your Session";
}

<div class="booking-wizard-container animate-fade-in" data-aos="fade-up">
    <!-- Progress Header -->
    <partial name="~/Views/Home/_BookingProgress.cshtml" model="1" />

    <!-- Step 1: Customer Info & Session -->
    <div class="wizard-step active" id="wizard-step-1">
        <div class="premium-card p-0 overflow-hidden">
            <div class="wizard-grid-layout">
                <!-- Column 1 -->
                <div class="wizard-column border-end" style="border-color: var(--card-border) !important;">
                    <div class="p-5" style="background: rgba(249, 115, 22, 0.08); border-bottom: 1px solid var(--card-border); box-shadow: inset 0 0 40px rgba(249, 115, 22, 0.05);">
                         <p class="mb-2 text-dim" style="font-size: 0.7rem; letter-spacing: 2px; font-weight: 700; text-transform: uppercase;">MEMBER PORTAL</p>
                         <h4 class="fw-bold mb-1" style="color: var(--primary); text-shadow: 0 0 15px rgba(249, 115, 22, 0.3);">@(ViewBag.CustomerName)</h4>
                         <small class="text-dim" style="opacity: 0.9;">@(ViewBag.CustomerEmail)</small>
                         <input type="hidden" id="customerName" value="@ViewBag.CustomerName">
                         <input type="hidden" id="customerEmail" value="@ViewBag.CustomerEmail">
                         <input type="hidden" id="customerPhone" value="@ViewBag.CustomerPhone">
                    </div>


                    <div class="session-group p-5">
                        <h5 class="session-label">&#9728; Morning Session</h5>
                        <div id="morning-slots" class="slots-grid"></div>
                    </div>
                </div>

                <!-- Column 2 -->
                <div class="wizard-column p-5">
                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label class="form-label-premium">Booking Date</label>
                            <input type="text" id="bookingDate" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" placeholder="Select Date">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label-premium">Duration</label>
                            <select id="duration" class="form-control">
                                <option value="1">1 Hour</option>
                                <option value="2">2 Hours</option>
                                <option value="3">3 Hours</option>
                                <option value="4">4 Hours</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="form-label-premium">Age Group</label>
                        <select id="ageGroup" class="form-control">
                            <option value="Adult">Adult (18+)</option>
                            <option value="Junior">Junior (12-17)</option>
                            <option value="Child">Child (Under 12)</option>
                        </select>
                    </div>

                    <div class="session-group">
                        <h5 class="session-label">&#127769; Night Session</h5>
                        <div id="night-slots" class="slots-grid"></div>
                    </div>
                </div>
            </div>

            <div class="wizard-actions px-5 pb-5 d-flex justify-content-end align-items-center">
                <div id="slot-hint" class="me-3 fw-bold" style="color: var(--primary); display:none; font-size: 0.9rem;"></div>
                <button class="btn-premium" onclick="proceedToConfigure()">NEXT</button>
            </div>
        </div>
    </div>
</div>

<style>
    .booking-wizard-container {
        max-width: 1200px;
        margin: 40px auto;
    }
    .wizard-grid-layout {
        display: grid;
        grid-template-columns: 1fr 1.2fr;
        gap: 0;
    }
    .form-label-premium {
        font-size: 0.75rem;
        color: var(--text-dim);
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        margin-bottom: 10px;
        display: block;
    }
    .session-label {
        font-size: 0.75rem;
        color: var(--primary);
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        gap: 15px;
    }
    .session-label::after {
        content: '';
        flex: 1;
        height: 1px;
        background: rgba(249, 115, 22, 0.1);
    }
    .slots-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
        gap: 15px;
    }
    .slot-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--card-border);
        border-radius: 16px;
        padding: 20px;
        text-align: center;
        cursor: pointer;
        transition: var(--transition-smooth);
    }
    .slot-card:hover {
        border-color: var(--primary);
        background: rgba(249, 115, 22, 0.05);
        transform: translateY(-3px);
    }
    .slot-card.selected {
        background: var(--primary);
        border-color: var(--primary);
        color: #000;
        box-shadow: 0 10px 20px var(--primary-glow);
    }
    .slot-number { display: block; font-size: 0.65rem; font-weight: 800; opacity: 0.6; margin-bottom: 5px; text-transform: uppercase; }
    .slot-time { display: block; font-size: 1.1rem; font-weight: 800; }

    /* Dropdown visibility fix */
    select.form-control option {
        background-color: #1a1f26 !important;
        color: #fff !important;
        padding: 10px !important;
    }
</style>


<script>
    let bookingData = {
        name: "@(ViewBag.CustomerName)",
        email: "@(ViewBag.CustomerEmail)",
        phone: "@(ViewBag.CustomerPhone)",
        date: "@DateTime.Today.ToString("yyyy-MM-dd")",
        duration: 1,
        selectedSlotIds: [],
        slotId: null,
        allAvailableSlots: []
    };

    document.addEventListener("DOMContentLoaded", () => {
        const fp = flatpickr("#bookingDate", {
            dateFormat: "Y-m-d",
            minDate: "today",
            disableMobile: "true",
            static: true,
            closeOnSelect: false,
            clickOpens: false,
            onChange: function(selectedDates, dateStr) {
                bookingData.date = dateStr;
                bookingData.selectedSlotIds = [];
                loadSlots();
            }
        });

        document.getElementById("bookingDate").addEventListener("click", () => {
            fp.toggle();
        });

        loadSlots();

        document.getElementById("duration").addEventListener("change", (e) => {
            bookingData.duration = parseInt(e.target.value);
            bookingData.selectedSlotIds = [];
            document.querySelectorAll(".slot-card").forEach(c => c.classList.remove("selected"));
            document.getElementById("slot-hint").style.display = "none";
        });
    });

    async function loadSlots() {
        const morningGrid = document.getElementById("morning-slots");
        const nightGrid = document.getElementById("night-slots");
        if (!morningGrid || !nightGrid) return;
        
        morningGrid.innerHTML = "<div class='text-dim small'>Loading...</div>";
        nightGrid.innerHTML = "<div class='text-dim small'>Loading...</div>";
        
        try {
            const response = await fetch(`/Booking/GetAvailableSlotsAjax?date=${bookingData.date}`);
            const slots = await response.json();
            
            morningGrid.innerHTML = "";
            nightGrid.innerHTML = "";
            bookingData.allAvailableSlots = slots;

            slots.forEach(slot => {
                const card = document.createElement("div");
                card.className = "slot-card";
                card.id = `slot-${slot.slotId}`;
                card.onclick = () => selectSlot(slot);
                card.innerHTML = `
                    <span class="slot-number">${slot.label}</span>
                    <span class="slot-time">${slot.slotStartTime} - ${slot.slotEndTime}</span>
                `;
                if (slot.isNight) nightGrid.appendChild(card);
                else morningGrid.appendChild(card);
            });

            if (morningGrid.innerHTML === "") morningGrid.innerHTML = "<p class='text-dim small'>No morning slots available</p>";
            if (nightGrid.innerHTML === "") nightGrid.innerHTML = "<p class='text-dim small'>No night slots available</p>";
        } catch (err) {
            console.error(err);
        }
    }

    function selectSlot(slot) {
        const duration = bookingData.duration;
        const index = bookingData.selectedSlotIds.indexOf(slot.slotId);

        if (index > -1) {
            bookingData.selectedSlotIds.splice(index, 1);
        } else {
            if (bookingData.selectedSlotIds.length >= duration) {
                alert(`Please select only ${duration} slot(s).`);
                return;
            }
            bookingData.selectedSlotIds.push(slot.slotId);
        }

        document.querySelectorAll(".slot-card").forEach(c => c.classList.remove("selected"));
        bookingData.selectedSlotIds.forEach(id => {
            const el = document.getElementById(`slot-${id}`);
            if (el) el.classList.add("selected");
        });

        const hint = document.getElementById("slot-hint");
        const picks = bookingData.selectedSlotIds.length;
        if (picks < duration) {
            hint.style.display = "block";
            hint.innerText = `Select ${duration} slots (${duration - picks} left)`;
        } else {
            hint.style.display = "block";
            hint.innerText = "All slots selected.";
            bookingData.slotId = bookingData.selectedSlotIds.sort((a,b)=>a-b)[0];
        }
    }

    function proceedToConfigure() {
        if (bookingData.selectedSlotIds.length < bookingData.duration) {
            alert("Please select your time slots first.");
            return;
        }
        
        const ageGroup = document.getElementById("ageGroup").value;
        const url = `/Booking/SelectionLane?slotId=${bookingData.slotId}&name=${encodeURIComponent(bookingData.name)}&email=${encodeURIComponent(bookingData.email)}&phone=${encodeURIComponent(bookingData.phone)}&date=${bookingData.date}&duration=${bookingData.duration}&ageGroup=${ageGroup}`;
        window.location.href = url;
    }
</script>
