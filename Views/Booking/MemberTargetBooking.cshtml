@{
    ViewData["Title"] = "Book Your Session";
    Layout = "_MemberLayout";
}

<div class="booking-wizard-container animate-fade-in" data-aos="fade-up">
    <!-- Progress Header -->
    <partial name="~/Views/Home/BookingProgress.cshtml" model="1" />

    <!-- Step 1: Customer Info & Session -->
    <div class="wizard-step active" id="wizard-step-1">
        <div class="premium-card p-0 overflow-hidden">
            <div class="wizard-grid-layout">
                <!-- Column 1 (Left): Form Fields & Rules -->
                <div class="wizard-column border-end p-5" style="border-color: var(--card-border) !important;">
                    <input type="hidden" id="customerName" value="@ViewBag.CustomerName">
                    <input type="hidden" id="customerEmail" value="@ViewBag.CustomerEmail">
                    <input type="hidden" id="customerPhone" value="@ViewBag.CustomerPhone">

                    <!-- Number of Archers -->
                    <input type="hidden" id="numberOfPax" value="1">
                    <input type="hidden" id="savedSlotIds" value="">

                    <div class="mb-4">
                        <label class="form-label-premium">Session Type</label>
                        <select id="sessionType" class="form-control">
                            <option value="game">Game Session</option>
                            <option value="self_training">Self Training</option>
                        </select>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label class="form-label-premium">Booking Date</label>
                            <input type="text" id="bookingDate" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" placeholder="Select Date">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label-premium" id="durationLabel">Select Slots</label>
                            <select id="duration" class="form-control">
                                <option value="2">1 Slot</option>
                                <option value="4">2 Slots</option>
                            </select>
                        </div>
                    </div>

                    <div id="game-session-banner" class="p-4" style="display: none; background: rgba(255, 77, 77, 0.05); border: 1px dashed rgba(255, 77, 77, 0.2); border-radius: 20px;">
                        <h5 class="text-white fw-bold mb-3 d-flex align-items-center gap-2">
                            <i class="bi bi-info-circle-fill text-primary"></i> Notes
                        </h5>
                        <ul class="text-dim small ps-3 mb-0" style="line-height: 1.8;">
                            <li>Available on weekdays only (8:15 AM - 4:30 PM).</li>                            
                            <li><strong>No Coach</strong> will be present.</li>
                            <li><strong>RM 20.00</strong> /per slot.</li>
                            <li>Max 4 hours (2 Slot).</li>
                        </ul>
                    </div>


                    <div id="self-training-banner" class="p-4" style="display: none; background: rgba(255, 77, 77, 0.05); border: 1px dashed rgba(255, 77, 77, 0.2); border-radius: 20px;">
                        <h5 class="text-white fw-bold mb-3 d-flex align-items-center gap-2">
                            <i class="bi bi-info-circle-fill text-primary"></i> Notes
                        </h5>
                        <ul class="text-dim small ps-3 mb-0" style="line-height: 1.8;">
                            <li>Available every night (8:00 PM - 12:00 AM).</li>
                            <li>Exclusive member-only practice session.</li>
                            <li><strong>No Coach</strong> will be present.</li>
                            <li><strong>RM 20.00</strong> /per slot.</li>
                            <li>Max 4 hours (2 Slot).</li>
                        </ul>
                    </div>
                    
                </div>

                <!-- Column 2 (Right): Time Slots Grid -->
                <div class="wizard-column p-5">
                    <div class="session-group mb-5" id="morning-session-wrapper">
                        <h5 class="session-label">&#9728; Morning Session</h5>
                        <div id="morning-slots" class="slots-grid"></div>
                    </div>

                    <div class="session-group" id="night-session-wrapper">
                        <h5 class="session-label">&#127769; Night Session</h5>
                        <div id="night-slots" class="slots-grid"></div>
                    </div>
                </div>
            </div>

            <div class="wizard-actions px-5 pb-5 d-flex justify-content-end align-items-center">
                <div id="slot-hint" class="me-3 fw-bold" style="color: var(--primary); display:none; font-size: 0.9rem;"></div>
                <button class="btn-premium" onclick="proceedToConfigure()">NEXT</button>
            </div>
        </div>
    </div>
</div>

<style>
    .booking-wizard-container {
        max-width: 1200px;
        margin: 40px auto;
    }
    .wizard-grid-layout {
        display: grid;
        grid-template-columns: 1fr 1.2fr;
        gap: 0;
    }
    .form-label-premium {
        font-size: 0.75rem;
        color: var(--text-dim);
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        margin-bottom: 10px;
        display: block;
    }
    .session-label {
        font-size: 0.75rem;
        color: var(--primary);
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        gap: 15px;
    }
    .session-label::after {
        content: '';
        flex: 1;
        height: 1px;
        background: rgba(255, 77, 77, 0.1);
    }
    .slots-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
        gap: 15px;
    }
    .slot-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--card-border);
        border-radius: 16px;
        padding: 20px;
        text-align: center;
        cursor: pointer;
        transition: var(--transition-smooth);
    }
    .slot-card:hover {
        border-color: var(--primary);
        background: rgba(255, 77, 77, 0.05);
        transform: translateY(-3px);
    }
    .slot-card.selected {
        background: var(--primary);
        border-color: var(--primary);
        color: #000;
        box-shadow: 0 10px 20px var(--primary-glow);
    }
    .slot-number { display: block; font-size: 0.65rem; font-weight: 800; opacity: 0.6; margin-bottom: 5px; text-transform: uppercase; }
    .slot-time { display: block; font-size: 1.1rem; font-weight: 800; }

    /* Dropdown visibility fix */
    select.form-control option {
        background-color: #1a1f26 !important;
        color: #fff !important;
        padding: 10px !important;
    }
</style>


<script>
    let bookingData = {
        name: "@(ViewBag.CustomerName)",
        email: "@(ViewBag.CustomerEmail)",
        phone: "@(ViewBag.CustomerPhone)",
        date: "@DateTime.Today.ToString("yyyy-MM-dd")",
        duration: 2,
        selectedSlotIds: [],
        slotId: null,
        allAvailableSlots: []
    };

    let fpInstance;

    document.addEventListener("DOMContentLoaded", () => {
        fpInstance = flatpickr("#bookingDate", {
            dateFormat: "Y-m-d",
            minDate: "today",
            disableMobile: "true",
            disable: [
                function(date) {
                    // Default to Game mode: Disable weekends (Saturday/Sunday)
                    return (date.getDay() === 0 || date.getDay() === 6);
                }
            ],
            onChange: function(selectedDates, dateStr) {
                bookingData.date = dateStr;
                bookingData.selectedSlotIds = [];
                loadSlots();
            }
        });

        // Initial date validation: If today is Saturday or Sunday, force next Monday
        let initDate = fpInstance.selectedDates[0] || new Date();
        let day = initDate.getDay();
        if (day === 0 || day === 6) {
            let offset = (day === 6) ? 2 : 1;
            let newDate = new Date(initDate.setDate(initDate.getDate() + offset));
            fpInstance.setDate(newDate, true);
        }

        loadSlots();

        document.getElementById("duration").addEventListener("change", (e) => {
            bookingData.duration = parseInt(e.target.value);
            bookingData.selectedSlotIds = [];
            document.querySelectorAll(".slot-card").forEach(c => c.classList.remove("selected"));
            document.getElementById("slot-hint").style.display = "none";
            loadSlots();
        });

        document.getElementById("sessionType").addEventListener("change", (e) => {
            const sType = e.target.value;
            const durationSelect = document.getElementById("duration");
            const durationLabel = document.getElementById("durationLabel");
            const morningWrapper = document.getElementById("morning-session-wrapper");
            const nightWrapper = document.getElementById("night-session-wrapper");
            
            const gameBanner = document.getElementById("game-session-banner");
            const classBanner = document.getElementById("class-session-banner");
            const selfTrainingBanner = document.getElementById("self-training-banner");

            bookingData.selectedSlotIds = [];
            document.querySelectorAll(".slot-card").forEach(c => c.classList.remove("selected"));
            document.getElementById("slot-hint").style.display = "none";

            // Default: Show morning session (daytime), hide night session, hide all banners
            if (morningWrapper) morningWrapper.style.display = "block";
            if (nightWrapper) nightWrapper.style.display = "none";
            if (gameBanner) gameBanner.style.display = "none";
            if (classBanner) classBanner.style.display = "none";
            if (selfTrainingBanner) selfTrainingBanner.style.display = "none";

            if (sType === "game") {
                // Game session (Weekday only)
                if (gameBanner) gameBanner.style.display = "block";
                durationLabel.innerText = "Select Slots";
                durationSelect.innerHTML = `
                    <option value="2">1 Slot</option>
                    <option value="4">2 Slots</option>
                `;
                bookingData.duration = 2;

                // Restrict datepicker to Weekdays only (disable Sat/Sun)
                fpInstance.set('disable', [
                    function(date) {
                        return (date.getDay() === 0 || date.getDay() === 6);
                    }
                ]);
                fpInstance.redraw();

                // If currently selected date is weekend, force next Monday
                let curDate = fpInstance.selectedDates[0] || new Date();
                let curDay = curDate.getDay();
                if (curDay === 0 || curDay === 6) {
                    let offset = (curDay === 6) ? 2 : 1;
                    let newDate = new Date(curDate.setDate(curDate.getDate() + offset));
                    fpInstance.setDate(newDate, true);
                }

            } else if (sType === "self_training") {
                // Self Training (Everyday, Night only)
                if (selfTrainingBanner) selfTrainingBanner.style.display = "block";
                durationLabel.innerText = "Select Slots";
                durationSelect.innerHTML = `
                    <option value="2">1 Slot</option>
                    <option value="4">2 Slots</option>
                `;
                bookingData.duration = 2;

                // Hide morning session wrapper, show night session wrapper
                if (morningWrapper) morningWrapper.style.display = "none";
                if (nightWrapper) nightWrapper.style.display = "block";

                // Everyday is available (no disable filter on flatpickr)
                fpInstance.set('disable', []);
                fpInstance.redraw();
            }
            loadSlots();
        });

        // Trigger change event on page load to initialize the default state
        document.getElementById("sessionType").dispatchEvent(new Event("change"));
    });

    async function loadSlots() {
        const morningGrid = document.getElementById("morning-slots");
        const nightGrid = document.getElementById("night-slots");
        if (!morningGrid || !nightGrid) return;
        
        morningGrid.innerHTML = "<div class='text-dim small'>Loading...</div>";
        nightGrid.innerHTML = "<div class='text-dim small'>Loading...</div>";
        
        try {
            const response = await fetch(`/Booking/GetAvailableSlotsAjax?date=${bookingData.date}`);
            let slots = await response.json();
            
            // Filter slots based on session type
            const sType = document.getElementById("sessionType").value;
            if (sType === "self_training") {
                // Self Training: Only show night 2-hour slots
                slots = slots.filter(slot => slot.isNight && slot.slotDurationHours === 2);
            } else {
                // Game session: Only show daytime 2-hour slots
                slots = slots.filter(slot => !slot.isNight && slot.slotDurationHours === 2);
            }
            
            morningGrid.innerHTML = "";
            nightGrid.innerHTML = "";
            bookingData.allAvailableSlots = slots;

            slots.forEach(slot => {
                const card = document.createElement("div");
                card.className = "slot-card";
                card.id = `slot-${slot.slotId}`;
                card.onclick = () => selectSlot(slot);
                card.innerHTML = `
                    <span class="slot-number">${slot.label}</span>
                    <span class="slot-time">${slot.slotStartTime} - ${slot.slotEndTime}</span>
                `;
                if (slot.isNight) nightGrid.appendChild(card);
                else morningGrid.appendChild(card);
            });

            if (morningGrid.innerHTML === "") morningGrid.innerHTML = "<p class='text-dim small'>No morning slots available</p>";
            if (nightGrid.innerHTML === "") nightGrid.innerHTML = "<p class='text-dim small'>No night slots available</p>";

            // Restore from hidden input if we came from history.back()
            const saved = document.getElementById("savedSlotIds").value;
            if (saved) {
                const arr = saved.split(',').map(Number).filter(n => n);
                // Only restore if length matches
                if (arr.length > 0) {
                    bookingData.selectedSlotIds = arr;
                    bookingData.slotId = arr[0];
                    arr.forEach(id => {
                        const el = document.getElementById(`slot-${id}`);
                        if (el) el.classList.add("selected");
                    });
                    const hint = document.getElementById("slot-hint");
                    const maxSlots = bookingData.duration / 2;
                    if (arr.length >= maxSlots && hint) {
                        hint.style.display = "block";
                        hint.innerText = "All slots selected.";
                    }
                }
            }
        } catch (err) {
            console.error(err);
        }
    }

    function selectSlot(slot) {
        const maxSlots = bookingData.duration / 2;
        const index = bookingData.selectedSlotIds.indexOf(slot.slotId);

        if (index > -1) {
            bookingData.selectedSlotIds.splice(index, 1);
        } else {
            if (bookingData.selectedSlotIds.length >= maxSlots) {
                if (maxSlots === 1) {
                    bookingData.selectedSlotIds = [];
                } else {
                    alert(`Please select only ${maxSlots} slot(s) (${bookingData.duration} hours).`);
                    return;
                }
            }
            bookingData.selectedSlotIds.push(slot.slotId);
        }

        document.querySelectorAll(".slot-card").forEach(c => c.classList.remove("selected"));
        bookingData.selectedSlotIds.forEach(id => {
            const el = document.getElementById(`slot-${id}`);
            if (el) el.classList.add("selected");
        });

        const hint = document.getElementById("slot-hint");
        const picks = bookingData.selectedSlotIds.length;
        if (picks < maxSlots) {
            if (hint) {
                hint.style.display = "block";
                hint.innerText = `Select ${maxSlots} slot(s) (${maxSlots - picks} left)`;
            }
        } else {
            if (hint) {
                hint.style.display = "block";
                hint.innerText = "All slots selected.";
            }
            bookingData.selectedSlotIds.sort((a,b)=>a-b);
            bookingData.slotId = bookingData.selectedSlotIds[0];
        }
        document.getElementById("savedSlotIds").value = bookingData.selectedSlotIds.join(',');
    }

    function adjustPax(change) {
        let pax = parseInt(document.getElementById("numberOfPax").value) || 1;
        pax += change;
        if (pax < 1) pax = 1;
        if (pax > 80) pax = 80;
        document.getElementById("numberOfPax").value = pax;
        document.getElementById("paxDisplay").innerText = pax;
    }

    function proceedToConfigure() {
        const maxSlots = bookingData.duration / 2;
        if (bookingData.selectedSlotIds.length < maxSlots) {
            alert("Please select your time slots first.");
            return;
        }
        
        const sType = document.getElementById("sessionType").value;
        const pax = document.getElementById("numberOfPax").value;
        const shooterSelect = document.getElementById("shooterSelect");
        const studentId = shooterSelect ? shooterSelect.value : "";
        
        const url = `/Booking/SelectTarget?slotId=${bookingData.slotId}&name=${encodeURIComponent(bookingData.name)}&email=${encodeURIComponent(bookingData.email)}&phone=${encodeURIComponent(bookingData.phone)}&date=${bookingData.date}&duration=${bookingData.duration}&numberOfPax=${pax}&sessionType=${sType}&studentId=${studentId}`;
        window.location.href = url;
    }
</script>
