@{
    ViewData["Title"] = "Class Booking";
    Layout = "_MemberLayout";
}

<div class="booking-wizard-container animate-fade-in" data-aos="fade-up">
    <!-- Progress Header -->
    <div class="booking-progress-bar mb-5">
        <div class="progress-step active">
            <span class="step-num"><i class="bi bi-mortarboard-fill"></i></span>
            <span class="step-title">Class Scheduler</span>
        </div>
    </div>

    <!-- Step 1: Customer Info & Session -->
    <div class="wizard-step active" id="wizard-step-1">
        <div class="premium-card p-0 overflow-hidden">
            <div class="wizard-grid-layout">
                <!-- Column 1 (Left): Form Fields & Rules -->
                <div class="wizard-column border-end p-5" style="border-color: var(--card-border) !important;">
                    <input type="hidden" id="customerName" value="@ViewBag.CustomerName">
                    <input type="hidden" id="customerEmail" value="@ViewBag.CustomerEmail">
                    <input type="hidden" id="customerPhone" value="@ViewBag.CustomerPhone">

                    <div class="mb-4">
                        <label class="form-label-premium">Booking Service</label>
                        <div class="fw-bold text-white fs-5" style="letter-spacing: 0.5px;">Archery Class Session</div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label-premium d-flex justify-content-between align-items-center mb-3">
                            <span>Student</span>
                            <button type="button" class="btn btn-sm btn-outline-primary" style="border-radius: 50px; padding: 4px 16px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.5px;" onclick="selectAllShooters()">Select All</button>
                        </label>
                        <div class="p-4" style="background: rgba(255, 77, 77, 0.05); border: 1px dashed rgba(255, 77, 77, 0.2); border-radius: 20px; max-height: 250px; overflow-y: auto;" id="shooterCheckboxes">
                            @if (ViewBag.ParentHasClass != null && (bool)ViewBag.ParentHasClass)
                            {
                                <div class="form-check mb-2 border-bottom pb-2" style="border-color: rgba(255, 77, 77, 0.1) !important;">
                                    <input class="form-check-input shooter-checkbox" type="checkbox" value="0" id="shooter_0">
                                    <label class="form-check-label text-white" for="shooter_0">
                                        Myself (@ViewBag.CustomerName)
                                    </label>
                                </div>
                            }
                            @if (ViewBag.Students != null && ((IEnumerable<dynamic>)ViewBag.Students).Any())
                            {
                                foreach (var student in ViewBag.Students)
                                {
                                    <div class="form-check mb-2">
                                        <input class="form-check-input shooter-checkbox" type="checkbox" value="@student.StudentId" id="shooter_@student.StudentId">
                                        <label class="form-check-label text-white" for="shooter_@student.StudentId">
                                            @student.FullName
                                        </label>
                                    </div>
                                }
                            }
                            else
                            {
                                <p class="text-dim small mb-0">No eligible archers found.</p>
                            }
                        </div>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label class="form-label-premium">Select Weekend Date</label>
                            <input type="text" id="bookingDate" class="form-control" placeholder="Select Weekend Date">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label-premium">Select Slots</label>
                            <select id="duration" class="form-control">
                                <option value="2">1 Slot</option>
                                <option value="4">2 Slots</option>
                                <option value="6">3 Slots</option>
                            </select>
                        </div>
                    </div>

                    <div id="class-session-banner" class="p-4" style="background: rgba(255, 77, 77, 0.05); border: 1px dashed rgba(255, 77, 77, 0.2); border-radius: 20px;">
                        <h5 class="text-white fw-bold mb-3 d-flex align-items-center gap-2">
                            <i class="bi bi-info-circle-fill text-primary"></i> Notes
                        </h5>
                        <ul class="text-dim small ps-3 mb-0" style="line-height: 1.8;">
                            <li>Available on weekends only (8:15 AM - 4:30 PM).</li>                        
                            <li><strong>Training With Coach</strong></li>
                        </ul>
                    </div>
                </div>

                <!-- Column 2 (Right): Time Slots Grid -->
                <div class="wizard-column p-5">
                    <div class="session-group">
                        <h5 class="session-label">&#9728; Available Class Slots</h5>
                        <div id="morning-slots" class="slots-grid"></div>
                    </div>

                    <div id="slot-hint" class="alert-premium mt-4" style="visibility: hidden;">&nbsp;</div>

                    <button class="btn-premium w-100 mt-5 justify-content-center" id="btnNext" onclick="confirmClassBooking()">
                        CONFIRM CLASS BOOKING <i class="bi bi-check2-circle ms-2"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Class Booking Success Modal -->
<div id="successModal" class="global-notif-overlay" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.9); backdrop-filter: blur(15px); display: none; align-items: center; justify-content: center; z-index: 10000; padding: 20px;">
    <div class="premium-card text-center" style="max-width: 500px; padding: 40px; height: auto; border-color: var(--primary);">
        <div class="mb-4">
            <i class="bi bi-check-circle-fill" style="font-size: 3.5rem; color: #22c55e;"></i>
        </div>
        <h2 class="fw-900 mb-2 text-white" style="font-size: 1.8rem;">CLASS SESSION BOOKED!</h2>
        <p class="text-dim mb-4" style="font-size: 0.9rem;">Your class booking has been registered successfully.</p>
        
        <button class="btn-premium w-100 justify-content-center mt-4" onclick="window.location.href='/Booking/MemberCalendar'">
            GO TO CALENDAR <i class="bi bi-calendar-event ms-2"></i>
        </button>
    </div>
</div>

@section Styles {
<style>
    .booking-progress-bar {
        display: flex;
        justify-content: center;
        margin-top: 20px;
    }
    .progress-step {
        display: flex;
        flex-direction: column;
        align-items: center;
        color: var(--text-dim);
    }
    .progress-step.active .step-num {
        background: var(--primary);
        color: #000;
        box-shadow: 0 0 20px var(--primary-glow);
    }
    .progress-step.active .step-title {
        color: #fff;
        font-weight: 700;
    }
    .step-num {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.05);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        margin-bottom: 10px;
        transition: 0.3s;
    }
    .step-title {
        font-size: 0.85rem;
        letter-spacing: 1px;
        text-transform: uppercase;
    }

    .booking-wizard-container { max-width: 1100px; margin: 0 auto; }
    .wizard-grid-layout { display: grid; grid-template-columns: 1fr 1fr; min-height: 580px; }
    .wizard-column { display: flex; flex-direction: column; }
    
    .session-label {
        font-size: 0.75rem;
        color: var(--text-dim);
        letter-spacing: 2px;
        text-transform: uppercase;
        font-weight: 800;
        margin-bottom: 25px;
    }
    
    .slots-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
        gap: 15px;
    }
    
    .slot-card {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid var(--card-border);
        border-radius: 16px;
        padding: 18px 10px;
        text-align: center;
        cursor: pointer;
        transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        flex-direction: column;
        gap: 8px;
    }
    
    .slot-card:hover {
        border-color: var(--primary);
        background: rgba(255, 77, 77, 0.03);
        transform: translateY(-3px);
    }
    
    .slot-card.selected {
        border-color: var(--primary);
        background: var(--primary);
        box-shadow: 0 8px 20px var(--primary-glow);
    }
    
    .slot-card.selected .slot-number,
    .slot-card.selected .slot-time {
        color: #000 !important;
        font-weight: 700;
    }
    
    .slot-number { font-size: 0.8rem; font-weight: 700; color: var(--text-dim); letter-spacing: 1px; text-transform: uppercase; }
    .slot-time { font-size: 0.95rem; font-weight: 800; color: #fff; }
    
    .alert-premium {
        background: rgba(255, 77, 77, 0.05);
        border: 1px solid rgba(255, 77, 77, 0.2);
        border-radius: 16px;
        padding: 20px;
        color: #fff;
        font-weight: 600;
        font-size: 0.9rem;
        line-height: 1.5;
    }
</style>
}

@section Scripts {
<script>
    // State management
    const bookingData = {
        name: "",
        email: "",
        phone: "",
        date: "",
        duration: 2,
        selectedSlotIds: [],
        slotId: 0,
        selectedSlot: null
    };

    let fpInstance = null;

    document.addEventListener("DOMContentLoaded", function() {
        // Pre-populate data
        bookingData.name = document.getElementById("customerName").value;
        bookingData.email = document.getElementById("customerEmail").value;
        bookingData.phone = document.getElementById("customerPhone").value;

        // Initialize date picker (Weekend restrict only)
        fpInstance = flatpickr("#bookingDate", {
            dateFormat: "Y-m-d",
            minDate: "today",
            defaultDate: getNextSaturday(),
            disable: [
                function(date) {
                    // Disable everything except Saturday (6) and Sunday (0)
                    return (date.getDay() !== 0 && date.getDay() !== 6);
                }
            ],
            onChange: function(selectedDates, dateStr) {
                bookingData.date = dateStr;
                bookingData.selectedSlotIds = [];
                loadSlots();
            }
        });

        document.getElementById("duration").addEventListener("change", (e) => {
            bookingData.duration = parseInt(e.target.value);
            bookingData.selectedSlotIds = [];
            document.querySelectorAll(".slot-card").forEach(c => c.classList.remove("selected"));
            document.getElementById("slot-hint").style.visibility = "hidden";
            document.getElementById("slot-hint").innerHTML = "&nbsp;";
            loadSlots();
        });

        // Set initial date
        bookingData.date = document.getElementById("bookingDate").value;
        loadSlots();
    });

    function getNextSaturday() {
        let date = new Date();
        let day = date.getDay();
        if (day !== 0 && day !== 6) {
            let offset = 6 - day;
            date.setDate(date.getDate() + offset);
        }
        return date;
    }

    async function loadSlots() {
        const morningGrid = document.getElementById("morning-slots");
        if (!morningGrid) return;
        
        morningGrid.innerHTML = "<div class='text-dim small'>Loading slots...</div>";
        bookingData.slotId = 0;
        bookingData.selectedSlotIds = [];
        bookingData.selectedSlot = null;
        document.getElementById("slot-hint").style.visibility = "hidden";
        document.getElementById("slot-hint").innerHTML = "&nbsp;";
        
        try {
            const response = await fetch(`/Booking/GetAvailableSlotsAjax?date=${bookingData.date}`);
            let slots = await response.json();
            
            // Weekend daytime slots ONLY: duration is 2 hours, daytime only (not isNight)
            slots = slots.filter(slot => !slot.isNight && slot.slotDurationHours === 2);
            
            morningGrid.innerHTML = "";
            
            if (slots.length === 0) {
                morningGrid.innerHTML = "<p class='text-dim small'>No slots available for this date.</p>";
                return;
            }

            slots.forEach(slot => {
                const card = document.createElement("div");
                card.className = "slot-card";
                card.id = `slot-${slot.slotId}`;
                card.onclick = () => selectSlot(slot);
                card.innerHTML = `
                    <span class="slot-number">${slot.label}</span>
                    <span class="slot-time">${slot.slotStartTime} - ${slot.slotEndTime}</span>
                `;
                morningGrid.appendChild(card);
            });
        } catch (err) {
            console.error(err);
            morningGrid.innerHTML = "<p class='text-dim small'>Failed to load slots.</p>";
        }
    }

    function selectSlot(slot) {
        const maxSlots = bookingData.duration / 2;
        const index = bookingData.selectedSlotIds.indexOf(slot.slotId);

        if (index > -1) {
            bookingData.selectedSlotIds.splice(index, 1);
        } else {
            if (bookingData.selectedSlotIds.length >= maxSlots) {
                if (maxSlots === 1) {
                    bookingData.selectedSlotIds = [];
                } else {
                    alert(`Please select only ${maxSlots} slot(s) (${bookingData.duration} hours).`);
                    return;
                }
            }
            bookingData.selectedSlotIds.push(slot.slotId);
        }

        document.querySelectorAll(".slot-card").forEach(c => c.classList.remove("selected"));
        bookingData.selectedSlotIds.forEach(id => {
            const el = document.getElementById(`slot-${id}`);
            if (el) el.classList.add("selected");
        });

        const hint = document.getElementById("slot-hint");
        const picks = bookingData.selectedSlotIds.length;
        if (picks < maxSlots) {
            if (hint) {
                hint.style.visibility = "visible";
                hint.innerText = `Select ${maxSlots} slot(s) (${maxSlots - picks} left)`;
            }
        } else {
            if (hint) {
                hint.style.visibility = "visible";
                hint.innerText = "All slots selected.";
            }
            bookingData.selectedSlotIds.sort((a,b)=>a-b);
            bookingData.slotId = bookingData.selectedSlotIds[0];
        }
    }

    async function confirmClassBooking() {
        const maxSlots = bookingData.duration / 2;
        if (bookingData.selectedSlotIds.length < maxSlots) {
            alert(`Please select all ${maxSlots} slot(s) before confirming class booking.`);
            return;
        }

        const btn = document.getElementById("btnNext");
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> RESERVING...';

        const formData = new FormData();
        formData.append("slotId", bookingData.slotId);
        formData.append("date", bookingData.date);
        formData.append("duration", bookingData.duration);
        
        const selectedShooters = [];
        document.querySelectorAll('.shooter-checkbox:checked').forEach(chk => {
            formData.append("studentIds", chk.value);
            selectedShooters.push(chk.value);
        });

        if (selectedShooters.length === 0) {
            alert("Please select at least one archer.");
            return;
        }

        try {
            const response = await fetch('/Booking/CreateClassBooking', {
                method: 'POST',
                body: formData
            });
            const result = await response.json();

            if (result.success) {
                document.getElementById("successModal").style.display = "flex";
            } else {
                alert("Booking failed: " + result.message);
                btn.disabled = false;
                btn.innerHTML = 'CONFIRM CLASS BOOKING <i class="bi bi-check2-circle ms-2"></i>';
            }
        } catch (err) {
            alert("Connection error. Please try again.");
            btn.disabled = false;
            btn.innerHTML = 'CONFIRM CLASS BOOKING <i class="bi bi-check2-circle ms-2"></i>';
        }
    }
    function selectAllShooters() {
        const checkboxes = document.querySelectorAll('.shooter-checkbox');
        const allChecked = Array.from(checkboxes).every(chk => chk.checked);
        checkboxes.forEach(chk => chk.checked = !allChecked);
    }
</script>
}
