@{
    ViewData["Title"] = "Configure Your Target";
    var slotId = ViewBag.SlotId;
    var name = ViewBag.Name;
    var email = ViewBag.Email;
    var date = ViewBag.Date;
    var duration = ViewBag.Duration;
    var ageGroup = ViewBag.AgeGroup;
}

<div class="booking-wizard-container animate-fade-in">
    <!-- Progress Header -->
    <partial name="~/Views/Home/_BookingProgress.cshtml" model="2" />

    <!-- Step 2: Target Size -->
    <div class="wizard-step active" id="wizard-step-2">
        <div class="glass-card">
            <h3 class="step-title">Choose Your Target Size</h3>
            
            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <div class="target-size-card" id="size-Large" onclick="selectTargetSize('Large')">
                        <div class="size-img-wrapper">
                            <img src="/images/target.png" alt="Large">
                        </div>
                        <div class="size-info">
                            <span class="size-name">Large (122cm)</span>
                            <small>Professional</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="target-size-card" id="size-Medium" onclick="selectTargetSize('Medium')">
                        <div class="size-img-wrapper" style="padding: 8px;">
                            <img src="/images/target.png" alt="Medium">
                        </div>
                        <div class="size-info">
                            <span class="size-name">Medium (80cm)</span>
                            <small>Intermediate</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="target-size-card" id="size-Inter" onclick="selectTargetSize('Inter')">
                        <div class="size-img-wrapper" style="padding: 15px;">
                            <img src="/images/target.png" alt="Intermediate">
                        </div>
                        <div class="size-info">
                            <span class="size-name">Intermediate (60cm)</span>
                            <small>Club</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="target-size-card" id="size-Small" onclick="selectTargetSize('Small')">
                        <div class="size-img-wrapper" style="padding: 22px;">
                            <img src="/images/target.png" alt="Small">
                        </div>
                        <div class="size-info">
                            <span class="size-name">Small (40cm)</span>
                            <small>Precision</small>
                        </div>
                    </div>
                </div>
            </div>

            <div class="glass-card mb-4 p-4 text-center" style="background: rgba(0,0,0,0.05); border-radius: 20px; max-width: 500px; margin: 0 auto 30px;">
                <label class="form-label-premium mb-3 d-block">Select Amount</label>
                <div id="targetAmountContainer" class="d-flex justify-content-center" style="gap: 20px;">
                    <p class="text-muted small">Please select a size first.</p>
                </div>
                <p id="amountHint" class="mt-3 small mb-0" style="color: var(--active-blue); font-weight: 600;"></p>
            </div>

            <div class="wizard-actions mt-4">
                <button class="btn-premium-outline" onclick="history.back()">Back</button>
                <button class="btn-premium" onclick="goToStep3()">Next</button>
            </div>
        </div>
    </div>

    <!-- Step 3: Lane Selection -->
    <div class="wizard-step" id="wizard-step-3">
        <div class="glass-card">
            <h3 class="step-title">Select Target Lane</h3>

            <div class="mb-4 p-3 rounded-4 text-center animate-fade-in" style="background: rgba(138, 154, 91, 0.1); border: 1px solid rgba(138, 154, 91, 0.3);">
                <div style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1.5px; font-weight: 700; color: var(--deep-blue); margin-bottom: 5px;">Selected Category</div>
                <div class="d-flex align-items-center justify-content-center">
                    <span style="font-size: 1.2rem; font-weight: 800; color: #2b3a2a;">@ageGroup</span>
                </div>
                <div class="mt-2" style="font-size: 0.75rem; font-weight: 600; color: var(--active-blue);">
                    <i class="bi bi-info-circle me-1"></i> Here are the lanes available for you :<b>Lanes @(ageGroup == "Adult" ? "11 - 20" : "1 - 10")</b>
                </div>
            </div>
            
            <div class="glass-card mb-4 p-4" style="background: rgba(0,0,0,0.05); border-radius: 20px; border: 1px solid rgba(255,255,255,0.1);">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
                    <div>
                        <label class="form-label-premium mb-1" style="font-size: 0.9rem;">Number of Archers (Pax)</label>
                        <p class="mb-0" style="color: var(--deep-blue); font-weight: 700; font-size: 0.85rem;" id="laneRequiredHint">
                            <i class="fas fa-info-circle me-1"></i> Min 1 Lane Required
                        </p>
                    </div>
                    
                    <div class="modern-counter">
                        <button class="counter-btn" onclick="updatePax(-1)">-</button>
                        <div class="counter-value" id="paxDisplay">1</div>
                        <button class="counter-btn" onclick="updatePax(1)">+</button>
                        <input type="hidden" id="numberOfPax" value="1">
                    </div>
                </div>
            </div>

            <div id="target-hint" class="mt-3 mb-3 fw-bold text-center" style="color: var(--active-blue);">Select your preferred lane(s).</div>
            
            <div id="targetsGrid" class="targets-grid"></div>

            <div class="wizard-actions mt-5">
                <button class="btn-premium-outline" onclick="goToStep2()">Back</button>
                <button class="btn-premium" onclick="goToStep4()">Next</button>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --active-blue: #8A9A5B;
        --deep-blue: #6D7B48;
        --glass: #A9BA9D;
        --glass-border: rgba(255, 255, 255, 0.08);
    }

    body { background: #ECE7CA !important; font-family: 'Outfit', sans-serif; }
    .booking-wizard-container { max-width: 1100px; margin: 50px auto; padding: 0 20px; }

    .glass-card { background: var(--glass); border-radius: 25px; padding: 2.5rem; border: 1px solid var(--glass-border); }
    .wizard-step { display: none; }
    .wizard-step.active { display: block; }
    
    .target-size-card { background: #ddead1; border-radius: 15px; padding: 15px; cursor: pointer; transition: 0.3s; text-align: center; border: 1px solid transparent; }
    .target-size-card:hover { border-color: var(--active-blue); }
    .target-size-card.selected { background: var(--active-blue); border-color: var(--active-blue); }
    .size-img-wrapper { 
        width: 100px; 
        height: 100px; 
        border-radius: 50%; 
        overflow: hidden; 
        margin: 0 auto 15px; 
        background: white; 
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px solid var(--deep-blue);
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }
    .size-img-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: contain;
    }
    .size-info {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2px;
    }
    .size-name { 
        display: block; 
        font-weight: 800; 
        font-size: 0.85rem; 
        color: #2b3a2a;
    }
    .size-info small {
        display: block;
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        opacity: 0.7;
        font-weight: 600;
    }
    
    .amount-btn { width: 45px; height: 45px; border-radius: 50%; border: 1px solid var(--glass-border); background: #ddead1; font-weight: 800; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: 0.3s; }
    .amount-btn.selected { background: var(--active-blue); box-shadow: 0 5px 15px rgba(0,0,0,0.1); }

    .targets-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; margin-top: 20px; }
    .target-box { aspect-ratio: 1; background: #ddead1; border-radius: 10px; display: flex; flex-direction: column; align-items: center; justify-content: center; cursor: pointer; transition: 0.2s; }
    .target-box.selected { background: var(--active-blue); font-weight: 800; border: 2px solid var(--deep-blue); scale: 1.05; }
    .target-box.disabled { opacity: 0.15; cursor: not-allowed; filter: grayscale(1); border: 1px dashed rgba(0,0,0,0.2); }
    .target-box.restricted { 
        opacity: 0.3; 
        cursor: not-allowed; 
        background: rgba(0,0,0,0.05); 
        position: relative;
    }
    .target-box.restricted::after {
        content: "🚫";
        position: absolute;
        font-size: 0.8rem;
        top: 5px;
        right: 5px;
    }

    .btn-premium { background: linear-gradient(to right, var(--active-blue), var(--deep-blue)); border: none; color: black; padding: 12px 25px; border-radius: 10px; font-weight: bold; text-transform: uppercase; }
    .btn-premium-outline { background: transparent; border: 1px solid rgba(0,0,0,0.1); color: #2b3a2a; padding: 12px 25px; border-radius: 10px; font-weight: bold; margin-right: 10px; }

    /* Modern Counter Styles */
    .modern-counter {
        display: flex;
        align-items: center;
        background: rgba(138, 154, 91, 0.15);
        border-radius: 12px;
        padding: 5px 15px;
        border: 1px solid rgba(138, 154, 91, 0.2);
        gap: 15px;
    }
    .counter-btn {
        width: 30px;
        height: 30px;
        border: none;
        background: transparent;
        color: var(--deep-blue);
        font-size: 1.8rem;
        font-weight: 300;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: 0.2s;
        line-height: 1;
    }
    .counter-btn:hover {
        color: var(--active-blue);
        transform: scale(1.2);
    }
    .counter-value {
        width: 50px;
        height: 50px;
        background: white;
        border: 1px solid rgba(138, 154, 91, 0.3);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        font-weight: 700;
        color: #2b3a2a;
        user-select: none;
        box-shadow: 0 2px 5px rgba(0,0,0,0.05);
    }
</style>

<script>
    let bookingData = {
        slotId: "@slotId",
        name: "@name",
        email: "@email",
        date: "@date",
        duration: "@duration",
        ageGroup: "@ageGroup",
        pax: 1,
        targetSize: null,
        targetAmount: 1,
        selectedTargetIds: [],
        totalPrice: 0,
        laneRanges: {}
    };

    function selectTargetSize(size) {
        bookingData.targetSize = size;
        bookingData.targetAmount = 1;
        document.querySelectorAll(".target-size-card").forEach(c => c.classList.remove("selected"));
        document.getElementById(`size-${size === "Intermediate" ? "Inter" : size}`).classList.add("selected");
        renderTargetAmounts();
    }

    function renderTargetAmounts() {
        const container = document.getElementById("targetAmountContainer");
        const hint = document.getElementById("amountHint");
        let max = 1;
        if (bookingData.targetSize === "Medium") max = 2;
        if (bookingData.targetSize === "Inter") max = 3;
        if (bookingData.targetSize === "Small") max = 4;
        
        container.innerHTML = "";
        for(let i=1; i<=max; i++) {
            const btn = document.createElement("button");
            btn.className = `amount-btn ${bookingData.targetAmount === i ? 'selected' : ''}`;
            btn.innerText = i;
            btn.onclick = () => { bookingData.targetAmount = i; renderTargetAmounts(); };
            container.appendChild(btn);
        }
        hint.innerText = bookingData.targetSize === "Large" ? "1 per lane limit." : `Up to ${max} per lane.`;
    }

    function updatePax(change) {
        let val = parseInt(document.getElementById("numberOfPax").value);
        val += change;
        if (val < 1) val = 1;
        if (val > 80) val = 80;
        
        document.getElementById("numberOfPax").value = val;
        document.getElementById("paxDisplay").innerText = val;
        bookingData.pax = val;

        // Calculate required lanes
        const requiredLanes = Math.ceil(val / 4);
        const hint = document.getElementById("laneRequiredHint");
        hint.innerHTML = `<i class="fas fa-info-circle me-1"></i> Min ${requiredLanes} Lane${requiredLanes > 1 ? 's' : ''} Required`;
        
        if (bookingData.selectedTargetIds.length < requiredLanes && bookingData.selectedTargetIds.length > 0) {
            hint.style.color = "#dc3545"; // Red if not enough lanes selected
        } else {
            hint.style.color = "var(--deep-blue)";
        }
    }

    function goToStep2() {
        document.getElementById("wizard-step-3").classList.remove("active");
        document.getElementById("wizard-step-2").classList.add("active");
        document.getElementById("step3-indicator").classList.remove("active");
    }

    async function goToStep3() {
        if (!bookingData.targetSize) { alert("Please select a size."); return; }
        
        document.getElementById("wizard-step-2").classList.remove("active");
        document.getElementById("wizard-step-3").classList.add("active");
        document.getElementById("step3-indicator").classList.add("active");

        const grid = document.getElementById("targetsGrid");
        grid.innerHTML = "<div class='text-center w-100 py-4'><div class='spinner-border text-success'></div><p class='mt-2'>Loading available lanes...</p></div>";
        
        try {
            const resp = await fetch(`/Booking/GetAvailableTargetsAjax?slotId=${bookingData.slotId}&date=${bookingData.date}&duration=${bookingData.duration}`);
            const availableTargets = await resp.json();
            
            grid.innerHTML = "";
            const isAdult = (bookingData.ageGroup === "Adult");

            for(let i=1; i<=20; i++) {
                const box = document.createElement("div");
                const isTaken = !availableTargets.includes(i);
                
                // Logic: Adults 11-20, Kids 1-10
                const isRestricted = isAdult ? (i <= 10) : (i >= 11);
                
                box.className = `target-box ${isTaken ? 'disabled' : ''} ${isRestricted ? 'restricted' : ''}`;
                
                let statusText = isTaken ? 'Taken' : (isRestricted ? 'Restricted' : 'Open');
                
                box.innerHTML = `
                    <span style="font-size: 1.2rem; font-weight: 800;">${i}</span>
                    <small style="font-size:0.65rem; text-transform: uppercase; opacity: 0.8;">${statusText}</small>
                `;

                if(!isTaken && !isRestricted) {
                    box.onclick = () => selectTarget(i);
                } else if (isRestricted) {
                    box.title = isAdult ? "Lanes 1-10 are for Kids/Juniors" : "Lanes 11-20 are for Adults";
                }

                grid.appendChild(box);
            }
        } catch(e) { 
            grid.innerHTML = "<div class='text-center w-100 p-4 text-danger'>Error loading lanes. Please try again.</div>"; 
        }
    }

    function selectTarget(num) {
        const idx = bookingData.selectedTargetIds.indexOf(num);
        if (idx > -1) {
            bookingData.selectedTargetIds.splice(idx, 1);
        } else {
            bookingData.selectedTargetIds.push(num);
        }
        document.querySelectorAll(".target-box").forEach(b => b.classList.remove("selected"));
        bookingData.selectedTargetIds.forEach(id => {
            const el = document.querySelectorAll(".target-box")[id-1];
            if(el) el.classList.add("selected");
        });
    }

    function goToStep4() {
        bookingData.pax = parseInt(document.getElementById("numberOfPax").value);
        
        if (bookingData.selectedTargetIds.length === 0) { alert("Select a lane."); return; }
        
        // Validation: 1 lane max 4 pax
        const maxCapacity = bookingData.selectedTargetIds.length * 4;
        if (bookingData.pax > maxCapacity) {
            alert(`You have ${bookingData.pax} archers, but selected lanes can only accommodate ${maxCapacity} people. Please select more lanes (1 lane = max 4 people).`);
            return;
        }

        // Final price calculation (Simplified for now)
        const hour = 10; // Default morning
        bookingData.totalPrice = hour * bookingData.duration;

        const form = document.createElement("form");
        form.method = "POST";
        const isGuest = "@(ViewBag.IsGuest ?? false)".toLowerCase() === "true";
        form.action = isGuest ? "/Booking/PaymentGuest" : "/Booking/Payment";
        
        const fields = {
            SlotId: bookingData.slotId,
            CustomerName: bookingData.name,
            CustomerEmail: bookingData.email,
            Date: bookingData.date,
            Duration: bookingData.duration,
            TotalPrice: bookingData.totalPrice,
            SelectedLanes: bookingData.selectedTargetIds.join(", "),
            TargetSize: bookingData.targetSize,
            TargetAmount: bookingData.targetAmount,
            NumberOfPax: bookingData.pax
        };

        for (let k in fields) {
            const input = document.createElement("input");
            input.type = "hidden";
            input.name = k;
            input.value = fields[k];
            form.appendChild(input);
        }
        document.body.appendChild(form);
        form.submit();
    }
</script>
