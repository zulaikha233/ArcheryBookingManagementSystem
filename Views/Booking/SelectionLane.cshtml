@{
    ViewData["Title"] = "Configure Your Target";
    var slotId = ViewBag.SlotId;
    var name = ViewBag.Name;
    var email = ViewBag.Email;
    var phone = ViewBag.Phone;
    var date = ViewBag.Date;
    var duration = ViewBag.Duration;
    var ageGroup = ViewBag.AgeGroup;
}

<div class="booking-wizard-container py-5">
    <!-- Progress Header -->
    <div data-aos="fade-down">
        <partial name="~/Views/Home/_BookingProgress.cshtml" model="2" />
    </div>

    <!-- Step 2: Target Size -->
    <div class="wizard-step active" id="wizard-step-2" data-aos="fade-up">
        <div class="premium-card">
            <h3 class="fw-bold mb-4" style="color: var(--primary);">Choose Your Target Size</h3>
            
            <div class="row g-4 mb-5">
                <div class="col-md-3">
                    <div class="target-size-card" id="size-Large" onclick="selectTargetSize('Large')">
                        <div class="size-img-wrapper">
                            <img src="/images/target.png" alt="Large">
                        </div>
                        <div class="size-info">
                            <span class="size-name">Large (122cm)</span>
                            <small>Professional</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="target-size-card" id="size-Medium" onclick="selectTargetSize('Medium')">
                        <div class="size-img-wrapper" style="padding: 12px;">
                            <img src="/images/target.png" alt="Medium">
                        </div>
                        <div class="size-info">
                            <span class="size-name">Medium (80cm)</span>
                            <small>Intermediate</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="target-size-card" id="size-Inter" onclick="selectTargetSize('Inter')">
                        <div class="size-img-wrapper" style="padding: 20px;">
                            <img src="/images/target.png" alt="Intermediate">
                        </div>
                        <div class="size-info">
                            <span class="size-name">Intermediate (60cm)</span>
                            <small>Club</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="target-size-card" id="size-Small" onclick="selectTargetSize('Small')">
                        <div class="size-img-wrapper" style="padding: 28px;">
                            <img src="/images/target.png" alt="Small">
                        </div>
                        <div class="size-info">
                            <span class="size-name">Small (40cm)</span>
                            <small>Precision</small>
                        </div>
                    </div>
                </div>
            </div>

            <div class="premium-card mb-5 p-4 text-center" style="background: rgba(255, 77, 77, 0.05); max-width: 500px; margin: 0 auto;">
                <label class="form-label-premium mb-3 d-block">Target Face Amount</label>
                <div id="targetAmountContainer" class="d-flex justify-content-center gap-4">
                    <p class="text-dim">Please select a size first.</p>
                </div>
                <p id="amountHint" class="mt-3 small mb-0 fw-bold" style="color: var(--primary);"></p>
            </div>

            <div class="wizard-actions d-flex justify-content-between mt-5">
                <button class="btn-premium-outline" onclick="history.back()">BACK</button>
                <button class="btn-premium" onclick="goToStep3()">NEXT</button>
            </div>
        </div>
    </div>

    <!-- Step 3: Lane Selection -->
    <div class="wizard-step" id="wizard-step-3">
        <div class="premium-card">
            <h3 class="fw-bold mb-4" style="color: var(--primary);">Select Target Lane</h3>

            <div class="mb-4 p-4 rounded-4 text-center" style="background: rgba(255, 77, 77, 0.08); border: 1px solid var(--primary-glow);">
                <div class="text-dim fw-bold mb-2" style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 2px;">Target Category</div>
                <div class="h3 fw-900 mb-2" style="color: #fff;">@ageGroup</div>
                <div class="text-dim small">
                    <i class="bi bi-info-circle me-1"></i> Dedicated lanes for your category: <b class="text-primary">Lanes @(ageGroup == "Adult" ? "11 - 20" : "1 - 10")</b>
                </div>
            </div>
            
            <div class="premium-card mb-4 p-4" style="background: rgba(255,255,255,0.02);">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-4">
                    <div>
                        <label class="form-label-premium mb-1">Number of Archers</label>
                        <p class="mb-0 text-dim small" id="laneRequiredHint">
                            <i class="bi bi-info-square me-1"></i> Minimum 1 lane recommended per 4 archers.
                        </p>
                    </div>
                    
                    <div class="counter-input-container">
                        <button class="counter-btn" onclick="updatePax(-1)"><i class="bi bi-dash"></i></button>
                        <div class="counter-input" id="paxDisplay" style="width: 60px;">1</div>
                        <button class="counter-btn" onclick="updatePax(1)"><i class="bi bi-plus"></i></button>
                        <input type="hidden" id="numberOfPax" value="1">
                    </div>
                </div>
            </div>

            <div id="target-hint" class="mb-4 fw-bold text-center text-dim" style="font-size: 0.9rem;">Select your preferred lane(s) on the grid.</div>
            
            <div id="targetsGrid" class="targets-grid"></div>

            <div class="wizard-actions d-flex justify-content-between mt-5">
                <button class="btn-premium-outline" onclick="goToStep2()">BACK</button>
                <button class="btn-premium" onclick="goToStep4()">CONFIRM BOOKING</button>
            </div>
        </div>
    </div>
</div>


<style>
    :root {
    --active-blue: var(--primary);
    --text-muted: #94a3b8;
}

.booking-wizard-container { max-width: 1100px; margin: 40px auto; }

.wizard-step { display: none; }
.wizard-step.active { display: block; }

.target-size-card { 
    background: rgba(255, 255, 255, 0.03); 
    border: 1px solid var(--card-border); 
    border-radius: 24px; 
    padding: 25px 15px; 
    cursor: pointer; 
    transition: var(--transition-smooth); 
    text-align: center; 
}

.target-size-card:hover { border-color: var(--primary); transform: translateY(-5px); }
.target-size-card.selected { background: var(--primary); border-color: var(--primary); }

.size-img-wrapper { 
    width: 90px; 
    height: 90px; 
    border-radius: 50%; 
    overflow: hidden; 
    margin: 0 auto 15px; 
    background: #fff; 
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 20px rgba(0,0,0,0.2);
}

.size-img-wrapper img { width: 85%; height: 85%; object-fit: contain; }

.size-name { display: block; font-weight: 800; font-size: 0.9rem; color: #fff; transition: var(--transition-smooth); }
.target-size-card.selected .size-name { color: #000; }

.size-info small { display: block; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 1px; opacity: 0.6; font-weight: 700; color: var(--text-dim); }
.target-size-card.selected small { color: #000; opacity: 0.8; }

.amount-btn { 
    width: 48px; 
    height: 48px; 
    border-radius: 50%; 
    border: 1px solid var(--card-border); 
    background: rgba(255, 255, 255, 0.05); 
    color: #fff;
    font-weight: 800; 
    cursor: pointer; 
    transition: var(--transition-smooth); 
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 5px;
}



.amount-btn.selected { background: var(--primary); color: #000; border: none; box-shadow: 0 5px 15px var(--primary-glow); }

.targets-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; margin-top: 20px; }

.target-box { 
    aspect-ratio: 1; 
    background: rgba(255, 255, 255, 0.03); 
    border: 1px solid var(--card-border); 
    border-radius: 16px; 
    display: flex; 
    flex-direction: column; 
    align-items: center; 
    justify-content: center; 
    cursor: pointer; 
    transition: var(--transition-smooth); 
}

.target-box:hover:not(.disabled) { border-color: var(--primary); transform: scale(1.05); }
.target-box.selected { background: var(--primary); color: #000; border: none; font-weight: 900; box-shadow: 0 10px 20px var(--primary-glow); }
.target-box.disabled { opacity: 0.4; cursor: not-allowed; filter: grayscale(1); background: rgba(255,255,255,0.01); border-color: rgba(255,255,255,0.05); }
.target-box.restricted { opacity: 0.5; cursor: not-allowed; position: relative; border-style: dashed; border-color: rgba(255,255,255,0.2); }


.fw-900 { font-weight: 900; }

.counter-btn {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--card-border);
    background: rgba(255, 255, 255, 0.05);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition-smooth);
}

.counter-btn:hover {
    background: var(--primary);
    color: #000;
    border-color: var(--primary);
}

.counter-input-container {
    display: flex;
    align-items: center;
    gap: 15px;
    background: rgba(255, 255, 255, 0.03);
    padding: 10px 20px;
    border-radius: 100px;
    border: 1px solid var(--card-border);
}
</style>


<script>
    let bookingData = {
        slotId: "@slotId",
        name: "@name",
        email: "@email",
        phone: "@phone",
        date: "@date",
        duration: "@duration",
        ageGroup: "@ageGroup",
        pax: 1,
        targetSize: null,
        targetAmount: 1,
        selectedTargetIds: [],
        totalPrice: 0,
        laneRanges: {}
    };

    function selectTargetSize(size) {
        bookingData.targetSize = size;
        bookingData.targetAmount = 1;
        document.querySelectorAll(".target-size-card").forEach(c => c.classList.remove("selected"));
        document.getElementById(`size-${size === "Intermediate" ? "Inter" : size}`).classList.add("selected");
        renderTargetAmounts();
    }

    function renderTargetAmounts() {
        const container = document.getElementById("targetAmountContainer");
        const hint = document.getElementById("amountHint");
        let max = 1;
        if (bookingData.targetSize === "Medium") max = 2;
        if (bookingData.targetSize === "Inter") max = 3;
        if (bookingData.targetSize === "Small") max = 4;
        
        container.innerHTML = "";
        for(let i=1; i<=max; i++) {
            const btn = document.createElement("button");
            btn.className = `amount-btn ${bookingData.targetAmount === i ? 'selected' : ''}`;
            btn.innerText = i;
            btn.onclick = () => { bookingData.targetAmount = i; renderTargetAmounts(); };
            container.appendChild(btn);
        }
        hint.innerText = bookingData.targetSize === "Large" ? "1 per lane limit." : `Up to ${max} per lane.`;
    }

    function updatePax(change) {
        let val = parseInt(document.getElementById("numberOfPax").value);
        val += change;
        if (val < 1) val = 1;
        if (val > 80) val = 80;
        
        document.getElementById("numberOfPax").value = val;
        document.getElementById("paxDisplay").innerText = val;
        bookingData.pax = val;

        // Calculate required lanes
        const requiredLanes = Math.ceil(val / 4);
        const hint = document.getElementById("laneRequiredHint");
        hint.innerHTML = `<i class="fas fa-info-circle me-1"></i> Min ${requiredLanes} Lane${requiredLanes > 1 ? 's' : ''} Required`;
        
        if (bookingData.selectedTargetIds.length < requiredLanes && bookingData.selectedTargetIds.length > 0) {
            hint.style.color = "#dc3545"; // Red if not enough lanes selected
        } else {
            hint.style.color = "var(--deep-blue)";
        }
    }

    function goToStep2() {
        document.getElementById("wizard-step-3").classList.remove("active");
        document.getElementById("wizard-step-2").classList.add("active");
        document.getElementById("step3-indicator").classList.remove("active");
    }

    async function goToStep3() {
        if (!bookingData.targetSize) { alert("Please select a size."); return; }
        
        document.getElementById("wizard-step-2").classList.remove("active");
        document.getElementById("wizard-step-3").classList.add("active");
        document.getElementById("step3-indicator").classList.add("active");

        const grid = document.getElementById("targetsGrid");
        grid.innerHTML = "<div class='text-center w-100 py-4'><div class='spinner-border text-success'></div><p class='mt-2'>Loading available lanes...</p></div>";
        
        try {
            const resp = await fetch(`/Booking/GetAvailableTargetsAjax?slotId=${bookingData.slotId}&date=${bookingData.date}&duration=${bookingData.duration}`);
            const availableTargets = await resp.json();
            
            grid.innerHTML = "";
            const isAdult = (bookingData.ageGroup === "Adult");

            for(let item of availableTargets) {
                const i = item.targetNumber;
                const status = item.status;
                const box = document.createElement("div");
                
                const isTaken = (status === 'Taken');
                const isMaintenance = (status === 'Maintenance');
                const isAdult = (bookingData.ageGroup === "Adult");
                const isRestricted = isAdult ? (i <= 10) : (i >= 11);
                
                box.className = `target-box ${isTaken || isMaintenance ? 'disabled' : ''} ${isRestricted ? 'restricted' : ''}`;
                
                let statusText = isMaintenance ? 'MAINTENANCE' : (isTaken ? 'Taken' : (isRestricted ? 'Restricted' : 'Open'));
                
                box.innerHTML = `
                    <span style="font-size: 1.2rem; font-weight: 800;">${i}</span>
                    <small style="font-size:0.5rem; text-transform: uppercase; opacity: 0.9; font-weight:800; letter-spacing: -0.2px;">${statusText}</small>
                `;

                if(!isTaken && !isRestricted && !isMaintenance) {
                    box.onclick = () => selectTarget(i);
                } else if (isRestricted) {
                    box.title = isAdult ? "Lanes 1-10 are for Kids/Juniors" : "Lanes 11-20 are for Adults";
                } else if (isMaintenance) {
                    box.style.background = "#ff6b6b";
                    box.style.color = "white";
                    box.title = "This lane is currently under maintenance.";
                }

                grid.appendChild(box);
            }
        } catch(e) { 
            grid.innerHTML = "<div class='text-center w-100 p-4 text-danger'>Error loading lanes. Please try again.</div>"; 
        }
    }

    function selectTarget(num) {
        const idx = bookingData.selectedTargetIds.indexOf(num);
        if (idx > -1) {
            bookingData.selectedTargetIds.splice(idx, 1);
        } else {
            bookingData.selectedTargetIds.push(num);
        }
        document.querySelectorAll(".target-box").forEach(b => b.classList.remove("selected"));
        bookingData.selectedTargetIds.forEach(id => {
            const el = document.querySelectorAll(".target-box")[id-1];
            if(el) el.classList.add("selected");
        });
    }

    function goToStep4() {
        bookingData.pax = parseInt(document.getElementById("numberOfPax").value);
        
        if (bookingData.selectedTargetIds.length === 0) { alert("Select a lane."); return; }
        
        // Validation: 1 lane max 4 pax
        const maxCapacity = bookingData.selectedTargetIds.length * 4;
        if (bookingData.pax > maxCapacity) {
            alert(`You have ${bookingData.pax} archers, but selected lanes can only accommodate ${maxCapacity} people. Please select more lanes (1 lane = max 4 people).`);
            return;
        }

        // Final price calculation (Simplified for now)
        const hour = 10; // Default morning
        bookingData.totalPrice = hour * bookingData.duration;

        const form = document.createElement("form");
        form.method = "POST";
        const isGuest = "@(ViewBag.IsGuest ?? false)".toLowerCase() === "true";
        form.action = isGuest ? "/Booking/PaymentGuest" : "/Booking/Payment";
        
        const fields = {
            SlotId: bookingData.slotId,
            CustomerName: bookingData.name,
            CustomerEmail: bookingData.email,
            PhoneNumber: bookingData.phone,
            Date: bookingData.date,
            Duration: bookingData.duration,
            TotalPrice: bookingData.totalPrice,
            SelectedLanes: bookingData.selectedTargetIds.join(", "),
            TargetSize: bookingData.targetSize,
            TargetAmount: bookingData.targetAmount,
            NumberOfPax: bookingData.pax
        };

        for (let k in fields) {
            const input = document.createElement("input");
            input.type = "hidden";
            input.name = k;
            input.value = fields[k];
            form.appendChild(input);
        }
        document.body.appendChild(form);
        form.submit();
    }
</script>
