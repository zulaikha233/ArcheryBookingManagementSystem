@model ArcheryAlley.Models.BookingSlots

<div class="container animate-in">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="text-center mb-5">
                <h1 class="hero-title" style="font-size: 2.8rem;">RESERVE <span style="color: #2b3a2a">LANE</span></h1>
                <p style="color: #b0b0b0">Finalize your archery session details below.</p>
            </div>

            <div class="premium-card">
                <form asp-action="ConfirmBooking" method="post">
                    <input type="hidden" name="SlotId" value="@Model.SlotId" />

                    <div class="mb-4">
                        <label class="form-label fw-bold text-uppercase" style="color: var(--primary); letter-spacing: 1px; font-size: 0.8rem">CUSTOMER NAME</label>
                        <div class="input-group">
                            <input type="text" name="CustomerName" class="form-control border-0 py-3" placeholder="Enter Full Name" required />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold text-uppercase" style="color: var(--primary); letter-spacing: 1px; font-size: 0.8rem">EMPLOYEE ID</label>
                        <div class="input-group">
                            <input type="text" name="EmpId" class="form-control border-0 py-3" placeholder="Your Staff ID" required />
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold" style="color: var(--primary); letter-spacing: 0.5px; font-size: 0.75rem">LANE ID</label>
                            <input type="text" value="@Model.SlotId.ToString("D2")" class="form-control border-0 py-2" style="background: #ffffff !important; color: #2b3a2a !important; font-weight: bold;" readonly />
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold text-uppercase text-muted" style="font-size: 0.8rem">START TIME</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-0"><i class="bi bi-clock"></i></span>
                            <input type="text" value="@Model.SlotStartTime.ToString(@"hh\:mm")" class="form-control border-0 py-2" style="background: #ffffff !important; color: #2b3a2a !important; font-weight: bold;" readonly />
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold text-uppercase text-muted" style="font-size: 0.8rem">END TIME</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-0"><i class="bi bi-clock-fill"></i></span>
                            <input type="text" value="@Model.SlotEndTime.ToString(@"hh\:mm")" class="form-control border-0 py-2" style="background: #ffffff !important; color: #2b3a2a !important; font-weight: bold;" readonly />
                        </div>
                    </div>

                    <div class="text-center mt-5">
                        <button type="submit" class="btn-premium py-3 px-5 shadow-lg">CONFIRM RESERVATION</button>
                    </div>
                </form>
            </div>

            <div class="text-center mt-4">
                <a href="@Url.Action("GetFreeSlots", "Booking")" class="text-decoration-none" style="color: #b0b0b0; font-size: 0.9rem">
                    ← Change Lane Selection
                </a>
            </div>
        </div>
    </div>
</div>

