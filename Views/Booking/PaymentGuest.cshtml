@model ArcheryAlley.Models.PaymentViewModel

@{
    ViewData["Title"] = "PAYMENT";
}

<div class="booking-wizard-container py-5" data-aos="fade-up">
    <div class="premium-card p-0 overflow-hidden">
                <div class="row g-0">
                    <!-- Left Column: Summary -->
                    <div class="col-lg-5 p-5" style="background: rgba(255, 77, 77, 0.03); border-right: 1px solid var(--card-border);">
                        <div class="mb-4 text-center">
                             <div class="mb-3">
                                 <i class="bi bi-receipt" style="font-size: 3rem; color: var(--primary);"></i>
                             </div>
                             <h2 class="hero-title" style="font-size: 1.8rem;">BOOKING <span>SUMMARY</span></h2>
                        </div>

                        <div class="summary-list">
                            <div class="summary-item">
                                <span class="label">Date</span>
                                <span class="value">@Model.Date</span>
                            </div>
                            <div class="summary-item">
                                <span class="label">Time</span>
                                <span class="value">@Model.Time</span>
                            </div>
                            <div class="summary-item">
                                <span class="label">Lanes</span>
                                <span class="value">@Model.SelectedLanes</span>
                            </div>
                            <div class="summary-item">
                                <span class="label">Pax</span>
                                <span class="value">@Model.NumberOfPax Archers</span>
                            </div>
                        </div>

                        <div class="total-box mt-5 text-center">
                            <p class="text-dim mb-1" style="font-size: 0.7rem; letter-spacing: 2px;">TOTAL AMOUNT</p>
                            <h1 style="color: var(--primary); font-weight: 900; font-size: 3rem;">RM @Model.TotalPrice.ToString("0.00")</h1>
                        </div>
                    </div>

                    <!-- Right Column: Payment Options -->
                    <div class="col-lg-7 p-5">
                        <h4 class="mb-4 text-dim fw-bold" style="font-size: 0.8rem; letter-spacing: 2px;">SELECT PAYMENT METHOD</h4>
                        
                        <div class="row g-4 mb-4">
                            <div class="col-md-4">
                                <label class="payment-method-card">
                                    <input type="radio" name="paymentMethod" value="fpx" checked onchange="togglePaymentUI()">
                                    <div class="method-card-content">
                                        <div class="icon-box"><i class="bi bi-bank"></i></div>
                                        <div class="title mt-2">Online Banking</div>
                                        <small class="text-dim">FPX</small>
                                    </div>
                                </label>
                            </div>
                            <div class="col-md-4">
                                <label class="payment-method-card">
                                    <input type="radio" name="paymentMethod" value="card" onchange="togglePaymentUI()">
                                    <div class="method-card-content">
                                        <div class="icon-box"><i class="bi bi-credit-card"></i></div>
                                        <div class="title mt-2">Credit / Card</div>
                                        <small class="text-dim">Visa/Master</small>
                                    </div>
                                </label>
                            </div>
                            <div class="col-md-4">
                                <label class="payment-method-card">
                                    <input type="radio" name="paymentMethod" value="counter" onchange="togglePaymentUI()">
                                    <div class="method-card-content">
                                        <div class="icon-box"><i class="bi bi-cash-stack"></i></div>
                                        <div class="title mt-2">At Counter</div>
                                        <small class="text-dim">Cash/QR</small>
                                    </div>
                                </label>
                            </div>
                        </div>

                        <!-- Payment Detail Boxes -->
                        <div id="fpxUI" class="payment-detail-box p-4 mb-4">
                            <label class="form-label-premium mb-2">Select Your Bank</label>
                            <select id="bankSelection" class="form-select">
                                <option value="">-- Choose Retail Bank --</option>
                                <option value="Maybank2U">Maybank2U</option>
                                <option value="CIMB Clicks">CIMB Clicks</option>
                                <option value="Public Bank">Public Bank</option>
                                <option value="RHB Now">RHB Now</option>
                                <option value="Bank Islam">Bank Islam</option>
                                <option value="AmBank">AmBank</option>
                            </select>
                            <p class="text-dim small mt-3 mb-0"><i class="bi bi-shield-lock me-1"></i> Redirecting to secure bank portal.</p>
                        </div>

                        <div id="cardUI" class="payment-detail-box p-4 mb-4" style="display: none;">
                            <label class="form-label-premium mb-2">Card Details</label>
                            <input type="text" class="form-control mb-3" placeholder="Card Number (0000 0000 0000 0000)">
                            <div class="row g-3">
                                <div class="col-6">
                                    <input type="text" class="form-control" placeholder="MM/YY">
                                </div>
                                <div class="col-6">
                                    <input type="text" class="form-control" placeholder="CVV">
                                </div>
                            </div>
                        </div>

                        <div class="price-breakdown mb-4">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-dim">Original Price</span>
                                <span class="fw-bold">RM @Model.TotalPrice.ToString("0.00")</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-dim">Taxes & Fees</span>
                                <span class="fw-bold" style="color: #22c55e;">INCLUDED</span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center pt-3 border-top" style="border-color: rgba(255,255,255,0.1) !important;">
                            <span class="fw-bold text-uppercase" style="letter-spacing: 1px;">Total Due</span>
                            <h2 class="m-0" style="color: var(--primary); font-weight: 800;">RM @Model.TotalPrice.ToString("0.00")</h2>
                        </div>

                        <button class="btn-premium w-100 mt-4 justify-content-center" id="confirmBtn" onclick="generateKioskCode()">
                            CONFIRM & PAY
                        </button>
                    </div>
                </div>
    </div>
</div>

<!-- Kiosk Success Modal -->
<div id="kioskModal" class="global-notif-overlay" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.9); backdrop-filter: blur(15px); display: none; align-items: center; justify-content: center; z-index: 2000; padding: 20px;">
    <div class="premium-card text-center" style="max-width: 500px; padding: 40px; height: auto; border-color: var(--primary);">
        <div class="mb-4">
            <i class="bi bi-check-circle-fill" style="font-size: 3.5rem; color: var(--primary);"></i>
        </div>
        <h2 class="fw-900 mb-2" style="font-size: 1.8rem;">BOOKING CONFIRMED!</h2>
        <p class="text-dim mb-4" style="font-size: 0.9rem;">Please show this code at the counter for payment and entry.</p>
        
        <div id="displayCode" style="font-size: 3.5rem; font-weight: 900; color: var(--primary); letter-spacing: 8px; border: 2px dashed var(--card-border); padding: 25px; border-radius: 20px; background: rgba(255, 77, 77, 0.05);">------</div>
        
        <button class="btn-premium w-100 justify-content-center mt-4" onclick="window.location.href='/'">
            DONE <i class="bi bi-house-door ms-2"></i>
        </button>
    </div>
</div>

<style>
    .booking-wizard-container {
        max-width: 1100px;
        margin: 0 auto;
    }
    .summary-item {
        display: flex;
        justify-content: space-between;
        padding: 15px 0;
        border-bottom: 1px solid var(--card-border);
    }
    .summary-item .label { color: var(--text-dim); font-size: 0.8rem; text-transform: uppercase; font-weight: 600; }
    .summary-item .value { color: #fff; font-weight: 700; }

    .payment-method-card { cursor: pointer; display: block; height: 100%; }
    .payment-method-card input { display: none; }
    
    .method-card-content {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--card-border);
        border-radius: 24px;
        padding: 25px 15px;
        text-align: center;
        transition: var(--transition-smooth);
        height: 100%;
        display: flex;
        flex-column: column;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }
    
    .payment-method-card:hover .method-card-content { border-color: var(--primary); transform: translateY(-5px); background: rgba(255, 255, 255, 0.05); }
    
    .payment-method-card input:checked + .method-card-content {
        border-color: var(--primary);
        background: var(--primary);
        box-shadow: 0 10px 20px var(--primary-glow);
    }

    .payment-method-card input:checked + .method-card-content .icon-box,
    .payment-method-card input:checked + .method-card-content .title,
    .payment-method-card input:checked + .method-card-content .text-dim {
        color: #000 !important;
        opacity: 1;
    }
    
    .icon-box {
        width: 50px;
        height: 50px;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.6rem;
        color: var(--primary);
        transition: var(--transition-smooth);
    }
    
    .method-card-content .title { display: block; font-weight: 800; color: #fff; font-size: 0.85rem; letter-spacing: 0.5px; transition: var(--transition-smooth); }
    .method-card-content small { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 1px; transition: var(--transition-smooth); }
    
    .payment-detail-box {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid var(--card-border);
        border-radius: 20px;
        animation: fadeInDown 0.3s ease;
    }

    .form-label-premium {
        font-size: 0.7rem;
        color: var(--text-dim);
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        display: block;
    }

    @@keyframes fadeInDown {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<script>
    function togglePaymentUI() {
        const method = document.querySelector('input[name="paymentMethod"]:checked').value;
        document.getElementById("fpxUI").style.display = (method === "fpx") ? "block" : "none";
        document.getElementById("cardUI").style.display = (method === "card") ? "block" : "none";
    }

    async function generateKioskCode() {
        const btn = document.getElementById("confirmBtn");
        const method = document.querySelector('input[name="paymentMethod"]:checked').value;

        // Validation for online payments
        if (method === 'fpx') {
            const bank = document.getElementById('bankSelection').value;
            if (!bank) {
                showNotif("Please select a bank to proceed with FPX payment.", 'warning');
                return;
            }
        }

        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> PROCESSING...';

        const formData = new FormData();
        formData.append("SlotId", "@Model.SlotId");
        formData.append("CustomerName", "@Model.CustomerName");
        formData.append("CustomerEmail", "@Model.CustomerEmail");
        const firstLane = "@Model.SelectedLanes".split(',')[0].trim();
        formData.append("TargetNo", firstLane);
        formData.append("RangeNo", "1");
        formData.append("Duration", "@Model.Duration");
        formData.append("TotalPrice", "@Model.TotalPrice");
        formData.append("SelectedLanes", "@Model.SelectedLanes");
        formData.append("SelectedLaneRanges", "@Model.SelectedLaneRanges");
        formData.append("NumberOfPax", "@Model.NumberOfPax");
        formData.append("RateCode", ""); 
        formData.append("PaymentMethod", method);

        try {
            const response = await fetch('/Booking/CreateCustomerBooking', {
                method: 'POST',
                body: formData
            });
            const result = await response.json();

            if (result.success) {
                document.getElementById("displayCode").innerText = result.bookingCode;
                document.getElementById("kioskModal").style.display = "flex";
            } else {
                showNotif("Error: " + result.message, 'error');
                btn.disabled = false;
                btn.innerHTML = 'CONFIRM & PAY <i class="bi bi-shield-check ms-2"></i>';
            }
        } catch (err) {
            showNotif("Connection error. Please try again.", 'error');
            btn.disabled = false;
            btn.innerHTML = 'CONFIRM & PAY <i class="bi bi-shield-check ms-2"></i>';
        }
    }
</script>
