@using Microsoft.AspNetCore.Http
@{
    var userRole = Context.Session.GetString("UserRole");
    var userName = Context.Session.GetString("UserName");
    var customerName = Context.Session.GetString("CustomerName");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Akma Archery</title>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;500;700;800;900&display=swap" rel="stylesheet">
    <!-- Bootstrap -->
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- AOS Library -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <!-- Custom Premium Styles -->
    <link href="~/css/archery_modern.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <!-- Flatpickr (Modern Calendar) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <style>
        .logout-btn-premium {
            color: #ff6b6b !important;
            border: 1px solid rgba(255, 107, 107, 0.2);
            width: 45px;
            height: 45px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            transition: var(--transition-smooth);
            background: rgba(255, 107, 107, 0.05);
            font-size: 1.2rem;
            position: relative;
        }

        .logout-btn-premium:hover {
            background: rgba(255, 107, 107, 0.15) !important;
            color: #ff5252 !important;
            transform: translateY(-2px) rotate(8deg);
            box-shadow: 0 5px 20px rgba(255, 107, 107, 0.2);
            border-color: rgba(255, 107, 107, 0.5);
        }

        .logout-btn-premium::before {
            content: 'Logout';
            position: absolute;
            bottom: -30px;
            right: 0;
            background: rgba(0,0,0,0.8);
            color: #fff;
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 0.7rem;
            opacity: 0;
            pointer-events: none;
            transition: var(--transition-smooth);
            white-space: nowrap;
        }

        .logout-btn-premium:hover::before {
            opacity: 1;
            bottom: -35px;
        }

        .back-btn-premium {
            color: var(--primary) !important;
            border: 1px solid rgba(255, 77, 77, 0.2);
            width: 45px;
            height: 45px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            transition: var(--transition-smooth);
            background: rgba(255, 77, 77, 0.05);
            font-size: 1.2rem;
            position: relative;
        }

        .back-btn-premium:hover {
            background: rgba(255, 77, 77, 0.15) !important;
            color: #fff !important;
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(255, 77, 77, 0.2);
            border-color: rgba(255, 77, 77, 0.5);
        }

        .back-btn-premium::before {
            content: 'Back';
            position: absolute;
            bottom: -30px;
            right: 0;
            background: rgba(0,0,0,0.8);
            color: #fff;
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 0.7rem;
            opacity: 0;
            pointer-events: none;
            transition: var(--transition-smooth);
            white-space: nowrap;
        }

        .back-btn-premium:hover::before {
            opacity: 1;
            bottom: -35px;
        }
    </style>
</head>
<body>
        @{
            var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
            var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
            
            bool isLoginPage = currentAction == "Login" || currentAction == "CustomerLogin" || currentAction == "CustomerRegister";
            bool isHomePage = currentController == "Home" && currentAction == "Index";
            bool isClassRegistration = currentController == "Account" && currentAction == "ClassRegistration";
            
            // Define booking process actions
            var bookingActions = new[] { "StaffBooking", "GetFreeSlots", "SelectionLane", "Payment", "PaymentGuest", "GuestBooking", "BookSlots" };
            bool isBookingProcess = currentController == "Booking" && bookingActions.Contains(currentAction);
            
            bool hideNavbar = isBookingProcess;
        }

        @if (!hideNavbar)
        {
            <nav class="navbar navbar-expand-lg glass-nav sticky-top">
                <div class="container-fluid d-flex align-items-center position-relative px-4">
                    <a class="navbar-brand d-flex align-items-center" href="@(userRole == "Member" ? Url.Action("MemberDashboard", "Account") : Url.Content("~/"))" style="position: absolute; left: 30px; z-index: 100;">
                        <img src="~/images/Archery_Logo.png" alt="Logo" class="navbar-logo" />
                        <span>AKMA</span>&nbsp;ARCHERY 
                    </a>
                    <button class="navbar-toggler ms-auto" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" style="border-color: var(--card-border); z-index: 101;">
                        <i class="bi bi-list" style="color: var(--primary); font-size: 1.5rem;"></i>
                    </button>
                    <div class="collapse navbar-collapse" id="navbarContent">
                        <ul class="navbar-nav mx-auto align-items-center">
                            <li class="nav-item">
                                <a class="nav-link" href="@(userRole == "Member" ? Url.Action("MemberDashboard", "Account") : Url.Action("Index", "Home"))">
                                    <i class="bi bi-house-door me-1"></i> Home
                                </a>
                            </li>
                            @if (userRole == "Member")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" href="@Url.Action("MemberDashboard", "Account")">
                                        <i class="bi bi-speedometer2 me-1"></i> Dashboard
                                    </a>
                                </li>
                            }
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("AboutUs", "Home")"><i class="bi bi-info-circle me-1"></i> About Us</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("ArcheryLevels", "Home")">
                                    <i class="bi bi-trophy me-1"></i> Archery Levels
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("Membership", "Home")">
                                    <i class="bi bi-card-checklist me-1"></i> Membership
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("GearSupport", "Home")"><i class="bi bi-gear me-1"></i> Gear Support</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="javascript:void(0)" onclick="showNotif('This feature is coming soon!', 'info')">
                                    <i class="bi bi-images me-1"></i> Gallery
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("ContactUs", "Home")"><i class="bi bi-envelope me-1"></i> Contact Us</a>
                            </li>

                            @if (userRole == "Staff")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" href="@Url.Action("StaffBooking", "Booking")"><i class="bi bi-cpu me-1"></i> Slot Reservation</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="@Url.Action("BookingHistory", "Booking")"><i class="bi bi-clock-history me-1"></i> Booking History</a>
                                </li>
                            }


                            @if (userRole == "Admin")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" href="@Url.Action("ManageSlots", "Slot")"><i class="bi bi-speedometer2 me-1"></i> Dashboard</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="@Url.Action("ManageRates", "Rate")"><i class="bi bi-tags me-1"></i> Rates</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="@Url.Action("ManageLanes", "Management")"><i class="bi bi-layers me-1"></i> Lanes</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="@Url.Action("Register", "Account")"><i class="bi bi-person-plus me-1"></i> Add Staff</a>
                                </li>
                            }
                        </ul>
                        
                    </div>
                @if ((!string.IsNullOrEmpty(userName) || !string.IsNullOrEmpty(customerName)) && !isLoginPage && !isHomePage && !isClassRegistration)
                {
                    <div style="position: absolute; right: 30px; top: 50%; transform: translateY(-50%); z-index: 100;">
                        <a class="logout-btn-premium" href="@Url.Action("Logout", "Account")" title="Logout">
                            <i class="bi bi-box-arrow-right"></i>
                        </a>
                    </div>
                }
            </nav>
        }
        else if ((!string.IsNullOrEmpty(userName) || !string.IsNullOrEmpty(customerName)) && !isLoginPage)
        {
            <!-- Floating Logout for Booking Process -->
            <div style="position: fixed; right: 30px; top: 30px; z-index: 9999;">
                <a class="logout-btn-premium" href="@Url.Action("Logout", "Account")" title="Logout" 
                   style="background: rgba(15, 23, 42, 0.8); backdrop-filter: blur(10px); border: 1px solid var(--card-border); box-shadow: 0 10px 30px rgba(0,0,0,0.5);">
                    <i class="bi bi-box-arrow-right"></i>
                </a>
            </div>
        }

    <main role="main">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <!-- Global Custom Notification Modal -->
    <div id="globalNotifOverlay" style="
        position: fixed; top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0,0,0,0.85); backdrop-filter: blur(15px);
        display: none; align-items: center; justify-content: center;
        z-index: 9999; opacity: 0; transition: opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1);">
        <div id="globalNotifBox" style="
            background: #0f172a;
            border: 1px solid var(--card-border);
            border-radius: 32px; padding: 50px 40px;
            text-align: center; max-width: 450px; width: 90%;
            box-shadow: 0 40px 100px rgba(0,0,0,0.8);
            transform: translateY(30px); transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);">
            <div id="globalNotifIcon" style="
                width: 80px; height: 80px; border-radius: 24px;
                display: flex; align-items: center; justify-content: center;
                font-size: 2.5rem; margin: 0 auto 25px;
                box-shadow: 0 15px 30px rgba(0,0,0,0.2);"></div>
            <h3 id="globalNotifTitle" style="color: #fff; font-weight: 800; margin-bottom: 10px; font-size: 1.5rem;">System Message</h3>
            <p id="globalNotifMsg" style="
                color: var(--text-dim); font-size: 1rem; line-height: 1.6;
                margin: 0 0 35px; font-family: 'Inter', sans-serif;"></p>
            <button onclick="closeNotif()" class="btn-premium w-100" style="justify-content: center;">
                CONTINUE
            </button>
        </div>
    </div>

    <script>
        // Initialize AOS
        AOS.init({
            duration: 1000,
            once: true,
            easing: 'ease-out-cubic'
        });

        function showNotif(message, type = 'info') {
            const overlay = document.getElementById('globalNotifOverlay');
            const icon    = document.getElementById('globalNotifIcon');
            const msg     = document.getElementById('globalNotifMsg');
            const box     = document.getElementById('globalNotifBox');
            const title   = document.getElementById('globalNotifTitle');

            const config = {
                error:   { bg: 'rgba(239, 68, 68, 0.1)',  border: '#ef4444', icon: 'bi-x-lg', color: '#ef4444', title: 'Action Failed' },
                warning: { bg: 'rgba(245, 158, 11, 0.1)', border: '#f59e0b', icon: 'bi-exclamation-triangle', color: '#f59e0b', title: 'Attention' },
                info:    { bg: 'rgba(255, 77, 77, 0.1)',   border: '#ff4d4d', icon: 'bi-info-circle', color: '#ff4d4d', title: 'System Info' }
            };

            const c = config[type] || config.info;
            icon.style.background = c.bg;
            icon.style.border     = `1px solid ${c.border}`;
            icon.style.color      = c.color;
            icon.innerHTML        = `<i class="bi ${c.icon}"></i>`;
            msg.textContent       = message;
            title.textContent     = c.title;
            title.style.color     = c.color;

            overlay.style.display = 'flex';
            setTimeout(() => {
                overlay.style.opacity = '1';
                box.style.transform = 'translateY(0)';
            }, 10);
        }

        function closeNotif() {
            const overlay = document.getElementById('globalNotifOverlay');
            const box     = document.getElementById('globalNotifBox');
            overlay.style.opacity = '0';
            box.style.transform = 'translateY(30px)';
            setTimeout(() => { overlay.style.display = 'none'; }, 400);
        }
    </script>
</body>
</html>




