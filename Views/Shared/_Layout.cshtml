@using Microsoft.AspNetCore.Http
@{
    var userRole = Context.Session.GetString("UserRole");
    var userName = Context.Session.GetString("UserName");
    var customerName = Context.Session.GetString("CustomerName");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Archery Arena</title>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;500;700;800&display=swap" rel="stylesheet">
    <!-- Bootstrap -->
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Custom Premium Styles -->
    <link href="~/css/archery_modern.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg glass-nav sticky-top">
        <div class="container">
            <a class="navbar-brand" href="~/">
                <span style="color: #8A9A5B">ARCHERY</span> ARENA
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarContent">
                <ul class="navbar-nav ms-auto align-items-center">
                    @if (userRole == "Staff")
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("StaffBooking", "Booking")"><i class="bi bi-cpu"></i> Slot Reservation</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("BookingHistory", "Booking")">Booking History</a>
                        </li>
                    }


                    @if (userRole == "Admin")
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("ManageSlots", "Slot")">Admin Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("ManageRates", "Rate")">Manage Rates</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("ManageLanes", "Management")">Manage Lanes</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Register", "Account")">Register Staff</a>
                        </li>
                    }
                    

                </ul>
                
                @if (!string.IsNullOrEmpty(userName) || !string.IsNullOrEmpty(customerName))
                {
                    <div style="position: absolute; right: 25px; top: 50%; transform: translateY(-50%);">
                        <a class="nav-link p-0" href="@Url.Action("Logout", "Account")" title="Logout">
                            <div class="logout-icon-wrapper">
                                <i class="bi bi-box-arrow-right" style="font-size: 1.5rem; color: #ff6b6b; transition: 0.3s;"></i>
                            </div>
                        </a>
                    </div>
                }
            </div>
        </div>
    </nav>

    <div class="container mt-4 animate-in">
        @if (!string.IsNullOrEmpty(userName) || !string.IsNullOrEmpty(customerName))
        {
            <div class="user-greeting mb-3" style="color: #8A9A5B; font-size: 0.9rem; font-weight: 500; letter-spacing: 0.5px;">
                <i class="bi bi-person-circle me-2" style="font-size: 1.1rem; vertical-align: middle;"></i>Hello, @(userName ?? customerName)
            </div>
        }
        @RenderBody()
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <!-- Global Custom Notification Modal -->
    <div id="globalNotifOverlay" style="
        position: fixed; top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0,0,0,0.7); backdrop-filter: blur(8px);
        display: none; align-items: center; justify-content: center;
        z-index: 9999; opacity: 0; transition: opacity 0.25s ease;">
        <div id="globalNotifBox" style="
            background: rgba(18, 20, 35, 0.95);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 20px; padding: 40px 36px;
            text-align: center; max-width: 420px; width: 90%;
            box-shadow: 0 25px 60px rgba(0,0,0,0.5);
            transform: scale(0.9); transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);">
            <div id="globalNotifIcon" style="
                width: 70px; height: 70px; border-radius: 50%;
                display: flex; align-items: center; justify-content: center;
                font-size: 2rem; margin: 0 auto 20px;"></div>
            <p id="globalNotifMsg" style="
                color: #ddd; font-size: 0.95rem; line-height: 1.6;
                margin: 0 0 28px; font-family: 'Inter', sans-serif;"></p>
            <button onclick="closeNotif()" style="
                background: linear-gradient(135deg, #8A9A5B, #6D7B48);
                color: #000; border: none; padding: 11px 36px;
                border-radius: 25px; font-weight: 700; font-size: 0.85rem;
                cursor: pointer; letter-spacing: 0.5px;
                transition: transform 0.2s, box-shadow 0.2s;">OK</button>
        </div>
    </div>

    <script>
        function showNotif(message, type = 'info') {
            const overlay = document.getElementById('globalNotifOverlay');
            const icon    = document.getElementById('globalNotifIcon');
            const msg     = document.getElementById('globalNotifMsg');

            const config = {
                error:   { bg: 'rgba(255,80,80,0.15)',  border: '#ff5050', symbol: '✕', color: '#ff6b6b' },
                warning: { bg: 'rgba(255,190,50,0.15)', border: '#ffbe32', symbol: '!', color: '#ffbe32' },
                info:    { bg: 'rgba(138,154,91,0.12)',   border: '#8A9A5B', symbol: 'i', color: '#8A9A5B' }
            };

            const c = config[type] || config.info;
            icon.style.background = c.bg;
            icon.style.border     = `2px solid ${c.border}`;
            icon.style.color      = c.color;
            icon.style.fontWeight = 'bold';
            icon.textContent      = c.symbol;
            msg.textContent       = message;

            overlay.style.display = 'flex';
            setTimeout(() => {
                overlay.style.opacity = '1';
                document.getElementById('globalNotifBox').style.transform = 'scale(1)';
            }, 10);
        }

        function closeNotif() {
            const overlay = document.getElementById('globalNotifOverlay');
            overlay.style.opacity = '0';
            document.getElementById('globalNotifBox').style.transform = 'scale(0.9)';
            setTimeout(() => { overlay.style.display = 'none'; }, 280);
        }
    </script>
</body>
</html>



