@{
    ViewData["Title"] = "Staff Dashboard";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Staff Dashboard — Archery Alley</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        :root {
            --primary: #f97316;
            --primary-dark: #c2410c;
            --red: #dc2626;
            --red-dark: #991b1b;
            --bg: #0a0a0a;
            --sidebar-bg: #111111;
            --card-bg: #1a1a1a;
            --card-border: rgba(255,255,255,0.07);
            --sidebar-width: 260px;
            --topbar-height: 60px;
            --text-light: #f1f5f9;
            --text-dim: #94a3b8;
            --white: #ffffff;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Outfit', sans-serif;
            background: var(--bg);
            color: var(--text-light);
            display: flex;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* ══════════════════════════════
           SIDEBAR
        ══════════════════════════════ */
        .sidebar {
            width: var(--sidebar-width);
            background: var(--sidebar-bg);
            min-height: 100vh;
            position: fixed;
            top: 0; left: 0;
            display: flex;
            flex-direction: column;
            z-index: 200;
            border-right: 1px solid rgba(255,255,255,0.06);
            transition: transform 0.3s ease, width 0.3s ease;
        }

        /* Collapsed state on desktop */
        .sidebar.collapsed { width: 68px; }

        .sidebar.collapsed .sidebar-logo span,
        .sidebar.collapsed .staff-badge,
        .sidebar.collapsed .nav-label,
        .sidebar.collapsed .nav-text,
        .sidebar.collapsed .logout-text { display: none; }

        .sidebar.collapsed .sidebar-logo { font-size: 0; }
        .sidebar.collapsed .sidebar-logo::before { content: '🏹'; font-size: 1.4rem; }
        .sidebar.collapsed .nav-item { justify-content: center; padding: 14px; }
        .sidebar.collapsed .nav-item i { width: auto; font-size: 1.3rem; }
        .sidebar.collapsed .logout-btn { justify-content: center; padding: 14px; }
        .sidebar.collapsed .sidebar-header { justify-content: center; padding: 20px 10px; }

        .sidebar-header {
            padding: 24px 20px 20px;
            border-bottom: 1px solid rgba(249,115,22,0.2);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .sidebar-logo {
            font-size: 1.1rem;
            font-weight: 800;
            color: var(--primary);
            letter-spacing: 1px;
            text-transform: uppercase;
            white-space: nowrap;
            overflow: hidden;
        }

        .sidebar-logo span {
            display: block;
            font-size: 0.68rem;
            color: rgba(255,255,255,0.35);
            font-weight: 400;
            letter-spacing: 2px;
            margin-top: 2px;
        }

        .sidebar-toggle-btn {
            background: none;
            border: none;
            color: rgba(255,255,255,0.4);
            font-size: 1.2rem;
            cursor: pointer;
            padding: 4px;
            border-radius: 6px;
            transition: 0.2s;
            flex-shrink: 0;
        }
        .sidebar-toggle-btn:hover { color: var(--primary); }

        .staff-badge {
            margin: 14px 16px;
            padding: 12px 14px;
            background: rgba(249,115,22,0.1);
            border: 1px solid rgba(249,115,22,0.25);
            border-radius: 12px;
            overflow: hidden;
            white-space: nowrap;
        }

        .staff-badge p {
            font-size: 0.62rem;
            color: rgba(255,255,255,0.35);
            text-transform: uppercase;
            letter-spacing: 1.5px;
            margin-bottom: 3px;
        }

        .staff-badge h6 { font-size: 0.9rem; color: #fff; font-weight: 600; }

        .sidebar-nav {
            flex: 1;
            padding: 12px 10px;
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        .nav-label {
            font-size: 0.6rem;
            color: rgba(255,255,255,0.2);
            text-transform: uppercase;
            letter-spacing: 2px;
            padding: 10px 8px 5px;
            font-weight: 600;
            white-space: nowrap;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 14px;
            border-radius: 10px;
            color: rgba(255,255,255,0.5);
            text-decoration: none;
            font-size: 0.88rem;
            font-weight: 500;
            transition: 0.2s;
            white-space: nowrap;
            overflow: hidden;
        }

        .nav-item:hover { background: rgba(249,115,22,0.1); color: var(--primary); }
        .nav-item.active {
            background: rgba(249,115,22,0.15);
            color: var(--primary);
            border-left: 3px solid var(--primary);
        }
        .nav-item i { font-size: 1.1rem; width: 20px; text-align: center; flex-shrink: 0; }

        .sidebar-footer {
            padding: 12px 10px;
            border-top: 1px solid rgba(255,255,255,0.06);
        }

        .logout-btn {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 14px;
            border-radius: 10px;
            color: rgba(220,38,38,0.7);
            text-decoration: none;
            font-size: 0.88rem;
            font-weight: 500;
            transition: 0.2s;
            white-space: nowrap;
            overflow: hidden;
        }
        .logout-btn:hover { background: rgba(220,38,38,0.1); color: var(--red); }

        /* ══════════════════════════════
           OVERLAY (mobile)
        ══════════════════════════════ */
        .sidebar-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.6);
            z-index: 199;
            backdrop-filter: blur(2px);
        }
        .sidebar-overlay.active { display: block; }

        /* ══════════════════════════════
           TOP BAR (mobile only)
        ══════════════════════════════ */
        .topbar {
            display: none;
            position: fixed;
            top: 0; left: 0; right: 0;
            height: var(--topbar-height);
            background: var(--sidebar-bg);
            border-bottom: 1px solid rgba(249,115,22,0.2);
            align-items: center;
            justify-content: space-between;
            padding: 0 16px;
            z-index: 150;
        }

        .topbar-logo {
            font-size: 1rem;
            font-weight: 800;
            color: var(--primary);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .topbar-menu-btn {
            background: none;
            border: none;
            color: rgba(255,255,255,0.7);
            font-size: 1.5rem;
            cursor: pointer;
            padding: 6px;
            border-radius: 8px;
            transition: 0.2s;
        }
        .topbar-menu-btn:hover { color: var(--primary); }

        /* ══════════════════════════════
           MAIN CONTENT
        ══════════════════════════════ */
        .main-content {
            margin-left: var(--sidebar-width);
            flex: 1;
            padding: 40px;
            min-height: 100vh;
            transition: margin-left 0.3s ease;
        }

        .main-content.sidebar-collapsed { margin-left: 68px; }

        .page-header { margin-bottom: 32px; }

        .page-header p {
            font-size: 0.78rem;
            color: var(--text-dim);
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 6px;
        }

        .page-header h1 { font-size: 2rem; font-weight: 800; letter-spacing: -0.5px; color: var(--white); }
        .page-header h1 span { color: var(--primary); }

        /* ══════════════════════════════
           STATUS BAR
        ══════════════════════════════ */
        .status-bar { display: flex; gap: 12px; margin-bottom: 28px; flex-wrap: wrap; }

        .status-chip {
            background: var(--card-bg);
            border: 1px solid rgba(249,115,22,0.2);
            border-radius: 50px;
            padding: 7px 16px;
            font-size: 0.78rem;
            font-weight: 600;
            color: var(--text-dim);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .status-dot {
            width: 7px; height: 7px;
            border-radius: 50%;
            background: var(--primary);
            animation: pulse 2s infinite;
        }

        /* ══════════════════════════════
           DASHBOARD GRID 2x2
        ══════════════════════════════ */
        .dashboard-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            max-width: 860px;
        }

        .dash-card {
            background: var(--card-bg);
            border-radius: 20px;
            padding: 28px 24px;
            text-decoration: none;
            color: var(--text-light);
            border: 1px solid var(--card-border);
            display: flex;
            flex-direction: column;
            gap: 14px;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .dash-card::before {
            content: '';
            position: absolute;
            top: 0; right: 0;
            width: 100px; height: 100px;
            background: rgba(249,115,22,0.05);
            border-radius: 50%;
            transform: translate(30px,-30px);
            transition: 0.3s;
        }

        .dash-card:hover { transform: translateY(-4px); color: var(--text-light); }
        .dash-card:hover::before { transform: translate(20px,-20px) scale(1.2); }

        .card-icon {
            width: 50px; height: 50px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.4rem;
            color: #fff;
        }

        .card-label { font-size: 0.62rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: 2px; font-weight: 600; }
        .card-title { font-size: 1.1rem; font-weight: 700; color: var(--white); line-height: 1.3; }
        .card-desc  { font-size: 0.8rem; color: var(--text-dim); line-height: 1.5; }

        .card-footer-row { display: flex; align-items: center; justify-content: space-between; margin-top: auto; }

        .card-tag { font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; padding: 3px 9px; border-radius: 20px; }
        .card-arrow { font-size: 1.1rem; transition: 0.2s; }
        .dash-card:hover .card-arrow { transform: translateX(4px); }

        /* Colour variants */
        .dash-card--orange { border-color: rgba(249,115,22,0.2); }
        .dash-card--orange:hover { border-color: var(--primary); box-shadow: 0 14px 36px rgba(249,115,22,0.18); }
        .dash-card--red    { border-color: rgba(220,38,38,0.2); }
        .dash-card--red:hover    { border-color: var(--red);     box-shadow: 0 14px 36px rgba(220,38,38,0.18); }
        .dash-card--white  { border-color: rgba(255,255,255,0.08); }
        .dash-card--white:hover  { border-color: rgba(255,255,255,0.35); box-shadow: 0 14px 36px rgba(255,255,255,0.05); }

        .card-icon--orange { background: linear-gradient(135deg,#f97316,#c2410c); box-shadow: 0 6px 18px rgba(249,115,22,0.4); }
        .card-icon--red    { background: linear-gradient(135deg,#dc2626,#7f1d1d); box-shadow: 0 6px 18px rgba(220,38,38,0.4); }
        .card-icon--white  { background: linear-gradient(135deg,#e2e8f0,#94a3b8); box-shadow: 0 6px 18px rgba(255,255,255,0.1); }
        .card-icon--fire   { background: linear-gradient(135deg,#f97316,#dc2626); box-shadow: 0 6px 18px rgba(220,38,38,0.5); }
        .card-icon--white i { color: #1a1a1a; }

        .card-arrow--orange { color: var(--primary); }
        .card-arrow--red    { color: var(--red); }
        .card-arrow--white  { color: rgba(255,255,255,0.55); }

        .card-tag--orange { background: rgba(249,115,22,0.15); color: var(--primary);           border: 1px solid rgba(249,115,22,0.3); }
        .card-tag--red    { background: rgba(220,38,38,0.15);  color: #f87171;                  border: 1px solid rgba(220,38,38,0.3); }
        .card-tag--white  { background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.45);  border: 1px solid rgba(255,255,255,0.1); }

        /* ══════════════════════════════
           ANIMATIONS
        ══════════════════════════════ */
        @@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
        @@keyframes fadeUp { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:translateY(0)} }

        .dash-card:nth-child(1){animation:fadeUp 0.4s ease both}
        .dash-card:nth-child(2){animation:fadeUp 0.5s ease both}
        .dash-card:nth-child(3){animation:fadeUp 0.6s ease both}
        .dash-card:nth-child(4){animation:fadeUp 0.7s ease both}

        /* ══════════════════════════════
           RESPONSIVE — TABLET / MOBILE
           Honor 200 Lite ≈ 390px wide
        ══════════════════════════════ */
        @@media (max-width: 768px) {
            .sidebar { transform: translateX(-100%); width: var(--sidebar-width) !important; }
            .sidebar.mobile-open { transform: translateX(0); }
            .sidebar-toggle-btn { display: none; }
            .topbar { display: flex; }
            .main-content { margin-left: 0 !important; padding: 76px 14px 24px; }
            .page-header h1 { font-size: 1.45rem; }
            .dashboard-grid { grid-template-columns: 1fr 1fr; gap: 12px; max-width: 100%; }
            .dash-card { padding: 18px 14px; border-radius: 16px; gap: 10px; }
            .card-icon { width: 42px; height: 42px; font-size: 1.2rem; border-radius: 12px; }
            .card-title { font-size: 0.92rem; }
            .card-desc  { font-size: 0.72rem; }
            .card-tag   { font-size: 0.55rem; padding: 2px 7px; }
            .status-chip { font-size: 0.7rem; padding: 5px 10px; }
        }

        /* Very small phones — single column */
        @@media (max-width: 380px) {
            .dashboard-grid { grid-template-columns: 1fr; }
            .card-desc { display: none; }
        }
    </style>
</head>
<body>

    <!-- ── OVERLAY (mobile tap to close) ── -->
    <div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

    <!-- ── TOP BAR (mobile only) ── -->
    <div class="topbar">
        <div class="topbar-logo">Archery Alley</div>
        <button class="topbar-menu-btn" onclick="openSidebar()" aria-label="Open menu">
            <i class="bi bi-list"></i>
        </button>
    </div>

    <!-- ── SIDEBAR ── -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <div class="sidebar-logo">
                Archery Alley
                <span>Staff Portal</span>
            </div>
            <button class="sidebar-toggle-btn" id="desktopToggle" onclick="toggleDesktopSidebar()" aria-label="Collapse sidebar">
                <i class="bi bi-layout-sidebar-reverse" id="toggleIcon"></i>
            </button>
        </div>

        <div class="staff-badge">
            <p>Logged in as</p>
            <h6>@(ViewBag.StaffName ?? "Staff")</h6>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-label">Menu</div>

            <a href="/Booking/StaffDashboard" class="nav-item active">
                <i class="bi bi-grid-fill"></i>
                <span class="nav-text">Dashboard</span>
            </a>
            <a href="/Account/Profile" class="nav-item">
                <i class="bi bi-person-circle"></i>
                <span class="nav-text">Profile</span>
            </a>
            <a href="/Attendance/Index" class="nav-item">
                <i class="bi bi-calendar-check"></i>
                <span class="nav-text">Student Attendance</span>
            </a>
            <a href="/Report/StudentPerformance" class="nav-item">
                <i class="bi bi-bar-chart-line"></i>
                <span class="nav-text">Performance Report</span>
            </a>
            <a href="/Booking/StaffBooking" class="nav-item">
                <i class="bi bi-bullseye"></i>
                <span class="nav-text">Slot Booking</span>
            </a>
        </nav>

        <div class="sidebar-footer">
            <a href="/Account/Logout" class="logout-btn">
                <i class="bi bi-box-arrow-left"></i>
                <span class="logout-text">Logout</span>
            </a>
        </div>
    </aside>

    <!-- ── MAIN CONTENT ── -->
    <main class="main-content" id="mainContent">

        <!-- ── 4 NAV BUTTONS IN A ROW ── -->
        <div class="nav-row">

            <a href="/Account/Profile" class="nav-btn-card nav-btn--orange">
                <div class="nav-btn-icon card-icon--orange"><i class="bi bi-person-fill"></i></div>
                <div class="nav-btn-text">
                    <div class="nav-btn-label">Account</div>
                    <div class="nav-btn-title">My Profile</div>
                </div>
                <i class="bi bi-arrow-right nav-btn-arrow nav-btn-arrow--orange"></i>
            </a>

            <a href="/Booking/StudentAttendance" class="nav-btn-card nav-btn--red">
                <div class="nav-btn-icon card-icon--red"><i class="bi bi-calendar-check-fill"></i></div>
                <div class="nav-btn-text">
                    <div class="nav-btn-label">Records</div>
                    <div class="nav-btn-title">Attendance</div>
                </div>
                <i class="bi bi-arrow-right nav-btn-arrow nav-btn-arrow--red"></i>
            </a>

            <a href="/Report/StudentPerformance" class="nav-btn-card nav-btn--white">
                <div class="nav-btn-icon card-icon--white"><i class="bi bi-bar-chart-fill"></i></div>
                <div class="nav-btn-text">
                    <div class="nav-btn-label">Analytics</div>
                    <div class="nav-btn-title">Performance</div>
                </div>
                <i class="bi bi-arrow-right nav-btn-arrow nav-btn-arrow--white"></i>
            </a>

            <a href="/Booking/StaffBooking" class="nav-btn-card nav-btn--orange">
                <div class="nav-btn-icon card-icon--fire"><i class="bi bi-bullseye"></i></div>
                <div class="nav-btn-text">
                    <div class="nav-btn-label">Reservations</div>
                    <div class="nav-btn-title">Slot Booking</div>
                </div>
                <i class="bi bi-arrow-right nav-btn-arrow nav-btn-arrow--orange"></i>
            </a>

        </div>

        <!-- ── MAIN INFO CONTAINER ── -->
        <div class="info-container">

            <!-- Greeting block -->
            <div class="info-greeting">
                <div class="greeting-icon">👋</div>
                <div>
                    <div class="greeting-sub">Welcome back, Coach</div>
                    <div class="greeting-name">@(ViewBag.StaffName ?? "Staff")</div>
                </div>
            </div>

            <div class="info-divider"></div>
            <!-- ── CLOCK IN CARD ── -->
            <div class="glass-card clock-card" id="clockCard">
                <div class="clock-left">
                    <div class="clock-icon" id="clockIcon">
                        <i class="bi bi-box-arrow-in-right"></i>
                    </div>
                    <div>
                        <div class="clock-title" id="clockTitle">Not Clocked In</div>
                        <div class="clock-sub" id="clockSub">You have not clocked in today</div>
                    </div>
                </div>
                <div class="clock-right">
                    <div class="clock-times" id="clockTimes" style="display:none;">
                        <div class="clock-time-item" id="clockInDisplay" style="display:none;">
                            <i class="bi bi-box-arrow-in-right" style="color:var(--present-color);"></i>
                            <span id="clockInTime">—</span>
                        </div>
                        <div class="clock-time-item" id="clockOutDisplay" style="display:none;">
                            <i class="bi bi-box-arrow-right" style="color:#f87171;"></i>
                            <span id="clockOutTime">—</span>
                        </div>
                    </div>
                    <button class="btn-clock" id="clockBtn" onclick="handleClock()">
                        <i class="bi bi-box-arrow-in-right"></i>
                        <span>Clock In</span>
                    </button>
                </div>
            </div>

            <!-- Date block -->
            <div class="info-date-block">
                <div class="info-date-day">@DateTime.Today.ToString("dddd")</div>
                <div class="info-date-full">@DateTime.Today.ToString("dd MMMM yyyy")</div>
                <div class="info-status-row">
                    <div class="status-dot-pulse"></div>
                    <span>System Online</span>
                </div>
            </div>

        </div>

    </main>

    <style>
        /* ── NAV ROW — 4 buttons in a single horizontal row ── */
        .nav-row {
            display: flex;
            gap: 16px;
            margin-bottom: 24px;
            flex-wrap: wrap;
        }

        .nav-btn-card {
            flex: 1;
            min-width: 140px;
            background: var(--card-bg);
            border-radius: 16px;
            padding: 16px 18px;
            text-decoration: none;
            color: var(--text-light);
            border: 1px solid var(--card-border);
            display: flex;
            align-items: center;
            gap: 12px;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .nav-btn-card:hover { transform: translateY(-3px); color: var(--text-light); }

        /* colour variants — reuse existing card colours */
        .nav-btn--orange { border-color: rgba(249,115,22,0.2); }
        .nav-btn--orange:hover { border-color: var(--primary); box-shadow: 0 10px 28px rgba(249,115,22,0.18); }
        .nav-btn--red    { border-color: rgba(220,38,38,0.2); }
        .nav-btn--red:hover    { border-color: var(--red);     box-shadow: 0 10px 28px rgba(220,38,38,0.18); }
        .nav-btn--white  { border-color: rgba(255,255,255,0.08); }
        .nav-btn--white:hover  { border-color: rgba(255,255,255,0.35); box-shadow: 0 10px 28px rgba(255,255,255,0.05); }

        .nav-btn-icon {
            width: 40px; height: 40px;
            border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.1rem; color: #fff; flex-shrink: 0;
        }

        .nav-btn-text { flex: 1; min-width: 0; }
        .nav-btn-label { font-size: 0.6rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: 1.5px; font-weight: 600; }
        .nav-btn-title { font-size: 0.9rem; font-weight: 700; color: var(--white); margin-top: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

        .nav-btn-arrow { font-size: 0.9rem; flex-shrink: 0; transition: 0.2s; }
        .nav-btn-card:hover .nav-btn-arrow { transform: translateX(3px); }
        .nav-btn-arrow--orange { color: var(--primary); }
        .nav-btn-arrow--red    { color: var(--red); }
        .nav-btn-arrow--white  { color: rgba(255,255,255,0.4); }

        /* ── INFO CONTAINER ── */
        .info-container {
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            border-radius: 24px;
            padding: 40px 48px;
            display: flex;
            align-items: center;
            gap: 48px;
            min-height: 200px;
            position: relative;
            overflow: hidden;
            animation: fadeUp 0.5s ease both;
        }

        /* subtle background glow */
        .info-container::before {
            content: '';
            position: absolute;
            top: -60px; right: -60px;
            width: 220px; height: 220px;
            background: radial-gradient(circle, rgba(249,115,22,0.08) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
        }

        /* Greeting */
        .info-greeting {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .greeting-icon {
            font-size: 3rem;
            line-height: 1;
            flex-shrink: 0;
        }

        .greeting-sub {
            font-size: 0.8rem;
            color: var(--text-dim);
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 600;
            margin-bottom: 6px;
        }

        .greeting-name {
            font-size: 2rem;
            font-weight: 800;
            color: var(--white);
            letter-spacing: -0.5px;
        }

        .greeting-name::first-letter {
            color: var(--primary);
        }

        /* Divider */
        .info-divider {
            width: 1px;
            height: 80px;
            background: rgba(255,255,255,0.08);
            flex-shrink: 0;
        }

        /* Date block */
        .info-date-block {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .info-date-day {
            font-size: 0.75rem;
            color: var(--primary);
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 700;
        }

        .info-date-full {
            font-size: 1.4rem;
            font-weight: 800;
            color: var(--white);
            letter-spacing: -0.3px;
        }

        .info-status-row {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.75rem;
            color: var(--text-dim);
            margin-top: 4px;
        }

        .status-dot-pulse {
            width: 8px; height: 8px;
            border-radius: 50%;
            background: var(--primary);
            animation: pulse 2s infinite;
            flex-shrink: 0;
        }

        /* ── RESPONSIVE ── */
        @@media (max-width: 768px) {
            .nav-row { gap: 10px; }
            .nav-btn-card { padding: 12px 14px; min-width: 0; }
            .nav-btn-title { font-size: 0.78rem; }
            .nav-btn-label { display: none; }
            .nav-btn-arrow { display: none; }
            .info-container { flex-direction: column; align-items: flex-start; gap: 20px; padding: 24px; min-height: auto; }
            .info-divider { width: 60px; height: 1px; }
            .greeting-name { font-size: 1.5rem; }
            .info-date-full { font-size: 1.1rem; }
        }

        @@media (max-width: 380px) {
            .nav-btn-icon { width: 34px; height: 34px; font-size: 0.95rem; }
            .nav-btn-title { font-size: 0.7rem; }
        }

        /* ── CLOCK IN CARD ── */
            .clock-card {
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 22px 28px;
                gap: 20px;
                flex-wrap: wrap;
                margin-top: 20px;
            }

            .clock-left {
                display: flex;
                align-items: center;
                gap: 16px;
            }

            .clock-icon {
                width: 46px; height: 46px;
                border-radius: 12px;
                background: rgba(249,115,22,0.12);
                border: 1px solid rgba(249,115,22,0.3);
                display: flex; align-items: center; justify-content: center;
                font-size: 1.3rem; color: var(--primary);
                flex-shrink: 0; transition: 0.3s;
            }
            .clock-icon.clocked { 
                background: rgba(52,211,153,0.12); 
                border-color: rgba(52,211,153,0.3); 
                color: #34D399; 
            }
            .clock-icon.done { 
                background: rgba(255,255,255,0.06); 
                border-color: rgba(255,255,255,0.1); 
                color: rgba(255,255,255,0.4); 
            }

            .clock-title { font-size: 0.95rem; font-weight: 700; color: var(--white); }
            .clock-sub   { font-size: 0.75rem; color: var(--text-dim); margin-top: 3px; }

            .clock-right {
                display: flex;
                align-items: center;
                gap: 16px;
                flex-wrap: wrap;
            }

            .clock-times { display: flex; gap: 16px; flex-wrap: wrap; }
            .clock-time-item {
                display: flex; align-items: center; gap: 6px;
                font-size: 0.82rem; font-weight: 600; color: var(--text-dim);
                background: var(--input-bg); border: 1px solid var(--card-border);
                border-radius: 8px; padding: 6px 12px;
            }

            .btn-clock {
                display: flex; align-items: center; gap: 8px;
                padding: 10px 22px; border-radius: var(--radius-sm);
                font-size: 0.85rem; font-weight: 700;
                cursor: pointer; font-family: 'Outfit', sans-serif;
                transition: 0.25s; border: none; white-space: nowrap;
                background: linear-gradient(135deg, var(--primary), var(--primary-dark));
                color: #fff; box-shadow: 0 6px 18px rgba(249,115,22,0.3);
            }
            .btn-clock:hover { transform: translateY(-2px); box-shadow: 0 10px 24px rgba(249,115,22,0.4); }
            .btn-clock.clocked {
                background: linear-gradient(135deg, #dc2626, #7f1d1d);
                box-shadow: 0 6px 18px rgba(220,38,38,0.3);
            }
            .btn-clock.clocked:hover { box-shadow: 0 10px 24px rgba(220,38,38,0.4); }
            .btn-clock.done {
                background: rgba(255,255,255,0.06);
                border: 1px solid rgba(255,255,255,0.1);
                color: var(--text-dim);
                box-shadow: none;
                cursor: not-allowed;
                transform: none;
            }
    </style>

    <script>
        const sidebar     = document.getElementById('sidebar');
        const mainContent = document.getElementById('mainContent');
        const overlay     = document.getElementById('sidebarOverlay');
        const toggleIcon  = document.getElementById('toggleIcon');

        // ── DESKTOP: collapse / expand ──
        function toggleDesktopSidebar() {
            const collapsed = sidebar.classList.toggle('collapsed');
            mainContent.classList.toggle('sidebar-collapsed', collapsed);
            toggleIcon.className = collapsed
                ? 'bi bi-layout-sidebar'
                : 'bi bi-layout-sidebar-reverse';
            localStorage.setItem('sidebarCollapsed', collapsed);
        }

        // ── MOBILE: open ──
        function openSidebar() {
            sidebar.classList.add('mobile-open');
            overlay.classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        // ── MOBILE: close ──
        function closeSidebar() {
            sidebar.classList.remove('mobile-open');
            overlay.classList.remove('active');
            document.body.style.overflow = '';
        }

        // Restore desktop collapsed state on page load
        window.addEventListener('DOMContentLoaded', () => {
            if (window.innerWidth > 768) {
                if (localStorage.getItem('sidebarCollapsed') === 'true') {
                    sidebar.classList.add('collapsed');
                    mainContent.classList.add('sidebar-collapsed');
                    toggleIcon.className = 'bi bi-layout-sidebar';
                }
            }
            loadClockStatus(); // Load clock status on page load
        });

        // Auto-close mobile sidebar when screen resizes to desktop
        window.addEventListener('resize', () => {
            if (window.innerWidth > 768) closeSidebar();
        });
                /* ── CLOCK IN/OUT ── */
        async function handleClock() {
            const btn = document.getElementById('clockBtn');
            const isClocked = btn.classList.contains('clocked');

            btn.disabled = true;

            try {
                const response = await fetch(isClocked ? '/Booking/ClockOut' : '/Booking/ClockIn', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' }
                });

                const result = await response.json();

                if (result.success) {
                    if (!isClocked) {
                        // Just clocked in
                        setClockState('clocked-in', result.time, null);
                    } else {
                        // Just clocked out
                        setClockState('completed', null, result.time);
                    }
                }
            } catch (err) {
                console.error('Clock error:', err);
            }

            btn.disabled = false;
        }

        function setClockState(status, clockIn, clockOut) {
            const btn      = document.getElementById('clockBtn');
            const icon     = document.getElementById('clockIcon');
            const title    = document.getElementById('clockTitle');
            const sub      = document.getElementById('clockSub');
            const times    = document.getElementById('clockTimes');
            const inDisp   = document.getElementById('clockInDisplay');
            const outDisp  = document.getElementById('clockOutDisplay');
            const inTime   = document.getElementById('clockInTime');
            const outTime  = document.getElementById('clockOutTime');

            if (status === 'clocked-in') {
                icon.className  = 'clock-icon clocked';
                icon.innerHTML  = '<i class="bi bi-check-circle-fill"></i>';
                title.textContent = 'Clocked In';
                sub.textContent   = `Clocked in at ${clockIn}`;
                btn.className   = 'btn-clock clocked';
                btn.innerHTML   = '<i class="bi bi-box-arrow-right"></i><span>Clock Out</span>';
                times.style.display  = '';
                inDisp.style.display = '';
                inTime.textContent   = clockIn;

            } else if (status === 'completed') {
                icon.className  = 'clock-icon done';
                icon.innerHTML  = '<i class="bi bi-moon-fill"></i>';
                title.textContent = 'Shift Complete';
                sub.textContent   = `Clocked out at ${clockOut}`;
                btn.className   = 'btn-clock done';
                btn.innerHTML   = '<i class="bi bi-check-lg"></i><span>Done for Today</span>';
                btn.disabled    = true;
                times.style.display   = '';
                outDisp.style.display = '';
                outTime.textContent   = clockOut;

            } else {
                // none — reset to default
                icon.className  = 'clock-icon';
                icon.innerHTML  = '<i class="bi bi-box-arrow-in-right"></i>';
                title.textContent = 'Not Clocked In';
                sub.textContent   = 'You have not clocked in today';
                btn.className   = 'btn-clock';
                btn.innerHTML   = '<i class="bi bi-box-arrow-in-right"></i><span>Clock In</span>';
                btn.disabled    = false;
                times.style.display = 'none';
            }
        }

        async function loadClockStatus() {
            try {
                const response = await fetch('/Booking/GetClockStatus');
                const result   = await response.json();

                if (result.status === 'clocked-in') {
                    setClockState('clocked-in', result.clockIn, null);
                    document.getElementById('clockInTime').textContent = result.clockIn;
                    document.getElementById('clockInDisplay').style.display = '';
                    document.getElementById('clockTimes').style.display = '';
                } else if (result.status === 'completed') {
                    setClockState('completed', null, result.clockOut);
                    document.getElementById('clockInTime').textContent  = result.clockIn;
                    document.getElementById('clockOutTime').textContent = result.clockOut;
                    document.getElementById('clockInDisplay').style.display  = '';
                    document.getElementById('clockOutDisplay').style.display = '';
                    document.getElementById('clockTimes').style.display = '';
                }
            } catch (err) {
                console.error('Load clock status error:', err);
            }
        }
    </script>

</body>
</html>
