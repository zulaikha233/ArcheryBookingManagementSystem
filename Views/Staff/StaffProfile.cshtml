@{
    ViewData["Title"] = "Staff Profile";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Profile — Archery Alley</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        :root {
            --primary: #f97316;
            --primary-dark: #c2410c;
            --red: #dc2626;
            --red-dark: #991b1b;
            --bg: #0a0a0a;
            --sidebar-bg: #111111;
            --card-bg: #1a1a1a;
            --card-border: rgba(255,255,255,0.07);
            --sidebar-width: 260px;
            --topbar-height: 60px;
            --text-light: #f1f5f9;
            --text-dim: #94a3b8;
            --white: #ffffff;
            --input-bg: #222222;
            --input-border: rgba(255,255,255,0.1);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Outfit', sans-serif;
            background: var(--bg);
            color: var(--text-light);
            display: flex;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* ------------------------------
           SIDEBAR (same as dashboard)
        ------------------------------ */
        .sidebar {
            width: var(--sidebar-width);
            background: var(--sidebar-bg);
            min-height: 100vh;
            position: fixed;
            top: 0; left: 0;
            display: flex;
            flex-direction: column;
            z-index: 200;
            border-right: 1px solid rgba(255,255,255,0.06);
            transition: transform 0.3s ease, width 0.3s ease;
        }

        .sidebar.collapsed { width: 68px; }
        .sidebar.collapsed .sidebar-logo span,
        .sidebar.collapsed .staff-badge,
        .sidebar.collapsed .nav-label,
        .sidebar.collapsed .nav-text,
        .sidebar.collapsed .logout-text { display: none; }
        .sidebar.collapsed .sidebar-logo { font-size: 0; }
        .sidebar.collapsed .sidebar-logo::before { content: '??'; font-size: 1.4rem; }
        .sidebar.collapsed .nav-item { justify-content: center; padding: 14px; }
        .sidebar.collapsed .nav-item i { width: auto; font-size: 1.3rem; }
        .sidebar.collapsed .logout-btn { justify-content: center; padding: 14px; }
        .sidebar.collapsed .sidebar-header { justify-content: center; padding: 20px 10px; }

        .sidebar-header {
            padding: 24px 20px 20px;
            border-bottom: 1px solid rgba(249,115,22,0.2);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .sidebar-logo {
            font-size: 1.1rem;
            font-weight: 800;
            color: var(--primary);
            letter-spacing: 1px;
            text-transform: uppercase;
            white-space: nowrap;
            overflow: hidden;
        }

        .sidebar-logo span {
            display: block;
            font-size: 0.68rem;
            color: rgba(255,255,255,0.35);
            font-weight: 400;
            letter-spacing: 2px;
            margin-top: 2px;
        }

        .sidebar-toggle-btn {
            background: none; border: none;
            color: rgba(255,255,255,0.4);
            font-size: 1.2rem; cursor: pointer;
            padding: 4px; border-radius: 6px; transition: 0.2s; flex-shrink: 0;
        }
        .sidebar-toggle-btn:hover { color: var(--primary); }

        .staff-badge {
            margin: 14px 16px; padding: 12px 14px;
            background: rgba(249,115,22,0.1);
            border: 1px solid rgba(249,115,22,0.25);
            border-radius: 12px; overflow: hidden; white-space: nowrap;
        }
        .staff-badge p { font-size: 0.62rem; color: rgba(255,255,255,0.35); text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 3px; }
        .staff-badge h6 { font-size: 0.9rem; color: #fff; font-weight: 600; }

        .sidebar-nav { flex: 1; padding: 12px 10px; display: flex; flex-direction: column; gap: 2px; }

        .nav-label { font-size: 0.6rem; color: rgba(255,255,255,0.2); text-transform: uppercase; letter-spacing: 2px; padding: 10px 8px 5px; font-weight: 600; white-space: nowrap; }

        .nav-item {
            display: flex; align-items: center; gap: 12px;
            padding: 12px 14px; border-radius: 10px;
            color: rgba(255,255,255,0.5); text-decoration: none;
            font-size: 0.88rem; font-weight: 500; transition: 0.2s;
            white-space: nowrap; overflow: hidden;
        }
        .nav-item:hover { background: rgba(249,115,22,0.1); color: var(--primary); }
        .nav-item.active { background: rgba(249,115,22,0.15); color: var(--primary); border-left: 3px solid var(--primary); }
        .nav-item i { font-size: 1.1rem; width: 20px; text-align: center; flex-shrink: 0; }

        .sidebar-footer { padding: 12px 10px; border-top: 1px solid rgba(255,255,255,0.06); }

        .logout-btn {
            display: flex; align-items: center; gap: 10px;
            padding: 12px 14px; border-radius: 10px;
            color: rgba(220,38,38,0.7); text-decoration: none;
            font-size: 0.88rem; font-weight: 500; transition: 0.2s;
            white-space: nowrap; overflow: hidden;
        }
        .logout-btn:hover { background: rgba(220,38,38,0.1); color: var(--red); }

        /* ------------------------------
           OVERLAY + TOPBAR (mobile)
        ------------------------------ */
        .sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 199; backdrop-filter: blur(2px); }
        .sidebar-overlay.active { display: block; }

        .topbar {
            display: none; position: fixed;
            top: 0; left: 0; right: 0;
            height: var(--topbar-height);
            background: var(--sidebar-bg);
            border-bottom: 1px solid rgba(249,115,22,0.2);
            align-items: center; justify-content: space-between;
            padding: 0 16px; z-index: 150;
        }
        .topbar-logo { font-size: 1rem; font-weight: 800; color: var(--primary); text-transform: uppercase; letter-spacing: 1px; }
        .topbar-menu-btn { background: none; border: none; color: rgba(255,255,255,0.7); font-size: 1.5rem; cursor: pointer; padding: 6px; border-radius: 8px; transition: 0.2s; }
        .topbar-menu-btn:hover { color: var(--primary); }

        /* ------------------------------
           MAIN CONTENT
        ------------------------------ */
        .main-content {
            margin-left: var(--sidebar-width);
            flex: 1; padding: 40px;
            min-height: 100vh;
            transition: margin-left 0.3s ease;
        }
        .main-content.sidebar-collapsed { margin-left: 68px; }

        /* ------------------------------
           PAGE HEADER
        ------------------------------ */
        .page-header { margin-bottom: 32px; }
        .page-header p { font-size: 0.78rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: 2px; margin-bottom: 6px; }
        .page-header h1 { font-size: 2rem; font-weight: 800; letter-spacing: -0.5px; color: var(--white); }
        .page-header h1 span { color: var(--primary); }

        /* ------------------------------
           PROFILE LAYOUT
        ------------------------------ */
        .profile-grid {
            display: grid;
            grid-template-columns: 300px 1fr;
            gap: 24px;
            max-width: 1000px;
        }

        .profile-card {
            background: var(--card-bg);
            border-radius: 20px;
            border: 1px solid var(--card-border);
            padding: 32px 24px;
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            gap: 16px;
        }

        /* -- Avatar -- */
        .avatar-wrap {
            position: relative;
            width: 120px; height: 120px;
        }

        .avatar-img {
            width: 120px; height: 120px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid rgba(249,115,22,0.4);
            box-shadow: 0 0 0 6px rgba(249,115,22,0.08);
            background: #2a2a2a;
        }

        .avatar-placeholder {
            width: 120px; height: 120px;
            border-radius: 50%;
            background: linear-gradient(135deg, #1f1f1f, #2a2a2a);
            border: 3px solid rgba(249,115,22,0.4);
            box-shadow: 0 0 0 6px rgba(249,115,22,0.08);
            display: flex; align-items: center; justify-content: center;
            font-size: 3rem; color: rgba(255,255,255,0.2);
        }

        .avatar-upload-btn {
            position: absolute;
            bottom: 4px; right: 4px;
            width: 32px; height: 32px;
            background: var(--primary);
            border: none; border-radius: 50%;
            color: #fff; font-size: 0.85rem;
            cursor: pointer; display: none;
            align-items: center; justify-content: center;
            box-shadow: 0 4px 12px rgba(249,115,22,0.5);
            transition: 0.2s;
        }
        .avatar-upload-btn:hover { background: var(--primary-dark); transform: scale(1.1); }
        .avatar-upload-btn.visible { display: flex; }

        #avatarFileInput { display: none; }

        /* -- Coach badge -- */
        .coach-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 5px 14px;
            border-radius: 20px;
            font-size: 0.72rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            background: rgba(249,115,22,0.15);
            color: var(--primary);
            border: 1px solid rgba(249,115,22,0.3);
        }

        .coach-badge.full-time { background: rgba(220,38,38,0.15); color: #f87171; border-color: rgba(220,38,38,0.3); }
        .coach-badge.guest     { background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.5); border-color: rgba(255,255,255,0.12); }

        .staff-name-display { font-size: 1.3rem; font-weight: 800; color: var(--white); }
        .staff-id-display   { font-size: 0.75rem; color: var(--text-dim); letter-spacing: 1px; }

        /* Admin-only notice */
        .admin-lock-note {
            display: flex; align-items: center; gap: 6px;
            font-size: 0.7rem; color: var(--text-dim);
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 8px; padding: 8px 12px;
            margin-top: 4px;
        }

        /* -- Info card (right column) -- */
        .info-card {
            background: var(--card-bg);
            border-radius: 20px;
            border: 1px solid var(--card-border);
            padding: 32px;
        }

        .info-card-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 28px;
        }

        .info-card-title { font-size: 1rem; font-weight: 700; color: var(--white); }
        .info-card-sub   { font-size: 0.75rem; color: var(--text-dim); margin-top: 2px; }

        .edit-btn {
            display: flex; align-items: center; gap: 8px;
            padding: 9px 18px;
            background: rgba(249,115,22,0.12);
            border: 1px solid rgba(249,115,22,0.3);
            border-radius: 10px;
            color: var(--primary);
            font-size: 0.82rem; font-weight: 600;
            cursor: pointer; transition: 0.2s;
        }
        .edit-btn:hover { background: rgba(249,115,22,0.2); }

        .save-btn {
            display: none; align-items: center; gap: 8px;
            padding: 9px 18px;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            border: none; border-radius: 10px;
            color: #fff; font-size: 0.82rem; font-weight: 700;
            cursor: pointer; transition: 0.2s;
            box-shadow: 0 4px 14px rgba(249,115,22,0.3);
        }
        .save-btn:hover { transform: translateY(-1px); box-shadow: 0 6px 18px rgba(249,115,22,0.4); }
        .save-btn.visible { display: flex; }

        .cancel-btn {
            display: none; align-items: center; gap: 6px;
            padding: 9px 14px;
            background: transparent;
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 10px;
            color: var(--text-dim); font-size: 0.82rem; font-weight: 600;
            cursor: pointer; transition: 0.2s; margin-right: 8px;
        }
        .cancel-btn:hover { border-color: rgba(255,255,255,0.25); color: var(--white); }
        .cancel-btn.visible { display: flex; }

        /* -- Field rows -- */
        .fields-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .field-group { display: flex; flex-direction: column; gap: 6px; }
        .field-group.full-width { grid-column: 1 / -1; }

        .field-label {
            font-size: 0.65rem;
            color: var(--text-dim);
            text-transform: uppercase;
            letter-spacing: 1.8px;
            font-weight: 600;
            display: flex; align-items: center; gap: 6px;
        }

        .field-label i { font-size: 0.8rem; color: var(--primary); }

        /* View mode value */
        .field-value {
            font-size: 0.95rem;
            color: var(--white);
            font-weight: 500;
            padding: 10px 0;
            border-bottom: 1px solid rgba(255,255,255,0.05);
            min-height: 42px;
        }

        .field-value.empty { color: var(--text-dim); font-style: italic; font-size: 0.85rem; }

        /* Edit mode input */
        .field-input {
            display: none;
            background: var(--input-bg);
            border: 1px solid var(--input-border);
            border-radius: 10px;
            padding: 10px 14px;
            color: var(--white);
            font-size: 0.92rem;
            font-family: 'Outfit', sans-serif;
            width: 100%;
            transition: 0.2s;
        }
        .field-input:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 0 3px rgba(249,115,22,0.1); }
        .field-input.visible { display: block; }

        select.field-input option { background: #1a1a1a; color: var(--white); }

        /* Coach title locked state */
        .field-input.locked {
            opacity: 0.5;
            cursor: not-allowed;
            pointer-events: none;
            border-style: dashed;
        }

        /* Divider */
        .section-divider {
            grid-column: 1 / -1;
            border: none;
            border-top: 1px solid rgba(255,255,255,0.05);
            margin: 4px 0;
        }

        .section-title {
            grid-column: 1 / -1;
            font-size: 0.7rem;
            color: var(--primary);
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 700;
            padding-top: 4px;
        }

        /* Save success toast */
        .toast {
            position: fixed;
            bottom: 30px; right: 30px;
            background: #1a1a1a;
            border: 1px solid rgba(249,115,22,0.4);
            border-radius: 14px;
            padding: 14px 20px;
            display: flex; align-items: center; gap: 12px;
            font-size: 0.88rem; font-weight: 600;
            color: var(--white);
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            transform: translateY(80px);
            opacity: 0;
            transition: all 0.4s cubic-bezier(0.175,0.885,0.32,1.275);
            z-index: 9999;
        }
        .toast.show { transform: translateY(0); opacity: 1; }
        .toast i { color: var(--primary); font-size: 1.2rem; }

        /* ------------------------------
           ANIMATIONS
        ------------------------------ */
        @@keyframes fadeUp { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:translateY(0)} }
        .profile-card { animation: fadeUp 0.4s ease both; }
        .info-card    { animation: fadeUp 0.5s ease both; }

        /* ------------------------------
           RESPONSIVE
        ------------------------------ */
        @@media (max-width: 768px) {
            .sidebar { transform: translateX(-100%); width: var(--sidebar-width) !important; }
            .sidebar.mobile-open { transform: translateX(0); }
            .sidebar-toggle-btn { display: none; }
            .topbar { display: flex; }
            .main-content { margin-left: 0 !important; padding: 76px 14px 24px; }
            .page-header h1 { font-size: 1.45rem; }
            .profile-grid { grid-template-columns: 1fr; }
            .profile-card { flex-direction: row; text-align: left; padding: 20px; gap: 20px; align-items: flex-start; flex-wrap: wrap; }
            .avatar-wrap { flex-shrink: 0; }
            .fields-grid { grid-template-columns: 1fr; }
            .info-card { padding: 20px; }
        }

        @@media (max-width: 480px) {
            .profile-card { flex-direction: column; align-items: center; text-align: center; }
            .fields-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

    <!-- -- OVERLAY -- -->
    <div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

    <!-- -- TOPBAR (mobile) -- -->
    <div class="topbar">
        <div class="topbar-logo">Archery Alley</div>
        <button class="topbar-menu-btn" onclick="openSidebar()"><i class="bi bi-list"></i></button>
    </div>

    <!-- -- SIDEBAR -- -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <div class="sidebar-logo">
                Archery Alley
                <span>Staff Portal</span>
            </div>
            <button class="sidebar-toggle-btn" id="desktopToggle" onclick="toggleDesktopSidebar()">
                <i class="bi bi-layout-sidebar-reverse" id="toggleIcon"></i>
            </button>
        </div>

        <div class="staff-badge">
            <p>Logged in as</p>
            <h6 id="sidebarName">@(ViewBag.StaffName ?? "Staff")</h6>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-label">Menu</div>
            <a href="/Booking/StaffDashboard" class="nav-item">
                <i class="bi bi-grid-fill"></i><span class="nav-text">Dashboard</span>
            </a>
            <a href="/Account/Profile" class="nav-item active">
                <i class="bi bi-person-circle"></i><span class="nav-text">Profile</span>
            </a>
            <a href="/Booking/StudentAttendance" class="nav-item">
                <i class="bi bi-calendar-check"></i><span class="nav-text">Student Attendance</span>
            </a>
            <a href="/Report/StudentPerformance" class="nav-item">
                <i class="bi bi-bar-chart-line"></i><span class="nav-text">Performance Report</span>
            </a>
            <a href="/Booking/StaffBooking" class="nav-item">
                <i class="bi bi-bullseye"></i><span class="nav-text">Slot Booking</span>
            </a>
        </nav>

        <div class="sidebar-footer">
            <a href="/Account/Logout" class="logout-btn">
                <i class="bi bi-box-arrow-left"></i>
                <span class="logout-text">Logout</span>
            </a>
        </div>
    </aside>

    <!-- -- MAIN CONTENT -- -->
    <main class="main-content" id="mainContent">

        <div class="page-header">
            <p>Staff Portal</p>
            <h1>My <span>Profile</span></h1>
        </div>

        <div class="profile-grid">

            <!-- -- LEFT: Avatar + identity card -- -->
            <div class="profile-card">
                <div class="avatar-wrap">
                    <!-- Shows image if uploaded, otherwise icon placeholder -->
                    <div class="avatar-placeholder" id="avatarPlaceholder">
                        <i class="bi bi-person-fill"></i>
                    </div>
                    <img class="avatar-img" id="avatarImg" src="" alt="Profile" style="display:none;">
                    <button class="avatar-upload-btn" id="avatarUploadBtn" onclick="document.getElementById('avatarFileInput').click()" title="Change photo">
                        <i class="bi bi-camera-fill"></i>
                    </button>
                    <input type="file" id="avatarFileInput" accept="image/*" onchange="handleAvatarUpload(event)">
                </div>

                <div>
                    <div class="staff-name-display" id="displayName">@(ViewBag.StaffName ?? "Staff Member")</div>
                    <div class="staff-id-display" style="margin-top:4px;">ID: @(ViewBag.EmpId ?? "—")</div>
                </div>

                <!-- Coach title badge -->
                <div class="coach-badge part-time" id="coachBadge">
                    <i class="bi bi-patch-check-fill"></i>
                    <span id="coachBadgeText">Part Time Coach</span>
                </div>

                <!-- Lock notice -->
                <div class="admin-lock-note">
                    <i class="bi bi-lock-fill" style="color: var(--text-dim); font-size: 0.75rem;"></i>
                    Coach title can only be changed by Admin
                </div>
            </div>

            <!-- -- RIGHT: Info fields -- -->
            <div class="info-card">
                <div class="info-card-header">
                    <div>
                        <div class="info-card-title">Personal Information</div>
                        <div class="info-card-sub">Keep your details up to date</div>
                    </div>
                    <div style="display:flex; gap:8px; align-items:center;">
                        <button class="cancel-btn" id="cancelBtn" onclick="cancelEdit()">
                            <i class="bi bi-x-lg"></i> Cancel
                        </button>
                        <button class="save-btn" id="saveBtn" onclick="saveProfile()">
                            <i class="bi bi-check-lg"></i> Save
                        </button>
                        <button class="edit-btn" id="editBtn" onclick="enterEditMode()">
                            <i class="bi bi-pencil"></i> Edit Profile
                        </button>
                    </div>
                </div>

                <div class="fields-grid">

                    <!-- Section: Basic Info -->
                    <div class="section-title">Basic Info</div>

                    <!-- Full Name -->
                    <div class="field-group">
                        <div class="field-label"><i class="bi bi-person"></i> Full Name</div>
                        <div class="field-value" id="val-name">@(ViewBag.StaffName ?? "—")</div>
                        <input class="field-input" id="inp-name" type="text" placeholder="Enter full name" value="@(ViewBag.StaffName ?? "")">
                    </div>

                    <!-- Gender -->
                    <div class="field-group">
                        <div class="field-label"><i class="bi bi-gender-ambiguous"></i> Gender</div>
                        <div class="field-value empty" id="val-gender">Not set</div>
                        <select class="field-input" id="inp-gender">
                            <option value="">Select gender</option>
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                            <option value="Prefer not to say">Prefer not to say</option>
                        </select>
                    </div>

                    <!-- Email -->
                    <div class="field-group">
                        <div class="field-label"><i class="bi bi-envelope"></i> Email</div>
                        <div class="field-value empty" id="val-email">Not set</div>
                        <input class="field-input" id="inp-email" type="email" placeholder="staff@example.com">
                    </div>

                    <!-- Phone -->
                    <div class="field-group">
                        <div class="field-label"><i class="bi bi-phone"></i> Phone Number</div>
                        <div class="field-value empty" id="val-phone">Not set</div>
                        <input class="field-input" id="inp-phone" type="tel" placeholder="e.g. 01X-XXXXXXX">
                    </div>

                    <hr class="section-divider">

                    <!-- Section: Emergency -->
                    <div class="section-title">Emergency Contact</div>

                    <!-- Emergency Contact Name -->
                    <div class="field-group">
                        <div class="field-label"><i class="bi bi-person-exclamation"></i> Contact Name</div>
                        <div class="field-value empty" id="val-emgname">Not set</div>
                        <input class="field-input" id="inp-emgname" type="text" placeholder="Emergency contact name">
                    </div>

                    <!-- Emergency Contact Phone -->
                    <div class="field-group">
                        <div class="field-label"><i class="bi bi-telephone-forward"></i> Contact Phone</div>
                        <div class="field-value empty" id="val-emgphone">Not set</div>
                        <input class="field-input" id="inp-emgphone" type="tel" placeholder="e.g. 01X-XXXXXXX">
                    </div>

                    <hr class="section-divider">

                    <!-- Section: Role -->
                    <div class="section-title">Role & Title</div>

                    <!-- Coach Title (locked, admin only) -->
                    <div class="field-group full-width">
                        <div class="field-label"><i class="bi bi-patch-check"></i> Coach Title <span style="color:var(--text-dim); font-size:0.6rem; font-weight:400; margin-left:4px;">(Admin only)</span></div>
                        <div class="field-value" id="val-coach">Part Time Coach</div>
                        <select class="field-input locked" id="inp-coach" disabled>
                            <option value="Part Time">Part Time Coach</option>
                            <option value="Full Time">Full Time Coach</option>
                            <option value="Guest">Guest Coach</option>
                        </select>
                    </div>

                </div>
            </div>
        </div>
    </main>

    <!-- -- SAVE TOAST -- -->
    <div class="toast" id="saveToast">
        <i class="bi bi-check-circle-fill"></i>
        Profile updated successfully!
    </div>

    <script>
        /* ------------------------------
           SIDEBAR LOGIC
        ------------------------------ */
        const sidebar     = document.getElementById('sidebar');
        const mainContent = document.getElementById('mainContent');
        const overlay     = document.getElementById('sidebarOverlay');
        const toggleIcon  = document.getElementById('toggleIcon');

        function toggleDesktopSidebar() {
            const collapsed = sidebar.classList.toggle('collapsed');
            mainContent.classList.toggle('sidebar-collapsed', collapsed);
            toggleIcon.className = collapsed ? 'bi bi-layout-sidebar' : 'bi bi-layout-sidebar-reverse';
            localStorage.setItem('sidebarCollapsed', collapsed);
        }

        function openSidebar() {
            sidebar.classList.add('mobile-open');
            overlay.classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function closeSidebar() {
            sidebar.classList.remove('mobile-open');
            overlay.classList.remove('active');
            document.body.style.overflow = '';
        }

        window.addEventListener('DOMContentLoaded', () => {
            if (window.innerWidth > 768 && localStorage.getItem('sidebarCollapsed') === 'true') {
                sidebar.classList.add('collapsed');
                mainContent.classList.add('sidebar-collapsed');
                toggleIcon.className = 'bi bi-layout-sidebar';
            }
        });

        window.addEventListener('resize', () => { if (window.innerWidth > 768) closeSidebar(); });

        /* ------------------------------
           AVATAR UPLOAD
        ------------------------------ */
        function handleAvatarUpload(event) {
            const file = event.target.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = (e) => {
                document.getElementById('avatarPlaceholder').style.display = 'none';
                const img = document.getElementById('avatarImg');
                img.src = e.target.result;
                img.style.display = 'block';
            };
            reader.readAsDataURL(file);
        }

        /* ------------------------------
           EDIT / SAVE / CANCEL
        ------------------------------ */
        // All editable field pairs: [valueElementId, inputElementId]
        const fields = [
            ['val-name',     'inp-name'],
            ['val-gender',   'inp-gender'],
            ['val-email',    'inp-email'],
            ['val-phone',    'inp-phone'],
            ['val-emgname',  'inp-emgname'],
            ['val-emgphone', 'inp-emgphone'],
            ['val-coach',    'inp-coach'],   // locked — won't be editable
        ];

        // Snapshot before editing (for cancel)
        let snapshot = {};

        function enterEditMode() {
            // Take snapshot
            fields.forEach(([valId, inpId]) => {
                const val = document.getElementById(valId);
                const inp = document.getElementById(inpId);
                snapshot[inpId] = inp.value;

                // Show input, hide value
                val.style.display = 'none';
                if (!inp.classList.contains('locked')) {
                    inp.classList.add('visible');
                } else {
                    // show locked input for visual context, but keep it disabled
                    inp.classList.add('visible');
                }
            });

            // Show camera button
            document.getElementById('avatarUploadBtn').classList.add('visible');

            // Swap buttons
            document.getElementById('editBtn').style.display    = 'none';
            document.getElementById('cancelBtn').classList.add('visible');
            document.getElementById('saveBtn').classList.add('visible');
        }

        function cancelEdit() {
            // Restore snapshot values
            fields.forEach(([valId, inpId]) => {
                const inp = document.getElementById(inpId);
                inp.value = snapshot[inpId] ?? '';
                inp.classList.remove('visible');
                document.getElementById(valId).style.display = '';
            });

            document.getElementById('avatarUploadBtn').classList.remove('visible');
            document.getElementById('editBtn').style.display    = '';
            document.getElementById('cancelBtn').classList.remove('visible');
            document.getElementById('saveBtn').classList.remove('visible');
        }

        function saveProfile() {
            // Write input values back to display elements
            fields.forEach(([valId, inpId]) => {
                const val = document.getElementById(valId);
                const inp = document.getElementById(inpId);
                const text = inp.value.trim();

                val.textContent = text || '—';
                val.className   = text ? 'field-value' : 'field-value empty';
                if (!text) val.textContent = 'Not set';

                inp.classList.remove('visible');
                val.style.display = '';
            });

            // Update name in sidebar + top of profile card
            const newName = document.getElementById('inp-name').value.trim();
            if (newName) {
                document.getElementById('displayName').textContent = newName;
                document.getElementById('sidebarName').textContent = newName;
            }

            // Update coach badge
            const coachVal = document.getElementById('inp-coach').value;
            updateCoachBadge(coachVal);

            document.getElementById('avatarUploadBtn').classList.remove('visible');
            document.getElementById('editBtn').style.display    = '';
            document.getElementById('cancelBtn').classList.remove('visible');
            document.getElementById('saveBtn').classList.remove('visible');

            // Show toast
            const toast = document.getElementById('saveToast');
            toast.classList.add('show');
            setTimeout(() => toast.classList.remove('show'), 3000);
        }

        function updateCoachBadge(value) {
            const badge     = document.getElementById('coachBadge');
            const badgeText = document.getElementById('coachBadgeText');
            badge.className = 'coach-badge';

            if (value === 'Full Time') {
                badge.classList.add('full-time');
                badgeText.textContent = 'Full Time Coach';
            } else if (value === 'Guest') {
                badge.classList.add('guest');
                badgeText.textContent = 'Guest Coach';
            } else {
                badge.classList.add('part-time');
                badgeText.textContent = 'Part Time Coach';
            }
        }
    </script>

</body>
</html>
