@{
    ViewBag.Title = "Archer Class Registration";
    Layout = "~/Views/Shared/_MemberLayout.cshtml";
}

@section Styles {
    <style>
        .wizard-container { max-width: 900px; margin: 0 auto; }
        .page-header { margin-bottom: 30px; }
        .archer-card {
            background: rgba(255,255,255,0.02);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 15px 20px;
            margin-bottom: 12px;
            transition: all 0.2s;
        }
        .archer-card:hover { border-color: rgba(255,255,255,0.2); }
        .archer-card.selected {
            background: rgba(16,185,129,0.05);
            border-color: #10B981;
        }
        .summary-card {
            background: linear-gradient(145deg, rgba(255,255,255,0.03), rgba(0,0,0,0.2));
            border-radius: var(--radius-md);
            padding: 30px;
            border: 1px solid rgba(255, 255, 255, 0.04);
            margin-top: 30px;
        }
    </style>
}

<div class="wizard-container py-3">
    <div class="text-center mb-5 page-header">
        <h1 class="text-white fw-extrabold mb-2" style="font-size: 2.2rem; letter-spacing: -0.5px;">CLASS <span style="color: var(--primary);">REGISTRATION</span></h1>
        <p class="text-dim">Select packages for your archers. You can register multiple archers at once.</p>
    </div>

    <!-- Alert Box -->
    <div class="alert mb-4" id="wizardAlertBox" style="background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); color: #ef4444; border-radius: 16px; display: none;">
        <i class="bi bi-exclamation-circle me-2"></i> <span id="wizardAlertMessage"></span>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3 p-3" style="background: rgba(0,0,0,0.2); border-radius: 12px; border: 1px solid rgba(255,255,255,0.05);">
        <div>
            <button type="button" class="btn btn-sm btn-outline-light me-2" onclick="selectAllArchers(true)">Select All</button>
            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="selectAllArchers(false)">Deselect All</button>
        </div>
        <div class="d-flex align-items-center gap-2">
            <span class="text-dim small fw-bold">APPLY TO ALL:</span>
            <select class="form-select form-select-sm bg-dark text-white border-secondary" style="width: auto; border-radius: 8px;" onchange="applyToAll(this.value)">
                <option value="">-- Choose Package --</option>
                <option value="4slots" data-price="150" data-name="2 Session (4 Slots)">4 Slots (RM 150)</option>
                <option value="6slots" data-price="210" data-name="6 Slots">6 Slots (RM 210)</option>
            </select>
        </div>
    </div>

    <div id="archersList">
        @if (ViewBag.UnregisteredStudents != null)
        {
            foreach (var archer in ViewBag.UnregisteredStudents)
            {
                bool isPreSelected = ViewBag.PreSelectedStudentId != null && ViewBag.PreSelectedStudentId == archer.StudentId;
                <div class="archer-card d-flex justify-content-between align-items-center @(isPreSelected ? "selected" : "")" id="card_@archer.StudentId">
                    <div class="form-check d-flex align-items-center mb-0">
                        <input class="form-check-input archer-checkbox" type="checkbox" value="@archer.StudentId" id="chk_@archer.StudentId" onchange="updateSelection()" @(isPreSelected ? "checked" : "") style="width: 20px; height: 20px; cursor: pointer;">
                        <label class="form-check-label text-white ms-3" for="chk_@archer.StudentId" style="cursor: pointer;">
                            <span class="fw-bold d-block" style="font-size: 1.05rem;">@archer.FullName</span>
                            <span class="text-dim small">@(archer.Age != null ? $"{archer.Age} years old" : "")</span>
                        </label>
                    </div>
                    <div>
                        <select class="form-select form-select-sm bg-dark text-white border-secondary pkg-select" id="pkg_@archer.StudentId" onchange="updateSelection()" style="min-width: 200px; border-radius: 8px;">
                            <option value="4slots" data-price="150" data-name="2 Session (4 Slots)">4 Slots Package (RM 150)</option>
                            <option value="6slots" data-price="210" data-name="6 Slots">6 Slots Package (RM 210)</option>
                        </select>
                    </div>
                </div>
            }
        }
    </div>

    <div class="summary-card">
        <h4 class="fw-bold text-white mb-4" style="font-size: 1.1rem; letter-spacing: 0.3px;">
            <i class="bi bi-receipt me-2" style="color: var(--primary);"></i>REGISTRATION SUMMARY
        </h4>
        
        <div id="summaryDetails">
            <p class="text-dim small">No archers selected.</p>
        </div>

        <div class="summary-row mt-3 pt-3 border-top" style="border-color: rgba(255,255,255,0.1) !important; display: flex; justify-content: space-between;">
            <span class="text-white fw-extrabold" style="font-size: 1.05rem;">TOTAL DUE</span>
            <span class="text-primary fw-extrabold" style="font-size: 2rem;" id="summaryTotal">RM 0.00</span>
        </div>

        <div class="mt-4 p-3" style="background: rgba(245,158,11,0.08); border: 1px solid rgba(245,158,11,0.2); border-radius: 12px;">
            <div class="d-flex align-items-center gap-3">
                <i class="bi bi-clock-fill" style="color: #F59E0B; font-size: 1.25rem;"></i>
                <p class="m-0 small" style="color: #F59E0B; font-size: 0.8rem; line-height: 1.4;">
                    <strong>Payment Pending</strong> — This amount will be added to your Fee / Payment section for settlement as a single combined invoice.
                </p>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-between gap-3 mt-5">
        <button type="button" class="btn-premium-outline" onclick="window.location.href='/Archer/MyArchers'">
            <i class="bi bi-arrow-left me-2"></i> BACK TO ARCHERS
        </button>
        <button type="button" class="btn-premium" id="confirmBtn" onclick="submitRegistration()">
            CONFIRM REGISTRATION <i class="bi bi-check-circle-fill ms-2"></i>
        </button>
    </div>
</div>

<!-- Success Modal -->
<div id="registrationSuccessModal" class="success-modal-overlay" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(10,12,18,0.8); backdrop-filter:blur(8px); z-index:999; justify-content:center; align-items:center;">
    <div class="success-modal-content" style="background: #0d121c; border: 1px solid rgba(255,255,255,0.05); border-radius: 30px; padding: 50px 40px; text-align: center; max-width: 500px; width: 90%; box-shadow: 0 45px 120px rgba(0,0,0,0.9);">
        <div style="width: 80px; height: 80px; border-radius: 25px; background: var(--primary); color: #000; font-size: 2.5rem; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px;">
            <i class="bi bi-check-lg"></i>
        </div>
        <h3 class="fw-extrabold text-white mb-2" style="font-size: 1.8rem;">REGISTRATION SUCCESS!</h3>
        <p class="text-dim mb-4" style="font-size: 0.95rem;">
            <span id="resArcherCount" style="color: var(--primary); font-weight: 700;"></span> archers have been successfully registered. The invoice has been grouped into your fee summary.
        </p>
        <button class="btn-premium w-100 mt-3" onclick="window.location.href='/Archer/MyArchers'" style="padding: 15px;">
            PROCEED TO PAYMENT <i class="bi bi-arrow-right ms-2"></i>
        </button>
    </div>
</div>

@section Scripts {
    <script>
        const annualFee = 80.00;

        function updateSelection() {
            const checkboxes = document.querySelectorAll('.archer-checkbox');
            const summaryDiv = document.getElementById('summaryDetails');
            let total = 0;
            let summaryHTML = '';

            checkboxes.forEach(chk => {
                const card = document.getElementById('card_' + chk.value);
                if (chk.checked) {
                    card.classList.add('selected');
                    const pkgSelect = document.getElementById('pkg_' + chk.value);
                    const pkgOption = pkgSelect.options[pkgSelect.selectedIndex];
                    const price = parseFloat(pkgOption.dataset.price);
                    const name = pkgOption.dataset.name;
                    const archerName = chk.nextElementSibling.querySelector('.fw-bold').innerText;

                    total += (annualFee + price);

                    summaryHTML += `
                        <div class="mb-3 pb-3 border-bottom" style="border-color: rgba(255,255,255,0.05) !important;">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="text-white fw-bold small">${archerName}</span>
                                <span class="text-white small">RM ${(annualFee + price).toFixed(2)}</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span class="text-dim" style="font-size: 0.75rem;">Registration (RM 80) + ${name} (RM ${price})</span>
                            </div>
                        </div>
                    `;
                } else {
                    card.classList.remove('selected');
                }
            });

            if (total === 0) {
                summaryDiv.innerHTML = '<p class="text-dim small">No archers selected.</p>';
                document.getElementById('confirmBtn').disabled = true;
            } else {
                summaryDiv.innerHTML = summaryHTML;
                document.getElementById('confirmBtn').disabled = false;
            }

            document.getElementById('summaryTotal').innerText = `RM ${total.toFixed(2)}`;
        }

        function selectAllArchers(select) {
            document.querySelectorAll('.archer-checkbox').forEach(chk => {
                chk.checked = select;
            });
            updateSelection();
        }

        function applyToAll(val) {
            if (!val) return;
            document.querySelectorAll('.pkg-select').forEach(sel => {
                sel.value = val;
            });
            updateSelection();
        }

        function showAlert(msg) {
            document.getElementById('wizardAlertMessage').innerText = msg;
            document.getElementById('wizardAlertBox').style.display = 'block';
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        async function submitRegistration() {
            document.getElementById('wizardAlertBox').style.display = 'none';
            
            const selected = [];
            document.querySelectorAll('.archer-checkbox:checked').forEach(chk => {
                const id = chk.value;
                const pkgSelect = document.getElementById('pkg_' + id);
                const pkgOption = pkgSelect.options[pkgSelect.selectedIndex];
                selected.push({
                    StudentId: parseInt(id),
                    PackageType: pkgOption.dataset.name,
                    PackagePrice: parseFloat(pkgOption.dataset.price)
                });
            });

            if (selected.length === 0) {
                showAlert("Please select at least one archer.");
                return;
            }

            const btn = document.getElementById('confirmBtn');
            btn.disabled = true;
            btn.innerHTML = `Processing... <div class="spinner-border spinner-border-sm text-light ms-2"></div>`;

            try {
                const resp = await fetch('/Archer/ConfirmBulkClassRegistration', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(selected)
                });
                const result = await resp.json();

                if (result.success) {
                    document.getElementById('resArcherCount').innerText = result.totalCount;
                    document.getElementById('registrationSuccessModal').style.display = 'flex';
                } else {
                    showAlert('Registration failed: ' + result.message);
                    btn.disabled = false;
                    btn.innerHTML = `CONFIRM REGISTRATION <i class="bi bi-check-circle-fill ms-2"></i>`;
                }
            } catch (err) {
                showAlert('Connection error. Please try again.');
                btn.disabled = false;
                btn.innerHTML = `CONFIRM REGISTRATION <i class="bi bi-check-circle-fill ms-2"></i>`;
            }
        }

        // Initialize on load
        document.addEventListener('DOMContentLoaded', updateSelection);
    </script>
}
