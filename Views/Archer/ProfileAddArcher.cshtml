@model ArcheryAlley.Models.ArcherViewModel

@{
    ViewData["Title"] = "Archer Profile";
    Layout = "_MemberLayout";
    
    int archerAge = Model.Age ?? 0;
    if (archerAge == 0 && Model.Birthday != null)
    {
        var birthDate = (DateTime)Model.Birthday;
        archerAge = DateTime.Today.Year - birthDate.Year;
        if (birthDate.Date > DateTime.Today.AddYears(-archerAge)) archerAge--;
    }
}

@section Styles {
    <style>
        .page-header { margin-bottom: 25px; }

        .settings-grid {
            display: grid;
            grid-template-columns: 280px 1fr;
            gap: 25px;
        }

        .settings-sidebar, .settings-content-card {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 16px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
            padding: 25px;
        }

        .settings-sidebar {
            display: flex;
            flex-direction: column;
        }

        .profile-summary {
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            padding-bottom: 20px;
            margin-bottom: 20px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        .profile-avatar {
            width: 90px;
            height: 90px;
            border-radius: 50%;
            background: var(--primary-light);
            border: 2px solid rgba(255, 77, 77, 0.2);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            box-shadow: 0 10px 20px rgba(255, 77, 77, 0.1);
            margin-bottom: 15px;
        }

        .profile-avatar i {
            color: var(--primary);
            font-size: 3rem;
        }

        .nav-pills .nav-link {
            color: var(--text-dim);
            padding: 12px 18px;
            border-radius: 12px;
            font-weight: 600;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            gap: 12px;
            transition: 0.3s;
            margin-bottom: 8px;
            border: 1px solid transparent;
            background: transparent;
            text-align: left;
        }

        .nav-pills .nav-link:hover {
            background: rgba(255, 255, 255, 0.03);
            color: #fff;
        }

        .nav-pills .nav-link.active {
            background: rgba(255, 77, 77, 0.08);
            color: var(--primary);
            border-color: rgba(255, 77, 77, 0.2);
        }

        .nav-pills .nav-link i {
            font-size: 1.1rem;
        }

        .settings-section-title {
            font-size: 1.25rem;
            font-weight: 800;
            color: #fff;
            margin-bottom: 25px;
            display: flex;
            align-items: center;
            gap: 10px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            padding-bottom: 15px;
        }

        .field-row {
            display: flex;
            flex-direction: column;
            margin-bottom: 20px;
            padding-bottom: 20px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.03);
        }

        .field-row:last-child {
            border-bottom: none;
            margin-bottom: 0;
            padding-bottom: 0;
        }

        .field-label {
            font-size: 0.75rem;
            color: var(--text-dim);
            text-transform: uppercase;
            letter-spacing: 1.5px;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .field-value {
            font-size: 1.05rem;
            color: #fff;
            font-weight: 600;
            background: rgba(255, 255, 255, 0.02);
            padding: 12px 18px;
            border-radius: 10px;
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .field-input {
            width: 100%;
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: #fff;
            padding: 12px 18px;
            border-radius: 10px;
            font-size: 1.05rem;
            font-weight: 600;
            transition: 0.3s;
            font-family: inherit;
        }

        .field-input:focus {
            outline: none;
            border-color: var(--primary);
            background: rgba(255, 255, 255, 0.05);
        }

        .field-input[readonly] {
            background: rgba(255, 255, 255, 0.01);
            color: var(--text-dim);
            border-color: transparent;
            cursor: not-allowed;
        }

        /* Responsive styling */
        @@media (max-width: 991px) {
            .settings-grid {
                grid-template-columns: 1fr;
            }
            .profile-summary {
                flex-direction: row;
                text-align: left;
                gap: 20px;
            }
            .profile-avatar { margin-bottom: 0; width: 70px; height: 70px; }
            .profile-avatar i { font-size: 2.2rem; }
            .nav-pills { flex-direction: row !important; overflow-x: auto; white-space: nowrap; gap: 10px; padding-bottom: 5px; }
            .nav-pills .nav-link { margin-bottom: 0; }
        }
    </style>
}

<div class="page-header d-flex justify-content-between align-items-end mb-4">
    <div>

        <h1 class="text-white">ARCHER <span style="color: var(--primary);">MANAGEMENT</span></h1>
    </div>
</div>

<div class="settings-grid">
    <!-- Left Sidebar Menu -->
    <div class="settings-sidebar">
        
        <div class="profile-summary">
            <div class="profile-avatar">
                <i class="bi bi-person-fill"></i>
            </div>
            <div>
                <h4 style="font-weight: 800; margin-bottom: 3px; color: #fff; font-size: 1.2rem;">@Model.FullName</h4>
                <div style="margin-top: 5px;">
                    @{
                        bool hasRegProfile = Model.ClassReg != null;
                    }
                    @if (!hasRegProfile)
                    {
                        <span style="font-size: 0.75rem; font-weight: 700; color: var(--primary); background: rgba(255, 77, 77, 0.1); border: 1px solid rgba(255, 77, 77, 0.2); padding: 4px 12px; border-radius: 50px;">
                            Not Registered
                        </span>
                    }
                    else
                    {
                        var isPaidProfile = Model.ClassReg.PaymentStatus == "Paid" || Model.ClassReg.PaymentStatus == "Success";
                        if (isPaidProfile)
                        {
                            <span style="font-size: 0.75rem; font-weight: 700; color: #10B981; background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.2); padding: 4px 12px; border-radius: 50px;">
                                <i class="bi bi-check-circle-fill" style="margin-right: 4px;"></i> Active
                            </span>
                        }
                        else
                        {
                            <span style="font-size: 0.75rem; font-weight: 700; color: #F59E0B; background: rgba(245, 158, 11, 0.1); border: 1px solid rgba(245, 158, 11, 0.2); padding: 4px 12px; border-radius: 50px;">
                                <i class="bi bi-clock-fill" style="margin-right: 4px;"></i> Pending
                            </span>
                        }
                    }
                </div>
            </div>
        </div>

        <h6 style="color: var(--text-dim); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1.5px; font-weight: 800; margin-bottom: 15px; padding-left: 5px;">Archer Profile</h6>
        
        <div class="nav flex-column nav-pills" id="v-pills-tab" role="tablist" aria-orientation="vertical">
            <a class="nav-link active" id="v-pills-personal-tab" href="javascript:void(0)" onclick="switchTab('personal')" role="tab" aria-controls="v-pills-personal" aria-selected="true" style="text-decoration: none;">
                <i class="bi bi-person-lines-fill"></i> Personal Info
            </a>
            <a class="nav-link" id="v-pills-class-tab" href="javascript:void(0)" onclick="switchTab('class')" role="tab" aria-controls="v-pills-class" aria-selected="false" style="text-decoration: none;">
                <i class="bi bi-box-seam-fill"></i> Class Details
            </a>
        </div>
    </div>

    <!-- Right Content Area -->
    <div class="settings-content-card">
        <div class="tab-content" id="v-pills-tabContent">
            
            <!-- Tab: Personal Info -->
            <div class="tab-pane fade show active" id="v-pills-personal" role="tabpanel" aria-labelledby="v-pills-personal-tab">
                <h3 class="settings-section-title">Personal Information</h3>
                
                <form method="post" action="/Archer/EditArcher">
                    <input type="hidden" name="StudentId" value="@Model.StudentId" />
                    
                    <div class="field-row">
                        <div class="field-label">Full Name</div>
                        <input type="text" name="FullName" class="field-input" value="@Model.FullName" />
                    </div>
                    
                    <div class="field-row">
                        <div class="field-label">Age</div>
                        <input type="text" class="field-input" readonly value="@(archerAge > 0 ? $"{archerAge} years old" : "N/A")" />
                    </div>

                    @if (!string.IsNullOrEmpty(Model.ICNumber))
                    {
                        <div class="field-row">
                            <div class="field-label">IC Number</div>
                            <input type="text" name="ICNumber" class="field-input" readonly value="@Model.ICNumber" />
                        </div>
                    }
                    
                    <div class="mt-4 pt-3" style="border-top: 1px solid rgba(255,255,255,0.05); display: flex; gap: 15px; justify-content: flex-end;">
                        <a href="/Archer/MyArchers" class="btn btn-outline-light" style="border-radius: 10px; font-weight: 600; padding: 10px 24px; border: 1px solid rgba(255,255,255,0.1); color: var(--text-dim); text-decoration: none;">Back</a>
                        <button type="submit" class="btn btn-primary" style="border-radius: 10px; font-weight: 700; padding: 10px 24px; background: var(--primary); border: none; color: #000;">Save Changes</button>
                    </div>
                </form>
            </div>

            <!-- Tab: Class Registration -->
            <div class="tab-pane fade" id="v-pills-class" role="tabpanel" aria-labelledby="v-pills-class-tab">
                <h3 class="settings-section-title">Class Details</h3>
                
                @if (Model.ClassReg != null)
                {
                    string displayPkg = Model.ClassReg.PackageType ?? "";
                    if (displayPkg.Contains("4 Slot")) displayPkg = "Starter Tier";
                    else if (displayPkg.Contains("6 Slot")) displayPkg = "Progressive Tier";

                    <div class="field-row">
                        <div class="field-label">Package Type</div>
                        <input type="text" class="field-input" readonly value="@displayPkg" />
                    </div>
                    
                    <div class="field-row">
                        <div class="field-label">Payment Status</div>
                        <div class="field-value" style="background: transparent; border: none; padding: 0;">
                            @{
                                var isPaid = Model.ClassReg.PaymentStatus == "Paid" || Model.ClassReg.PaymentStatus == "Success";
                            }
                            @if (isPaid)
                            {
                                <span style="font-size: 0.9rem; font-weight: 700; color: #10B981; background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.2); padding: 8px 16px; border-radius: 50px; display: inline-flex; align-items: center; gap: 8px;">
                                    <i class="bi bi-check-circle-fill"></i> Paid
                                </span>
                            }
                            else
                            {
                                <span style="font-size: 0.9rem; font-weight: 700; color: #F59E0B; background: rgba(245, 158, 11, 0.1); border: 1px solid rgba(245, 158, 11, 0.2); padding: 8px 16px; border-radius: 50px; display: inline-flex; align-items: center; gap: 8px;">
                                    <i class="bi bi-clock-fill"></i> Pending
                                </span>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="bi bi-clipboard-x text-dim" style="font-size: 3rem; opacity: 0.5;"></i>
                        <p class="text-dim mt-3" style="font-size: 1rem; font-weight: 500;">This archer has not registered for any classes yet.</p>
                        <a href="/Archer/AddArcherRegister?studentId=@Model.StudentId" class="btn btn-danger mt-3" style="border-radius: 12px; font-weight: 700; padding: 10px 24px; background: var(--primary); border: none; color: #000;">
                            <i class="bi bi-mortarboard-fill me-2"></i> Register Now
                        </a>
                    </div>
                }

                <div class="mt-4 pt-3" style="border-top: 1px solid rgba(255,255,255,0.05); display: flex; justify-content: flex-end;">
                    <a href="/Archer/MyArchers" class="btn btn-outline-light" style="border-radius: 10px; font-weight: 600; padding: 10px 24px; border: 1px solid rgba(255,255,255,0.1); color: var(--text-dim); text-decoration: none;">Back</a>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        function switchTab(tabId) {
            // Remove active classes from all pills
            document.querySelectorAll('#v-pills-tab .nav-link').forEach(function(el) {
                el.classList.remove('active');
            });
            // Hide all tab panes
            document.querySelectorAll('.tab-content .tab-pane').forEach(function(el) {
                el.classList.remove('show', 'active');
            });
            
            // Add active to clicked pill
            var tabBtn = document.getElementById('v-pills-' + tabId + '-tab');
            if(tabBtn) tabBtn.classList.add('active');
            
            // Show target tab pane
            var targetPane = document.getElementById('v-pills-' + tabId);
            if(targetPane) targetPane.classList.add('show', 'active');
        }
    </script>
}
